# ------------------------------------------------------------------------------
# PALETA CORPORATIVA AFP INTEGRA
# ------------------------------------------------------------------------------
PALETA = ["#3494BA", "#00AECB", "#ACD7CA", "#516FED", "#0B3C5D",
          "#7FC8DE", "#C9E4DA", "#8A9BF0", "#1B6E8C", "#5FBFD4"]
COLOR_TEXTO = "#1F2933"
COLOR_GRID = "#E5EAF0"
FUENTE = "Segoe UI, Calibri, sans-serif"

LAYOUT_BASE = dict(
    font=dict(family=FUENTE, size=12, color=COLOR_TEXTO),
    plot_bgcolor="white",
    paper_bgcolor="white",
    margin=dict(l=50, r=30, t=60, b=60),
    legend=dict(orientation="h", yanchor="bottom", y=-0.25, x=0),
    hoverlabel=dict(font_family=FUENTE),
)


def _apply(fig: go.Figure, titulo: str, y_titulo: str = "") -> go.Figure:
    fig.update_layout(title=dict(text=titulo, font=dict(size=16)), **LAYOUT_BASE)
    fig.update_yaxes(showgrid=False, zeroline=False, title=y_titulo,
                     showline=True, linecolor=COLOR_GRID)
    fig.update_xaxes(showgrid=False, zeroline=False, showline=True, linecolor=COLOR_GRID)
    return fig


# ==============================================================================
# PIVOTEO DEL HISTÓRICO LARGO
# ==============================================================================
def _obj(hist: pd.DataFrame, objeto: str, metrica: str | None = None,
         corte: str | None = None) -> pd.DataFrame:
    d = hist[hist["OBJETO"] == objeto]
    if metrica:
        d = d[d["METRICA"] == metrica]
    if corte:
        d = d[d["FECHA_CORTE"].astype(str) == str(corte)]
    return d.copy()


# ==============================================================================
# GRÁFICOS (equivalentes a los charts de la hoja Presentacion)
# ==============================================================================
def fig_serie_metricas(hist: pd.DataFrame) -> go.Figure:
    """Métricas y Metas: Huella (miles Tn) e Intensidad por corte."""
    d = _obj(hist, "Resumen_Bloques")
    d = d[d["DIM_1"] == "TOTAL"]
    h = d[d["METRICA"] == "Huella (miles Tn)"].groupby("FECHA_CORTE")["VALOR"].sum()
    i = d[d["METRICA"] == "Intensidad-M"].groupby("FECHA_CORTE")["VALOR"].sum()
    fig = go.Figure()
    fig.add_bar(x=h.index, y=h.values, name="Huella (miles Tn CO2)",
                marker_color=PALETA[0],
                text=[f"{v:,.1f}" for v in h.values], textposition="outside")
    fig.add_scatter(x=i.index, y=i.values, name="Intensidad (Tn CO2 / USD MM)",
                    yaxis="y2", mode="lines+markers",
                    line=dict(color=PALETA[3], width=3), marker=dict(size=9))
    fig.update_layout(yaxis2=dict(overlaying="y", side="right", showgrid=False))
    return _apply(fig, "Métricas y Metas — evolución por corte")


def fig_bloques_apilado(hist: pd.DataFrame, corte: str, metrica: str) -> go.Figure:
    """Huella / Intensidad apilada por bloque de estrategia (BU, TD, ALT)."""
    d = _obj(hist, "Resumen_Bloques", metrica, corte)
    d = d[d["DIM_1"] != "TOTAL"]
    fig = go.Figure()
    for k, (_, r) in enumerate(d.iterrows()):
        fig.add_bar(x=[corte], y=[r["VALOR"]], name=r["DIM_1"],
                    marker_color=PALETA[k % len(PALETA)])
    total = d["VALOR"].sum()
    fig.update_layout(barmode="stack",
                      annotations=[dict(x=corte, y=total, text=f"{total:,.0f}",
                                        showarrow=False, yshift=12,
                                        font=dict(size=13, color=COLOR_TEXTO))])
    return _apply(fig, f"{metrica} por estrategia — {corte}")


def fig_contribuyentes(hist: pd.DataFrame, corte: str, objeto: str,
                       titulo: str, top_n: int = 15) -> go.Figure:
    d = _obj(hist, objeto, "Huella", corte)
    d = d.groupby("DIM_1")["VALOR"].sum().sort_values(ascending=True).tail(top_n)
    fig = go.Figure(go.Bar(x=d.values, y=d.index, orientation="h",
                           marker_color=PALETA[0],
                           text=[f"{v:,.0f}" for v in d.values],
                           textposition="outside"))
    return _apply(fig, titulo, "")


def fig_soberanos(hist: pd.DataFrame, corte: str) -> go.Figure:
    h = _obj(hist, "Soberanos", "Huella", corte).groupby("DIM_1")["VALOR"].sum()
    a = _obj(hist, "Soberanos", "Inv MM$", corte).groupby("DIM_1")["VALOR"].sum()
    idx = h.sort_values(ascending=False).index
    fig = go.Figure()
    fig.add_bar(x=idx, y=h.reindex(idx).values, name="Huella (Tn CO2)",
                marker_color=PALETA[0])
    fig.add_scatter(x=idx, y=a.reindex(idx).values, name="AUM (USD MM)",
                    yaxis="y2", mode="markers",
                    marker=dict(size=12, color=PALETA[3], symbol="diamond"))
    fig.update_layout(yaxis2=dict(overlaying="y", side="right", showgrid=False))
    return _apply(fig, f"Exposición soberana por emisor — {corte}")


def fig_aum_composicion(hist: pd.DataFrame, corte: str) -> go.Figure:
    d = _obj(hist, "AUM_por_Rank", "Inv MM$", corte).groupby("DIM_1")["VALOR"].sum()
    d = d[d > 0].sort_values(ascending=False)
    fig = go.Figure(go.Pie(labels=d.index, values=d.values, hole=0.45,
                           marker=dict(colors=PALETA * 3),
                           textinfo="label+percent"))
    fig.update_layout(**LAYOUT_BASE, title=dict(
        text=f"Composición del AUM por Rank_rt — {corte}", font=dict(size=16)))
    return fig


def fig_estrategia_plus1(hist: pd.DataFrame, corte: str) -> go.Figure:
    d = _obj(hist, "Estrategia_x_Plus1", "Huella", corte)
    piv = d.pivot_table(index="DIM_1", columns="DIM_2", values="VALOR",
                        aggfunc="sum", fill_value=0)
    fig = go.Figure()
    for k, c in enumerate(piv.columns):
        fig.add_bar(x=piv.index, y=piv[c].values, name=str(c),
                    marker_color=PALETA[k % len(PALETA)])
    fig.update_layout(barmode="stack")
    tot = piv.sum(axis=1)
    fig.update_layout(annotations=[
        dict(x=i, y=v, text=f"{v:,.0f}", showarrow=False, yshift=12)
        for i, v in tot.items()])
    return _apply(fig, f"Huella por Estrategia × Plus_1 — {corte}")


