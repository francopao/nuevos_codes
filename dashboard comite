JS = """
<script>
function aplicarFiltros(){
  const corte = document.getElementById('selCorte').value;
  document.querySelectorAll('[data-corte]').forEach(el=>{
    el.classList.toggle('oculto', el.dataset.corte !== corte && el.dataset.corte !== 'ALL');
  });
  const sel = document.getElementById('selBloques');
  const activos = Array.from(sel.selectedOptions).map(o=>o.value);
  document.querySelectorAll('[data-plotly]').forEach(div=>{
    const gd = div.querySelector('.js-plotly-plot') || div;
    if(!gd.data) return;
    const vis = gd.data.map(t => activos.length===0 || activos.includes(t.name) ? true : 'legendonly');
    Plotly.restyle(gd, {visible: vis});
  });
}
document.addEventListener('DOMContentLoaded', ()=>{
  document.getElementById('selCorte').addEventListener('change', aplicarFiltros);
  document.getElementById('selBloques').addEventListener('change', aplicarFiltros);
  aplicarFiltros();
});
</script>
"""


def construir_dashboard(ruta_historico: str | Path = SALIDA_HISTORICO,
                        ruta_salida: str | Path = SALIDA_DASHBOARD) -> Path:
    hist = HistoricoExporter(str(ruta_historico)).cargar_historico()
    if hist.empty:
        raise ValueError("El histórico está vacío: ejecutar M11 primero.")
    hist["FECHA_CORTE"] = hist["FECHA_CORTE"].astype(str)
    cortes = sorted(hist["FECHA_CORTE"].unique(), reverse=True)
    bloques = sorted(_obj(hist, "Resumen_Bloques")["DIM_1"].unique().tolist())
    bloques = [b for b in bloques if b != "TOTAL"]

    partes: list[str] = []
    primero = True

    def render(fig: go.Figure, corte: str = "ALL", full: bool = False) -> str:
        nonlocal primero
        html = pio.to_html(fig, include_plotlyjs=primero, full_html=False,
                           config={"displayModeBar": False, "responsive": True})
        primero = False
        cls = "card full" if full else "card"
        return f'<div class="{cls}" data-corte="{corte}" data-plotly>{html}</div>'

    # Serie temporal (transversal a todos los cortes)
    partes.append(render(fig_serie_metricas(hist), "ALL", full=True))

    # Bloques por corte
    for c in cortes:
        partes.append(render(fig_bloques_apilado(hist, c, "Huella"), c))
        partes.append(render(fig_bloques_apilado(hist, c, "Intensidad-M"), c))
        partes.append(render(fig_aum_composicion(hist, c), c))
        partes.append(render(fig_estrategia_plus1(hist, c), c))
        partes.append(render(fig_soberanos(hist, c), c, full=True))
        partes.append(render(fig_contribuyentes(
            hist, c, "Contrib_BU_TD", f"Mayores contribuyentes BU + TD — {c}"), c))
        partes.append(render(fig_contribuyentes(
            hist, c, "Contrib_General", f"Mayores contribuyentes (general) — {c}"), c))

    opciones_corte = "".join(f'<option value="{c}">{c}</option>' for c in cortes)
    opciones_bloque = "".join(f'<option value="{b}" selected>{b}</option>' for b in bloques)

    html = f"""<!DOCTYPE html><html lang="es"><head><meta charset="utf-8">
<title>Huella de Carbono — Dashboard</title>{CSS}</head><body>
<header>
  <h1>Huella de Carbono e Intensidad — Portafolio de Inversiones</h1>
  <p>AFP Integra · Multifondos 1, 2 y 3 · generado automáticamente desde el pipeline Python</p>
</header>
<div class="controles">
  <div class="control"><label>Fecha de corte</label>
    <select id="selCorte">{opciones_corte}</select></div>
  <div class="control"><label>Bloques / series (selección múltiple)</label>
    <select id="selBloques" multiple>{opciones_bloque}</select></div>
</div>
<div class="grid">{''.join(partes)}</div>
<footer>Fuente: Tabla de Valorización de Instrumentos (BD Huella con Proxies).
Reemplaza íntegramente la hoja «Presentacion».</footer>
{JS}</body></html>"""

    ruta = Path(ruta_salida)
    ruta.parent.mkdir(parents=True, exist_ok=True)
    ruta.write_text(html, encoding="utf-8")
    print(f"[M14] Dashboard -> {ruta}")
    return ruta


if __name__ == "__main__":
    construir_dashboard()
