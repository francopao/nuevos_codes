def limpiar_precios_rvl(df_raw: pd.DataFrame, campo: str,
                        mapa_ticker_sbs: dict[str, str]) -> pd.DataFrame:
    """
    Extrae un bloque de la hoja RVL (Px_last o TOT_RETURN_INDEX_GROSS_DVDS).

    FIX 2026 (este era el causante de los huecos gigantes en BD y de los
    #N/A del Resumen):
      - Las fechas ya NO están en la columna B como asumía el port anterior:
        cada bloque trae su PROPIA columna de fechas (la primera del bloque),
        igual que en el original 2022 que usaba 'column_2' de polars.
      - La fila de códigos SBS que la hoja tenía en 2022 hoy está vacía y solo
        quedan tickers Bloomberg, así que acá renombramos ticker → SBS con el
        mapeo armado desde Parametria y la hoja Benchmark. Todo lo demás del
        proceso (weights, sectores, Resumen) se engancha por SBS, causa.
    """
    mask = (df_raw.iloc[2] == campo).values
    if not mask.any():
        fallar(f"Hoja RVL: no existe ningún bloque con campo '{campo}'.")
    bloque = df_raw.loc[:, mask]

    # Primera columna del bloque = fechas; el resto = tickers (fila 5 visible)
    # Ojo: algunas celdas de fecha llegan como serial numérico de Excel (p.ej.
    # 46106 = 25/03/2026) en vez de datetime. El detalle fino: si le pasas ese
    # número a pd.to_datetime "a secas", lo interpreta como NANOSEGUNDOS desde
    # 1970 y te regala fechas 1970-01-01 sin marcar error — eso fue lo que
    # metió 81 filas basura al inicio de la hoja BD y descuadró todo el
    # Resumen. Acá convertimos celda por celda según su tipo real.
    def _a_fecha(v):
        if isinstance(v, dt.datetime):
            return pd.Timestamp(v)
        if isinstance(v, (int, float)) and 20000 <= v <= 80000:
            return pd.Timestamp("1899-12-30") + pd.Timedelta(days=float(v))
        if isinstance(v, str):
            return pd.to_datetime(v, dayfirst=True, errors="coerce")
        return pd.NaT

    fechas = bloque.iloc[5:, 0].map(_a_fecha)
    tickers = [str(t).strip() if t is not None else "" for t in bloque.iloc[4, 1:]]

    df = bloque.iloc[5:, 1:].copy()
    df.columns = tickers
    df = df.loc[fechas.notna().values]
    df.index = pd.Index(fechas.dropna().values, name="Fecha")
    if df.empty:
        fallar(f"Hoja RVL/{campo}: no se encontraron fechas válidas en la "
               f"primera columna del bloque. ¿Cambió la estructura de la hoja?")

    # Ticker Bloomberg → código SBS
    sin_mapa = []
    nuevas = {}
    for t in df.columns:
        sbs = mapa_ticker_sbs.get(t)
        if sbs is None:
            sin_mapa.append(t)
        else:
            nuevas[t] = sbs
    if sin_mapa:
        warnings.warn(
            f"Hoja RVL/{campo}: {len(sin_mapa)} columna(s) sin código SBS "
            f"identificable, se excluyen (agrégalas en la columna A de "
            f"Parametria si las necesitas): {sorted(set(sin_mapa))}")
    df = df[list(nuevas)].rename(columns=nuevas)
    df = df.loc[:, ~df.columns.duplicated()]

    df = df.astype(object).replace(_BLANCOS_BLOOMBERG, np.nan).bfill().fillna(0)
    return convertir_columnas_object_a_float(df).sort_index()


def construir_mapa_ticker_sbs(parametria: pd.DataFrame,
                              wb_bench: pd.DataFrame) -> dict[str, str]:
    """
    Arma el diccionario ticker-Bloomberg → SBS combinando:
      1) Parametria: col A (código G&P / raíz del ticker) → col C (SBS).
      2) Hoja Benchmark: fila 'Ticker' → fila 'SBS' (cubre renombres tipo
         GBVLAC1→PEP900001103 que Parametria escribe distinto).
    Genera variantes razonables del header de la hoja RVL: con/sin ' Equity',
    con/sin sufijo de bolsa (PE/US/CN/CI/CB) y el caso 'XXX Equity2'.
    """
    mapa: dict[str, str] = {}
    sufijos = (" PE", " US", " CN", " CI", " CB")

    def registrar(raiz: str, sbs: str) -> None:
        raiz = str(raiz).strip()
        sbs = str(sbs).strip()
        if not raiz or raiz.lower() == "nan" or not sbs or sbs.lower() == "nan":
            return
        variantes = {raiz, f"{raiz} Equity"}
        base = raiz
        for s in sufijos:
            if raiz.endswith(s):
                base = raiz[: -len(s)]
        for s in sufijos:
            variantes |= {f"{base}{s} Equity", f"{base}{s}"}
        variantes |= {f"{raiz} Equity2", f"{base} US Equity2"}
        for v in variantes:
            mapa.setdefault(v, sbs)

    # 2) Benchmark primero: es la fuente más literal de ticker→SBS
    fila_ticker = wb_bench.index[wb_bench.iloc[:, 0].astype(str).str.strip() == "Ticker"]
    fila_sbs = wb_bench.index[wb_bench.iloc[:, 0].astype(str).str.strip() == "SBS"]
    if len(fila_ticker) and len(fila_sbs):
        for t, s in zip(wb_bench.iloc[fila_ticker[0], 1:],
                        wb_bench.iloc[fila_sbs[0], 1:]):
            if pd.notna(t) and pd.notna(s):
                registrar(t, s)

    # 1) Parametria: pisa/añade con la fuente oficial de la cartera
    for _, fila in parametria.iterrows():
        registrar(fila["GP"], fila["SBS"])

    # 3) Alias manuales (renombres tipo FSM↔FVI); mandan sobre lo anterior
    gp_a_sbs = dict(zip(parametria["GP"].astype(str).str.strip(),
                        parametria["SBS"]))
    for header_rvl, gp in ALIAS_TICKERS.items():
        if gp in gp_a_sbs:
            mapa[header_rvl] = gp_a_sbs[gp]
    return mapa


def limpiar_benchmark(wb: pd.DataFrame, nombre: str,
                      precios_ref: pd.DataFrame) -> pd.DataFrame:
    cols = wb.columns[wb.iloc[0].isin(["Benchmark", nombre])]
    if len(cols) == 0:
        fallar(f"Hoja Benchmark: no se encontró el bloque '{nombre}'.")
    limpio = wb[cols].iloc[4:].reset_index(drop=True).copy()
    limpio.columns = limpio.iloc[0]
    limpio = limpio.drop(0).reset_index(drop=True)
    limpio = limpio.rename(columns={limpio.columns[0]: "Fecha"})
    limpio["Fecha"] = pd.to_datetime(limpio["Fecha"], errors="coerce")
    limpio = (limpio.dropna(subset=["Fecha"]).set_index("Fecha")
                    .replace("-", 0).apply(pd.to_numeric, errors="coerce"))
    return limpio.reindex(precios_ref.index).ffill()


