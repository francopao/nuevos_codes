def _pxq(precios, cantidades, dedup=False):
    df = precios.mul(cantidades, axis=0).dropna(axis=0, how="all").copy()
    if dedup:
        df = df[~df.index.duplicated(keep="first")]
    return df


def _weight(pxq: pd.DataFrame) -> pd.DataFrame:
    tot = pxq.sum(axis=1)
    n = int((tot == 0).sum())
    # 1-2 fechas en cero al inicio de la serie es normal (arranque de datos);
    # solo avisamos si son varias, que ahí sí huele a datos faltantes.
    if n > 2:
        warnings.warn(f"weights: {n} fechas con PxQ total = 0 → pesos NaN esas fechas.")
    return pxq.div(tot.replace(0, np.nan), axis=0)


def _ret_ponderado(retornos, weights):
    return retornos.mul(weights, axis=0).dropna(axis=0, how="all").copy()


def _rezagar(df: pd.DataFrame) -> pd.DataFrame:
    """Peso del día T se aplica al retorno de T+1 (shift de índice)."""
    df = df.copy()
    df.index = pd.Index(df.index).to_series().reset_index(drop=True).shift(-1).values
    return df.iloc[:-1].copy()


def _acumular(ret: pd.DataFrame) -> pd.DataFrame:
    return (1 + ret.replace([np.inf, -np.inf], np.nan).fillna(0)).cumprod() * 100


