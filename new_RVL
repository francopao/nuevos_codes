        pdf.savefig(fig); plt.close(fig)

        for sector in lista_sectores:
            fig, axis = plt.subplots(2, 2, figsize=(22, 17))
            fig.suptitle(f"Rendimiento Acumulado: {sector}",
                         fontsize=20, fontweight="bold")
