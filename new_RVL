def localizar_fila_encabezado(df: pd.DataFrame, tokens: tuple[str, ...],
                              contexto: str) -> int:
    """
    Encuentra dinámicamente la fila de encabezado del QEST buscando la fila
    que contiene TODOS los tokens dados (p.ej. 'Fondo' y 'Fecha').
    El código 2022 usaba posiciones fijas (fila 10 en DQ_IN, fila 13 en DQ_RV);
    el QEST actual tiene los encabezados corridos, así que se detectan.
    """
    for i in range(min(60, len(df))):
        fila = set(df.iloc[i].astype(str).tolist())
        if all(t in fila for t in tokens):
            return i
    fallar(f"{contexto}: no se encontró la fila de encabezado con "
           f"{tokens} en las primeras 60 filas del QEST. "
           f"¿Cambió la estructura de la hoja?")


def actualizar_DQ_IN(df1: pd.DataFrame, DQ_IN_BD: pd.DataFrame,
                     lista_in: list[str]) -> pd.DataFrame:
    """Anexa a DQ_IN_BD los registros del QEST posteriores a la última fecha."""
    hdr = localizar_fila_encabezado(df1, ("Fondo", "Dato", "Fecha", "SBS"), "DQ_IN")
    df = df1.iloc[hdr:].transpose().rename(columns={hdr: "Isins"})
    filtrada = df[df["Isins"].isin(lista_in)].transpose()
    if filtrada.empty:
        fallar("DQ_IN: el filtro por ISINs de Parametria no encontró columnas. "
               "Verifica que los ISINs de Parametria coincidan con los del QEST.")
    filtrada.columns = filtrada.iloc[0].to_list()
    filtrada = filtrada.iloc[1:]

    if DQ_IN_BD.empty or "Fecha" not in DQ_IN_BD.columns:
        fallar("La hoja DQ_IN del Monitor está vacía o sin columna 'Fecha'.")
    ultima = DQ_IN_BD["Fecha"].iloc[-1]
    print(f"DQ IN — última fecha en Monitor: {ultima}")

    fechas_qest = filtrada["Fecha"].values.tolist()
    # +9: el bloque QEST repite 9 filas de encabezado por fecha (igual que 2022)
    ubi = buscar_fecha(fechas_qest, ultima, "DQ_IN") + 9

    nuevos = (filtrada.iloc[ubi:]
              .reset_index(drop=True)
              .loc[lambda d: d["Dato"] == "Q"])
    if nuevos.empty:
        print("DQ IN — sin registros nuevos (Monitor ya al día).")
    else:
        print(f"DQ IN — {len(nuevos)} registros nuevos anexados.")
    return pd.concat([DQ_IN_BD, nuevos]).reset_index(drop=True)


def actualizar_DQ_SIS(df2: pd.DataFrame, DQ_SIS_BD: pd.DataFrame,
                      lista_ex: list[str]) -> pd.DataFrame:
    """Anexa a DQ_SIS los registros nuevos del QEST (sistema HA/PF/RI).

    FIX 2026: el encabezado ('Fondo | Fecha | Fondo_Fecha | ISINs…') ya no
    está en la fila 13 fija que asumía el código 2022 — el QEST actual lo
    tiene corrido (hoy fila 15). Se detecta dinámicamente y se corta desde
    allí, lo que además elimina las filas basura/TEST previas.
    """
    hdr = localizar_fila_encabezado(df2, ("Fondo", "Fecha", "Fondo_Fecha"), "DQ_SIS")
    df3 = df2.iloc[hdr:].transpose().rename(columns={hdr: "Isins"})
    filtrada = df3[df3["Isins"].isin(lista_ex)].transpose()
    if filtrada.empty:
        fallar("DQ_SIS: el filtro por ISINs de Parametria no encontró columnas "
               "en DQ_RV. Verifica que coincidan con los del QEST.")
    filtrada = filtrada.reset_index(drop=True).dropna(how="all")
    filtrada.columns = filtrada.iloc[0].to_list()   # fila 0 = encabezado detectado
    filtrada = filtrada.drop(0).drop(columns=["Fondo"])

    base = DQ_SIS_BD.copy()
    base.columns = base.iloc[0].to_list()
    base_h = base.drop(0)
    hist = base_h.iloc[2:]

    if "Fecha" not in hist.columns:
        fallar("La hoja DQ_SIS del Monitor no tiene columna 'Fecha' en la fila esperada.")
    ultima = hist["Fecha"][::-1].drop_duplicates().iloc[0]
    print(f"DQ SIS — última fecha en Monitor: {ultima}")

    fechas_qest = filtrada["Fecha"].values.tolist()
    ubi = buscar_fecha(fechas_qest, ultima, "DQ_SIS")

    nuevos = filtrada.iloc[ubi:].reset_index(drop=True).dropna(how="all")
    final_hist = base_h.iloc[:ubi]

    final_hist = final_hist.loc[:, ~final_hist.columns.duplicated()]
    nuevos = nuevos.loc[:, ~nuevos.columns.duplicated()]
    return pd.concat([final_hist, nuevos], ignore_index=True)


