def calculo_aum(df: pd.DataFrame) -> pd.DataFrame:
    """
    Extrae la serie de AUM por AFP-Fondo desde DataHistórica.

    FIX 2026: el código 2022 asumía que la fila de rótulos ('Fecha',
    'HA-FONDO1', 'IN-FONDO1', …) estaba en la posición fija 4. En el archivo
    actual está en la fila 5 (y puede volver a correrse). Ahora se localiza
    dinámicamente la fila que contiene 'Fecha' junto a los rótulos AFP-FONDO,
    y se indexa por NOMBRE de columna en vez de por posición.
    """
    hdr = None
    for i in range(min(60, len(df))):
        fila = set(df.iloc[i].astype(str).str.strip().tolist())
        if "Fecha" in fila and any(f"{a}-FONDO1" in fila for a in AFPS):
            hdr = i
            break
    if hdr is None:
        fallar(f"AUM: no se encontró la fila de rótulos ('Fecha' + 'XX-FONDOn') "
               f"en las primeras 60 filas de DataHistórica de {AUM_PATH.name}. "
               f"¿Cambió la estructura de la hoja o el rango de columnas leído?")

    rotulos = df.iloc[hdr].astype(str).str.strip()
    datos = df.iloc[hdr + 1:].copy()
    datos.columns = rotulos.to_list()
    datos = datos.loc[:, ~pd.Index(datos.columns).duplicated()]

    if "Fecha" not in datos.columns:
        fallar("AUM: la fila de rótulos detectada no contiene 'Fecha'.")

    fechas = pd.to_datetime(datos["Fecha"], errors="coerce")
    datos = datos.loc[fechas.notna()].copy()
    datos.index = fechas.dropna()

    lista_df = []
    for fondo in FONDOS:
        for afp in AFPS:
            col = f"{afp}-FONDO{fondo}"
            if col not in datos.columns:
                fallar(f"AUM: no se encontró la serie '{col}' en DataHistórica "
                       f"de {AUM_PATH.name}. Rótulos detectados (fila {hdr + 1}): "
                       f"{[c for c in datos.columns if 'FONDO' in str(c)][:12]}…")
            serie = (datos[[col]].replace("ND", 0)
                     .apply(pd.to_numeric, errors="coerce").fillna(0)
                     .astype(np.float64)
                     .set_axis([f"{afp}_F{fondo}"], axis=1)
                     .sort_index().loc["2014-12-30":])
            serie = serie[~serie.index.duplicated(keep="last")]
            lista_df.append(serie)

    out = pd.concat(lista_df, axis=1)
    out["Total"] = out.sum(axis=1)
    for afp in AFPS:
        out[f"{afp}_MF"] = out.filter(like=f"{afp}_").sum(axis=1)
        out[f"{afp}_Share"] = out[f"{afp}_MF"] / out["Total"].replace(0, np.nan)

    combinaciones = {"EXIN": ["HA", "PF", "RI"], "EXHA": ["IN", "PF", "RI"],
                     "EXPF": ["IN", "HA", "RI"], "EXRI": ["IN", "PF", "HA"]}
    for fondo in FONDOS:
        for nuevo, cols in combinaciones.items():
            out[f"{nuevo}_F{fondo}"] = out[[f"{c}_F{fondo}" for c in cols]].sum(axis=1)
    for afp in AFPS:
        out[f"Aum_{afp}"] = out[f"{afp}_F1"] + out[f"{afp}_F2"] + out[f"{afp}_F3"]
    return out.drop(columns=["Total"])


