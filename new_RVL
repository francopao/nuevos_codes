_AVISO_CALAMINE_DADO = False


def leer_excel(path: Path, sheet: str, **kw) -> pd.DataFrame:
    """
    Lectura SOLO-LECTURA con calamine (rápido, no bloquea ni altera el archivo,
    y lee valores calculados aunque las celdas tengan fórmulas).
    Si calamine no está instalado, cae a openpyxl y avisa UNA sola vez.
    """
    global _AVISO_CALAMINE_DADO
    try:
        return pd.read_excel(path, sheet_name=sheet, engine="calamine", **kw)
    except ImportError:
        if not _AVISO_CALAMINE_DADO:
            warnings.warn("python-calamine no instalado; usando openpyxl (MUCHO "
                          "más lento). Instala:  pip install python-calamine")
            _AVISO_CALAMINE_DADO = True
        return pd.read_excel(path, sheet_name=sheet, engine="openpyxl", **kw)
    except ValueError as e:
        fallar(f"No se pudo leer la hoja '{sheet}' de {path.name}: {e}")


def leer_rvl_acotado(path: Path, max_filas: int = 12000) -> pd.DataFrame:
    """
    Lector especial para la hoja RVL: como las fórmulas de Bloomberg están
    arrastradas hasta el fondo de la hoja (¡1,048,576 filas!), leerla entera
    era lo que hacía que la corrida demorara ~17 minutos. Acá leemos fila por
    fila en modo read_only y frenamos apenas se acaban los datos reales
    (30 filas vacías seguidas), o al llegar al tope de seguridad.
    """
    import openpyxl
    try:
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
    except Exception as e:
        fallar(f"No se pudo abrir {path.name} para leer la hoja RVL: {e}")
    if "RVL" not in wb.sheetnames:
        fallar(f"{path.name} no tiene hoja 'RVL'.")
    ws = wb["RVL"]
    filas, vacias_seguidas = [], 0
    for i, row in enumerate(ws.iter_rows(min_row=1, max_row=max_filas,
                                         values_only=True)):
        if i >= 6 and all(v is None for v in row):
            vacias_seguidas += 1
            if vacias_seguidas >= 30:
                break
        else:
            vacias_seguidas = 0
            filas.append(row)
    wb.close()
    if len(filas) < 6:
        fallar("La hoja RVL tiene menos filas de las esperadas; revisa que las "
               "fórmulas de Bloomberg estén calculadas y guardadas.")
    df = pd.DataFrame(filas)
    print(f"Hoja RVL — leídas {len(df)} filas útiles (lectura acotada, rápida).")
    return df.astype(object)


def buscar_fecha(lista_fechas: list, fecha, contexto: str) -> int:
    """index() blindado: si la última fecha del Monitor no existe en el QEST,
    explica el problema en vez de reventar con ValueError críptico."""
    try:
        return lista_fechas.index(fecha)
    except ValueError:
        fallar(
            f"{contexto}: la última fecha registrada en el Monitor "
            f"({fecha!r}) NO aparece en el QEST. Posibles causas: el QEST fue "
            f"depurado/reiniciado, formatos de fecha distintos, o la hoja del "
            f"Monitor tiene una fecha manual errónea. Revisa ambas hojas antes "
            f"de volver a correr."
        )


def convertir_columnas_object_a_float(df: pd.DataFrame) -> pd.DataFrame:
    """Convierte a float64 toda columna object/str (pandas>=2.1 puede devolver
    dtype 'str' tras leer Excel; pedir ambos es retrocompatible)."""
    df = df.copy()
    for col in df.select_dtypes(include=["object", "string"]).columns:
        df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0).astype("float64")
    return df


def detectar_sufijo_cartera(nombre_clave: str) -> str:
    low = nombre_clave.lower()
    if any(t in low for t in ("_il", "iliq", "ilíquida", "iliquida")):
        return "_IL"
    if any(t in low for t in ("_l", "_liq", "liquida", "líquida")):
        return "_L"
    return ""


