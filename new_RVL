def comprobar_bd(df_final: pd.DataFrame, fecha_corte) -> None:
    """
    Chequeo pensado para revisarse A OJO, sin saber programar:

    1) Verifica la estructura de BD (lo que las fórmulas OFFSET+NETWORKDAYS
       del Resumen asumen a ciegas): una fila por día hábil, sin huecos, sin
       duplicados, sin fechas basura, terminando en el corte.
    2) Calcula Day / WTD / MTD / YTD componiendo los retornos diarios entre
       FECHAS reales (el método "a mano": producto de (1+retorno) entre la
       fecha de inicio y el corte). Compara estos números con los del Resumen:
       si BD está bien exportado deben calzar casi exactos.
    """
    print("\n" + "=" * 72)
    print("COMPROBACIÓN AUTOMÁTICA DE LA HOJA BD (para revisar a ojo)")
    print("=" * 72)

    idx = df_final.index
    corte = pd.Timestamp(fecha_corte)
    checks = [
        ("Una fila por día hábil, sin huecos ni sobras",
         len(idx) == len(pd.bdate_range(idx.min(), idx.max()))),
        ("Sin fechas duplicadas", not idx.duplicated().any()),
        ("Sin sábados ni domingos", bool((idx.weekday < 5).all())),
        ("Sin fechas basura (1970 / posteriores al corte)",
         idx.min() > pd.Timestamp("2000-01-01") and idx.max() <= corte),
        ("Última fila = fecha de corte", idx.max() == corte),
    ]
    for texto, ok in checks:
        print(f"  [{'OK' if ok else '!!'}] {texto}")

    # Check cruzado de fuentes: el EPU calculado con BDat (Retorno_VP) y con
    # Bloomberg (Retorno_Precios) deben acumular casi lo mismo en el año. Si
    # divergen fuerte, BDat volvió a venir con fechas faltantes sin parchar.
    ini_ytd = pd.Timestamp(corte.year, 1, 1)
    c_bdat, c_rvl = "Retorno_VP_5460042E8427", "Retorno_Precios_No_Acum_5460042E8427"
    if c_bdat in df_final.columns and c_rvl in df_final.columns:
        a = float((1 + pd.to_numeric(df_final[c_bdat], errors="coerce")
                   .loc[ini_ytd:corte].fillna(0)).prod() - 1)
        b = float((1 + pd.to_numeric(df_final[c_rvl], errors="coerce")
                   .loc[ini_ytd:corte].fillna(0)).prod() - 1)
        print(f"  [{'OK' if abs(a - b) < 0.05 else '!!'}] Calidad de fuentes: "
              f"EPU YTD vía BDat {a:.2%} vs vía Bloomberg {b:.2%} (una brecha "
              f"chica por moneda/metodología es normal; >5pp = revisar BDat)")
    col_in = "Ret_IN_F1_O_Total"
    if col_in in df_final.columns:
        s = pd.to_numeric(df_final[col_in], errors="coerce").loc[ini_ytd:corte]
        print(f"  [{'OK' if int(s.isna().sum()) <= 3 else '!!'}] Ret IN F1 con "
              f"dato todos los días del año ({int(s.isna().sum())} vacíos de {len(s)})")

    ini_mtd = pd.Timestamp(corte.year, corte.month, 1)
    ini_wtd = corte - pd.Timedelta(days=int(corte.weekday()))  # lunes

    def _acum(col: str, desde) -> float:
        if col not in df_final.columns:
            return float("nan")
        s = pd.to_numeric(df_final[col], errors="coerce").loc[desde:corte].fillna(0)
        return float((1 + s).prod() - 1)

    series = {
        "IN F1": "Ret_IN_F1_O_Total",   "IN F2": "Ret_IN_F2_O_Total",
        "IN F3": "Ret_IN_F3_O_Total",   "IN M": "Ret_IN_M_O_Total",
        "EXSIS F1": "Ret_EXSIS_F1_O_Total",
        "EPU": "Retorno_Precios_No_Acum_5460042E8427",
        "ETFPERU": "Retorno_Precios_No_Acum_5076822E0800",
    }
    print(f"\n  Retornos compuestos POR FECHAS al {corte:%d-%m-%Y} "
          f"(compáralos con los charts del Resumen):")
    print(f"  {'Serie':<10}{'Day':>9}{'WTD':>9}{'MTD':>9}{'YTD':>9}")
    for nombre, col in series.items():
        print(f"  {nombre:<10}{_acum(col, corte):>8.2%} "
              f"{_acum(col, ini_wtd):>8.2%} {_acum(col, ini_mtd):>8.2%} "
              f"{_acum(col, ini_ytd):>8.2%}")
    print("  (Day = fila del corte; WTD desde el lunes; MTD desde el 1 del "
          "mes; YTD desde el 1 de enero. Diferencias grandes vs Resumen = "
          "problema; diferencias mínimas por feriados son normales.)")
    print("=" * 72)


