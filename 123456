def _cols_en_ventana(ws, fila_fecha):
    """Columnas cuyas fechas (en 'fila_fecha') caen en el semestre objetivo Y que
    además tienen al menos un dato numérico en la zona de filas de datos (para no
    contar meses futuros aún sin cargar, p.ej. el mes en curso). Si tras filtrar no
    queda ninguna, hace fallback a los 6 meses más recientes CON datos y lo informa."""
    import datetime
    objetivo = _meses_semestre_anterior()
    obj_set = set(objetivo)

    # ¿tiene esta columna algún número en la zona de datos? (bajo fila_fecha)
    fila_ini = fila_fecha + 1
    fila_fin = ws.max_row
    def col_tiene_datos(c):
        for rr in range(fila_ini, fila_fin + 1):
            v = ws.cell(rr, c).value
            if isinstance(v, (int, float)) and v != 0:
                return True
        return False

    todas = []   # (date, col) solo columnas-fecha CON datos reales
    for c in range(1, ws.max_column + 1):
        v = ws.cell(fila_fecha, c).value
        d = v if isinstance(v, datetime.datetime) else None
        if d is None and isinstance(v, str):
            for fmt in ("%d/%m/%Y", "%Y-%m-%d", "%d-%m-%Y", "%m/%d/%Y"):
                try:
                    d = datetime.datetime.strptime(v.strip().split()[0], fmt); break
                except Exception:
                    pass
        if d is not None and col_tiene_datos(c):
            todas.append((d, c))

    cols = [c for d, c in todas if (d.year, d.month) in obj_set]
    presentes = {(d.year, d.month) for d, c in todas if (d.year, d.month) in obj_set}
    faltantes = [ym for ym in objetivo if ym not in presentes]
    etq = f"{objetivo[0][0]}-{objetivo[0][1]:02d} a {objetivo[-1][0]}-{objetivo[-1][1]:02d}"
    if not cols:
        # fallback: 6 meses más recientes CON datos
        todas.sort(reverse=True)
        cols = [c for d, c in todas[:6]]
        return cols, etq, faltantes, True
    return cols, etq, faltantes, False
```

Los cambios respecto a tu versión: (1) agregué `col_tiene_datos(c)` que verifica que la columna tenga algún número distinto de 0 en la zona de datos; (2) solo se agregan a `todas` las columnas-fecha que además tienen datos reales; (3) el fallback ahora cae a los últimos meses **con datos**, no simplemente los últimos por fecha.

