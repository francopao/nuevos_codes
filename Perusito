## EDIT B — Dos helpers nuevos

Pega estos **dos helpers justo antes de `def load_produccion(`** (junto a `_geo_metalica`):

```python
def _canon_empresa_todas(tit):
    """Canoniza un TITULAR venga en nombre corto (BD), legal (metálica) o ya canónico.
    Devuelve el nombre canónico o None si no se reconoce."""
    n = norm(tit)
    for tabla in (EQUIV_MINERAS_MENSUAL, EQUIV_EMPRESAS_PRODUCCION):
        v = {norm(k): val for k, val in tabla.items()}.get(n)
        if v:
            return v
    return {norm(c): c for c in EMPRESAS_CANONICAS}.get(n)


def _load_activos_sin_ubigeo(risk_path):
    """Hoja de mapeo MANUAL de ubicación (prioridad máxima). La leo del propio archivo
    de riesgos (RISK_PATTERNS). Headers dinámicos: TITULAR/UNIDAD/DEPARTAMENTO/
    PROVINCIA/DISTRITO. Devuelve {(canónico, UNIDAD norm): (dep, prov, dist)}.
    Si la hoja no existe, devuelve {} sin romper nada."""
    if not risk_path:
        return {}
    try:
        xl = pd.ExcelFile(risk_path)
    except Exception as e:
        log(f"Activos sin Ubigeo: no se pudo abrir el archivo de riesgos ({e}); se omite.", "WARN")
        return {}
    hoja = next((s for s in xl.sheet_names
                 if any(norm(h) in norm(s) for h in SHEET_ACTIVOS_SIN_UBIGEO_HINTS)), None)
    if hoja is None:
        log("Activos sin Ubigeo: hoja no encontrada; se omite el mapeo manual.")
        return {}
    raw = xl.parse(hoja, header=None, dtype=object)
    hr, sc = detect_header_row(raw, ["TITULAR", "UNIDAD", "DEPARTAMENTO", "DISTRITO"])
    if sc < 3:
        log("Activos sin Ubigeo: no se hallaron headers TITULAR/UNIDAD/DEP/DIST; se omite.", "WARN")
        return {}
    hdr = [norm(x) for x in raw.iloc[hr].tolist()]
    idx = lambda nm: next((i for i, h in enumerate(hdr) if h == nm), None)
    cT, cU, cD, cP, cI = idx("TITULAR"), idx("UNIDAD"), idx("DEPARTAMENTO"), \
                         idx("PROVINCIA"), idx("DISTRITO")
    if None in (cT, cU, cD):
        log("Activos sin Ubigeo: faltan columnas mínimas (TITULAR/UNIDAD/DEPARTAMENTO); se omite.", "WARN")
        return {}
    out, nomap = {}, []
    for r in range(hr + 1, len(raw)):
        row = raw.iloc[r].tolist()
        cell = lambda c: row[c] if (c is not None and c < len(row)) else None
        tit, uni, dep = cell(cT), cell(cU), cell(cD)
        if not tit or not uni or not dep:
            continue
        can = _canon_empresa_todas(tit)
        if not can:
            nomap.append(str(tit)); continue
        out[(can, norm(uni))] = (str(dep).strip(),
                                 str(cell(cP)).strip() if cell(cP) else "",
                                 str(cell(cI)).strip() if cell(cI) else "")
    if nomap:
        log(f"Activos sin Ubigeo: {len(nomap)} fila(s) con TITULAR no reconocido "
            f"(ignoradas): {sorted(set(nomap))}", "WARN")
    if out:
        log(f"Activos sin Ubigeo: {len(out)} activo(s) con ubicación manual (prioridad alta).")
    return out
```

