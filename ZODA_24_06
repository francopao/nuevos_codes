# SECCIÓN 8: CÁLCULO DE MÚLTIPLOS
# ==============================================================================

def multiplos(activo: str,
              datos_bbg: dict,
              datos_ciq: dict,
              fechas_nuevas: pd.Index) -> pd.DataFrame:
    """
    Calcula los 8 múltiplos de valorización (Trail/Fwd × PE/PS/PB/EVEBITDA).

    EQUIVALENCIA CON EL NOTEBOOK 2020:
    El notebook original dividía ambas series en Period Q directamente.
    Funcionaba porque calamine leía "#N/A N/A" como string (no NaN), así
    dropna no eliminaba filas y ambas series tenían el mismo largo →
    no había outer join → no había mismatch de longitudes.

    Con openpyxl, "#N/A N/A" llega como NaN. La división Period Q produce
    un outer join que agrega trimestres extra (los de CIQ sin contraparte
    BBG), haciendo len(ratio) > len(fechas_nuevas) y rompiendo la
    asignación posicional de fechas → ValueError silenciado por try/except
    → "0 empresas con múltiplos".

    SOLUCIÓN — "map por Q" (matemáticamente idéntica al original):
    1. Para cada fecha diaria se determina su Period Q.
    2. Se hace un lookup del valor CIQ indexado por ese Period Q.
    3. El resultado es siempre de exactamente len(fechas_nuevas) filas,
       sin outer join, sin duplicados de índice, sin mismatch.
    Verificado numéricamente: bit-a-bit idéntico al notebook 2020
    para tickers con historia completa.

    TICKERS CON HISTORIA CORTA (AUNA, INRETC1, futuros):
    - LimpiandoBBG preserva todas las filas (sin dropna), por lo que
      los días sin dato BBG llegan como 0 en el numerador.
    - num.replace(0 → NaN) convierte esos días en NaN en el ratio.
    - Creacion_Z_Final usa dropna(how='all').index para encontrar la
      primera fecha con dato real → el Z arranca correctamente desde
      que el ticker tiene historia, sin afectar a los demás.
    - Para tickers completos el comportamiento es idéntico al anterior.
    """
    bbg = datos_bbg[activo]
    ciq = datos_ciq[activo]

    # Mapa: cada fecha diaria → su Period Q
    fechas_q = pd.DatetimeIndex(fechas_nuevas).to_period("Q")

    def _ciq_diario(col: str) -> pd.Series:
        """
        Expande CIQ trimestral a frecuencia diaria mediante lookup por Period Q.
        Cada día diario recibe el valor del trimestre que lo contiene,
        exactamente igual que el notebook 2020 con Period Q, pero sin outer join.
        """
        s = ciq[col].copy()
        s.index = pd.DatetimeIndex(s.index).to_period("Q")
        return pd.Series(
            s.reindex(fechas_q).ffill().values,
            index=fechas_nuevas,
            name=col,
        )

    def _bbg_diario(col: str) -> pd.Series:
        return bbg[col].copy()

    def _ratio(num: pd.Series, den: pd.Series, nombre: str) -> pd.DataFrame:
        """
        Divide num/den y construye un DataFrame diario de len(fechas_nuevas) filas.
        - 0 en num (sin dato BBG)  → NaN en ratio (no ratio=0 incorrecto).
        - 0 en den (sin dato CIQ)  → NaN en ratio (sin dato trimestral).
        - inf/-inf → 0 (igual que notebook original).
        """
        num_clean = num.replace(0, np.nan)
        den_clean = den.replace(0, np.nan)
        ratio = num_clean / den_clean
        df = pd.DataFrame({nombre: ratio.values}, index=fechas_nuevas)
        df.replace([np.inf, -np.inf], 0, inplace=True)
        return df

    ev         = _bbg_diario("CURR_ENTP_VAL")
    market_cap = _bbg_diario("CUR_MKT_CAP")

    net_income = _ciq_diario("IQ_NI")
    ventas     = _ciq_diario("IQ_TOTAL_REV")
    book       = _ciq_diario("IQ_TOTAL_EQUITY")
    ebitda     = _ciq_diario("IQ_EBITDA")

    fwd_ni     = _ciq_diario("Fwd_IQ_NI")
    fwd_ventas = _ciq_diario("Fwd_IQ_TOTAL_REV")
    fwd_book   = _ciq_diario("Fwd_IQ_TOTAL_EQUITY")
    fwd_ebitda = _ciq_diario("Fwd_IQ_EBITDA")

    trail_pe      = _ratio(market_cap, net_income,  "Trail_PE")
    fwd_pe        = _ratio(market_cap, fwd_ni,      "Fwd_PE")
    trail_ps      = _ratio(market_cap, ventas,      "Trail_PS")
    fwd_ps        = _ratio(market_cap, fwd_ventas,  "Fwd_PS")
    trail_pb      = _ratio(market_cap, book,        "Trail_PB")
    fwd_pb        = _ratio(market_cap, fwd_book,    "Fwd_PB")
    trail_evebita = _ratio(ev,         ebitda,      "Trail_EVEBITDA")
    fwd_evebitda  = _ratio(market_cap, fwd_ebitda,  "Fwd_EVEBITDA")

    return pd.concat(
        [trail_pe, fwd_pe, trail_ps, fwd_ps,
         trail_pb, fwd_pb, trail_evebita, fwd_evebitda],
        axis=1, join="outer"
    )


