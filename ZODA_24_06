          f"{len(Empresas_Min_Utl)} Min/Utl")

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 2: Actualizar DQ_IN
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[2/9] Actualizando base DQ_IN...")
    dq_in_bd = leer_hoja_excel(RUTA_ZODA, "DQ_IN", con_encabezado=True)
    df_qest  = leer_hoja_excel(RUTA_QEST, "DQ_IN")
    base_dq_in = actualizar_DQ_IN(df_qest, dq_in_bd)
    base_dq_in = base_dq_in.reset_index(drop=True)
    base_dq_in.loc[3:, "Fecha"] = pd.to_datetime(
        base_dq_in.loc[3:, "Fecha"], dayfirst=True, errors="coerce"
    )

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 3: Leer hojas de datos
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[3/9] Leyendo datos de Bloomberg y Capital IQ desde ZODA.xlsm...")
    Financials_Datos  = leer_hoja_excel(RUTA_ZODA, "Financials")
    Min_Utl_Datos     = leer_hoja_excel(RUTA_ZODA, "Min y Uti")
    Cons_Const_Datos  = leer_hoja_excel(RUTA_ZODA, "Cons y Const")
    Indices_Datos     = leer_hoja_excel(RUTA_ZODA, "Indices")

    # Fechas trimestrales: column_1 desde fila 5, igual que el notebook
    Fechas_Tri = pd.to_datetime(
        Financials_Datos["column_1"].iloc[5:], errors="coerce"
    ).dropna()

    # Fechas diarias: primera columna etiquetada "Px_last" en fila 2
    mask_px = Financials_Datos.iloc[2] == "Px_last"
    Fechas_Diarias = pd.to_datetime(
        Financials_Datos.loc[5:, mask_px].iloc[:, 0], errors="coerce"
    ).dropna()

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 4: Limpiar datos
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[4/9] Limpiando datos y calculando múltiplos de valorización...")

    # Solo procesar tickers que realmente existen en su hoja
    def _existe(hoja, ticker):
        return (hoja.iloc[4] == ticker).any()

    Datos_CIQ, Datos_BBG = {}, {}
    for t in Todas_Finan:
        if _existe(Financials_Datos, t):
            Datos_CIQ[t] = LimpiandoCIQ(Financials_Datos, Fechas_Tri,     t)
            Datos_BBG[t] = LimpiandoBBG(Financials_Datos, Fechas_Diarias,  t)
    for t in Todas_Cons_Const:
        if _existe(Cons_Const_Datos, t):
            Datos_CIQ[t] = LimpiandoCIQ(Cons_Const_Datos, Fechas_Tri,     t)
            Datos_BBG[t] = LimpiandoBBG(Cons_Const_Datos, Fechas_Diarias,  t)
    for t in Todas_Min_Utl:
        if _existe(Min_Utl_Datos, t):
            Datos_CIQ[t] = LimpiandoCIQ(Min_Utl_Datos,   Fechas_Tri,     t)
            Datos_BBG[t] = LimpiandoBBG(Min_Utl_Datos,   Fechas_Diarias,  t)

    total_pedidos = len(Todas_Finan) + len(Todas_Cons_Const) + len(Todas_Min_Utl)
    print(f"  → {len(Datos_BBG)}/{total_pedidos} tickers con datos en el Excel")

    # Índices
    Matriz_Indices = {i: LimpiandoIndices(Indices_Datos, Fechas_Diarias, i)
                      for i in TODAS_INDICES}

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 5: Calcular múltiplos
    # (Fechas_Nuevas = índice diario de BAP, igual que el notebook original)
    # ──────────────────────────────────────────────────────────────────────────
    # Tomar primer ticker disponible como referencia de fechas
    primer_ticker = next(iter(Datos_BBG))
    Fechas_Nuevas = Datos_BBG[primer_ticker].index

    Matriz_Multiplos = {}
    for t in Datos_BBG:
        try:
            Matriz_Multiplos[t] = multiplos(t, Datos_BBG, Datos_CIQ, Fechas_Nuevas)
        except Exception as e:
            print(f"  ⚠️  {t}: error en múltiplos → {e}")

    # Múltiplos de índices: columnas 1 en adelante (sin PX_LAST)
    Matriz_Multiplos_Indices = {
        i: Matriz_Indices[i].iloc[:, 1:] for i in TODAS_INDICES
    }

    print(f"  → Múltiplos calculados para {len(Matriz_Multiplos)} empresas")

    # Exportar CSV intermedio para zoda_dashboard_v3.py
    # ↓↓↓ ESTA es la única fuente de múltiplos del dashboard ZODA.
    #     Si algún día se decide retirar el CSV, eliminar SOLO esta línea.
    exportar_multiplos_csv(Matriz_Multiplos, RUTA_MULTIPLOS_CSV)

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 6: Market Cap para ponderación de baskets
    # ──────────────────────────────────────────────────────────────────────────
    market_cap_parts = []
    for t in Datos_BBG:
        if "CUR_MKT_CAP" in Datos_BBG[t].columns:
            temp = pd.DataFrame(Datos_BBG[t]["CUR_MKT_CAP"]).rename(columns={"CUR_MKT_CAP": t})
            market_cap_parts.append(temp)
    MarketCap = pd.concat(market_cap_parts, axis=1, sort=False) if market_cap_parts else pd.DataFrame()

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 7: Z-scores absolutos (igual que notebook: es_finan como variable global)
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[5/9] Calculando Z-scores...")

    Matriz_Z_Financieras = {}
    for t in Empresas_Financieras:
        if t in Matriz_Multiplos:
            Matriz_Z_Financieras[f"Z_{t}"] = pd.DataFrame(
                Creacion_Z_Final(Matriz_Multiplos[t], es_finan=True),
                columns=[f"Z_{t}"]
            )

    Matriz_Z_Cons_Const = {}
    for t in Empresas_Cons_Const:
        if t in Matriz_Multiplos:
            Matriz_Z_Cons_Const[f"Z_{t}"] = pd.DataFrame(
                Creacion_Z_Final(Matriz_Multiplos[t], es_finan=False),
                columns=[f"Z_{t}"]
            )

    Matriz_Z_Min_Utl = {}
    for t in Empresas_Min_Utl:
        if t in Matriz_Multiplos:
            Matriz_Z_Min_Utl[f"Z_{t}"] = pd.DataFrame(
                Creacion_Z_Final(Matriz_Multiplos[t], es_finan=False),
                columns=[f"Z_{t}"]
            )

    # Z-scores de índices
    Matriz_Z_Indices = {}
    for i in TODAS_INDICES:
        Matriz_Z_Indices[i] = pd.DataFrame(
            Creacion_Z_Final(Matriz_Multiplos_Indices[i], es_finan=False),
            columns=[i]
        )

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 8: Baskets y Z relativos
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[6/9] Calculando Baskets y Z relativos (basket y BVL)...")

    Matriz_Baskets_Finan = {
        t: Creacion_DF_Basket(Basket_Financieras[t], Matriz_Multiplos, MarketCap, Fechas_Diarias)
        for t in Empresas_Financieras if t in Basket_Financieras
    }
    Matriz_Baskets_Cons_Const = {
        t: Creacion_DF_Basket(Basket_Cons_Const[t], Matriz_Multiplos, MarketCap, Fechas_Diarias)
        for t in Empresas_Cons_Const if t in Basket_Cons_Const
    }
    Matriz_Baskets_Min_Utl = {
        t: Creacion_DF_Basket(Basket_Min_Utl[t], Matriz_Multiplos, MarketCap, Fechas_Diarias)
        for t in Empresas_Min_Utl if t in Basket_Min_Utl
    }

    # Z_Basket = Z-score de (mult_empresa / mult_basket)  ← fiel al notebook
    Matriz_Z_Financieras_Basket = {}
    for t in Empresas_Financieras:
        if t in Matriz_Multiplos and t in Matriz_Baskets_Finan:
            ratio = Matriz_Multiplos[t].div(Matriz_Baskets_Finan[t])
            Matriz_Z_Financieras_Basket[f"Z_Basket_{t}"] = pd.DataFrame(
                Creacion_Z_Final(ratio, es_finan=True), columns=[f"Z_Basket_{t}"]
            )

    Matriz_Z_Cons_Const_Basket = {}
    for t in Empresas_Cons_Const:
        if t in Matriz_Multiplos and t in Matriz_Baskets_Cons_Const:
            ratio = Matriz_Multiplos[t].div(Matriz_Baskets_Cons_Const[t])
            Matriz_Z_Cons_Const_Basket[f"Z_Basket_{t}"] = pd.DataFrame(
                Creacion_Z_Final(ratio, es_finan=False), columns=[f"Z_Basket_{t}"]
            )

    Matriz_Z_Min_Utl_Basket = {}
    for t in Empresas_Min_Utl:
        if t in Matriz_Multiplos and t in Matriz_Baskets_Min_Utl:
            ratio = Matriz_Multiplos[t].div(Matriz_Baskets_Min_Utl[t])
            Matriz_Z_Min_Utl_Basket[f"Z_Basket_{t}"] = pd.DataFrame(
                Creacion_Z_Final(ratio, es_finan=False), columns=[f"Z_Basket_{t}"]
            )

    # Z_BVL = Z-score de (mult_empresa / mult_SPBLPGPT)  ← fiel al notebook
    def _z_bvl(t, mult_emp, es_fin):
        ratio = mult_emp.div(Matriz_Multiplos_Indices["SPBLPGPT Index"])
        return pd.DataFrame(
            Creacion_Z_Final(ratio, es_finan=es_fin), columns=[f"Z_BVL_{t}"]
        )

    Matriz_Z_Financieras_BVL = {
        f"Z_BVL_{t}": _z_bvl(t, Matriz_Multiplos[t], True)
        for t in Empresas_Financieras if t in Matriz_Multiplos
    }
    Matriz_Z_Cons_Const_BVL = {
        f"Z_BVL_{t}": _z_bvl(t, Matriz_Multiplos[t], False)
        for t in Empresas_Cons_Const if t in Matriz_Multiplos
    }
    Matriz_Z_Min_Utl_BVL = {
        f"Z_BVL_{t}": _z_bvl(t, Matriz_Multiplos[t], False)
        for t in Empresas_Min_Utl if t in Matriz_Multiplos
    }

    # Z_MXLA = Z-score de (mult_indice / mult_MXLA)  ← fiel al notebook
    Matriz_Z_Indices_MXLA = {}
    for i in TODAS_INDICES:
        if i == "MXLA Index":
            break
        ratio = Matriz_Multiplos_Indices[i].div(Matriz_Multiplos_Indices["MXLA Index"])
        Matriz_Z_Indices_MXLA[f"Z_MXLA_{i}"] = pd.DataFrame(
            Creacion_Z_Final(ratio, es_finan=False), columns=[f"Z_MXLA_{i}"]
        )

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 9: Consolidar Base_Final_Z (orden exacto del notebook original)
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[7/9] Consolidando Z-scores y exportando a Excel...")

    # Concatenar DataFrames individuales igual que el notebook:
    # [Z_emp | Z_basket_emp | Z_BVL_emp | Z_indices | Z_MXLA_indices]
    DF_Z_Financieras        = pd.concat(Matriz_Z_Financieras.values(),        axis=1, sort=False)
    DF_Z_Cons_Const         = pd.concat(Matriz_Z_Cons_Const.values(),         axis=1, sort=False)
    DF_Z_Min_Utl            = pd.concat(Matriz_Z_Min_Utl.values(),            axis=1, sort=False)
    DF_Z_Financieras_Basket = pd.concat(Matriz_Z_Financieras_Basket.values(), axis=1, sort=False)
    DF_Z_Cons_Const_Basket  = pd.concat(Matriz_Z_Cons_Const_Basket.values(),  axis=1, sort=False)
    DF_Z_Min_Utl_Basket     = pd.concat(Matriz_Z_Min_Utl_Basket.values(),     axis=1, sort=False)
    DF_Z_Financieras_BVL    = pd.concat(Matriz_Z_Financieras_BVL.values(),    axis=1, sort=False)
    DF_Z_Cons_Const_BVL     = pd.concat(Matriz_Z_Cons_Const_BVL.values(),     axis=1, sort=False)
    DF_Z_Min_Utl_BVL        = pd.concat(Matriz_Z_Min_Utl_BVL.values(),        axis=1, sort=False)
    DF_Z_Indices            = pd.concat(Matriz_Z_Indices.values(),             axis=1, sort=False)
    DF_Z_Indices_MXLA       = pd.concat(Matriz_Z_Indices_MXLA.values(),       axis=1, sort=False)

    Base_Final_Z = pd.concat([
        DF_Z_Financieras,
        DF_Z_Cons_Const,
        DF_Z_Min_Utl,
        DF_Z_Financieras_Basket,
        DF_Z_Cons_Const_Basket,
        DF_Z_Min_Utl_Basket,
        DF_Z_Financieras_BVL,
        DF_Z_Cons_Const_BVL,
        DF_Z_Min_Utl_BVL,
        DF_Z_Indices,
        DF_Z_Indices_MXLA,
    ], axis=1, sort=False)

    # Escribir BD y DQ_IN en ZODA.xlsm
    escribir_df_en_excel(RUTA_ZODA, "BD",    Base_Final_Z)
    escribir_df_en_excel(RUTA_ZODA, "DQ_IN", base_dq_in, incluir_indice=False)

    # Exportar histórico de múltiplos por GICS
    exportar_multiplos_historicos(Matriz_Multiplos, RUTA_ZODA, RUTA_MULTIPLOS_HIST)

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 10: Exportar múltiplos comparables a la red
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[8/9] Exportando múltiplos comparables a la red...")
    todas_empresas = list(Datos_BBG.keys())
    todas_baskets  = {**Matriz_Baskets_Finan,
                      **Matriz_Baskets_Cons_Const,
                      **Matriz_Baskets_Min_Utl}

    exportar_multiplos_comparables(
        Matriz_Multiplos, todas_baskets, todas_empresas,
        Fechas_Tri, Fechas_Diarias, RUTA_MULT_COMP
    )

    # ──────────────────────────────────────────────────────────────────────────
    # PASO 11: PDF de gráficos
    # ──────────────────────────────────────────────────────────────────────────
    print("\n[9/9] Generando PDF de gráficos...")
    generar_pdf(
        Matriz_Multiplos,
        DF_Z_Financieras, DF_Z_Cons_Const, DF_Z_Min_Utl,
        Empresas_Financieras, Empresas_Cons_Const, Empresas_Min_Utl,
        fecha_hoy, RUTA_PDF
    )

    # ──────────────────────────────────────────────────────────────────────────
    # FIN
    # ──────────────────────────────────────────────────────────────────────────
    fin = datetime.datetime.now()
    print("\n" + "=" * 70)
    print(f"  ✓ Completado en {fin - inicio}")
    print(f"  Hora de término: {fin.strftime('%d/%m/%Y %H:%M:%S')}")
    print("=" * 70)
    print(r"  \(._.)/  ¡Corrió con éxito!")
    print("     |")
    print("    7 7")


