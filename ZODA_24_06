# SECCIÓN 6: FORWARDS A 12 MESES (idéntico al notebook original)
# ==============================================================================

def forwards_one_year(base: pd.DataFrame, names: list) -> pd.DataFrame:
    """
    Para cada fecha del índice, toma el valor de 12 meses adelante.
    Si no existe la fecha exacta, usa la anterior más cercana.
    Replica exactamente la función forwards_one_year del notebook original.
    """
    fechas_bd = pd.Series(base.index.tolist())
    date_to_index = {date: idx for idx, date in enumerate(fechas_bd)}
    max_fecha = fechas_bd.max()
    tasa = 0

    doce_meses = {name: [None] * len(fechas_bd) for name in names}

    for idx, dia in enumerate(fechas_bd):
        fwd = (dia + pd.DateOffset(months=12)).replace(hour=0, minute=0, second=0)

        for name in names:
            col_idx = names.index(name)
            if fwd in date_to_index:
                valor = base.iloc[date_to_index[fwd], col_idx]
            else:
                previas = fechas_bd[fechas_bd < fwd]
                if not previas.empty:
                    cercana = previas.max()
                    valor = base.iloc[date_to_index[cercana], col_idx]
                    if fwd > max_fecha:
                        diff_dias = (fwd - max_fecha).days
                        valor = valor * (1 + tasa) ** (diff_dias / 365)
                else:
                    valor = None
            doce_meses[name][idx] = valor

    fwd_df = pd.DataFrame(doce_meses, index=base.index)
    return pd.concat([base, fwd_df], axis=1)


