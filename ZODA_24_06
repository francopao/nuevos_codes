def exportar_multiplos_csv(matriz_multiplos: dict, ruta_csv: str) -> None:
    """
    Exporta Matriz_Multiplos a un CSV en formato largo (long format):
      Fecha | Ticker | Trail_PE | Fwd_PE | Trail_PS | Fwd_PS |
      Trail_PB | Fwd_PB | Trail_EVEBITDA | Fwd_EVEBITDA

    Este CSV es la única fuente de múltiplos para zoda_dashboard_v3.py,
    eliminando el recalculo de ~55 segundos en cada generación del dashboard.

    DISEÑO:
    - Datos diarios a resolución completa (misma frecuencia que Matriz_Multiplos).
    - zoda_dashboard_v3.py aplica su propio resample al leerlo (bi-weekly).
    - Los NaN se preservan como celdas vacías en CSV (no como 0) para que
      el dashboard pueda distinguir "sin dato" de "múltiplo = 0".
    - El archivo se sobreescribe en cada ejecución de ZODA_03_06_2026.py.
    - Añade columna "GeneradoEn" con timestamp para trazabilidad.
    """
    partes = []
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")

    for ticker, df_mult in matriz_multiplos.items():
        df_tmp = df_mult.copy().reset_index()
        df_tmp.rename(columns={df_tmp.columns[0]: "Fecha"}, inplace=True)
        df_tmp.insert(1, "Ticker", ticker)
        df_tmp["GeneradoEn"] = timestamp
        partes.append(df_tmp)

    if not partes:
        print("  ⚠️  exportar_multiplos_csv: Matriz_Multiplos vacía, CSV no generado.")
        return

    csv_final = pd.concat(partes, ignore_index=True)

    # Asegurar que Fecha quede como string ISO para portabilidad
    csv_final["Fecha"] = pd.to_datetime(csv_final["Fecha"]).dt.strftime("%Y-%m-%d")

    csv_final.to_csv(ruta_csv, index=False, encoding="utf-8-sig")

    n_tickers = csv_final["Ticker"].nunique()
    n_filas   = len(csv_final)
    tam_mb    = os.path.getsize(ruta_csv) / 1_048_576
    print(f"  ✓ CSV exportado: {os.path.basename(ruta_csv)}")
    print(f"    → {n_tickers} tickers | {n_filas:,} filas | {tam_mb:.1f} MB")

