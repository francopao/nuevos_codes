def exportar_multiplos_historicos(todos_multiplos: dict,
                                   ruta_zoda: str,
                                   ruta_salida: str) -> None:
    """
    Crea Multiplos_hist.xlsx con una pestaña por sector GICS.
    Incluye TODOS los múltiplos (trailing + forward).

    ──────────────────────────────────────────────────────────────────────
    FIABILIDAD DE HEADERS (corrección frente a versiones anteriores)
    ──────────────────────────────────────────────────────────────────────
    Versiones previas hacían melt → pivot → renombrado por nombre de
    empresa. Ese camino contaminaba los encabezados: el pivot cruzaba todas
    las empresas en un único índice de fechas y, al renombrar BBG→Empresa
    vía la hoja GICS, dos tickers que mapeaban al mismo nombre (o un nombre
    desfasado/ausente) terminaban con un header de empresa X mostrando los
    datos de la empresa Y.

    Ahora cada bloque de columnas se construye DIRECTAMENTE desde
    todos_multiplos[ticker] — exactamente la misma fuente fiable que usa
    exportar_multiplos_csv (Multiplos_diarios.csv). Sin melt, sin pivot,
    sin join cruzado entre empresas. Por construcción, el dato NUNCA puede
    saltar de una empresa a otra.

    El nombre de empresa se usa SOLO como etiqueta del header, jamás como
    clave de unión. Para que el header siempre tenga sentido y sea
    verificable, la etiqueta superior del MultiIndex es:

        "Nombre (TICKER)"   si el ticker tiene Empresa en la hoja GICS
        "TICKER"            si no la tiene

    Así, aunque la hoja GICS tenga un nombre incorrecto o falte, el ticker
    BBG (identidad 100 % confiable, igual que el CSV) acompaña al dato y lo
    desambigua. Si dos tickers comparten nombre, el ticker los distingue.

    Además se imprime un diagnóstico con los tickers que no encontraron
    'Empresa' o 'GICS' en la hoja, para corregir esos mapeos en la fuente.
    """
    print("  → Exportando histórico de múltiplos por sector GICS...")

    # Mapa BBG ticker → Empresa / GICS desde la hoja GICS de ZODA.xlsm
    dic = leer_hoja_excel(ruta_zoda, "GICS", con_encabezado=True)
    dic = dic.apply(lambda c: c.str.strip() if c.dtype == "object" else c)
    mapa_emp  = dic.set_index("BBG")["Empresa"].to_dict()
    mapa_gics = dic.set_index("BBG")["GICS"].to_dict()

    nombres_mult = [
        "Trail_PE", "Fwd_PE", "Trail_PS", "Fwd_PS",
        "Trail_PB", "Fwd_PB", "Trail_EVEBITDA", "Fwd_EVEBITDA"
    ]

    # ── Diagnóstico: tickers sin mapeo en la hoja GICS ────────────────────
    sin_nombre = [t for t in todos_multiplos if t not in mapa_emp or pd.isna(mapa_emp.get(t))]
    sin_gics   = [t for t in todos_multiplos if t not in mapa_gics or pd.isna(mapa_gics.get(t))]
    if sin_nombre:
        print(f"    ⚠ {len(sin_nombre)} ticker(s) sin 'Empresa' en hoja GICS "
              f"(se usará el ticker como header): {sin_nombre}")
    if sin_gics:
        print(f"    ⚠ {len(sin_gics)} ticker(s) sin 'GICS' "
              f"(irán a la hoja 'Sin GICS'): {sin_gics}")

    # ── Agrupar tickers por sector conservando el dato propio de cada uno ──
    sectores = {}
    for ticker, df_mult in todos_multiplos.items():
        sector = mapa_gics.get(ticker)
        sector = "Sin GICS" if sector is None or pd.isna(sector) else str(sector)

        nombre = mapa_emp.get(ticker)
        nombre = None if nombre is None or pd.isna(nombre) else str(nombre)

        # Header autoexplicativo y a prueba de colisiones.
        etiqueta = f"{nombre} ({ticker})" if nombre else str(ticker)

        sectores.setdefault(sector, []).append((etiqueta, ticker, df_mult))

    # ── Escribir una hoja por sector ──────────────────────────────────────
    with pd.ExcelWriter(ruta_salida, engine="openpyxl") as writer:
        for sector in sorted(sectores):
            bloques = []
            for etiqueta, ticker, df_mult in sectores[sector]:
                # Solo múltiplos conocidos, en orden fijo.
                cols = [c for c in nombres_mult if c in df_mult.columns]
                if not cols:
                    continue
                # 0 → NaN para no ensuciar la hoja con ceros de "sin dato".
                bloque = df_mult[cols].copy().replace(0, np.nan)
                # MultiIndex de columnas: (Empresa (TICKER), Multiplo)
                bloque.columns = pd.MultiIndex.from_product(
                    [[etiqueta], cols], names=["Empresa", "Multiplo"]
                )
                bloques.append(bloque)

            if not bloques:
                continue

            # Unión por fecha (outer) preservando cada bloque intacto.
            # Cada bloque mantiene su propio dato → sin contaminación.
            hoja = pd.concat(bloques, axis=1, join="outer").sort_index()
            hoja.index.name = "Fecha"
            hoja = hoja.dropna(how="all")  # quitar filas totalmente vacías
            hoja.to_excel(writer, sheet_name=str(sector)[:31])

    print(f"  ✓ Guardado: {ruta_salida}")


