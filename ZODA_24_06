def exportar_multiplos_comparables(matriz_multiplos: dict,
                                    matriz_baskets: dict,
                                    todas_empresas: list,
                                    fechas_tri: pd.Series,
                                    fechas_diarias: pd.Index,
                                    ruta_salida: str) -> None:
    """
    Exporta múltiplos trimestrales de empresa y basket al Excel de red.
    Replica la lógica de combinado + combinado_basket del notebook.
    """

    def _appendar(df, combinado, prefijo):
        df2 = df.copy()
        df2.columns = [f"{prefijo}_{col}" for col in df2.columns]
        return pd.concat([combinado, df2], axis=1, sort=False)

    # Alinear a fechas trimestrales
    fechas_d_sorted = pd.DatetimeIndex(fechas_diarias).sort_values()
    fechas_q_alineadas = [fechas_d_sorted.asof(q) for q in fechas_tri]

    combinado = pd.DataFrame()
    for t in todas_empresas:
        if t in matriz_multiplos:
            combinado = _appendar(
                matriz_multiplos[t].fillna(0).reindex(fechas_q_alineadas),
                combinado, t
            )

    combinado_basket = pd.DataFrame()
    for t in todas_empresas:
        if t in matriz_baskets:
            combinado_basket = _appendar(
                matriz_baskets[t].fillna(0).reindex(fechas_q_alineadas),
                combinado_basket, t
            )

    combinado_final = pd.concat([combinado, combinado_basket], axis=1, sort=False)

    try:
        wb = load_workbook(ruta_salida, keep_vba=True)
        ws = wb["Multiplos"] if "Multiplos" in wb.sheetnames else wb.create_sheet("Multiplos")
        ws.delete_rows(1, ws.max_row)

        df_exp = combinado_final.reset_index()
        for ci, cn in enumerate(df_exp.columns, 1):
            ws.cell(row=1, column=ci, value=str(cn))
        for ri, row in enumerate(df_exp.itertuples(index=False), 2):
            for ci, val in enumerate(row, 1):
                if isinstance(val, pd.Timestamp):
                    val = val.to_pydatetime()
                elif isinstance(val, float) and np.isnan(val):
                    val = None
                ws.cell(row=ri, column=ci, value=val)
        wb.save(ruta_salida)
        print(f"  ✓ Escrito en red: {ruta_salida}")
    except Exception as e:
        print(f"  ✗ Error al escribir en red: {e}")


