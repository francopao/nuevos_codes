## Cambio 2 — Columnas "Score" y "Mitigantes" en las tablas post‑mapa

Estas son las tablas `tbl3` (las que salen debajo del mapa, con el check "Desglosar por empresa"). Busca en el string del HTML el bloque que empieza con:

```js
// Estado del selector "Desglosar" (exclusivo de chart 3, ...
const DESGLOSE_TBL3={};
```

Reemplaza **desde `const DESGLOSE_TBL3={};` hasta el final de la función `buildTbl3` (justo antes de `// ====... ADICIÓN 4`)** por este bloque completo:

```js
const DESGLOSE_TBL3={};
// NUEVO: estado del botón que muestra/oculta la columna Mitigantes en tbl3
let MOSTRAR_MITIG_TBL3=false;

function toggleDesglose(hzkey, checked){
  DESGLOSE_TBL3[hzkey]=checked;
  const hz=HZ.find(h=>h.key===hzkey);
  const m=MAPAS.find(x=>x.hz.key===hzkey);
  buildTbl3(hz, m?m.filtroEmisor:null, m?m.filtroSector:null);
}
// NUEVO: alterna la columna Mitigantes en las 3 tablas a la vez
function toggleMitigTbl3(){
  MOSTRAR_MITIG_TBL3=!MOSTRAR_MITIG_TBL3;
  HZ.forEach(hz=>{ const m=MAPAS.find(x=>x.hz.key===hz.key);
    buildTbl3(hz, m?m.filtroEmisor:null, m?m.filtroSector:null); });
}

function buildTbl3(hz, filtroEmisor, filtroSector){
  const wrap=document.getElementById('tbl3_'+hz.key);
  if(!wrap) return;
  const col=hz.col;
  const niveles=[1,2,3,4,5];
  const desglosar=!!DESGLOSE_TBL3[hz.key];

  // NUEVO: mismos scores que la sección "Score por empresa" (ADICIÓN 4).
  // hz.key es 'mm' | 'inu' | 'seq' -> escenario correspondiente.
  const SC=calcScores();
  const sKey=hz.key;
  const scoreEmp=e=>(SC[e]&&typeof SC[e][sKey]==='number')?SC[e][sKey]:null;

  const portCat={}; niveles.forEach(L=>portCat[L]=0);
  const secCat={}, compCat={};
  D.forEach(d=>{
    const L=d[col];
    if(niveles.indexOf(L)<0) return;          // sin N/D
    (d.ap||[]).forEach(a=>{
      const m=a.m*classFrac(a.e); if(m<=0) return;
      const sec=EMP_SECTOR[a.e]||a.s||'(sin sector)';
      portCat[L]+=m;
      (secCat[sec]=secCat[sec]||{})[L]=(secCat[sec][L]||0)+m;
      const cc=(compCat[sec]=compCat[sec]||{});
      (cc[a.e]=cc[a.e]||{})[L]=(cc[a.e][L]||0)+m;
    });
  });

  const sectoresDisp = filtroSector ? [filtroSector]
    : [...new Set(Object.values(EMP_SECTOR).filter(Boolean))].sort();
  const pc=(num,den)=> den>0 ? (num/den*100).toLocaleString('es-PE',{maximumFractionDigits:1})+'%' : '—';

  // NUEVO: score del sector = promedio de los scores de sus empresas ponderado
  // por la plata de cada empresa con score CENEPRED válido en este peligro.
  const scoreSector=sec=>{
    const comps=compCat[sec]||{}; let num=0, den=0;
    Object.keys(comps).forEach(emp=>{
      const s=scoreEmp(emp); if(s===null) return;
      const w=niveles.reduce((t,L)=>t+(comps[emp][L]||0),0);
      if(w>0){ num+=s*w; den+=w; }
    });
    return den>0 ? num/den : null;
  };
  const celScore=v=> v===null
    ? '<td style="text-align:center">—</td>'
    : '<td class="sc-cell" style="background:'+scoreBg(v)+'">'+v.toFixed(2)+'</td>';
  const celMit=emp=> MOSTRAR_MITIG_TBL3 ? mitiCell(emp) : '';
  const celMitVacia=()=> MOSTRAR_MITIG_TBL3 ? '<td style="text-align:center">—</td>' : '';

  let html='<label class="tbl3-chk"><input type="checkbox" '+(desglosar?'checked':'')+
           ' onchange="toggleDesglose(\''+hz.key+'\',this.checked)"> Desglosar por empresa</label>'+
           '<button class="lyrbtn" style="margin-left:10px" onclick="toggleMitigTbl3()">'+
           (MOSTRAR_MITIG_TBL3?'Ocultar Mitigantes':'Mostrar Mitigantes')+'</button>';

  sectoresDisp.forEach(sec=>{
    const sc=secCat[sec]; if(!sc) return;
    const secTot=niveles.reduce((s,L)=>s+(sc[L]||0),0);
    if(secTot<=0) return;
    html+='<div class="tbl3-titulo">'+sec+'</div>';
    html+='<table class="tbl3"><thead><tr><th class="idx">Riesgo</th>';
    niveles.forEach(L=>{ html+='<th>'+L+'</th>'; });
    html+='<th>Score</th>';                                   // NUEVO
    if(MOSTRAR_MITIG_TBL3) html+='<th>Mitigantes</th>';       // NUEVO
    html+='</tr></thead><tbody>';
    if(!desglosar){
      html+='<tr><td class="idx">AUM '+sec+'</td>';
      niveles.forEach(L=>{ html+='<td>'+pc(sc[L]||0, secTot)+'</td>'; });
      html+=celScore(scoreSector(sec))+celMitVacia()+'</tr>';
    } else {
      const comps=compCat[sec]||{};
      Object.keys(comps).sort().forEach(emp=>{
        const cc=comps[emp];
        const compTot=niveles.reduce((s,L)=>s+(cc[L]||0),0);
        if(compTot<=0) return;
        html+='<tr><td class="idx">'+emp+'</td>';
        niveles.forEach(L=>{ html+='<td>'+pc(cc[L]||0, compTot)+'</td>'; });
        html+=celScore(scoreEmp(emp))+celMit(emp)+'</tr>';
      });
      html+='<tr class="tbl3-sector"><td class="idx">AUM '+sec+'</td>';
      niveles.forEach(L=>{ html+='<td>'+pc(sc[L]||0, secTot)+'</td>'; });
      html+=celScore(scoreSector(sec))+celMitVacia()+'</tr>';
    }
    html+='<tr class="tbl3-total"><td class="idx">AUM Total</td>';
    niveles.forEach(L=>{ html+='<td>'+pc(sc[L]||0, portCat[L]||0)+'</td>'; });
    html+='<td>—</td>'+celMitVacia()+'</tr></tbody></table>';
  });

  wrap.innerHTML = html || '<p style="font-size:11px;color:var(--plomo)">Sin exposición para este filtro.</p>';
}
```

