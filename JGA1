# 4. WORDING DINAMICO - plantillas del Excel + reglas de redaccion
# ============================================================================
def _lista_es(items):
    """['a','b','c'] -> 'a, b y c'  (redaccion en espaniol)"""
    items = [i for i in items if i]
    if not items:
        return ""
    if len(items) == 1:
        return items[0]
    return ", ".join(items[:-1]) + " y " + items[-1]


def _pct(x):
    return f"{round(x * 100)}%"


MESES = ["enero","febrero","marzo","abril","mayo","junio",
         "julio","agosto","setiembre","octubre","noviembre","diciembre"]


def _fecha_es(d):
    return f"{d.day} de {MESES[d.month-1]} de {d.year}"


def _plural(n, sing, plur):
    return sing if n == 1 else plur


def redactar(bloque, param, periodo):
    """Genera los parrafos del Word segun las plantillas editables de la hoja Textos."""
    T = param["textos"]
    inst = param["config"].get("Nombre_Institucion", "AFP Integra")
    out = {}

    if bloque is None:
        return {"sin_datos": T.get("sin_datos", "Sin registros.")}

    # --- sector: cuantos sectores hacen falta para superar el 50%
    secs = sorted(bloque["sectores"], key=lambda s: -s["pct"])
    acum, top = 0.0, []
    for s in secs:
        top.append(s["sector"])
        acum += s["pct"]
        if acum >= 0.5:
            break
    out["sector"] = T["sector"].format(
        periodo=periodo, n_juntas=bloque["n_juntas"],
        junta_larga="juntas obligatorias anuales de accionistas" if bloque["tipo"] == "JOA"
                    else "juntas generales de accionistas",
        n_empresas=bloque["n_empresas"], pct_top=_pct(acum), sectores_top=_lista_es(top))

    # --- temas: los "no recurrentes" son los que aparecen en <=2 puntos
    conteo = {t: sum(s["datos"][i] for s in bloque["barras"]["series"])
              for i, t in enumerate(bloque["barras"]["temas"])}
    raros = [t for t, n in sorted(conteo.items(), key=lambda kv: kv[1]) if n <= 2][:3]
    tema_top = max(conteo, key=conteo.get) if conteo else ""
    out["temas"] = T["temas"].format(
        n_puntos=bloque["n_puntos"],
        temas_raros=_lista_es(raros) if raros else "ninguno adicional",
        tema_top=tema_top)

    # --- votos en contra
    if bloque["n_contra"]:
        out["contras"] = T["contras"].format(
            n_contra=bloque["n_contra"], institucion=inst,
            temas_contra=_lista_es([c["tema"] for c in bloque["contra_tema"][:3]]))
    else:
        out["contras"] = f"No emitimos votos en contra durante el {periodo}."

    # --- votos en contra ligados a directores
    if bloque["motivos_dir"]:
        n_md = sum(m["n"] for m in bloque["motivos_dir"])
        plantilla = T["contras_dir"]
        if n_md == 1:
            plantilla = plantilla.replace("{n_contra_dir} votos en contra", "1 voto en contra")
            plantilla = plantilla.replace("La mayor parte de los votos en contra se emitieron",
                                          "El voto en contra se emitio")
        out["contras_dir"] = plantilla.format(
            n_contra_dir=n_md,
            motivo_top=_lista_es([m["motivo"].lower() for m in bloque["motivos_dir"][:2]]),
            motivos_lista=_lista_es([m["motivo"] for m in bloque["motivos_dir"]]))
    else:
        out["contras_dir"] = ""

    # --- independencia
    nd = bloque["n_dir_fav"]
    if nd:
        n_ind = next((i["n"] for i in bloque["independencia"] if i["tipo"] == "Independiente"), 0)
        if n_ind == nd:
            frase = "todos ellos calificaban como independientes"
        elif n_ind == 0:
            frase = "ninguno de ellos calificaba como independiente"
        else:
            frase = (f"{n_ind} de ellos {_plural(n_ind,'calificaba','calificaban')} "
                     f"como {_plural(n_ind,'independiente','independientes')} ({_pct(n_ind/nd)})")
        out["independencia"] = T["independencia"].format(
            n_dir=nd, n_indep=n_ind, pct_indep=_pct(n_ind / nd), frase_indep=frase)

        if bloque["experiencia"]:
            tot_e = sum(e["n"] for e in bloque["experiencia"])
            e0 = bloque["experiencia"][0]
            out["experiencia"] = T["experiencia"].format(
                n_dir=nd, esp_top=e0["esp"], pct_esp_top=_pct(e0["n"] / tot_e))
        else:
            out["experiencia"] = ""
    else:
        out["independencia"] = ""
        out["experiencia"] = ""

    return out


