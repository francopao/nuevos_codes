</style></head><body>

<h1 id="titulo"></h1>
<div class="sub" id="subtitulo"></div>

<div class="filtros">
  <div><label>Año</label><select id="fAnio"></select></div>
  <div><label>Trimestre</label><select id="fTri"></select></div>
  <div><label>Tipo de junta</label><select id="fTipo"></select></div>
  <div><label>Sector</label><select id="fSec"></select></div>
  <div><label>Empresa</label><select id="fEmp"></select></div>
</div>

<div class="kpis" id="kpis"></div>

<div class="grid">
  <div class="card full"><h2>Votación por tema de agenda</h2><div class="wrap alto"><canvas id="c1"></canvas></div></div>
  <div class="card full"><h2>Distribución por sector</h2><div class="tree" id="tree"></div></div>
  <div class="card"><h2>Votos en contra por tema</h2><div class="wrap"><canvas id="c2"></canvas></div></div>
  <div class="card"><h2>Motivos de voto en contra (directores)</h2><div class="wrap"><canvas id="c6"></canvas></div></div>
  <div class="card"><h2>Independencia de directores</h2><div class="wrap"><canvas id="c11"></canvas></div></div>
  <div class="card"><h2>Experiencia de directores</h2><div class="wrap"><canvas id="c9"></canvas></div></div>
  <div class="card full"><h2>Detalle por empresa</h2><div id="tabla"></div></div>
</div>

<footer id="pie"></footer>

<script>
const DATOS = __DATOS__;
const META  = __META__;
const GEN   = "__GENERADO__";
const P="#"+META.primario, S="#"+META.secundario, A="#"+META.acento;
const PALETA=[P,S,A,"#5B6DAE","#3E9FBF","#7FC9DB","#A9BCE0","#BFBFBF","#2F4380","#89D6E6","#C8CE3F","#8A93B8","#4C6FA5"];
let charts={};

document.getElementById("titulo").textContent=META.titulo;
document.getElementById("pie").textContent=META.pie+"  ·  Generado "+GEN;

function unicos(campo){return [...new Set(DATOS.map(d=>d[campo]).filter(v=>v!==""&&v!==0))];}
function llenar(id,vals,etiqueta,mapa){
  const s=document.getElementById(id);
  s.innerHTML='<option value="">'+etiqueta+'</option>';
  vals.forEach(v=>{const o=document.createElement("option");o.value=v;
    o.textContent=mapa&&mapa[v]?mapa[v]:v;s.appendChild(o);});
  s.onchange=render;
}
llenar("fAnio",unicos("anio").sort((a,b)=>b-a),"Todos");
llenar("fTri",["T1","T2","T3","T4"],"Todos");
llenar("fTipo",unicos("tj"),"Todas",META.tipos);
llenar("fSec",unicos("sec").sort((a,b)=>(META.orden_sector[a]||99)-(META.orden_sector[b]||99)),"Todos");
llenar("fEmp",unicos("emp").sort(),"Todas");

function filtrar(){
  const a=fAnio.value,t=fTri.value,tj=fTipo.value,se=fSec.value,em=fEmp.value;
  return DATOS.filter(d=>(!a||d.anio==a)&&(!t||d.tri==t)&&(!tj||d.tj==tj)&&(!se||d.sec==se)&&(!em||d.emp==em));
}
const cuenta=d=>META.decisiones[d.dec]&&META.decisiones[d.dec].cuenta;

function pinta(id,cfg){
  if(charts[id])charts[id].destroy();
  charts[id]=new Chart(document.getElementById(id),cfg);
}
const SIN={responsive:true,maintainAspectRatio:false};

function render(){
  const F=filtrar(), C=F.filter(cuenta);
  const juntas=new Set(F.map(d=>d.jid));
  const contras=C.filter(d=>d.dec==="En Contra");
  const dirsFav=C.filter(d=>d.dir&&d.dec==="A Favor");

  // ---- KPIs
  document.getElementById("kpis").innerHTML=[
    [juntas.size,"Juntas"],[new Set(F.map(d=>d.emp)).size,"Empresas"],
    [C.length,"Puntos votados"],[contras.length,"Votos en contra"],
    [dirsFav.length,"Directores a favor"]
  ].map(k=>`<div class="kpi"><div class="n">${k[0]}</div><div class="l">${k[1]}</div></div>`).join("");

  if(!F.length){
    document.getElementById("tabla").innerHTML='<div class="vacio">No hay registros para esta combinación de filtros.</div>';
    document.getElementById("tree").innerHTML='<div class="vacio">Sin datos</div>';
    Object.values(charts).forEach(c=>c.destroy());charts={};
    return;
  }

  // ---- Chart 1: barras apiladas tema x decision
  const m={};C.forEach(d=>{(m[d.tema]=m[d.tema]||{})[d.dec]=(m[d.tema][d.dec]||0)+1;});
  const temas=Object.keys(m).sort((x,y)=>tot(m[x])-tot(m[y]));
  function tot(o){return Object.values(o).reduce((a,b)=>a+b,0);}
  const decs=Object.keys(META.decisiones).filter(k=>META.decisiones[k].cuenta
              &&temas.some(t=>m[t][k]));
  pinta("c1",{type:"bar",data:{labels:temas,datasets:decs.map(k=>({
      label:k,backgroundColor:META.decisiones[k].color,data:temas.map(t=>m[t][k]||0)}))},
    options:{...SIN,indexAxis:"y",scales:{x:{stacked:true,grid:{display:false}},
      y:{stacked:true,grid:{display:false},ticks:{font:{size:11}}}},
      plugins:{legend:{position:"bottom",labels:{boxWidth:12,font:{size:11}}},
        datalabels:false}}});

  // ---- Treemap de sectores
  const bySec={};F.forEach(d=>{const o=bySec[d.sec]=bySec[d.sec]||{e:new Set(),j:new Set()};
    o.e.add(d.emp);o.j.add(d.jid);});
  const tj=juntas.size;
  document.getElementById("tree").innerHTML=Object.keys(bySec)
    .sort((a,b)=>bySec[b].j.size-bySec[a].j.size).map(s=>{
      const o=bySec[s],pc=tj?Math.round(o.j.size/tj*100):0;
      const w=Math.max(14,Math.min(46,pc*1.5+14));
      return `<div class="tile" style="background:${META.sectores[s]||"#BFBFBF"};flex:1 1 ${w}%">
        <span>Empresas: ${o.e.size}</span><div><b>${pc}%</b><br><span>${s}</span></div></div>`;
    }).join("");

  // ---- Chart 2: contras por tema
  dona("c2",cont(contras,"tema"));
  // ---- Chart 6: motivos ligados a eleccion de directores
  const md=contras.filter(d=>META.motivos[d.mot]==="Eleccion y Numero de Directores");
  dona("c6",cont(md,"mot"),true);
  // ---- Chart 11: independencia
  dona("c11",cont(dirsFav.filter(d=>d.ind),"ind"),true);
  // ---- Chart 9: experiencia
  const ex={};dirsFav.forEach(d=>{[d.e1,d.e2].forEach(e=>{if(e)ex[e]=(ex[e]||0)+1;});});
  dona("c9",ex,true);

  tablaDetalle(F);
}

function cont(arr,campo){const o={};arr.forEach(d=>{if(d[campo])o[d[campo]]=(o[d[campo]]||0)+1;});return o;}
function dona(id,obj,anillo){
  const k=Object.keys(obj).sort((a,b)=>obj[b]-obj[a]);
  if(!k.length){if(charts[id])charts[id].destroy();
    const cv=document.getElementById(id);cv.getContext("2d").clearRect(0,0,cv.width,cv.height);return;}
  const t=k.reduce((a,x)=>a+obj[x],0);
  pinta(id,{type:anillo?"doughnut":"pie",
    data:{labels:k,datasets:[{data:k.map(x=>obj[x]),backgroundColor:PALETA,borderColor:"#fff",borderWidth:2}]},
    options:{...SIN,cutout:anillo?"52%":0,plugins:{legend:{position:"right",
      labels:{boxWidth:12,font:{size:11},generateLabels:ch=>k.map((l,i)=>({
        text:l+"  "+Math.round(obj[l]/t*100)+"%",fillStyle:PALETA[i%PALETA.length],index:i}))}},
      tooltip:{callbacks:{label:c=>c.label+": "+c.raw+" ("+Math.round(c.raw/t*100)+"%)"}}}}});
}

function tablaDetalle(F){
  const g={};
  F.forEach(d=>{(g[d.emp]=g[d.emp]||{})[d.fec]=(g[d.emp][d.fec]||[]);g[d.emp][d.fec].push(d);});
  let h='<table><thead><tr><th style="width:70px">Punto</th><th>Tema de agenda</th>'
       +'<th style="width:140px">Votación</th></tr></thead><tbody>';
  Object.keys(g).sort().forEach(e=>{
    h+=`<tr class="emp"><td colspan="3">${e}</td></tr>`;
    Object.keys(g[e]).sort().forEach(f=>{
      h+=`<tr class="fec"><td colspan="3">${f}</td></tr>`;
      g[e][f].sort((a,b)=>a.pto.localeCompare(b.pto,undefined,{numeric:true})).forEach(d=>{
        const col=(META.decisiones[d.dec]||{}).color||"#BFBFBF";
        const nota=d.jus||d.mot?`<div class="jus">${d.jus||d.mot}</div>`:"";
        h+=`<tr><td>${d.pto}</td><td>${d.txt}${nota}</td>
            <td><span class="pill" style="background:${col}">${d.dec}</span></td></tr>`;
      });
    });
  });
  document.getElementById("tabla").innerHTML=h+"</tbody></table>";
}

document.getElementById("subtitulo").textContent=
  META.institucion+"  ·  "+DATOS.length+" puntos de agenda registrados";
render();
</script></body></html>"""


# ============================================================================
# 6. REPORTE WORD - mismo orden de secciones que el PDF publicado
# ============================================================================
def _png_barras(bloque, param):
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    b = bloque["barras"]
    fig, ax = plt.subplots(figsize=(8.2, max(2.6, 0.34 * len(b["temas"]))))
    izq = [0] * len(b["temas"])
    for s in b["series"]:
        ax.barh(b["temas"], s["datos"], left=izq, color=s["color"], label=s["nombre"], height=.62)
        for i, (v, x0) in enumerate(zip(s["datos"], izq)):
            if v:
                ax.text(x0 + v / 2, i, str(v), ha="center", va="center",
                        color="white", fontsize=8, fontweight="bold")
        izq = [a + c for a, c in zip(izq, s["datos"])]
    ax.set_yticks(range(len(b["temas"])))
    ax.set_yticklabels(b["temas"], fontsize=8)
    ax.legend(fontsize=8, loc="lower right", frameon=False)
    for sp in ("top", "right", "left"):
        ax.spines[sp].set_visible(False)
    ax.tick_params(axis="x", labelsize=8)
    ax.grid(False)
    fig.tight_layout()
    buf = io.BytesIO(); fig.savefig(buf, format="png", dpi=170); plt.close(fig)
    buf.seek(0); return buf


def _png_circular(datos, etiquetas, colores, anillo=True):
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    fig, ax = plt.subplots(figsize=(5.4, 3.1))
    w = dict(width=.48) if anillo else {}
    ax.pie(datos, colors=colores, startangle=90, counterclock=False,
           autopct=lambda p: f"{p:.0f}%" if p >= 4 else "",
           textprops=dict(color="white", fontsize=9, fontweight="bold"),
           wedgeprops=w)
    ax.legend(etiquetas, fontsize=8, loc="center left", bbox_to_anchor=(1.0, .5), frameon=False)
    ax.axis("equal")
    fig.tight_layout()
    buf = io.BytesIO(); fig.savefig(buf, format="png", dpi=170); plt.close(fig)
    buf.seek(0); return buf


def _png_sectores(bloque, param):
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    secs = sorted(bloque["sectores"], key=lambda s: -s["pct"])
    fig, ax = plt.subplots(figsize=(8.2, 2.5))
    x = 0.0
    for s in secs:
        w = max(s["pct"], .05)
        ax.add_patch(plt.Rectangle((x, 0), w * .98, 1, color=s["color"]))
        ax.text(x + w * .49, .70, f"Empresas: {s['empresas']}", ha="center",
                color="white", fontsize=8)
        ax.text(x + w * .49, .34, s["sector"], ha="center", color="white",
                fontsize=8, fontweight="bold")
        ax.text(x + w * .49, .14, _pct(s["pct"]), ha="center", color="white", fontsize=8)
        x += w
    ax.set_xlim(0, max(x, 1)); ax.set_ylim(0, 1); ax.axis("off")
    fig.tight_layout()
    buf = io.BytesIO(); fig.savefig(buf, format="png", dpi=170); plt.close(fig)
    buf.seek(0); return buf


def generar_word(bloques, param, periodo, ruta_salida):
    from docx import Document
    from docx.shared import Pt, Inches, RGBColor
    from docx.enum.text import WD_ALIGN_PARAGRAPH

    cfg = param["config"]
    NAV = RGBColor(*bytes.fromhex(cfg.get("Color_Primario", "1E2E6E")))
    CYN = RGBColor(*bytes.fromhex(cfg.get("Color_Secundario", "00AECB")))
    PAL = [param["sectores"][s]["color"] for s in param["sectores"]] or ["#1E2E6E"]

    doc = Document()
    st = doc.styles["Normal"]; st.font.name = "Arial"; st.font.size = Pt(10)

    def parr(txt, size=10, color=NAV, bold=False, just=True, space=8):
        if not txt:
            return
        p = doc.add_paragraph()
        p.paragraph_format.space_after = Pt(space)
        if just:
            p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
        r = p.add_run(txt); r.font.size = Pt(size); r.font.color.rgb = color; r.bold = bold
        return p

    def img(buf, ancho=6.3):
        doc.add_picture(buf, width=Inches(ancho))
        doc.paragraphs[-1].alignment = WD_ALIGN_PARAGRAPH.CENTER

    # --------- portada
    parr(cfg.get("Titulo_Reporte", "REPORTE DE JUNTAS DE ACCIONISTAS"), 24, NAV, True, False, 2)
    parr(periodo, 20, CYN, True, False, 18)
    parr(param["textos"].get("intro", "").format(
        institucion=cfg.get("Nombre_Institucion", "AFP Integra"), periodo=periodo), 10)
    parr("*El reporte ha sido elaborado con la informacion disponible al "
         + _fecha_es(datetime.now()) + ".", 8, RGBColor(0x6B, 0x72, 0x80), False, 18)
    doc.add_page_break()

    letras = "abcdefghij"
    for idx, bloque in enumerate(bloques):
        if bloque is None:
            continue
        w = redactar(bloque, param, periodo)
        parr(f"{letras[idx]}) {bloque['etiqueta']} - {periodo}", 13, CYN, True, False, 10)

        # 1. Distribucion por sector
        parr(f"• Total de {bloque['tipo']}s y Distribucion por Sector", 11, CYN, True, False, 6)
        parr(w["sector"])
        img(_png_sectores(bloque, param))

        # 2. Votacion por tema de agenda
        parr(f"• Votacion por Tema de Agenda en {bloque['tipo']}s", 11, CYN, True, False, 6)
        img(_png_barras(bloque, param))
        parr(w["temas"])

        # 3. Votos en contra
        if bloque["contra_tema"]:
            parr(f"• Votos en Contra en {bloque['tipo']}s", 11, CYN, True, False, 6)
            parr(w["contras"])
            img(_png_circular([c["n"] for c in bloque["contra_tema"]],
                              [c["tema"] for c in bloque["contra_tema"]], PAL, False), 5.2)

        # 4. Directores
        if bloque["n_dir_fav"] or bloque["motivos_dir"]:
            parr(f"• Votacion respecto a directores en {bloque['tipo']}s:", 11, CYN, True, False, 6)

            if bloque["motivos_dir"]:
                parr("- Votos en contra", 10, NAV, True, False, 4)
                parr(w["contras_dir"])
                img(_png_circular([m["n"] for m in bloque["motivos_dir"]],
                                  [m["motivo"] for m in bloque["motivos_dir"]], PAL, False), 5.2)

            if bloque["independencia"]:
                parr("- Independencia", 10, NAV, True, False, 4)
                parr(w["independencia"])
                img(_png_circular([i["n"] for i in bloque["independencia"]],
                                  [i["tipo"] for i in bloque["independencia"]], PAL), 5.2)

            if bloque["experiencia"]:
                parr("- Experiencia", 10, NAV, True, False, 4)
                parr(w["experiencia"])
                img(_png_circular([e["n"] for e in bloque["experiencia"]],
                                  [e["esp"] for e in bloque["experiencia"]], PAL), 5.2)

        # 5. Detalle por empresa
        doc.add_page_break()
        parr(f"• Votacion por empresa en {bloque['tipo']}s {periodo}", 11, CYN, True, False, 8)
        tb = doc.add_table(rows=1, cols=2); tb.style = "Table Grid"
        for c, t in zip(tb.rows[0].cells, ("Temas de Agenda", "Votacion")):
            r = c.paragraphs[0].add_run(t); r.bold = True; r.font.size = Pt(9)
        for e in bloque["tabla"]:
            for f in e["fechas"]:
                fila = tb.add_row().cells
                r = fila[0].paragraphs[0].add_run(f"{e['empresa']}\n{f['fecha']}")
                r.bold = True; r.font.size = Pt(9); r.font.color.rgb = NAV
                for p in f["puntos"]:
                    fl = tb.add_row().cells
                    rr = fl[0].paragraphs[0].add_run(f"{p['punto']}. {p['texto']}")
                    rr.font.size = Pt(8)
                    voto = p["decision"]
                    if p["decision"] == "En Contra" and p["motivo"]:
                        voto += f". {p['motivo']}"
                    rv = fl[1].paragraphs[0].add_run(voto); rv.font.size = Pt(8)
        if idx < len(bloques) - 1:
            doc.add_page_break()

    doc.save(ruta_salida)
    print(f"[OK] Word       -> {ruta_salida}")


# ============================================================================
# 7. MAIN
# ============================================================================
def main():
    ap = argparse.ArgumentParser(description="Dashboard y reporte de Juntas de Accionistas")
    ap.add_argument("--bd", default=RUTA_BD, help="ruta al Excel de la BD")
    ap.add_argument("--anio", type=int, default=None, help="filtra el Word a un anio")
    ap.add_argument("--trimestre", default=None, help="T1 | T2 | T3 | T4")
    ap.add_argument("--salida", default=CARPETA_SALIDA)
    ap.add_argument("--solo-dashboard", action="store_true")
    ap.add_argument("--solo-word", action="store_true")
    args = ap.parse_args()

    print("=" * 70)
    print("JUNTAS DE ACCIONISTAS - generacion de reportes")
    print("=" * 70)

    registros, param = cargar_bd(args.bd)
    print(f"[OK] BD leida: {len(registros)} filas, {len(param['empresas'])} empresas parametrizadas.")
    validar(registros, param)

    os.makedirs(args.salida, exist_ok=True)
    sello = datetime.now().strftime("%Y%m%d_%H%M")

    # --- El dashboard siempre lleva la data completa; los filtros son del navegador.
    if not args.solo_word:
        generar_html(registros, param,
                     os.path.join(args.salida, f"Dashboard_Juntas_{sello}.html"))

    if not args.solo_dashboard:
        sub = registros
        etiquetas = []
        if args.anio:
            sub = [r for r in sub if r["anio"] == args.anio]
            etiquetas.append(str(args.anio))
        if args.trimestre:
            sub = [r for r in sub if r["trimestre"] == args.trimestre.upper()]
            etiquetas.append(args.trimestre.upper())
        periodo = " - ".join(etiquetas) if etiquetas else "periodo completo"

        if not sub:
            sys.exit(f"[ERROR] No hay registros para {periodo}.")

        orden = sorted(param["tipos"], key=lambda t: param["tipos"][t]["orden"])
        bloques = [agregar(sub, param, t) for t in orden]
        bloques = [b for b in bloques if b]
        if not bloques:
            sys.exit("[ERROR] No hay juntas computables en el periodo.")

        nom = f"Reporte_Juntas_{periodo.replace(' - ','_').replace(' ','_')}_{sello}.docx"
        generar_word(bloques, param, periodo, os.path.join(args.salida, nom))

    print("=" * 70)
    print("Listo.")


if __name__ == "__main__":
    main()
