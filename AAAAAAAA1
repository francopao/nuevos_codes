# Bloomberg a veces exporta estas columnas sin el sufijo "(P)", o con la
# primera columna (Name) sin encabezado (queda como 'Unnamed: 0'). Este mapa
# tolera ambas variantes sin depender de qué formato trajo el archivo.
ALIAS_COLUMNAS = {
    'Name': ['Name', 'Unnamed: 0', 'Unnamed:0'],
    'Market Value (%) (P)': ['Market Value (%) (P)', 'Market Value (%)'],
    'MSCI ESG Rating (P)': ['MSCI ESG Rating (P)', 'MSCI ESG Rating'],
    'Px Close (P)': ['Px Close (P)', 'Px Close'],
}


def resolver_alias_columnas(df):
    """Renombra variantes conocidas de columnas a su nombre canónico
    (p.ej. 'Market Value (%)' -> 'Market Value (%) (P)')."""
    df = df.copy()
    for canonico, alias_list in ALIAS_COLUMNAS.items():
        if canonico in df.columns:
            continue
        for alias in alias_list:
            if alias in df.columns:
                df = df.rename(columns={alias: canonico})
                break
    return df


# ---------------------------------------------------------------------------
# Utilidades de limpieza
# ---------------------------------------------------------------------------

def limpiar_numero(serie):
    """Convierte a float, removiendo asteriscos y espacios que a veces
    contaminan las celdas numéricas exportadas desde Bloomberg."""
    return pd.to_numeric(
        serie.astype(str).str.replace('*', '', regex=False).str.strip().replace(
            {'': np.nan, 'nan': np.nan, 'None': np.nan}
        ),
        errors='coerce'
    )


def normalizar_columnas(df):
    df = df.copy()
    df.columns = [str(c).strip().replace('\n', ' ') if c is not None else c for c in df.columns]
    return deduplicar_columnas(df)


def deduplicar_columnas(df):
    """Si tras normalizar quedan columnas duplicadas (p.ej. dos 'Pos (Mkt) (P)'),
    les agrega sufijo .1, .2... para que no rompan selecciones por nombre."""
    cols = pd.Series(df.columns)
    for dup in cols[cols.duplicated()].unique():
        idxs = cols[cols == dup].index
        for i, idx in enumerate(idxs):
            if i != 0:
                cols[idx] = f"{dup}.{i}"
    df.columns = cols
    return df


def encontrar_fila_encabezado(ruta, hoja=0, max_filas_busqueda=10, columna_ancla='ISIN'):
    """Algunos exports traen una fila de título arriba del encabezado real.
    Busca en las primeras filas cuál calza como encabezado (contiene la
    columna ancla, p.ej. 'ISIN')."""
    preview = pd.read_excel(ruta, sheet_name=hoja, header=None, nrows=max_filas_busqueda)
    for i in range(len(preview)):
        fila = preview.iloc[i].astype(str).str.strip()
        if (fila == columna_ancla).any():
            return i
    return 0  # fallback: asumir que la primera fila es el encabezado


def leer_comparable(ruta, nombre_archivo):
    if not os.path.exists(ruta):
        raise FileNotFoundError(f"No se encontró el archivo: {ruta}")

    header_row = encontrar_fila_encabezado(ruta)
    df = pd.read_excel(ruta, header=header_row)
    df = normalizar_columnas(df)
    df = resolver_alias_columnas(df)

    faltantes = [c for c in REQUIRED_COLS if c not in df.columns]
    if faltantes:
        raise KeyError(
            f"En '{nombre_archivo}' faltan columnas requeridas {faltantes}. "
            f"Columnas encontradas: {list(df.columns)}"
        )
    return df


