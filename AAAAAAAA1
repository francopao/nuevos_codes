def abrir_libro(app, ruta, intentos=3, espera=3):
    """Abre un libro reutilizando la App de Excel compartida, con reintentos
    ante fallas COM transitorias (WinError -2147467259 y similares)."""
    ultimo_error = None
    for intento in range(1, intentos + 1):
        try:
            return app.books.open(ruta, read_only=True, update_links=False)
        except Exception as e:
            ultimo_error = e
            print(f"[AVISO] Intento {intento}/{intentos} falló al abrir '{ruta}': {e}")
            time.sleep(espera)
    raise OSError(f"No se pudo abrir '{ruta}' tras {intentos} intentos. Último error: {ultimo_error}")


def tc1(app, dia, mes, anio):
    fecha = f"{anio}-{mes}-{dia}"
    print(fecha)
    fecha_sin_guion = re.sub("-", "", fecha)

    wb = None
    try:
        wb = abrir_libro(app, RUTA_RIESGO)
        sheet = wb.sheets['Tipo de Cambio']
        sheet.range('B1').value = fecha_sin_guion
        time.sleep(5)
        data = sheet.used_range.value
    finally:
        if wb is not None:
            wb.close()

    df = pd.DataFrame(data)
    valor = None
    for i, j in zip(df[4], df[3]):
        if str(i) == '2':
            valor = j
            break

    if valor is None:
        raise ValueError(f"No se pudo ubicar el tipo de cambio para la fecha {fecha} en '{RUTA_RIESGO}'.")

    print(valor)
    return float(valor)


