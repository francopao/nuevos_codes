def obtener_aum_por_comparable(app, mes, anio):
    wb = None
    try:
        wb = abrir_libro(app, RUTA_MKTCAP)
        sheet = wb.sheets['MKT']
        data = sheet.used_range.value
    finally:
        if wb is not None:
            wb.close()

    df_h = pd.DataFrame(data)
    df_h = df_h.drop([0])
    df_h.columns = df_h.iloc[0, ::]
    df_h = df_h.drop([1])
    df_h = normalizar_columnas(df_h)
    df_h.columns = df_h.columns.str.replace(' Equity', '', regex=False)

    fecha_col = dt.strptime(f"01/{mes}/{anio}", '%d/%m/%Y')
    print(fecha_col)

    if 'FECHA' not in df_h.columns:
        raise KeyError(f"'Market Cap.xlsx' no tiene columna 'FECHA'. Columnas: {list(df_h.columns)}")

    df_h = df_h.loc[df_h['FECHA'] == fecha_col]

    if len(df_h) != 1:
        raise ValueError(
            f"Se esperaba 1 fila para la fecha {fecha_col} en 'Market Cap.xlsx', "
            f"pero se encontraron {len(df_h)}"
        )

    columnas_aum = {
        "IEMG US": "IEMG US", "CEMB US": "CEMB US", "ILF US": "ILF US",
        "ACWI US": "ACWI US", "EEM US": "EEM US", "SWDA LN": "SWDA LN",
        "EPU US": "EPU US", "ETF Perú": "ETFPERUD PE",
    }

    aum = {}
    faltantes = [col for col in columnas_aum.values() if col not in df_h.columns]
    if faltantes:
        raise KeyError(f"'Market Cap.xlsx' no tiene las columnas {faltantes}. Columnas: {list(df_h.columns)}")

    for clave, col in columnas_aum.items():
        valor = limpiar_numero(df_h[col]).iloc[0]
        if pd.isna(valor):
            raise ValueError(f"El valor de AUM para '{clave}' (columna '{col}') está vacío o no es numérico.")
        aum[clave] = float(valor)

    print(aum)
    return aum


