def comparables(dia, mes, anio):
    app = xw.App(visible=False, add_book=False)
    app.display_alerts = False
    app.screen_updating = False
    try:
        return _comparables_impl(app, dia, mes, anio)
    finally:
        try:
            app.quit()
        except Exception as e:
            print(f"[AVISO] No se pudo cerrar limpiamente la App de Excel: {e}")


def _comparables_impl(app, dia, mes, anio):
    tc = tc1(app, dia, mes, anio)
    aum_dict = obtener_aum_por_comparable(app, mes, anio)

    df_Total = pd.DataFrame()
    errores = []

    for clave, nombre_base in COMPARABLES_FILES.items():
        nombre_archivo = f"{anio}{mes} {nombre_base}"
        ruta = os.path.join(RUTA_COMPARABLES, nombre_archivo)
        print(nombre_archivo)

        try:
            df_h = leer_comparable(ruta, nombre_archivo)

            df_h['Sector1'] = df_h['Name'].apply(lambda x: x[2:] if str(x).startswith('› ') else '')
            df_h['Sector1'] = df_h['Sector1'].replace('', np.nan)
            df_h['Sector1'] = df_h['Sector1'].ffill()

            df_h = df_h[df_h["ISIN"].notna()]
            df_h['Market Value (%) (P)'] = limpiar_numero(df_h['Market Value (%) (P)'])
            df_h = df_h[df_h['Market Value (%) (P)'].notna()]

            df_h.insert(3, 'AFP', clave)
            df_h['Market Value (%) (P)'] = df_h['Market Value (%) (P)'] / 100

            print('El Market Value en el archivo ' + nombre_archivo + ' es: ' + str(df_h['Market Value (%) (P)'].sum()))
            df_Total = pd.concat([df_Total, df_h]).sort_index(ignore_index=True)

        except Exception as e:
            errores.append(f"{nombre_archivo}: {e}")
            print(f"[ERROR] Falló '{nombre_archivo}': {e}")

    if df_Total.empty:
        raise RuntimeError(
            "No se pudo procesar ningún archivo de comparables. Errores:\n" + "\n".join(errores)
        )

    if errores:
        print("=== AVISO: algunos archivos fallaron y fueron omitidos ===")
        for err in errores:
            print(" - " + err)

    df_Total = df_Total.get([
        'ISIN', 'Market Value (%) (P)', 'AFP', 'Name', 'MSCI ESG Rating (P)',
        'Crncy', 'Cntry (Risk)', 'Class - Broad', 'Px Close (P)', 'Sector1'
    ])

    df_Total.insert(2, 'Fondo', 'Multifondos')
    df_Total.insert(3, 'AssetClass', 'RVI')
    df_Total.insert(4, 'Strategy', 'BU')
    df_Total.insert(6, 'AUM', '')
    df_Total.insert(7, 'Tipo', tc)
    df_Total.insert(8, 'Precio', '')
    df_Total.insert(9, 'Q', '')

    df_Total['Precio'] = limpiar_numero(df_Total['Px Close (P)'])
    df_Total = df_Total.drop('Px Close (P)', axis=1)

    df_Total.insert(11, 'Empresa', df_Total['Name'])
    df_Total.insert(12, 'SBS', '')

    fecha = dt.strptime(f"01/{mes}/{anio}", '%d/%m/%Y')
    df_Total.insert(13, 'Fecha', fecha)
    df_Total.insert(14, 'cod emisor', '')

    df_Total = df_Total.rename(columns={
        "Market Value (%) (P)": "Weight", "Name": "Nombre", "Sector1": "Sector GICS"
    })

    diccionario2 = obtener_diccionario_paises(app)
    cntry_risk = df_Total["Cntry (Risk)"].astype(str).str.strip()
    df_Total.insert(19, 'País', cntry_risk.map(diccionario2['Nombre País']))
    df_Total.insert(20, 'Región', cntry_risk.map(diccionario2['Geografía Integra']))
    df_Total.insert(21, 'Mercado', cntry_risk.map(diccionario2['Mercado']))

    sin_match = df_Total.loc[df_Total['País'].isna(), 'Cntry (Risk)'].dropna().unique()
    if len(sin_match) > 0:
        print(f"[AVISO] Country Code(s) sin match en Subyacentes/Parametros: {list(sin_match)}")

    df_Total['AFP'] = df_Total['AFP'].astype(str).str.strip()
    df_Total['AUM'] = df_Total['AFP'].map(aum_dict)
    sin_aum = df_Total.loc[df_Total['AUM'].isna(), 'AFP'].unique()
    if len(sin_aum) > 0:
        raise ValueError(f"No se encontró AUM para las AFP: {list(sin_aum)}")

    df_Total['Pct_FFMM'] = df_Total['Weight']

    ruta_salida = RUTA_OUTPUT + f"{anio}{mes} Comparables.xlsx"
    df_Total.to_excel(ruta_salida, index=False)
    print(f"Archivo generado: {ruta_salida}")

    return df_Total


