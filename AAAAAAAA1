def obtener_diccionario_paises(app):
    wb3 = None
    try:
        wb3 = abrir_libro(app, RUTA_SUBYACENTES)
        sheet3 = wb3.sheets['Parametros']
        data = sheet3.used_range.value
    finally:
        if wb3 is not None:
            wb3.close()

    df_dic3 = pd.DataFrame(data)
    df_dic3.columns = df_dic3.iloc[1, ::]
    df_dic3 = df_dic3.drop([0, 1], axis=0)
    df_dic3 = normalizar_columnas(df_dic3)

    requeridas = ['Nombre País', 'Geografía Integra', 'Mercado', 'Country Code']
    faltantes = [c for c in requeridas if c not in df_dic3.columns]
    if faltantes:
        raise KeyError(f"'Subyacentes.xlsx' (Parametros) no tiene columnas {faltantes}. Columnas: {list(df_dic3.columns)}")

    df_dic3 = df_dic3.get(requeridas)
    df_dic3['Country Code'] = df_dic3['Country Code'].astype(str).str.strip()
    df_dic3 = df_dic3.drop_duplicates(subset='Country Code', keep='last')
    df_dic3 = df_dic3.set_index("Country Code")
    return df_dic3.to_dict()


