## 2) "Score por sector": selector múltiple + header dinámico

**Busca** la función completa `function buildScoreSector(){` y **reemplázala entera** (hasta su llave `}` de cierre, justo antes del comentario `// ====... CONTROLES`) por esta:

```js
function buildScoreSector(){
  let col=document.getElementById('colSector');
  if(!col){ col=document.createElement('div'); col.className='blk'; col.id='colSector';
    document.getElementById('secScores').appendChild(col); }
  const scores=calcScores();
  const emisores=Object.keys(scores);
  const sectores=[...new Set(Object.values(EMP_SECTOR).filter(Boolean))].sort();

  // NUEVO: selección múltiple. Si no hay nada elegido, se muestran TODOS.
  if(!Array.isArray(SECTOR_SEL)) SECTOR_SEL=[];
  const mostrar = SECTOR_SEL.length ? sectores.filter(s=>SECTOR_SEL.indexOf(s)>=0)
                                    : sectores;

  const opt=sectores.map(s=>'<option value="'+s.replace(/"/g,'&quot;')+'"'+
    (SECTOR_SEL.indexOf(s)>=0?' selected':'')+'>'+s+'</option>').join('');

  // NUEVO: una tabla por sector, con el nombre del sector como primer header.
  const tablas=mostrar.map(sec=>{
    const filas=emisores.filter(e=>EMP_SECTOR[e]===sec)
      .sort((a,b)=>scores[b].global-scores[a].global)
      .map(e=>'<tr><td><b>'+e+'</b></td>'+scCell(scores[e].global)+
              mitiCell(e)+'</tr>').join('');
    if(!filas) return '';
    return '<table class="piv"><thead><tr><th>'+sec+'</th>'+
           '<th>Score Global</th><th>Mitigantes</th></tr></thead><tbody>'+
           filas+'</tbody></table>';
  }).join('');

  col.innerHTML=
    '<h3><span class="dot" style="background:var(--cyan)"></span>Score por sector</h3>'+
    '<div class="scorectrls">'+
      '<label>Sector<select multiple size="5" id="filtSect">'+opt+'</select></label>'+
      '<button class="lyrbtn" id="btnLimpSec" style="align-self:center">Limpiar filtros</button>'+
    '</div>'+
    (tablas||'<p style="color:var(--plomo);font-size:12px">Sin empresas en el sector.</p>');

  document.getElementById('filtSect').onchange=ev=>{
    SECTOR_SEL=[...ev.target.selectedOptions].map(o=>o.value); buildScoreSector(); };
  document.getElementById('btnLimpSec').onclick=()=>{
    SECTOR_SEL=[]; buildScoreSector(); };
}
```

