EXCLUIR_HUELLA_CERO = True

COL = {
    "portafolio": "PORTAFOLIO",
    "grupo": "GRUPO",
    "nombre": "Nombre",
    "tipo_renta": "TIPO_RENTA",
    "estrategia": "Estrategia",
    "rank_rt": "Rank_rt",
    "plus": "Plus",
    "plus_1": "Plus_1",
