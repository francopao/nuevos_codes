# ------------------------------------------------------------------------------
PORTAFOLIOS_VALIDOS = ["IN-FONDO1", "IN-FONDO2", "IN-FONDO3"]  # excluye IN-FONDO0

# El filtro de página "Huella" de las pivots originales era una selección manual
