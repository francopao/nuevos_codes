## 2) FEN — columna "AUM (%)" en la tabla de empresas

Busca `function tablaEmpresasHTML(empresas, titulo){` y reemplaza **toda la función** por esta:

```js
function tablaEmpresasHTML(empresas, titulo){
  const rows = Object.entries(empresas).sort((a,b)=> b[1].aum - a[1].aum);
  // NUEVO: total de AUM de ESTA tabla = denominador del %
  const totalTbl = rows.reduce((s,[,i])=> s + i.aum, 0);
  let totN=0, totA=0;
  let h = (titulo ? '<div class="reg-tbl-title">'+titulo+'</div>' : '') +
    '<table class="regtbl"><thead><tr><th>Empresa</th><th>Activos Físicos</th>'+
    '<th>AUM</th><th>AUM (%)</th></tr></thead><tbody>';
  rows.forEach(([e,info])=>{
    totN += info.n; totA += info.aum;
    const pct = totalTbl>0 ? info.aum/totalTbl*100 : 0;
    h += '<tr><td class="idx">'+e+'</td><td>'+info.n+'</td>'+
         '<td>'+fmtS(info.aum)+'</td><td>'+fmtP(pct)+'</td></tr>';
  });
  h += '<tr class="reg-total"><td class="idx">Total</td><td>'+totN+'</td>'+
       '<td>'+fmtS(totA)+'</td><td>'+fmtP(totalTbl>0?100:0)+'</td></tr></tbody></table>';
  return h;
}
```

El denominador es el AUM total de esa misma tabla, así que la fila Total siempre da 100%.

