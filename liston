# 1. LECTURA DEL EXCEL
# ============================================================================
def _filas(ws, fila_encabezado, columnas):
    """Devuelve lista de dicts leyendo un bloque de columnas contiguo.
    Corta en la primera fila donde la primera columna esta vacia."""
    salida = []
    col_ini = columnas[0]
    for i in range(fila_encabezado + 1, ws.max_row + 1):
        primero = ws.cell(i, col_ini).value
        if primero is None or str(primero).strip() == "":
            if i > fila_encabezado + 1:
                break
            continue
        salida.append({j: ws.cell(i, j).value for j in columnas})
    return salida


def _txt(v):
    return "" if v is None else str(v).strip()


def cargar_bd(ruta=RUTA_BD):
    """Lee las 4 hojas del Excel y devuelve (registros, param)."""
    if not os.path.exists(ruta):
        sys.exit(f"[ERROR] No se encuentra la base de datos:\n  {ruta}")

    wb = openpyxl.load_workbook(ruta, data_only=True, read_only=False)
    for hoja in ("Registro", "Parametria", "Catalogos", "Textos"):
        if hoja not in wb.sheetnames:
            sys.exit(f"[ERROR] Falta la hoja '{hoja}' en {os.path.basename(ruta)}")

    # ---- Parametria: empresas
    pa = wb["Parametria"]
    empresas = {}
    for f in _filas(pa, 3, list(range(1, 9))):
        empresas[_txt(f[1])] = {
            "abrev": _txt(f[2]), "sector": _txt(f[3]), "ticker": _txt(f[4]),
            "isin": _txt(f[5]), "cod_sbs": _txt(f[6]), "activo": _txt(f[7]).upper() == "SI",
        }

    # ---- Catalogos
    ct = wb["Catalogos"]
    temas = OrderedDict()
    for f in _filas(ct, 3, [1, 2, 3]):
        temas[_txt(f[1])] = {"cod_sbs": _txt(f[2]), "orden": f[3] or 999}

    decisiones = OrderedDict()
    for f in _filas(ct, 3, [5, 6, 7]):
        decisiones[_txt(f[5])] = {
            "cuenta": _txt(f[6]).upper() == "SI",
            "color": "#" + _txt(f[7]).lstrip("#"),
        }

    tipos = OrderedDict()
    for f in _filas(ct, 3, [9, 10, 11]):
        tipos[_txt(f[9])] = {"etiqueta": _txt(f[10]), "orden": f[11] or 999}

    motivos = OrderedDict()
    for f in _filas(ct, 3, [13, 14]):
        motivos[_txt(f[13])] = _txt(f[14])

    especialidades = OrderedDict()
    for f in _filas(ct, 3, [18, 19]):
        especialidades[_txt(f[18])] = f[19] or 999

    sectores = OrderedDict()
    for f in _filas(ct, 3, [21, 22, 23]):
        sectores[_txt(f[21])] = {"color": "#" + _txt(f[22]).lstrip("#"), "orden": f[23] or 999}

    responsables = {}
    for f in _filas(ct, 3, [25, 26, 27]):
        responsables[_txt(f[25])] = {"doi": _txt(f[26]), "tipo": _txt(f[27])}

    # ---- Config (bloque clave/valor a partir de la fila 25, columnas A/B)
    config = {}
    for i in range(25, 35):
        k = _txt(ct.cell(i, 1).value)
        if k and k == k.replace(" ", "_") or k.startswith(("Color", "Nombre", "Titulo", "Pie", "Min")):
            config[k] = _txt(ct.cell(i, 2).value)

    # ---- Textos
    tx = wb["Textos"]
    textos = {}
    for f in _filas(tx, 3, [1, 2]):
        textos[_txt(f[1])] = _txt(f[2])

    # ---- Registro
    rg = wb["Registro"]
    COLS = ["empresa", "tipo_junta", "fecha", "punto", "texto_agenda", "tema", "decision",
            "motivo", "justificacion", "director", "independencia", "esp1", "esp2",
            "firma_auditora", "pct_aprob", "responsable", "comentario",
            "junta_id", "punto_uid", "sector", "anio", "trimestre", "es_director",
            "origen", "cargado_el", "estado", "editado"]
    registros = []
    for i in range(2, rg.max_row + 1):
        if not _txt(rg.cell(i, 1).value):
            continue
        r = {c: rg.cell(i, j + 1).value for j, c in enumerate(COLS)}
        for c in COLS:
            if c not in ("fecha", "pct_aprob", "anio"):
                r[c] = _txt(r[c])
        # fallback si el Excel no trae las formulas calculadas (openpyxl sin recalcular)
        # tolera fechas escritas como texto
        if isinstance(r["fecha"], str) and r["fecha"]:
            for fmt in ("%Y-%m-%d", "%d/%m/%Y", "%d-%m-%Y", "%Y-%m-%d %H:%M:%S"):
                try:
                    r["fecha"] = datetime.strptime(r["fecha"][:19], fmt)
                    break
                except ValueError:
                    continue
        if not r["junta_id"]:
            emp = empresas.get(r["empresa"], {})
            fch = r["fecha"]
            if isinstance(fch, (datetime, date)):
                r["junta_id"] = f"{emp.get('abrev','?')}|{fch:%Y%m%d}|{r['tipo_junta']}"
        if not r["sector"]:
            r["sector"] = empresas.get(r["empresa"], {}).get("sector", "SIN SECTOR")
        if not r["anio"] and isinstance(r["fecha"], (datetime, date)):
            r["anio"] = r["fecha"].year
        if not r["trimestre"] and isinstance(r["fecha"], (datetime, date)):
            r["trimestre"] = f"T{(r['fecha'].month - 1) // 3 + 1}"
        if not r["es_director"]:
            r["es_director"] = "SI" if r["director"] else "NO"
        r["_fila"] = i
        registros.append(r)

    wb.close()

    param = {"empresas": empresas, "temas": temas, "decisiones": decisiones,
             "tipos": tipos, "motivos": motivos, "especialidades": especialidades,
             "sectores": sectores, "responsables": responsables,
             "config": config, "textos": textos}
    return registros, param


# ============================================================================
# 2. VALIDACION - falla ruidosamente, nunca en silencio
# ============================================================================
def validar(registros, param):
    errores, avisos = [], []
    temas, decis, emps = param["temas"], param["decisiones"], param["empresas"]

    for r in registros:
        f = r["_fila"]
        if not r["tema"]:
            errores.append(f"Fila {f}: sin Tema ({r['empresa']} {r['punto']})")
        elif r["tema"] not in temas:
            errores.append(f"Fila {f}: Tema '{r['tema']}' no esta en Catalogos")
        if not r["decision"]:
            errores.append(f"Fila {f}: sin Decision ({r['empresa']} {r['punto']})")
        elif r["decision"] not in decis:
            errores.append(f"Fila {f}: Decision '{r['decision']}' no esta en Catalogos")
        if r["empresa"] not in emps:
            errores.append(f"Fila {f}: Empresa '{r['empresa']}' no esta en Parametria")
        if not isinstance(r["fecha"], (datetime, date)):
            errores.append(f"Fila {f}: Fecha invalida ({r['fecha']!r})")
        if r["decision"] == "En Contra" and not r["motivo"]:
            avisos.append(f"Fila {f}: voto En Contra sin Motivo")
        if r["director"] and not r["independencia"]:
            avisos.append(f"Fila {f}: director sin Independencia")
        if r["director"] and not r["esp1"]:
            avisos.append(f"Fila {f}: director sin Especialidad")

    if avisos:
        print(f"\n[AVISOS] {len(avisos)}")
        for a in avisos[:20]:
            print("  -", a)
        if len(avisos) > 20:
            print(f"  ... y {len(avisos)-20} mas")
    if errores:
        print(f"\n[ERRORES] {len(errores)} - el proceso se detiene")
        for e in errores[:30]:
            print("  -", e)
        if len(errores) > 30:
            print(f"  ... y {len(errores)-30} mas")
        sys.exit(1)
    print(f"[OK] Validacion: {len(registros)} filas, sin errores bloqueantes.")


# ============================================================================
# 3. AGREGACIONES - una funcion por chart del reporte
# ============================================================================
def _computables(registros, param):
    """Filas que suman a los conteos (excluye Cabecera, No Asistimos, etc.)."""
    d = param["decisiones"]
    return [r for r in registros if d.get(r["decision"], {}).get("cuenta", False)]


def agregar(registros, param, tipo_junta):
    """Devuelve el bloque completo de metricas para un tipo de junta (JOA/JGA)."""
    sub = [r for r in registros if r["tipo_junta"] == tipo_junta]
    comp = _computables(sub, param)
    if not sub:
        return None

    juntas = {r["junta_id"] for r in sub}
    emp_por_sector = defaultdict(set)
    juntas_por_sector = defaultdict(set)
    for r in sub:
        emp_por_sector[r["sector"]].add(r["empresa"])
        juntas_por_sector[r["sector"]].add(r["junta_id"])

    # -- Chart sectores (treemap del PDF: "Rectangulo 3 / 7")
    orden_sec = param["sectores"]
    sectores = []
    total_j = len(juntas)
    for s in sorted(juntas_por_sector, key=lambda x: orden_sec.get(x, {}).get("orden", 999)):
        sectores.append({
            "sector": s,
            "empresas": len(emp_por_sector[s]),
            "juntas": len(juntas_por_sector[s]),
            "pct": len(juntas_por_sector[s]) / total_j if total_j else 0,
            "color": orden_sec.get(s, {}).get("color", "#BFBFBF"),
        })

    # -- Chart 1: barras apiladas Tema x Decision
    decis_activas = [d for d, v in param["decisiones"].items() if v["cuenta"]]
    matriz = defaultdict(lambda: defaultdict(int))
    for r in comp:
        matriz[r["tema"]][r["decision"]] += 1
    temas_ord = sorted(matriz, key=lambda t: sum(matriz[t].values()))
    barras = {
        "temas": temas_ord,
        "series": [{"nombre": d,
                    "color": param["decisiones"][d]["color"],
                    "datos": [matriz[t].get(d, 0) for t in temas_ord]}
                   for d in decis_activas
                   if any(matriz[t].get(d, 0) for t in temas_ord)],
    }

    # -- Chart 2: votos en contra por tema
    contras = [r for r in comp if r["decision"] == "En Contra"]
    c_tema = Counter(r["tema"] for r in contras)
    contra_tema = [{"tema": t, "n": n} for t, n in c_tema.most_common()]

    # -- Chart de motivos (solo los ligados a Eleccion y Numero de Directores)
    map_motivo = param["motivos"]
    c_mot_dir = Counter(r["motivo"] for r in contras
                        if map_motivo.get(r["motivo"], "") == "Eleccion y Numero de Directores")
    motivos_dir = [{"motivo": m, "n": n} for m, n in c_mot_dir.most_common()]

    # -- Directores votados a favor
    dirs_fav = [r for r in comp if r["es_director"] == "SI" and r["decision"] == "A Favor"]
    c_ind = Counter(r["independencia"] for r in dirs_fav if r["independencia"])
    independencia = [{"tipo": k, "n": v} for k, v in c_ind.most_common()]

    c_exp = Counter()
    for r in dirs_fav:
        for e in (r["esp1"], r["esp2"]):
            if e:
                c_exp[e] += 1
    orden_e = param["especialidades"]
    experiencia = [{"esp": e, "n": n}
                   for e, n in sorted(c_exp.items(), key=lambda kv: (-kv[1], orden_e.get(kv[0], 999)))]

    # -- Tabla de detalle (equivalente al rango B85:B257)
    detalle = defaultdict(lambda: defaultdict(list))
    for r in sorted(sub, key=lambda x: (x["empresa"], x["fecha"] or date.min, x["punto"])):
        clave_f = r["fecha"].strftime("%d/%m/%Y") if isinstance(r["fecha"], (datetime, date)) else "s/f"
        detalle[r["empresa"]][clave_f].append({
            "punto": r["punto"], "texto": r["texto_agenda"], "decision": r["decision"],
            "justificacion": r["justificacion"], "motivo": r["motivo"],
        })
    tabla = [{"empresa": e, "fechas": [{"fecha": f, "puntos": p} for f, p in fs.items()]}
             for e, fs in detalle.items()]

    return {
        "tipo": tipo_junta,
        "etiqueta": param["tipos"].get(tipo_junta, {}).get("etiqueta", tipo_junta),
        "n_juntas": total_j,
        "n_empresas": len({r["empresa"] for r in sub}),
        "n_puntos": len(comp),
        "n_contra": len(contras),
        "n_dir_fav": len(dirs_fav),
        "sectores": sectores,
        "barras": barras,
        "contra_tema": contra_tema,
        "motivos_dir": motivos_dir,
        "independencia": independencia,
        "experiencia": experiencia,
        "tabla": tabla,
    }


