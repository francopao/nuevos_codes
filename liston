</style></head><body>

<h1 id="titulo"></h1>
<div class="sub" id="subtitulo"></div>

<div class="filtros">
  <div><label>Año</label><select id="fAnio"></select></div>
  <div><label>Trimestre</label><select id="fTri"></select></div>
  <div><label>Tipo de junta</label><select id="fTipo"></select></div>
  <div><label>Sector</label><select id="fSec"></select></div>
  <div><label>Empresa</label><select id="fEmp"></select></div>
</div>

<div class="kpis" id="kpis"></div>

<div class="grid">
  <div class="card full"><h2>Votación por tema de agenda</h2><div class="wrap alto"><canvas id="c1"></canvas></div></div>
  <div class="card full"><h2>Distribución por sector</h2><div class="tree" id="tree"></div></div>
  <div class="card"><h2>Votos en contra por tema</h2><div class="wrap"><canvas id="c2"></canvas></div></div>
  <div class="card"><h2>Motivos de voto en contra (directores)</h2><div class="wrap"><canvas id="c6"></canvas></div></div>
  <div class="card"><h2>Independencia de directores</h2><div class="wrap"><canvas id="c11"></canvas></div></div>
  <div class="card"><h2>Experiencia de directores</h2><div class="wrap"><canvas id="c9"></canvas></div></div>
  <div class="card full"><h2>Detalle por empresa</h2><div id="tabla"></div></div>
</div>

<footer id="pie"></footer>

<script>
const DATOS = __DATOS__;
const META  = __META__;
const GEN   = "__GENERADO__";
const P="#"+META.primario, S="#"+META.secundario, A="#"+META.acento;
const PALETA=[P,S,A,"#5B6DAE","#3E9FBF","#7FC9DB","#A9BCE0","#BFBFBF","#2F4380","#89D6E6","#C8CE3F","#8A93B8","#4C6FA5"];
let charts={};

document.getElementById("titulo").textContent=META.titulo;
document.getElementById("pie").textContent=META.pie+"  ·  Generado "+GEN;

function unicos(campo){return [...new Set(DATOS.map(d=>d[campo]).filter(v=>v!==""&&v!==0))];}
function llenar(id,vals,etiqueta,mapa){
  const s=document.getElementById(id);
  s.innerHTML='<option value="">'+etiqueta+'</option>';
  vals.forEach(v=>{const o=document.createElement("option");o.value=v;
    o.textContent=mapa&&mapa[v]?mapa[v]:v;s.appendChild(o);});
  s.onchange=render;
}
llenar("fAnio",unicos("anio").sort((a,b)=>b-a),"Todos");
llenar("fTri",["T1","T2","T3","T4"],"Todos");
llenar("fTipo",unicos("tj"),"Todas",META.tipos);
llenar("fSec",unicos("sec").sort((a,b)=>(META.orden_sector[a]||99)-(META.orden_sector[b]||99)),"Todos");
llenar("fEmp",unicos("emp").sort(),"Todas");

function filtrar(){
  const a=fAnio.value,t=fTri.value,tj=fTipo.value,se=fSec.value,em=fEmp.value;
  return DATOS.filter(d=>(!a||d.anio==a)&&(!t||d.tri==t)&&(!tj||d.tj==tj)&&(!se||d.sec==se)&&(!em||d.emp==em));
}
const cuenta=d=>META.decisiones[d.dec]&&META.decisiones[d.dec].cuenta;

function pinta(id,cfg){
  if(charts[id])charts[id].destroy();
  charts[id]=new Chart(document.getElementById(id),cfg);
}
const SIN={responsive:true,maintainAspectRatio:false};

function render(){
  const F=filtrar(), C=F.filter(cuenta);
  const juntas=new Set(F.map(d=>d.jid));
  const contras=C.filter(d=>d.dec==="En Contra");
  const dirsFav=C.filter(d=>d.dir&&d.dec==="A Favor");

  // ---- KPIs
  document.getElementById("kpis").innerHTML=[
    [juntas.size,"Juntas"],[new Set(F.map(d=>d.emp)).size,"Empresas"],
    [C.length,"Puntos votados"],[contras.length,"Votos en contra"],
    [dirsFav.length,"Directores a favor"]
  ].map(k=>`<div class="kpi"><div class="n">${k[0]}</div><div class="l">${k[1]}</div></div>`).join("");

  if(!F.length){
    document.getElementById("tabla").innerHTML='<div class="vacio">No hay registros para esta combinación de filtros.</div>';
    document.getElementById("tree").innerHTML='<div class="vacio">Sin datos</div>';
    Object.values(charts).forEach(c=>c.destroy());charts={};
    return;
  }

  // ---- Chart 1: barras apiladas tema x decision
  const m={};C.forEach(d=>{(m[d.tema]=m[d.tema]||{})[d.dec]=(m[d.tema][d.dec]||0)+1;});
  const temas=Object.keys(m).sort((x,y)=>tot(m[x])-tot(m[y]));
  function tot(o){return Object.values(o).reduce((a,b)=>a+b,0);}
  const decs=Object.keys(META.decisiones).filter(k=>META.decisiones[k].cuenta
              &&temas.some(t=>m[t][k]));
  pinta("c1",{type:"bar",data:{labels:temas,datasets:decs.map(k=>({
      label:k,backgroundColor:META.decisiones[k].color,data:temas.map(t=>m[t][k]||0)}))},
    options:{...SIN,indexAxis:"y",scales:{x:{stacked:true,grid:{display:false}},
      y:{stacked:true,grid:{display:false},ticks:{font:{size:11}}}},
      plugins:{legend:{position:"bottom",labels:{boxWidth:12,font:{size:11}}},
        datalabels:false}}});

  // ---- Treemap de sectores
  const bySec={};F.forEach(d=>{const o=bySec[d.sec]=bySec[d.sec]||{e:new Set(),j:new Set()};
    o.e.add(d.emp);o.j.add(d.jid);});
  const tj=juntas.size;
  document.getElementById("tree").innerHTML=Object.keys(bySec)
    .sort((a,b)=>bySec[b].j.size-bySec[a].j.size).map(s=>{
      const o=bySec[s],pc=tj?Math.round(o.j.size/tj*100):0;
      const w=Math.max(14,Math.min(46,pc*1.5+14));
      return `<div class="tile" style="background:${META.sectores[s]||"#BFBFBF"};flex:1 1 ${w}%">
        <span>Empresas: ${o.e.size}</span><div><b>${pc}%</b><br><span>${s}</span></div></div>`;
    }).join("");

  // ---- Chart 2: contras por tema
  dona("c2",cont(contras,"tema"));
  // ---- Chart 6: motivos ligados a eleccion de directores
  const md=contras.filter(d=>META.motivos[d.mot]==="Eleccion y Numero de Directores");
  dona("c6",cont(md,"mot"),true);
  // ---- Chart 11: independencia
  dona("c11",cont(dirsFav.filter(d=>d.ind),"ind"),true);
  // ---- Chart 9: experiencia
  const ex={};dirsFav.forEach(d=>{[d.e1,d.e2].forEach(e=>{if(e)ex[e]=(ex[e]||0)+1;});});
  dona("c9",ex,true);

  tablaDetalle(F);
}

function cont(arr,campo){const o={};arr.forEach(d=>{if(d[campo])o[d[campo]]=(o[d[campo]]||0)+1;});return o;}
function dona(id,obj,anillo){
  const k=Object.keys(obj).sort((a,b)=>obj[b]-obj[a]);
  if(!k.length){if(charts[id])charts[id].destroy();
    const cv=document.getElementById(id);cv.getContext("2d").clearRect(0,0,cv.width,cv.height);return;}
  const t=k.reduce((a,x)=>a+obj[x],0);
  pinta(id,{type:anillo?"doughnut":"pie",
    data:{labels:k,datasets:[{data:k.map(x=>obj[x]),backgroundColor:PALETA,borderColor:"#fff",borderWidth:2}]},
    options:{...SIN,cutout:anillo?"52%":0,plugins:{legend:{position:"right",
      labels:{boxWidth:12,font:{size:11},generateLabels:ch=>k.map((l,i)=>({
        text:l+"  "+Math.round(obj[l]/t*100)+"%",fillStyle:PALETA[i%PALETA.length],index:i}))}},
      tooltip:{callbacks:{label:c=>c.label+": "+c.raw+" ("+Math.round(c.raw/t*100)+"%)"}}}}});
}

function tablaDetalle(F){
  const g={};
  F.forEach(d=>{(g[d.emp]=g[d.emp]||{})[d.fec]=(g[d.emp][d.fec]||[]);g[d.emp][d.fec].push(d);});
  let h='<table><thead><tr><th style="width:70px">Punto</th><th>Tema de agenda</th>'
       +'<th style="width:140px">Votación</th></tr></thead><tbody>';
  Object.keys(g).sort().forEach(e=>{
    h+=`<tr class="emp"><td colspan="3">${e}</td></tr>`;
    Object.keys(g[e]).sort().forEach(f=>{
      h+=`<tr class="fec"><td colspan="3">${f}</td></tr>`;
      g[e][f].sort((a,b)=>a.pto.localeCompare(b.pto,undefined,{numeric:true})).forEach(d=>{
        const col=(META.decisiones[d.dec]||{}).color||"#BFBFBF";
        const nota=d.jus||d.mot?`<div class="jus">${d.jus||d.mot}</div>`:"";
        h+=`<tr><td>${d.pto}</td><td>${d.txt}${nota}</td>
            <td><span class="pill" style="background:${col}">${d.dec}</span></td></tr>`;
      });
    });
  });
  document.getElementById("tabla").innerHTML=h+"</tbody></table>";
}

document.getElementById("subtitulo").textContent=
  META.institucion+"  ·  "+DATOS.length+" puntos de agenda registrados";
render();
</script></body></html>"""


# ============================================================================
# 6a. GRAFICOS - se generan como imagen con matplotlib
# ============================================================================
def _mpl():
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt
    plt.rcParams.update({
        "font.family": "sans-serif",
        "font.sans-serif": ["Arial", "DejaVu Sans"],
        "axes.edgecolor": "#D9D9D9",
        "figure.facecolor": "white",
        "axes.facecolor": "white",
        "savefig.facecolor": "white",
    })
    return plt


def _guardar(fig, dpi=200):
    buf = io.BytesIO()
    fig.savefig(buf, format="png", dpi=dpi, bbox_inches="tight",
                facecolor="white")
    import matplotlib.pyplot as plt
    plt.close(fig)
    buf.seek(0)
    return buf


def _corta(txt, ancho=38):
    """Parte etiquetas largas en dos lineas, como en el reporte publicado."""
    txt = str(txt)
    if len(txt) <= ancho:
        return txt
    corte = txt.rfind(" ", 0, ancho)
    corte = corte if corte > 0 else ancho
    return txt[:corte] + "\n" + txt[corte + 1:]


def _png_barras(bloque, param, navy="#1E2E6E"):
    """Barras horizontales apiladas: Tema de agenda x Decision."""
    plt = _mpl()
    b = bloque["barras"]
    temas = [_corta(t) for t in b["temas"]]
    n = len(temas)
    fig, ax = plt.subplots(figsize=(9.4, max(2.6, 0.42 * n + 1.1)))

    izq = [0] * n
    for s in b["series"]:
        ax.barh(range(n), s["datos"], left=izq, color=s["color"],
                label=s["nombre"], height=.62)
        for i, (v, x0) in enumerate(zip(s["datos"], izq)):
            if v:
                ax.text(x0 + v / 2, i, str(v), ha="center", va="center",
                        color="white", fontsize=8.5, fontweight="bold")
        izq = [a + c for a, c in zip(izq, s["datos"])]

    ax.set_yticks(range(n))
    ax.set_yticklabels(temas, fontsize=8, color=navy)
    ax.set_xticks([])
    ax.set_xlim(0, max(izq) * 1.04 if max(izq) else 1)
    for sp in ax.spines.values():
        sp.set_visible(False)
    ax.grid(False)
    ax.legend(fontsize=8, loc="lower right", frameon=False,
              labelcolor=navy, handlelength=1.1, handleheight=1.1)
    fig.tight_layout()
    return _guardar(fig)


def _png_circular(datos, etiquetas, colores, anillo=True, navy="#1E2E6E"):
    """Torta o dona con leyenda a la derecha y porcentajes."""
    plt = _mpl()
    fig, ax = plt.subplots(figsize=(6.6, 3.4))
    w = dict(width=.42, edgecolor="white", linewidth=2) if anillo else \
        dict(edgecolor="white", linewidth=2)
    total = sum(datos) or 1
    ax.pie(datos, colors=colores[:len(datos)], startangle=90,
           counterclock=False,
           autopct=lambda p: f"{p:.0f}%" if p >= 4 else "",
           pctdistance=.78 if anillo else .62,
           textprops=dict(color="white", fontsize=9, fontweight="bold"),
           wedgeprops=w)
    ax.legend([f"{_corta(e, 30)}" for e in etiquetas], fontsize=8,
              loc="center left", bbox_to_anchor=(1.0, .5), frameon=False,
              labelcolor=navy, handlelength=1.1, handleheight=1.1)
    ax.axis("equal")
    fig.tight_layout()
    return _guardar(fig)


def _png_sectores(bloque, param, navy="#1E2E6E"):
    """Rectangulos proporcionales por sector, como el mosaico del reporte."""
    plt = _mpl()
    secs = sorted(bloque["sectores"], key=lambda s: -s["pct"])
    fig, ax = plt.subplots(figsize=(9.4, 2.9))
    x = 0.0
    for s in secs:
        w = max(s["pct"], .055)
        ax.add_patch(plt.Rectangle((x, 0), w * .99, 1, color=s["color"]))
        cx = x + w * .495
        ax.text(cx, .90, f"Empresas: {s['empresas']}", ha="center",
                va="center", color="white", fontsize=7.5)
        ax.text(cx, .17, _corta(s["sector"], 18), ha="center", va="center",
                color="white", fontsize=8, fontweight="bold")
        ax.text(cx, .05, f"{s['pct']*100:.2f}%", ha="center", va="center",
                color="white", fontsize=8, fontweight="bold")
        x += w
    ax.set_xlim(0, max(x, 1))
    ax.set_ylim(0, 1)
    ax.axis("off")
    fig.tight_layout()
    return _guardar(fig)


# ============================================================================
# 6b. REPORTE WORD - mismo orden y estilo que el reporte publicado
# ============================================================================
def _sombrear(celda, hex_color):
    from docx.oxml import parse_xml
    from docx.oxml.ns import nsdecls
    celda._tc.get_or_add_tcPr().append(
        parse_xml(f'<w:shd {nsdecls("w")} w:val="clear" w:fill="{hex_color}"/>'))


def _barra_izquierda(parrafo, hex_color, grosor=28):
    """Barra vertical de color al inicio del parrafo, como en el reporte."""
    from docx.oxml import parse_xml
    from docx.oxml.ns import nsdecls
    parrafo._p.get_or_add_pPr().append(parse_xml(
        f'<w:pBdr {nsdecls("w")}><w:left w:val="single" w:sz="{grosor}" '
        f'w:space="8" w:color="{hex_color}"/></w:pBdr>'))


def _sin_bordes(tabla):
    from docx.oxml import parse_xml
    from docx.oxml.ns import nsdecls
    tabla._tbl.tblPr.append(parse_xml(
        f'<w:tblBorders {nsdecls("w")}>' +
        "".join(f'<w:{b} w:val="none" w:sz="0" w:color="FFFFFF"/>'
                for b in ("top", "left", "bottom", "right",
                          "insideH", "insideV")) +
        '</w:tblBorders>'))


def generar_word(bloques, param, periodo, ruta_salida):
    from docx import Document
    from docx.shared import Pt, Inches, Cm, RGBColor
    from docx.enum.text import WD_ALIGN_PARAGRAPH
    from docx.enum.table import WD_TABLE_ALIGNMENT

    cfg = param["config"]
    hx = lambda k, d: cfg.get(k, d).lstrip("#")
    NAV = RGBColor(*bytes.fromhex(hx("Color_Primario", "1E2E6E")))
    CYN = RGBColor(*bytes.fromhex(hx("Color_Secundario", "00AECB")))
    AMA = hx("Color_Acento", "E3E829")
    GRIS = RGBColor(0x6B, 0x72, 0x80)
    PAL = [param["sectores"][s]["color"] for s in param["sectores"]] or ["#1E2E6E"]
    PAL_DEC = [v["color"] for v in param["decisiones"].values() if v["cuenta"]]

    doc = Document()
    st = doc.styles["Normal"]
    st.font.name = "Arial"
    st.font.size = Pt(10)
    st.font.color.rgb = NAV
    sec = doc.sections[0]
    sec.top_margin = Cm(2.2)
    sec.bottom_margin = Cm(2.0)
    sec.left_margin = Cm(2.2)
    sec.right_margin = Cm(2.2)

    # ---- logo en el encabezado de todas las paginas
    if os.path.exists(RUTA_LOGO):
        h = sec.header.paragraphs[0]
        h.alignment = WD_ALIGN_PARAGRAPH.RIGHT
        try:
            h.add_run().add_picture(RUTA_LOGO, width=Inches(1.55))
        except Exception as e:
            print(f"[AVISO] No se pudo insertar el logo: {e}")
    else:
        print(f"[AVISO] No se encontro el logo en {RUTA_LOGO}")

    # ---- pie de pagina
    pie = sec.footer.paragraphs[0]
    pie.alignment = WD_ALIGN_PARAGRAPH.LEFT
    rp = pie.add_run(cfg.get("Pie_Pagina", ""))
    rp.font.size = Pt(7.5)
    rp.font.color.rgb = CYN
    rp.bold = True

    def parr(txt, size=10, color=None, bold=False, just=True, space=8, after=None):
        if not txt:
            return None
        p = doc.add_paragraph()
        p.paragraph_format.space_after = Pt(space)
        p.paragraph_format.space_before = Pt(0)
        if just:
            p.alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
        r = p.add_run(txt)
        r.font.size = Pt(size)
        r.font.color.rgb = color if color is not None else NAV
        r.bold = bold
        return p

    def grafico(buf, ancho_cm=16.6):
        """Inserta la imagen del grafico centrada."""
        doc.add_picture(buf, width=Cm(ancho_cm))
        doc.paragraphs[-1].alignment = WD_ALIGN_PARAGRAPH.CENTER
        doc.paragraphs[-1].paragraph_format.space_after = Pt(10)

    def titulo_seccion(txt):
        """Titulo tipo 'a. Juntas Obligatorias Anuales (JOAs) - 2025'."""
        from docx.oxml import parse_xml
        from docx.oxml.ns import nsdecls
        p = doc.add_paragraph()
        p.paragraph_format.space_before = Pt(6)
        p.paragraph_format.space_after = Pt(12)
        r = p.add_run(txt)
        r.font.size = Pt(16)
        r.font.color.rgb = CYN
        r.bold = True
        p._p.get_or_add_pPr().append(parse_xml(
            f'<w:pBdr {nsdecls("w")}><w:bottom w:val="single" w:sz="8" '
            f'w:space="4" w:color="{hx("Color_Primario","1E2E6E")}"/></w:pBdr>'))
        return p

    def subtitulo(txt, size=12):
        """Subtitulo con la barra amarilla a la izquierda."""
        p = doc.add_paragraph()
        p.paragraph_format.space_before = Pt(10)
        p.paragraph_format.space_after = Pt(6)
        p.paragraph_format.left_indent = Pt(6)
        r = p.add_run(txt)
        r.font.size = Pt(size)
        r.font.color.rgb = CYN
        r.bold = True
        _barra_izquierda(p, AMA)
        return p

    def vineta(txt):
        p = doc.add_paragraph()
        p.paragraph_format.space_before = Pt(8)
        p.paragraph_format.space_after = Pt(4)
        p.paragraph_format.left_indent = Pt(10)
        r = p.add_run("\u25b8  " + txt)
        r.font.size = Pt(11)
        r.font.color.rgb = CYN
        return p

    # ================= PORTADA =================
    for _ in range(6):
        doc.add_paragraph()
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    r = p.add_run(cfg.get("Titulo_Reporte", "Reporte de Juntas de Accionistas"))
    r.font.size = Pt(30)
    r.font.color.rgb = CYN
    r.bold = True
    p = doc.add_paragraph()
    p.alignment = WD_ALIGN_PARAGRAPH.CENTER
    r = p.add_run(periodo)
    r.font.size = Pt(30)
    r.font.color.rgb = CYN
    r.bold = True
    for _ in range(5):
        doc.add_paragraph()

    # caja gris con el texto introductorio
    caja = doc.add_table(rows=1, cols=1)
    caja.alignment = WD_TABLE_ALIGNMENT.CENTER
    _sin_bordes(caja)
    cel = caja.rows[0].cells[0]
    _sombrear(cel, "D9DDE3")
    cel.paragraphs[0].paragraph_format.space_after = Pt(6)
    r = cel.paragraphs[0].add_run(param["textos"].get("intro", "").format(
        institucion=cfg.get("Nombre_Institucion", "AFP Integra"), periodo=periodo))
    r.font.size = Pt(9.5)
    r.font.color.rgb = NAV
    cel.paragraphs[0].alignment = WD_ALIGN_PARAGRAPH.JUSTIFY
    pn = cel.add_paragraph()
    rn = pn.add_run("*El reporte ha sido elaborado con la informacion disponible al "
                    + _fecha_es(datetime.now()) + ".")
    rn.font.size = Pt(7.5)
    rn.font.color.rgb = NAV
    doc.add_page_break()

    # ================= SECCIONES =================
    letras = "abcdefghij"
    for idx, bloque in enumerate(bloques):
        if bloque is None:
            continue
        w = redactar(bloque, param, periodo)
        tj = bloque["tipo"]
        titulo_seccion(f"{letras[idx]}. {bloque['etiqueta']} - {periodo}")

        # ---- 1. distribucion por sector (treemap: se mantiene como imagen)
        subtitulo(f"Total de {tj}s y Distribucion por Sector")
        parr(w["sector"])
        grafico(_png_sectores(bloque, param), 16.6)

        # ---- 2. votacion por tema de agenda (barras apiladas, editable)
        subtitulo(f"Votacion por Tema de Agenda en {tj}s")
        grafico(_png_barras(bloque, param), 16.6)
        parr(w["temas"])

        # ---- 3. votos en contra (torta, editable)
        if bloque["contra_tema"]:
            subtitulo(f"Votos en Contra en {tj}s")
            parr(w["contras"])
            grafico(_png_circular([c["n"] for c in bloque["contra_tema"]],
                                  [c["tema"] for c in bloque["contra_tema"]],
                                  PAL, anillo=False), 13.5)

        # ---- 4. directores
        if bloque["n_dir_fav"] or bloque["motivos_dir"]:
            subtitulo(f"Votacion respecto a directores en {tj}s:")

            if bloque["motivos_dir"]:
                vineta("Votos en contra")
                parr(w["contras_dir"])
                grafico(_png_circular([m["n"] for m in bloque["motivos_dir"]],
                                      [m["motivo"] for m in bloque["motivos_dir"]],
                                      PAL), 13.5)

            if bloque["independencia"]:
                vineta("Independencia")
                parr(w["independencia"])
                grafico(_png_circular([i["n"] for i in bloque["independencia"]],
                                      [i["tipo"] for i in bloque["independencia"]],
                                      PAL), 13.5)

            if bloque["experiencia"]:
                vineta("Experiencia")
                parr(w["experiencia"])
                grafico(_png_circular([e["n"] for e in bloque["experiencia"]],
                                      [e["esp"] for e in bloque["experiencia"]],
                                      PAL), 13.5)

        # ---- 5. detalle por empresa
        doc.add_page_break()
        subtitulo(f"Votacion por empresa en {tj}s {periodo}", size=13)
        p = doc.add_paragraph()
        p.paragraph_format.space_after = Pt(6)
        r = p.add_run(f"{tj} {periodo}")
        r.font.size = Pt(13)
        r.font.color.rgb = CYN

        tb = doc.add_table(rows=1, cols=2)
        tb.autofit = False
        _sin_bordes(tb)
        for c, t, anc in zip(tb.rows[0].cells, ("Temas de Agenda", "Votacion"),
                             (Cm(11.2), Cm(5.6))):
            c.width = anc
            _sombrear(c, AMA)
            rr = c.paragraphs[0].add_run(t)
            rr.bold = True
            rr.font.size = Pt(9)
            rr.font.color.rgb = NAV

        alterna = False
        for e in bloque["tabla"]:
            fe = tb.add_row().cells
            fe[0].width, fe[1].width = Cm(11.2), Cm(5.6)
            for c in fe:
                _sombrear(c, AMA)
            rr = fe[0].paragraphs[0].add_run(e["empresa"])
            rr.bold = True
            rr.font.size = Pt(9)
            rr.font.color.rgb = NAV
            for f in e["fechas"]:
                fd = tb.add_row().cells
                fd[0].width, fd[1].width = Cm(11.2), Cm(5.6)
                for c in fd:
                    _sombrear(c, "EDF29A")
                rr = fd[0].paragraphs[0].add_run(f["fecha"])
                rr.bold = True
                rr.font.size = Pt(9)
                rr.font.color.rgb = NAV
                for pto in f["puntos"]:
                    alterna = not alterna
                    fl = tb.add_row().cells
                    fl[0].width, fl[1].width = Cm(11.2), Cm(5.6)
                    for c in fl:
                        _sombrear(c, "E8EDF0" if alterna else "F7F9FA")
                    r1 = fl[0].paragraphs[0].add_run(
                        f"{pto['punto']}.  {pto['texto']}")
                    r1.font.size = Pt(8)
                    r1.font.color.rgb = NAV
                    voto = pto["decision"]
                    if pto["decision"] == "En Contra" and pto["motivo"]:
                        voto += (f". En linea con la Politica de Votacion de "
                                 f"{cfg.get('Nombre_Institucion','AFP Integra')} "
                                 f"({pto['motivo'].lower()})")
                    fl[1].paragraphs[0].alignment = WD_ALIGN_PARAGRAPH.CENTER
                    r2 = fl[1].paragraphs[0].add_run(voto)
                    r2.font.size = Pt(8)
                    r2.font.color.rgb = (CYN if pto["decision"] == "En Contra" else NAV)

        if idx < len(bloques) - 1:
            doc.add_page_break()

    doc.save(ruta_salida)
    print(f"[OK] Word       -> {ruta_salida}")


# ============================================================================
# 7. MAIN
# ============================================================================
def main():
    ap = argparse.ArgumentParser(description="Dashboard y reporte de Juntas de Accionistas")
    ap.add_argument("--bd", default=RUTA_BD, help="ruta al Excel de la BD")
    ap.add_argument("--anio", type=int, default=None, help="filtra el Word a un anio")
    ap.add_argument("--trimestre", default=None, help="T1 | T2 | T3 | T4")
    ap.add_argument("--salida", default=CARPETA_SALIDA)
    ap.add_argument("--solo-dashboard", action="store_true")
    ap.add_argument("--solo-word", action="store_true")
    args = ap.parse_args()

    print("=" * 70)
    print("JUNTAS DE ACCIONISTAS - generacion de reportes")
    print("=" * 70)

    registros, param = cargar_bd(args.bd)
    print(f"[OK] BD leida: {len(registros)} filas, {len(param['empresas'])} empresas parametrizadas.")
    validar(registros, param)

    os.makedirs(args.salida, exist_ok=True)
    sello = datetime.now().strftime("%Y%m%d_%H%M")

    # --- El dashboard siempre lleva la data completa; los filtros son del navegador.
    if not args.solo_word:
        generar_html(registros, param,
                     os.path.join(args.salida, f"Dashboard_Juntas_{sello}.html"))

    if not args.solo_dashboard:
        sub = registros
        etiquetas = []
        if args.anio:
            sub = [r for r in sub if r["anio"] == args.anio]
            etiquetas.append(str(args.anio))
        if args.trimestre:
            sub = [r for r in sub if r["trimestre"] == args.trimestre.upper()]
            etiquetas.append(args.trimestre.upper())
        periodo = " - ".join(etiquetas) if etiquetas else "periodo completo"

        if not sub:
            sys.exit(f"[ERROR] No hay registros para {periodo}.")

        orden = sorted(param["tipos"], key=lambda t: param["tipos"][t]["orden"])
        bloques = [agregar(sub, param, t) for t in orden]
        bloques = [b for b in bloques if b]
        if not bloques:
            sys.exit("[ERROR] No hay juntas computables en el periodo.")

        nom = f"Reporte_Juntas_{periodo.replace(' - ','_').replace(' ','_')}_{sello}.docx"
        generar_word(bloques, param, periodo, os.path.join(args.salida, nom))

    print("=" * 70)
    print("Listo.")


if __name__ == "__main__":
    main()
