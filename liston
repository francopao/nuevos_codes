# 5. DASHBOARD HTML INTERACTIVO
# ============================================================================
def generar_html(registros, param, ruta_salida):
    """Dashboard autocontenido: filtra en el navegador, sin dependencias locales."""
    datos = []
    for r in registros:
        datos.append({
            "emp": r["empresa"], "sec": r["sector"], "tj": r["tipo_junta"],
            "anio": int(r["anio"]) if r["anio"] else 0, "tri": r["trimestre"],
            "jid": r["junta_id"],
            "fec": r["fecha"].strftime("%d/%m/%Y") if isinstance(r["fecha"], (datetime, date)) else "",
            "pto": r["punto"], "txt": r["texto_agenda"], "tema": r["tema"],
            "dec": r["decision"], "mot": r["motivo"], "jus": r["justificacion"],
            "dir": r["director"], "ind": r["independencia"],
            "e1": r["esp1"], "e2": r["esp2"],
        })

    cfg = param["config"]
    meta = {
        "decisiones": {k: v for k, v in param["decisiones"].items()},
        "sectores": {k: v["color"] for k, v in param["sectores"].items()},
        "orden_sector": {k: v["orden"] for k, v in param["sectores"].items()},
        "motivos": param["motivos"],
        "tipos": {k: v["etiqueta"] for k, v in param["tipos"].items()},
        "esp_orden": param["especialidades"],
        "primario": cfg.get("Color_Primario", "1E2E6E"),
        "secundario": cfg.get("Color_Secundario", "00AECB"),
        "acento": cfg.get("Color_Acento", "E3E829"),
        "institucion": cfg.get("Nombre_Institucion", "AFP Integra"),
        "titulo": cfg.get("Titulo_Reporte", "REPORTE DE JUNTAS DE ACCIONISTAS"),
        "pie": cfg.get("Pie_Pagina", ""),
    }

    html = PLANTILLA_HTML.replace("__DATOS__", json.dumps(datos, ensure_ascii=False))
    html = html.replace("__META__", json.dumps(meta, ensure_ascii=False))
    html = html.replace("__GENERADO__", datetime.now().strftime("%d/%m/%Y %H:%M"))

    with open(ruta_salida, "w", encoding="utf-8") as fh:
        fh.write(html)
    print(f"[OK] Dashboard  -> {ruta_salida}")


