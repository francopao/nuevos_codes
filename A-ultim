def enviar_outlook(asunto, cuerpo_interno_html,
                   to="franco.olivares@sura.pe",
                   cc="franco.olivares@sura.pe",
                   ruta_logo=RUTA_LOGO):
    """
    Envía correo HTML por Outlook (sin SMTP / sin contraseñas).
    'cuerpo_interno_html' es solo el contenido; la firma y el logo se agregan aquí.
    """
    cuerpo = f"""
    <html>
    <body style="font-family: Calibri, Arial, sans-serif; color:#333;">
    {cuerpo_interno_html}
    {FIRMA_HTML}
    </body>
    </html>
    """

    outlook = win32.Dispatch("Outlook.Application")
    mail = outlook.CreateItem(0)
    mail.To = to
    mail.CC = cc
    mail.Subject = asunto
    mail.HTMLBody = cuerpo

    # Logo embebido (cid:logo_integra)
    if ruta_logo and os.path.exists(ruta_logo):
        attachment = mail.Attachments.Add(ruta_logo)
        attachment.PropertyAccessor.SetProperty(
            "http://schemas.microsoft.com/mapi/proptag/0x3712001F",
            "logo_integra"
        )

    mail.Send()
    print("✅ Correo enviado correctamente")


