            archivo = f"{indicador}-{cod_mes}{anio}.XLS"
            url = f"https://intranet2.sbs.gob.pe/estadistica/financiera/{anio}/{nombre_mes}/{archivo}"
            if existe_url(url):
                return {
                    "fecha": f"{nombre_mes} {anio}",
                    "Link": url,
                    "descripcion": f"{indicador} - {nombre_mes} {anio}",
                    "link": url
