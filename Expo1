<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Framework Riesgo Físico Climático — AFP Integra</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a1628;--bg2:#0f2040;--bg3:#162a4a;
  --teal:#00d4aa;--teal2:rgba(0,212,170,0.12);
  --blue:#3b82f6;--blue2:rgba(59,130,246,0.12);
  --amber:#f59e0b;--amber2:rgba(245,158,11,0.12);
  --coral:#ef4444;--coral2:rgba(239,68,68,0.12);
  --purple:#8b5cf6;--purple2:rgba(139,92,246,0.12);
  --green:#10b981;--green2:rgba(16,185,129,0.12);
  --text:#e2eaf5;--muted:#7a94b0;--border:rgba(255,255,255,0.07);
  --r:10px;
}
html{scroll-behavior:smooth}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.6}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--bg3)}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(10,22,40,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:4px;padding:0 20px;height:48px;overflow-x:auto}
.nav-brand{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--teal);letter-spacing:.12em;text-transform:uppercase;margin-right:16px;white-space:nowrap}
.nb{padding:6px 12px;border:none;background:none;font-family:'IBM Plex Sans',sans-serif;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;border-radius:6px;white-space:nowrap;transition:.15s}
.nb:hover,.nb.on{color:var(--teal);background:var(--teal2)}

/* PAGES */
.page{display:none;padding:32px 20px 60px;max-width:1000px;margin:0 auto}
.page.on{display:block}

/* TYPE */
.eyebrow{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);margin-bottom:8px;display:flex;align-items:center;gap:8px}
.eyebrow::before{content:'';width:16px;height:1px;background:var(--teal)}
h1{font-size:clamp(22px,4vw,34px);font-weight:600;color:#fff;margin-bottom:10px;line-height:1.2}
h2{font-size:18px;font-weight:600;color:#fff;margin-bottom:6px}
h3{font-size:14px;font-weight:600;color:#fff;margin-bottom:4px}
p{color:var(--muted);line-height:1.7}
p+p{margin-top:8px}
.mono{font-family:'IBM Plex Mono',monospace}
.gap{margin-top:36px}
.gap-sm{margin-top:18px}

/* CARDS */
.card{background:rgba(15,32,64,0.7);border:1px solid var(--border);border-radius:var(--r);padding:18px}
.card+.card{margin-top:12px}
.ct{border-left:2px solid var(--teal)}
.cb{border-left:2px solid var(--blue)}
.ca{border-left:2px solid var(--amber)}
.cc{border-left:2px solid var(--coral)}
.cp{border-left:2px solid var(--purple)}
.cg{border-left:2px solid var(--green)}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.ga{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
@media(max-width:600px){.g2,.g3{grid-template-columns:1fr}}

/* TAGS */
.tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:8px}
.tag{font-size:11px;padding:2px 8px;border-radius:12px;font-weight:500}
.tt{background:var(--teal2);color:var(--teal);border:1px solid rgba(0,212,170,.25)}
.tb{background:var(--blue2);color:#93c5fd;border:1px solid rgba(59,130,246,.25)}
.ta{background:var(--amber2);color:#fcd34d;border:1px solid rgba(245,158,11,.25)}
.tc{background:var(--coral2);color:#fca5a5;border:1px solid rgba(239,68,68,.25)}
.tp{background:var(--purple2);color:#c4b5fd;border:1px solid rgba(139,92,246,.25)}
.tg{background:var(--green2);color:#6ee7b7;border:1px solid rgba(16,185,129,.25)}

/* FLOW DIAGRAM */
.flow{display:flex;flex-direction:column;gap:0}
.flow-row{display:flex;align-items:stretch;gap:0;position:relative}
.flow-col{display:flex;flex-direction:column;align-items:center;gap:0;flex:1}
.fbox{padding:12px 14px;border-radius:8px;border:1px solid;font-size:12px;text-align:center;width:100%;position:relative}
.fbox h4{font-size:12px;font-weight:600;margin-bottom:3px}
.fbox p{font-size:11px;line-height:1.4}
.arrow-down{width:1px;height:24px;background:var(--border);margin:0 auto;position:relative}
.arrow-down::after{content:'▼';position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);font-size:9px;color:var(--muted)}
.arrow-right{width:24px;height:1px;background:var(--border);align-self:center;flex-shrink:0;position:relative}
.arrow-right::after{content:'▶';position:absolute;right:-8px;top:50%;transform:translateY(-50%);font-size:9px;color:var(--muted)}
.merge-line{height:2px;background:linear-gradient(90deg,var(--teal2),var(--teal),var(--teal2));margin:0;border-radius:1px}

/* CODE BLOCK */
.code{font-family:'IBM Plex Mono',monospace;font-size:11px;background:rgba(0,0,0,.4);border:1px solid rgba(0,212,170,.15);border-radius:8px;padding:14px 16px;color:#a5f3e8;line-height:1.9;overflow-x:auto;margin-top:10px}
.code .cm{color:var(--muted)}
.code .cv{color:#fcd34d}
.code .cf{color:#93c5fd}
.code .ck{color:#c4b5fd}

/* SOURCE ROW */
.src-row{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.src-row:last-child{border-bottom:none}
.src-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px}
.src-name{font-size:13px;font-weight:600;color:#fff}
.src-desc{font-size:11px;color:var(--muted);margin-top:2px;line-height:1.4}
.src-url{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--teal);margin-top:2px}

/* METRIC BOX */
.metric-hero{background:linear-gradient(135deg,var(--bg2),var(--bg3));border:1px solid var(--border);border-top:2px solid var(--teal);border-radius:var(--r);padding:24px;text-align:center;margin-bottom:20px}
.metric-big{font-family:'IBM Plex Mono',monospace;font-size:clamp(15px,3vw,20px);color:var(--teal);font-weight:500;line-height:1.6;margin:12px 0}
.metric-lbl{font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}

/* STEP */
.step-list{padding-left:28px;position:relative}
.step-list::before{content:'';position:absolute;left:8px;top:8px;bottom:0;width:1px;background:var(--border)}
.step{position:relative;padding-bottom:22px}
.step:last-child{padding-bottom:0}
.step::before{content:attr(data-n);position:absolute;left:-28px;top:0;width:18px;height:18px;border-radius:50%;background:var(--teal);color:var(--bg);font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:500;display:flex;align-items:center;justify-content:center;font-size:9px}
.step-t{font-size:13px;font-weight:600;color:#fff;margin-bottom:3px}
.step-b{font-size:12px;color:var(--muted)}

/* REF */
.ref{font-size:11px;color:var(--muted);font-family:'IBM Plex Mono',monospace;background:rgba(0,0,0,.25);padding:6px 10px;border-radius:5px;margin-top:6px;display:inline-block}

/* COMPARE TABLE */
.ctable{width:100%;border-collapse:collapse;font-size:12px;margin-top:14px}
.ctable th{padding:8px 12px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--teal);border-bottom:1px solid var(--border)}
.ctable td{padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--muted)}
.ctable td:first-child{color:#fff;font-weight:500}
.ctable tr:hover td{background:rgba(255,255,255,.02)}
.ok{color:var(--teal)}
.warn{color:var(--amber)}
.no{color:var(--coral)}
</style>
</head>
