# de dtype al reasignar columnas con nombre duplicado en pandas 3.
_num = {j: pd.to_numeric(Precios_Sin_Dividendos_R.iloc[:, j], errors='coerce').fillna(0).astype('float64')
        for j in range(Precios_Sin_Dividendos_R.shape[1])}
_cols = Precios_Sin_Dividendos_R.columns
_idx = Precios_Sin_Dividendos_R.index
Precios_Sin_Dividendos_R = pd.DataFrame(_num)
Precios_Sin_Dividendos_R.index = _idx
Precios_Sin_Dividendos_R.columns = _cols
```

