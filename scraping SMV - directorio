# -*- coding: utf-8 -*-
"""
Extraccion automatizada del Directorio (Junta Directiva) de empresas
desde el portal SMV (Bp_Directorio).

Flujo por empresa:
    1. Abre la URL de memorias del SMV (misma ficha de busqueda de emisor).
    2. Escribe el nombre de la empresa en el buscador y dispara la busqueda.
    3. En la ficha del emisor, hace click en el boton "Directorio"
       (id = btnDirectorio) en vez de "Memoria".
    4. Espera la tabla de directorio (id = MainContent_gvdirectorio).
    5. Extrae cada fila: Nombre del Personal, Nacionalidad, Documento de
       Identidad, Cargo, Fecha de Inicio, Independiente.
    6. Consolida todas las empresas en un unico CSV/Excel guardado en la
       misma carpeta base del codigo de referencia (RUTA_BASE).

Restricciones de diseno:
    - No usa xlwings ni win32com (cuelgan el kernel).
    - Es un archivo completo, ejecutable por celdas (# %%) en Spyder.
    - Comentarios en espaniol.

Dependencias (env fran36):
    pip install selenium openpyxl
    # Selenium >= 4.6 auto-gestiona el chromedriver (Selenium Manager).
"""

# %% ===========================  IMPORTS  ====================================
import os
import re
import csv
import unicodedata
from datetime import datetime

from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.common.exceptions import (
    TimeoutException, NoSuchElementException, StaleElementReferenceException,
)


# %% ===========================  PARAMETROS  =================================

URL_SMV = "https://www.smv.gob.pe/SIMV/Bp_Memorias?op=bq12"

# Ruta base donde se guarda el consolidado. Debe coincidir con la carpeta del
# codigo de referencia (Descargar_Memoria_SMV.py). Ajustar si cambia la maquina.
RUTA_BASE = r"Z:\Mesa de Inversiones\Bottom-Up\2 Proceso de Inversión Renta Fija\Corporates - Emisiones\Crédito - BU\3. ESG\39. Dashboard - Gobierno Corporativo\Python"

NOMBRE_ARCHIVO_SALIDA = "Directorio_Consolidado.csv"

# Ejecutar el navegador visible (False) o sin ventana (True).
HEADLESS = False

# Lista de empresas. El segundo valor es el nombre con el que se guarda en el
# consolidado (util para FOSSAL -> HOCHSCHILD MINING PERU).
EMPRESAS = [
    ("COMPAÑIA DE MINAS BUENAVENTURA S.A.A.", "COMPAÑIA DE MINAS BUENAVENTURA S.A.A."),
    ("MINSUR S.A.", "MINSUR S.A."),
