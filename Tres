## PARTE 1 — Python: nombres de semestre + mitigantes del semestre anterior

**1A.** Pega estos 3 helpers **justo después de la función `_periodo_actual`** (después de su `return candidatos[0]`):

```python
def _sem_hoja_a_nombre(hoja):
    """'1S26'->'Jun26', '2S25'->'Dic25'."""
    try:
        return ("Jun" if str(hoja)[0] == "1" else "Dic") + str(hoja)[2:]
    except Exception:
        return str(hoja)


def _sem_hoja_anterior(hoja):
    """Hoja del semestre anterior: '1S26'->'2S25', '2S25'->'1S25'."""
    try:
        s, yy = str(hoja)[0], int(str(hoja)[2:])
        return ("2S%02d" % ((yy - 1) % 100)) if s == "1" else ("1S%02d" % yy)
    except Exception:
        return None


def _leer_mitigantes_hoja(path, hoja, logfn=print):
    """Lee UNA hoja específica de Mitigantes.xlsx -> {empresa: 'Bajo'|'Medio'|'Alto'}.
    Devuelve {} si el archivo o la hoja no existen (no rompe nada)."""
    MAPA = {1: "Bajo", 2: "Medio", 3: "Alto"}
    out = {}
    if not path or not hoja or not os.path.exists(path):
        return out
    try:
        import openpyxl
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        if hoja not in wb.sheetnames:
            wb.close(); return out
        ws = wb[hoja]
        for row in ws.iter_rows(min_row=2, max_col=2, values_only=True):
            emp, val = (row[0], row[1]) if len(row) >= 2 else (None, None)
            if not emp:
                continue
            try:
                out[str(emp).strip()] = MAPA.get(int(round(float(val))), "\u2014")
            except (TypeError, ValueError):
                out[str(emp).strip()] = "\u2014"
        wb.close()
    except Exception as e:
        logfn(f"[Activos] Mitigantes hoja '{hoja}': {e}")
    return out
```

