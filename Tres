## PARTE 4 — Columnas Mitigantes por semestre

**4A.** Busca el final de `mitiCell` y **pega debajo** las dos funciones nuevas:
```javascript
function mitiCell(emisor){
  const v = getMitigante(emisor);
  // NUEVO: lógica invertida — mitigante Alto es BUENO (verde); Bajo es MALO (rojo).
  const bg = v==='Alto'?'#d4edda' : v==='Medio'?'#fff3cd' : v==='Bajo'?'#f8d7da' : '';
  return '<td style="text-align:center'+(bg?(';background:'+bg):'')+'">'+v+'</td>';
}
function getMitigantePrev(emisor){
  if(MITIGANTES_PREV[emisor]) return MITIGANTES_PREV[emisor];
  const norm = s => s.normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().trim();
  const ne = norm(emisor);
  const f = Object.keys(MITIGANTES_PREV).find(k => norm(k) === ne);
  return f ? MITIGANTES_PREV[f] : '\u2014';
}
function mitiCellPrev(emisor){
  const v = getMitigantePrev(emisor);
  const bg = v==='Alto'?'#d4edda' : v==='Medio'?'#fff3cd' : v==='Bajo'?'#f8d7da' : '';
  return '<td style="text-align:center'+(bg?(';background:'+bg):'')+'">'+v+'</td>';
}
```

