const MITIGANTES = PAYLOAD.mitigantes || {};
const MITIGANTES_PREV = PAYLOAD.mitigantes_prev || {};
const SEM_ACTUAL = PAYLOAD.sem_actual || '';
const SEM_PREV = PAYLOAD.sem_prev || '';
const HAS_MIT_PREV = Object.keys(MITIGANTES_PREV).length > 0;
// Paleta por emisor: 0=rojo prioritario, 1=azul, luego colores distintos.
const EMIS_PALETTE = ['#E4002B','#0033A0','#009E49','#F2A900','#7A3FBF',
                      '#00A3A3','#D45500','#B5006B','#5B6770','#8DB600'];
function _hex2rgb(h){h=h.replace('#','');return [parseInt(h.slice(0,2),16),parseInt(h.slice(2,4),16),parseInt(h.slice(4,6),16)];}
function _rgb2hex(r,g,b){const t=x=>('0'+Math.round(x).toString(16)).slice(-2);return '#'+t(r)+t(g)+t(b);}
// Sombrea el color base del emisor según nivel CENEPRED (1 claro .. 5 pleno).
// Sin score -> plomo (mismo criterio anterior).
function shadeByNivel(base, sc){
  if(!(sc>=1&&sc<=5)) return '#BFC5CC';
  const k=[0.32,0.48,0.64,0.82,1.0][sc-1];
  const c=_hex2rgb(base);
  return _rgb2hex(255-(255-c[0])*k, 255-(255-c[1])*k, 255-(255-c[2])*k);
}
```

