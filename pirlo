def _estilo_ejes(ax, con_fechas=True):
    """Aplica formato consistente a un subgráfico: grilla, fondo blanco, eje X anual."""
    ax.set_facecolor("white")
    ax.grid(True, which="major", color="#dddddd", linewidth=0.6, alpha=0.8)
    ax.tick_params(axis="both", labelsize=9)
    for spine in ["top", "right"]:
        ax.spines[spine].set_visible(False)
    if con_fechas:
        ax.xaxis.set_major_locator(mdates.YearLocator())
        ax.xaxis.set_major_formatter(mdates.DateFormatter("%b-%y"))
        for lbl in ax.get_xticklabels():
            lbl.set_rotation(0)
            lbl.set_ha("center")


def _plot_afp_panel(ax, df, titulo, solo_integra):
    """Dibuja EPU, ETF Perú, Integra (+resto de AFP si no es 'solo_integra')."""
    ax.plot(EPU_Var_Acum, color=COLOR_EPU, label="EPU", linewidth=1.3)
    ax.plot(ETFPERU_Var_Acum, color=COLOR_ETFPERU, label="ETF Perú", linewidth=1.3)
    orden = ["IN"] if solo_integra else ["IN", "HA", "PF", "RI"]
    for afp in orden:
        if afp in df.columns:
            ax.plot(df[afp], color=COLORS_AFP[afp], label=LABELS_AFP[afp], linewidth=1.6)
    ax.set_title(titulo, fontsize=13, fontweight="bold", fontname="Trebuchet MS", pad=8)
    _estilo_ejes(ax, con_fechas=True)


