                r, c = pos[clave]
                titulo = dict(fondos_orden)[clave]
                _plot_afp_panel(axis[r, c], df, titulo, solo_integra)
                ax_ref = axis[r, c]
        _leyenda_unica(fig, ax_ref)
        plt.tight_layout(rect=[0, 0.04, 1, 0.93])
        pdf.savefig(fig, facecolor="white")
        plt.close(fig)

        # ---------------- PÁGINAS POR SECTOR ----------------
        prefijo = "Rendimiento: " if solo_integra else "Rendimiento Acumulado: "
        for sector in Lista_Sectores:
            fig, axis = plt.subplots(2, 2, figsize=(16, 11), facecolor="white")
            fig.suptitle(f"{prefijo}{sector}", fontsize=18, fontweight="bold", color="#000000")
            fig.text(0.5, 0.945, subt, ha="center", fontsize=10, color="#555555")
            ax_ref = None
            hay_datos = False
            for nombre, df in Solo_Totales_Retornos_Sectoriales.items():
                partes = nombre.split("_")
                if partes[0] == sector and partes[1] in pos:
                    r, c = pos[partes[1]]
                    titulo = {"F1": "Fondo 1", "F2": "Fondo 2", "F3": "Fondo 3", "M": "Multifondo"}[partes[1]]
                    _plot_afp_panel(axis[r, c], df, titulo, solo_integra)
                    ax_ref = axis[r, c]
                    hay_datos = True
            if ax_ref is not None:
                _leyenda_unica(fig, ax_ref)
            plt.tight_layout(rect=[0, 0.04, 1, 0.93])
            pdf.savefig(fig, facecolor="white")
            plt.close(fig)

        # ---------------- PÁGINAS DE PRECIOS ----------------
        # Solo instrumentos que existen en el diccionario Y tienen algún dato
        # no nulo/no cero (antes se dibujaban ejes vacíos -> páginas en blanco).
        # Se selecciona POR POSICIÓN (no por nombre) para ser robustos ante
        # columnas con nombre DUPLICADO: en ese caso Precios_Con_Dividendos_R[col]
        # devuelve un DataFrame (no una Series) y `serie.notna().any()` produce una
        # Series -> el `and` lanza "The truth value of a Series is ambiguous".
        # Iterando por posición cada serie es 1-D garantizado.
        _cols_precios = list(Precios_Con_Dividendos_R.columns)
        candidatos = [j for j, col in enumerate(_cols_precios) if col in Diccionario_Parametria]
        con_datos = []
        for j in candidatos:
            serie = Precios_Con_Dividendos_R.iloc[:, j]
            if serie.notna().any() and (serie.fillna(0) != 0).any():
                con_datos.append(j)
        if not con_datos:
            log.warning("No hay instrumentos con datos de precio para graficar; se omite la página de Precios.")
        else:
            por_pagina = 8  # 4 filas x 2 columnas
            n_paginas = (len(con_datos) + por_pagina - 1) // por_pagina
            contador = 0
            for _ in range(n_paginas):
                fig, axis = plt.subplots(4, 2, figsize=(16, 20), facecolor="white")
                fig.suptitle("Precios", fontsize=18, fontweight="bold", color="#000000")
                for y in range(4):
                    for x in range(2):
                        if contador >= len(con_datos):
                            axis[y, x].axis("off")  # apaga ejes sobrantes en vez de dejarlos vacíos
                            continue
                        j = con_datos[contador]
                        col = _cols_precios[j]
                        axis[y, x].plot(Precios_Con_Dividendos_R.iloc[:, j], color="#3e63ad", linewidth=1.4)
                        axis[y, x].set_title(Diccionario_Parametria[col], fontsize=12,
                                             fontname="Trebuchet MS", pad=6)
                        _estilo_ejes(axis[y, x], con_fechas=True)
                        contador += 1
                plt.tight_layout(rect=[0, 0, 1, 0.96])
                pdf.savefig(fig, facecolor="white")
                plt.close(fig)
    return ruta_pdf


