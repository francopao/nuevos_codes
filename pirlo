def _reindex_columnas_seguro(df, columnas):
    """
    Equivalente a df.reindex(columns=columnas) pero robusto ante columnas
    DUPLICADAS en el DataFrame de origen (pandas 3 lanza ValueError
    "cannot reindex on an axis with duplicate labels" en ese caso).

    Si el origen tiene columnas repetidas, se conserva la PRIMERA aparición de
    cada una (mismo criterio que MATCH en Excel) antes de reindexar. Las
    columnas pedidas que no existan en el origen quedan como NaN.
    """
    if df.columns.duplicated().any():
        df = df.loc[:, ~df.columns.duplicated(keep="first")]
    return df.reindex(columns=columnas)


# %%
def _concat_preservando_esquema(base, nuevos):
    """
    Concatena verticalmente 'nuevos' debajo de 'base' preservando el esquema
    (columnas) de 'base'.

    Motivo: los encabezados de DQ_IN/DQ_SIS son listas de ISINs que pueden
    contener DUPLICADOS (p.ej. un mismo ISIN repetido en Parametria/Benchmark)
    y además la base histórica y los datos nuevos del QEST pueden tener
    conjuntos de columnas ligeramente distintos (instrumentos agregados o
    retirados entre corridas). En pandas 3, pd.concat sobre eje de filas
    intenta reindexar por etiqueta y falla con InvalidIndexError cuando las
    columnas no son únicas. Aquí concatenamos por POSICIÓN sobre el esquema de
    la base: se reindexa 'nuevos' a las columnas de 'base' de forma posicional
    (respetando duplicados) y se apilan los valores. Las columnas que estén en
    'nuevos' pero no en 'base' se descartan (la base define el contrato); las
    que estén en 'base' pero no en 'nuevos' quedan como NaN.
    """
    base_cols = list(base.columns)

    # Mapa columna->posiciones en 'nuevos' (respeta duplicados por orden de aparición)
    from collections import defaultdict
    pos_por_col = defaultdict(list)
    for i, c in enumerate(nuevos.columns):
        pos_por_col[c].append(i)

    usados = defaultdict(int)
    col_data = {}
    nuevos_vals = nuevos.to_numpy()
    for j, c in enumerate(base_cols):
        posiciones = pos_por_col.get(c, [])
        k = usados[c]
        if k < len(posiciones):
            col_data[j] = nuevos_vals[:, posiciones[k]]
            usados[c] += 1
        else:
            # columna de la base que no existe (o se agotó) en 'nuevos' -> NaN
            col_data[j] = np.full(len(nuevos), np.nan, dtype=object)

    nuevos_alineado = pd.DataFrame(
        {j: col_data[j] for j in range(len(base_cols))}
    )
    nuevos_alineado.columns = base_cols

    # Apilar por valores para no gatillar el reindex por etiquetas duplicadas
    base_reset = base.copy()
    base_reset.columns = range(len(base_cols))
    nuevos_reset = nuevos_alineado.copy()
    nuevos_reset.columns = range(len(base_cols))
    apilado = pd.concat([base_reset, nuevos_reset], ignore_index=True)
    apilado.columns = base_cols
    return apilado


