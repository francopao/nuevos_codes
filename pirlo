### Utilidad: localizar filas de encabezado dinámicamente
#
# Tanto DQ_IN como DQ_SIS parten de hojas "crudas" exportadas por QEST
# donde los datos reales empiezan después de un bloque de filas variable
# (resúmenes, nombres, tickers, etc.). El script original asumía una
# posición de fila FIJA para ese encabezado; se comprobó contra los datos
# reales que esa posición se había corrido (ver changelog), rompiendo el
# parseo de DQ_SIS en silencio. Esta función busca el encabezado por
# CONTENIDO en vez de por posición fija, y si no lo encuentra, falla con
# un mensaje claro en vez de seguir con datos desalineados.
# %%
def _localizar_fila_encabezado(df, valores_esperados, max_filas_busqueda=60):
    n = len(valores_esperados)
    limite = min(max_filas_busqueda, len(df))
    for i in range(limite):
        fila = df.iloc[i, :n].tolist()
        if fila == valores_esperados:
            return i
    raise ValueError(
        f"No se encontró la fila de encabezado esperada {valores_esperados} "
        f"en las primeras {limite} filas. La estructura de origen pudo haber "
        f"cambiado; revisa manualmente antes de continuar."
    )


