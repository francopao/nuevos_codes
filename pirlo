def detectar_sufijo_cartera(nombre_clave: str) -> str:
    """
    Devuelve "", "_L" o "_IL" según la clave 'nombre_clave'.
    Ajusta los if para que calcen con tu naming real:
    - Ej: '..._O' normal, '..._L' líquida, '..._IL' ilíquida.
    - O si usas '..._LIQ' y '..._ILIQ', busca esos tokens.
    """
    low = nombre_clave.lower()
    # ejemplos de patrones frecuentes:
    if any(tok in low for tok in ["_il", "_iliq", "iliq", "ilíquida", "iliquida"]):
        return "_IL"
    if any(tok in low for tok in ["_l", "_liq", "liquida", "líquida"]):
        return "_L"
    # Por descarte, normal:
    return ""


