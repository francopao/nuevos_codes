def main(dia: str = DIA, mes: str = MES, anio: str = ANIO,
         escenario: str = ESCENARIO_INPUT) -> pd.DataFrame:
    inicio = time.time()
    fecha_iso = f"{anio}-{mes}-{dia}"
    fecha_nueva = f"{dia}/{mes}/{anio}"
    log.info("=== BD G&P Soberanos %s%s | corte %s | escenario '%s' ===",
             anio, mes, fecha_iso, escenario)

    # ---- Único tramo que necesita Excel vivo -----------------------------
    with excel_dedicado() as app:
        df = leer_gp(app, escenario, mes, anio)
        tipo_cambio, dic_moneda = leer_tipo_cambio(app, fecha_iso)
    # A partir de aquí no queda ningún Excel abierto por el proceso.

    (inf1, inf2, inf3, haf1, haf2, haf3,
     rif1, rif2, rif3, pff1, pff2, pff3) = leer_aum(fecha_iso)
    aum = {
        "Integra": (inf1, inf2, inf3),
        "Habitat": (haf1, haf2, haf3),
        "Profuturo": (pff1, pff2, pff3),
        "Prima": (rif1, rif2, rif3),
        "Ex_Integra": (haf1 + pff1 + rif1, haf2 + pff2 + rif2, haf3 + pff3 + rif3),
    }

    escribir_excel(df, RUTAS.gp_salida(mes, anio))

    # ---- BU / TD / SOB por AFP -------------------------------------------
    base = calcular_weights(df)
    universos = {
        "BU": filtrar_bu(base),
        "TD": filtrar_por_sbs2(base, SBS2_TD, "TD"),
        "SOB": filtrar_por_sbs2(base, SBS2_SOB, "SOB"),
    }
    bloques = {
        estrategia: {nombre: por_afp(prefijo, universo, nombre, estrategia)
                     for prefijo, nombre in AFPS}
        for estrategia, universo in universos.items()
    }

    portafolio_afp = {
        nombre: agregar_aum(
            [bloques["BU"][nombre], bloques["TD"][nombre], bloques["SOB"][nombre]],
            aum[nombre])
        for _, nombre in AFPS
    }
    multifondos_afp = {
        nombre: consolidar_multifondos(portafolio_afp[nombre], aum[nombre])
        for _, nombre in AFPS
    }

    portafolio = pd.concat(portafolio_afp.values()).sort_index(ignore_index=True)
    multifondos = pd.concat(multifondos_afp.values()).sort_index(ignore_index=True)
    consolidado = pd.concat([portafolio, multifondos]).sort_index(ignore_index=True)
    consolidado.insert(0, "Fecha", fecha_nueva)

    # ---- TXT de Base Alerta ----------------------------------------------
    bu_integra, multi_integra = bloques["BU"]["Integra"], multifondos_afp["Integra"]
    prefijo = f"{mes}{anio}BUIN_"
    escribir_txt(bu_integra, multi_integra, RUTAS.base_alerta(f"{prefijo}.txt"))
    escribir_txt(bloques["TD"]["Integra"], multi_integra,
                 RUTAS.base_alerta(f"TDIN_{mes}{anio}.txt"))
    for sufijo, excluir in [
        ("F1 INBU", ["F3", "F2", "Multifondos"]),
        ("F2 INBU", ["F1", "F3", "Multifondos"]),
        ("F3 INBU", ["F1", "F2", "Multifondos"]),
        ("M INBU", ["F1", "F2", "F3"]),
    ]:
        escribir_txt(bu_integra, multi_integra,
                     RUTAS.base_alerta(f"{prefijo}{sufijo}.txt"), excluir)

    # ---- Cantidades -------------------------------------------------------
    dic_integra, dic_ope = leer_cantidades(fecha_iso, fecha_nueva)

    integra = pd.concat([
        cantidades_integra(portafolio, dic_integra, solo_fondo_propio=True),
        cantidades_integra(multi_integra, dic_integra, solo_fondo_propio=False),
    ]).sort_index(ignore_index=True)
    integra = integra[integra["Afp"] == "Integra"]

    otras = {
        abreviatura: cantidades_otras(
            portafolio_afp[nombre], multifondos_afp[nombre], dic_ope, abreviatura)
        for abreviatura, nombre in AFPS_OPE
    }

    total = pd.concat([integra, *otras.values()]).sort_index(ignore_index=True)

    # Ex_Integra = Habitat + Profuturo + Prima
    ex = pd.concat(otras.values()).sort_index(ignore_index=True)
    clave_ex = ex["SBS"] + ex["ISIN"] + ex["Fondo"] + ex["Strategy"]
    suma_q = ex.assign(Key=clave_ex).groupby("Key")["Q"].sum()

    ex_integra = consolidado[consolidado["Afp"] == "Ex_Integra"].sort_index(
        ignore_index=True).copy()
    ex_integra["Q"] = (ex_integra["SBS"] + ex_integra["ISIN"]
                       + ex_integra["Fondo"] + ex_integra["Strategy"]).map(suma_q)

    total = pd.concat([total, ex_integra]).sort_index(ignore_index=True)
    total = total.drop(columns=["Fecha"])
    total["codEmisor"] = total["SBS"].astype(str).str[2:6]

    # ---- Nombres, precios y tipo de cambio --------------------------------
    par_sbs = leer_parametria("SBS")
    nombre_param = total["SBS"].map(par_sbs["Name"])
    total["Nombre"] = np.where(total["Strategy"] == "BU", nombre_param, total["Nombre"])
    total["Tipo"] = tipo_cambio
    total["Fecha"] = fecha_nueva
    total = total.rename(columns={"Rank Rt": "assetclass"})
    total = total[["SBS", "ISIN", "Weight", "Fondo", "assetclass", "Strategy",
                   "Afp", "AUM", "Tipo", "Q", "Nombre", "Fecha", "codEmisor"]]

    total["Precio"] = total["SBS"].map(leer_precios(fecha_iso))
    total["Fecha"] = datetime.strptime(f"01/{mes}/{anio}", "%d/%m/%Y")
    total["Tipo"] = total["SBS"].str.get(6).map(dic_moneda)
    total["Inversión"] = total["Precio"] * total["Q"] * total["Tipo"]

    sin_precio = int(total["Precio"].isna().sum())
    if sin_precio:
        log.warning("%d posición(es) sin precio para %s.", sin_precio, fecha_nueva)

    ruta_bd1 = RUTAS.intermedio(f"{anio}{mes} BD1_S.xlsx")
    escribir_excel(total, ruta_bd1)

    # ---- Incorporar EPU / ETF Perú ----------------------------------------
    plantilla = pd.concat([
        plantilla_comparable(RUTAS.comparable(f"{anio}{mes} EPU US.xlsx"), SBS_EPU),
        plantilla_comparable(RUTAS.comparable(f"{anio}{mes} ETF Perú.xlsx"), SBS_ETF),
    ])

    # BD1_S se relee UNA vez (el original lo abría 3 veces vía Excel)
    bd1 = pd.read_excel(ruta_bd1)
    sbs2 = recortar_sbs(bd1["SBS"])
    es_etf = sbs2.isin(["54", "50"])

    bd_etf = bd1[es_etf].sort_index(ignore_index=True).copy()
    bd_etf["Strategy"] = "BU"
    bd_etf["key1"] = bd_etf["SBS"] + bd_etf["Fondo"] + bd_etf["Afp"]
    epu = cruzar_comparables(plantilla, bd_etf)

    resto = bd1[~es_etf].copy()
    resto["key1"] = (resto["ISIN"] + resto["Fondo"] + resto["Afp"]
                     + resto["assetclass"] + resto["Strategy"])
    epu["key1"] = (epu["ISIN"] + epu["Fondo"] + epu["AFP"]
                   + epu["assetclass"] + epu["Strategy"])

    peso_epu = resto["key1"].map(epu.set_index("key1")["Weight"].to_dict()).fillna(0)
    resto["Weight"] = resto["Weight"].fillna(0)
    resto.insert(2, "Weight_T", resto["Weight"] + peso_epu)
    portafolio_epu = (resto.drop(columns=["Weight"])
                           .rename(columns={"Weight_T": "Weight", "Afp": "AFP"}))

    solo_epu = epu[~epu["key1"].isin(set(resto["key1"]))]
    log.info("EPU/ETF: %d filas sumadas al portafolio, %d filas nuevas.",
             int((peso_epu > 0).sum()), len(solo_epu))

    df_total = pd.concat([portafolio_epu, solo_epu])

    # ---- Nombre / Empresa --------------------------------------------------
    par_isin = leer_parametria("ISIN")
    es_bu = df_total["Strategy"] == "BU"
    df_total.loc[es_bu, "Nombre"] = df_total.loc[es_bu, "ISIN"].map(par_isin["Nombre"])
    df_total["Empresa"] = df_total["Nombre"]

    identificador = df_total["ISIN"].map(par_isin.get("ID", {}))
    df_total["Empresa"] = np.where(es_bu & identificador.notna(),
                                   identificador, df_total["Empresa"])

    df_total = df_total[["SBS", "ISIN", "Weight", "Fondo", "assetclass", "Strategy",
                         "AFP", "AUM", "Tipo", "Precio", "Q", "Inversión", "Nombre",
                         "Empresa", "Fecha", "codEmisor", "key1"]]

    ruta_portafolio = RUTAS.intermedio(f"{anio}{mes} Portafolio_S.xlsx")
    escribir_excel(df_total, ruta_portafolio)

    # ---- Nuevos instrumentos -> Para.xlsx ----------------------------------
    parametria = CACHE.hoja(RUTAS.parametria, "BU")
    parametria.columns = parametria.iloc[0]
    parametria = parametria.drop(parametria.index[0])
    parametria = parametria.drop(parametria.loc[parametria["ISIN"].isin([None])].index)

    portafolio_bu = pd.read_excel(ruta_portafolio)
    portafolio_bu = portafolio_bu[portafolio_bu["Strategy"] == "BU"]
    nuevos = portafolio_bu[~portafolio_bu["ISIN"].isin(set(parametria["ISIN"]))]
    nuevos = nuevos[["ISIN", "SBS", "codEmisor", "Nombre"]].copy()
    nuevos.columns = ["ISIN", "SBS", "Cod.Emisor", "Nombre"]

    por_emisor = leer_parametria("Cod.Emisor")
    for posicion, (columna, origen) in enumerate(
        [("Moneda", "moneda"), ("Sector", "Sector"), ("Pais", "País"),
         ("Region", "Region"), ("Mercado", "mercado")], start=4
    ):
        nuevos.insert(posicion, columna, nuevos["Cod.Emisor"].map(por_emisor[origen]))

    if len(nuevos):
        log.warning("%d instrumento(s) nuevo(s) sin parametría previa.", len(nuevos))

    escribir_excel(pd.concat([parametria, nuevos]), RUTAS.dataset / "Para.xlsx")

    log.info("=== Proceso terminado en %.1f min ===", (time.time() - inicio) / 60)
    return df_total


