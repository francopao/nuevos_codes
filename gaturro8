# Lector en streaming para hojas gigantes (QEST_BD, BDPrecios)
# --------------------------------------------------------------------------
_RE_ROW = re.compile(rb'<row[^>]*r="(\d+)"[^>]*>(.*?)</row>', re.S)
_RE_CELL = re.compile(rb"<c([^>]*)(?:/>|>(.*?)</c>)", re.S)
_RE_REF = re.compile(rb'r="([A-Z]+)')
_RE_STY = re.compile(rb's="(\d+)"')
_RE_TIP = re.compile(rb't="([a-zA-Z]+)"')
_RE_VAL = re.compile(rb"<v[^>]*>(.*?)</v>", re.S)
_RE_INL = re.compile(rb"<is>.*?<t[^>]*>(.*?)</t>", re.S)

# numFmtId reservados de Excel que representan fechas/horas
_FMT_FECHA = set(range(14, 23)) | set(range(45, 48)) | {27, 30, 36, 50, 57, 58}


def _indice_columna(letras: bytes) -> int:
    n = 0
    for ch in letras:
        n = n * 26 + (ch - 64)
    return n - 1


def _desescapar(b: bytes) -> str:
    s = b.decode("utf8")
    if "&" in s:
        s = (s.replace("&lt;", "<").replace("&gt;", ">").replace("&quot;", '"')
              .replace("&apos;", "'").replace("&amp;", "&"))
    return s


class LectorRapido:
    """
    Lee hojas de decenas o cientos de MB devolviendo SOLO la fila de encabezado
    y las filas que cumplen un predicado. Evita materializar en memoria las
    ~13.000 x ~2.000 celdas que el proceso descarta igual.

    Interpreta shared strings, estilos de fecha y tipos igual que openpyxl
    (validado celda a celda contra `load_workbook(..., data_only=True)`).
    """

    def __init__(self, ruta: Path) -> None:
        if not ruta.exists():
            raise FileNotFoundError(f"No se encuentra el archivo: {ruta}")
        self.ruta = ruta
        self._zip = zipfile.ZipFile(ruta)
        wbx = self._zip.read("xl/workbook.xml").decode("utf8", "ignore")
        rels = dict(re.findall(
            r'Id="(rId\d+)"[^>]*Target="([^"]+)"',
            self._zip.read("xl/_rels/workbook.xml.rels").decode("utf8", "ignore"),
        ))
        self._hojas: dict[str, str] = {}
        for nombre, rid in re.findall(r'<sheet name="([^"]+)"[^>]*r:id="(rId\d+)"', wbx):
            destino = rels[rid].lstrip("/")
            self._hojas[nombre] = destino if destino.startswith("xl/") else "xl/" + destino
        self._cadenas: list[str] | None = None
        self._estilos_fecha: set[int] | None = None

    # -- recursos compartidos del libro --------------------------------
    @property
    def cadenas(self) -> list[str]:
        if self._cadenas is None:
            try:
                crudo = self._zip.read("xl/sharedStrings.xml")
            except KeyError:
                self._cadenas = []
            else:
                self._cadenas = [
                    _desescapar(b"".join(re.findall(rb"<t[^>]*>(.*?)</t>", si, re.S)))
                    for si in re.findall(rb"<si>(.*?)</si>", crudo, re.S)
                ]
        return self._cadenas

    @property
    def estilos_fecha(self) -> set[int]:
        if self._estilos_fecha is None:
            crudo = self._zip.read("xl/styles.xml").decode("utf8", "ignore")
            propios = {int(i): f for i, f in re.findall(
                r'<numFmt numFmtId="(\d+)" formatCode="([^"]*)"', crudo)}
            bloque = re.search(r"<cellXfs[^>]*>(.*?)</cellXfs>", crudo, re.S)
            ids = re.findall(r'numFmtId="(\d+)"', bloque.group(1)) if bloque else []
            fechas: set[int] = set()
            for idx, nf in enumerate(ids):
                nf = int(nf)
                if nf in _FMT_FECHA:
                    fechas.add(idx)
                elif nf in propios:
                    limpio = re.sub(r'\[[^\]]*\]|"[^"]*"', "", propios[nf])
                    if re.search(r"[dmyhs]", limpio, re.I) and "General" not in limpio:
                        fechas.add(idx)
            self._estilos_fecha = fechas
        return self._estilos_fecha

    # -- parsing de celdas ---------------------------------------------
    def _celdas(self, cuerpo: bytes, solo: set[int] | None) -> dict[int, object]:
        from openpyxl.utils.datetime import from_excel

        cadenas, estilos = self.cadenas, self.estilos_fecha
        salida: dict[int, object] = {}
        for celda in _RE_CELL.finditer(cuerpo):
            attrs, interior = celda.group(1), celda.group(2)
            ref = _RE_REF.search(attrs)
            if not ref or interior is None:
                continue
            col = _indice_columna(ref.group(1))
            if solo is not None and col not in solo:
                continue

            mt = _RE_TIP.search(attrs)
            tipo = mt.group(1) if mt else b"n"

            if tipo == b"inlineStr":
                inl = _RE_INL.search(interior)
                salida[col] = _desescapar(inl.group(1)) if inl else None
                continue

            mv = _RE_VAL.search(interior)
            if not mv:
                continue
            bruto = mv.group(1)

            if tipo == b"s":
                salida[col] = cadenas[int(bruto)]
            elif tipo == b"b":
                salida[col] = bruto == b"1"
            elif tipo in (b"str", b"e"):
                salida[col] = _desescapar(bruto)
            else:
                try:
                    numero = float(bruto)
                except ValueError:
                    salida[col] = _desescapar(bruto)
                    continue
                estilo = _RE_STY.search(attrs)
                if estilo and int(estilo.group(1)) in estilos:
                    try:
                        salida[col] = from_excel(numero)
                    except Exception:
                        salida[col] = numero
                elif (numero.is_integer() and abs(numero) < 1e15
                      and b"." not in bruto and b"E" not in bruto.upper()):
                    salida[col] = int(numero)
                else:
                    salida[col] = numero
        return salida

    # -- API -----------------------------------------------------------
    def filtrar(
        self,
        hoja: str,
        cols_filtro: Sequence[int],
        es_encabezado: Callable[[dict[int, object]], bool],
        es_dato: Callable[[dict[int, object]], bool],
    ) -> tuple[list[object], list[list[object]]]:
        """
        Recorre la hoja una sola vez y devuelve (encabezado, filas_que_cumplen).
        `cols_filtro` son las columnas necesarias para evaluar los predicados;
        el resto de la fila solo se parsea si la fila se conserva.
        """
        if hoja not in self._hojas:
            raise KeyError(f"[{self.ruta.name}] No existe la hoja '{hoja}'. "
                           f"Disponibles: {list(self._hojas)}")

        objetivo = set(cols_filtro)
        encabezado: dict[int, object] | None = None
        filas: list[dict[int, object]] = []
        ancho = 0
        t0 = time.time()

        with self._zip.open(self._hojas[hoja]) as fh:
            buffer = b""
            for bloque in iter(lambda: fh.read(1 << 22), b""):
                buffer += bloque
                corte = buffer.rfind(b"</row>")
                if corte == -1:
                    continue
                trozo, buffer = buffer[: corte + 6], buffer[corte + 6:]
                for fila in _RE_ROW.finditer(trozo):
                    cuerpo = fila.group(2)
                    parcial = self._celdas(cuerpo, objetivo)
                    if encabezado is None and es_encabezado(parcial):
                        encabezado = self._celdas(cuerpo, None)
                        ancho = max(ancho, max(encabezado, default=-1) + 1)
                        continue
                    if es_dato(parcial):
                        completa = self._celdas(cuerpo, None)
                        ancho = max(ancho, max(completa, default=-1) + 1)
                        filas.append(completa)

        if encabezado is None:
            raise ValueError(f"[{self.ruta.name}!{hoja}] No se localizó la fila de encabezado.")

        log.info("[%s!%s] encabezado + %d fila(s) en %.1fs.",
                 self.ruta.name, hoja, len(filas), time.time() - t0)
        cab = [encabezado.get(c) for c in range(ancho)]
        datos = [[f.get(c) for c in range(ancho)] for f in filas]
        return cab, datos

    def close(self) -> None:
        self._zip.close()

    def __enter__(self) -> "LectorRapido":
        return self

    def __exit__(self, *exc) -> None:
        self.close()


def a_diccionario(encabezado: Sequence[object],
                  filas: Iterable[Sequence[object]],
                  col_clave: int) -> dict[str, dict]:
    """
    Reproduce el `transpose().to_dict()` del código original:
    {valor_de_col_clave: {encabezado_i: valor_i}}.
    """
    return {str(fila[col_clave]): dict(zip(encabezado, fila)) for fila in filas}


