def leer_used_range(ruta: Path, hoja: str | int) -> pd.DataFrame:
    """
    Réplica exacta de `xw.sheets[...].used_range.value` (mismo recorte de filas
    y columnas) leída con openpyxl. Devuelve los valores cacheados de las
    fórmulas, que es lo que entrega xlwings sobre un libro que no recalcula.
    """
    from openpyxl import load_workbook

    if not ruta.exists():
        raise FileNotFoundError(f"No se encuentra el archivo: {ruta}")

    wb = load_workbook(ruta, read_only=True, data_only=True, keep_links=False)
    try:
        ws = wb[hoja] if isinstance(hoja, str) else wb[wb.sheetnames[hoja]]
        filas = list(ws.iter_rows(
            min_row=ws.min_row, max_row=ws.max_row,
            min_col=ws.min_column, max_col=ws.max_column,
            values_only=True,
        ))
    finally:
        wb.close()  # siempre
    return pd.DataFrame(filas)


class CacheLecturas:
    """Cada archivo se abre una sola vez por corrida, aunque se pidan N hojas."""

    def __init__(self) -> None:
        self._datos: dict[tuple[str, str | int], pd.DataFrame] = {}

    def hoja(self, ruta: Path, hoja: str | int) -> pd.DataFrame:
        clave = (str(ruta), hoja)
        if clave not in self._datos:
            t0 = time.time()
            self._datos[clave] = leer_used_range(ruta, hoja)
            log.info("Leído %s [%s] %s en %.1fs.", ruta.name, hoja,
                     self._datos[clave].shape, time.time() - t0)
        return self._datos[clave].copy()


