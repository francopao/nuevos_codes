@contextmanager
def excel_dedicado():
    """
    Instancia de Excel EXCLUSIVA del proceso: invisible, sin libro en blanco y
    con alertas apagadas. Al salir cierra sus libros y termina la instancia,
    pase lo que pase. La sesión de Excel del usuario no se ve afectada.
    """
    import xlwings as xw

    app = xw.App(visible=False, add_book=False)
    app.display_alerts = False
    app.screen_updating = False
    log.info("Instancia dedicada de Excel iniciada (PID %s).", getattr(app, "pid", "?"))
    try:
        yield app
    finally:
        for wb in list(getattr(app, "books", [])):
            try:
                wb.close()
            except Exception as exc:  # pragma: no cover
                log.warning("No se pudo cerrar un libro: %s", exc)
        try:
            app.quit()
        except Exception as exc:  # pragma: no cover
            log.warning("No se pudo cerrar la instancia de Excel: %s", exc)
        log.info("Instancia dedicada de Excel cerrada.")


def esperar_calculo(app, timeout: int = TIMEOUT_CALCULO) -> None:
    """Espera activa hasta que Excel deja de calcular (xlDone), no un sleep fijo."""
    time.sleep(ESPERA_MINIMA)
    inicio = time.time()
    try:
        while app.api.CalculationState != 0:
            if time.time() - inicio > timeout:
                log.warning("Excel sigue calculando tras %ds; se continúa.", timeout)
                return
            time.sleep(0.25)
    except Exception:
        time.sleep(5)  # driver sin CalculationState
        return
    log.debug("Cálculo terminado en %.1fs.", time.time() - inicio)


@contextmanager
def libro_excel(app, ruta: Path, ruta_alterna: Path | None = None):
    """Abre un libro en la instancia dedicada y GARANTIZA su cierre."""
    destino = ruta
    if not destino.exists():
        if ruta_alterna is None or not ruta_alterna.exists():
            raise FileNotFoundError(f"No se encuentra el archivo: {ruta}")
        log.warning("No existe %s -> se usa la alternativa %s", ruta.name, ruta_alterna)
        destino = ruta_alterna

    wb = app.books.open(str(destino), read_only=True, update_links=False)
    try:
        yield wb
    finally:
        try:
            wb.close()
        except Exception as exc:  # pragma: no cover
            log.warning("No se pudo cerrar %s: %s", destino.name, exc)


