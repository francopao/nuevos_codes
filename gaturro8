def _fechas_disponibles(valores: Iterable[object], n: int = 8) -> list[str]:
    fechas = pd.to_datetime(pd.Series(list(valores)), errors="coerce").dropna()
    return fechas.drop_duplicates().sort_values().dt.strftime("%d/%m/%Y").tolist()[-n:]


def exigir_no_vacio(filas: Sequence, contexto: str, fecha: datetime,
                    universo: Iterable[object] | None = None) -> None:
    if filas:
        return
    detalle = ""
    if universo is not None:
        detalle = f" Últimas fechas cargadas: {_fechas_disponibles(universo)}."
    raise ValueError(
        f"[{contexto}] No hay registros para {fecha:%d/%m/%Y}.{detalle} "
        "Verifique que la fuente esté actualizada o use una fecha de corte ya cargada."
    )


