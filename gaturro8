def recortar_sbs(serie: pd.Series) -> pd.Series:
    """Primeros 2 caracteres del SBS conservando los nulos (equivale a recor())."""
    return serie.where(serie.isna(), serie.astype(str).str[:2])


def _dummy(fondo: pd.Series, cual: str) -> pd.Series:
    return (fondo == cual).astype(int)


def calcular_weights(df: pd.DataFrame) -> pd.DataFrame:
    """Weight de cada AFP = INF - GAP. Se queda solo con Renta Fija y Variable."""
    for destino, base in zip(
        ["HAF1", "RIF1", "PFF1", "SIF1", "HAF2", "RIF2", "PFF2", "SIF2",
         "HAF3", "RIF3", "PFF3", "SIF3"],
        ["INF1"] * 4 + ["INF2"] * 4 + ["INF3"] * 4,
    ):
        df[destino] = df[base] - df[destino + "GAP"]
    return df.loc[df["Asset Class"].isin(["Renta Fija", "Renta Variable"])]


def filtrar_bu(df: pd.DataFrame) -> pd.DataFrame:
    """Bottom-Up: sin gobierno, sin fondos mutuos, solo AC Dir válidos."""
    gobierno = (df["Cat"].isin(["Gobierno"])
                | df["SubCat"].isin(["Gobierno"])
                | df["Sub Cat2"].isin(["Gobierno"]))
    fondo_mutuo = df["Categoría"].astype(str).str.contains("FM", regex=False, na=False)
    ac_valido = df["AC Dir"].isin(["PE", "PEC", "EMC", "INTER"])
    excluido = df["SBS2"].isin(SBS2_EXCLUIR_BU)

    out = df.loc[~gobierno & ~fondo_mutuo & ac_valido & ~excluido].copy()
    log.info("BU: %d posiciones.", len(out))
    return out


def filtrar_por_sbs2(df: pd.DataFrame, codigos: list[str], etiqueta: str) -> pd.DataFrame:
    out = df.loc[df["SBS2"].isin(codigos)].sort_index(ignore_index=True)
    log.info("%s: %d posiciones.", etiqueta, len(out))
    return out


def posiciones_fondo(columna: str, data: pd.DataFrame) -> pd.DataFrame:
    df = data.loc[data[columna] > 0, ["SBS", "ISIN", "Nombre", "Rank Rt", columna]].copy()
    df["Fondo"] = columna[-2:]
    return df.rename(columns={columna: "Weight"})


def por_afp(prefijo: str, data: pd.DataFrame, nombre: str, estrategia: str) -> pd.DataFrame:
    df = pd.concat([posiciones_fondo(f"{prefijo}{i}", data) for i in (1, 2, 3)])
    df = df.sort_index(ignore_index=True)
    df["Strategy"] = estrategia
    df["Afp"] = nombre
    return df


def agregar_aum(partes: list[pd.DataFrame], aum: tuple[float, float, float]) -> pd.DataFrame:
    df = pd.concat(partes).sort_index(ignore_index=True)
    df["AUM"] = sum(a * _dummy(df["Fondo"], f"F{i}") for i, a in zip((1, 2, 3), aum))
    return df


def consolidar_multifondos(df: pd.DataFrame, aum: tuple[float, float, float]) -> pd.DataFrame:
    df = df.copy()
    df["USD"] = df["Weight"] * sum(
        a * _dummy(df["Fondo"], f"F{i}") for i, a in zip((1, 2, 3), aum))
    df = df.drop(columns=["Fondo", "AUM", "Weight"]).sort_index(ignore_index=True)
    df = df.groupby(["SBS", "ISIN", "Nombre", "Rank Rt", "Strategy", "Afp"]).sum()

    total = sum(aum)
    df["AUM"] = total
    df["Weight"] = df["USD"] / total
    df = df.drop(columns=["USD"])
    df["Fondo"] = "Multifondos"
    return df.reset_index()


def cantidades_integra(df: pd.DataFrame, dic: dict, solo_fondo_propio: bool) -> pd.DataFrame:
    """
    solo_fondo_propio=True  -> Portafolio (Q solo si Fondo coincide y Afp=Integra)
    solo_fondo_propio=False -> Multifondos (Q = suma de los tres fondos)
    """
    out = df.copy()
    valores = [pd.to_numeric(out["SBS"].map(dic[f"IN-FONDO{i}"]), errors="coerce")
               for i in (1, 2, 3)]

    if solo_fondo_propio:
        integra = out["Afp"] == "Integra"
        q = sum(v.where(integra & (out["Fondo"] == f"F{i}"), 0).fillna(0)
                for i, v in zip((1, 2, 3), valores))
    else:
        q = sum(valores)

    out.insert(9, "Q", q)
    return out


def cantidades_otras(portafolio: pd.DataFrame, multifondos: pd.DataFrame,
                     dic: dict, abreviatura: str) -> pd.DataFrame:
    """Habitat / Profuturo / Prima: Q propio por fondo + suma en Multifondos."""
    out = pd.concat([portafolio, multifondos])
    valores = [
        pd.to_numeric(out["SBS"].map(dic[f"{abreviatura}-FONDO{i}"]), errors="coerce").fillna(0)
        for i in (1, 2, 3)
    ]
    es_multi = out["Fondo"] == "Multifondos"
    q_multi = (valores[0] + valores[1] + valores[2]).where(es_multi, 0)
    q_propio = sum(v.where(out["Fondo"] == f"F{i}", 0) for i, v in zip((1, 2, 3), valores))

    out.insert(9, "Q", q_propio + q_multi)
    return out


