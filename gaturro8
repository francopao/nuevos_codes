def escribir_excel(df: pd.DataFrame, ruta: Path) -> None:
    ruta.parent.mkdir(parents=True, exist_ok=True)
    if ruta.exists():
        log.warning("Se sobrescribe el archivo existente: %s", ruta.name)
    df.to_excel(ruta, index=False)
    log.info("Generado: %s (%d filas).", ruta.name, len(df))


def escribir_txt(df1: pd.DataFrame, df2: pd.DataFrame, ruta: Path,
                 excluir_fondos: list[str] | None = None) -> None:
    df = pd.concat([df1, df2]).sort_index(ignore_index=True)
    df = df[["ISIN", "Weight", "Fondo", "Rank Rt", "Strategy"]]
    df.columns = ["SECURITY_ID", "WEIGHT", "fondo", "class", "Strategy"]
    if excluir_fondos:
        df = df[~df["fondo"].isin(excluir_fondos)]
    ruta.parent.mkdir(parents=True, exist_ok=True)
    df.to_csv(ruta, sep=",", index=False)
    log.info("Generado: %s (%d filas).", ruta.name, len(df))


def plantilla_comparable(ruta: Path, sbs: str) -> pd.DataFrame:
    """Expande un ETF a las 5 AFP x 4 fondos (antes: doble bucle con concat)."""
    df = CACHE.hoja(ruta, 0)
    df.columns = df.iloc[0]
    df = df.drop(df.index[0])

    col_isin = next((c for c in df.columns if str(c).strip() == "ISIN"), None)
    col_mv = next((c for c in df.columns if str(c).strip().startswith("Market Value")), None)
    if col_isin is None or col_mv is None:
        raise KeyError(f"[{ruta.name}] Faltan 'ISIN' o 'Market Value...'. "
                       f"Columnas: {list(df.columns)}")

    df = df[df[col_isin].notna() & df[col_mv].notna()]
    base = pd.DataFrame({
        "ISIN": df[col_isin].to_numpy(),
        "Market Value (%) (P)": (pd.to_numeric(df[col_mv], errors="coerce") / 100)
                                .fillna(0).to_numpy(),
    })

    combinaciones = pd.MultiIndex.from_product(
        [["Integra", "Habitat", "Prima", "Profuturo", "Ex_Integra"],
         ["F1", "F2", "F3", "Multifondos"]],
        names=["AFP", "Fondo"],
    ).to_frame(index=False)

    out = base.merge(combinaciones, how="cross")
    out = out[["ISIN", "Market Value (%) (P)", "Fondo", "AFP"]]
    out["SBS"] = sbs
    out["key1"] = out["SBS"] + out["Fondo"] + out["AFP"]
    log.info("[%s] plantilla: %d filas.", ruta.name, len(out))
    return out.reset_index(drop=True)


def cruzar_comparables(plantilla: pd.DataFrame, bd_etf: pd.DataFrame) -> pd.DataFrame:
    epu = plantilla.copy()
    referencia = bd_etf.set_index("key1").to_dict()
    for columna in ["Weight", "assetclass", "Strategy", "AUM", "Tipo",
                    "Precio", "Q", "Nombre", "Fecha", "codEmisor"]:
        epu[columna] = epu["key1"].map(referencia[columna])

    epu = epu.dropna(subset=["Weight"])
    epu["peso"] = epu["Market Value (%) (P)"] * epu["Weight"]
    epu = epu.drop(columns=["Market Value (%) (P)", "key1", "Weight"])
    return epu.rename(columns={"peso": "Weight"})


