###############################################################################
#                                                                             #
#   MÓDULO 4 — G&P DETALLADO LOADER                                           #
#   Lee G&P_MLab_MMYYYY.xlsm hoja 'Detallado' en read_only, SOLO cols B/D/F/Q. #
#   Archivo ~120MB, hoja muy ancha: se acota la ventana B:Q para no cargar todo.#
#   Mapeo (R3, MATCH por SBS = Detallado!B):                                   #
#     SBS (llave) <- B | NOMBRE <- D | ASSET_CLASS <- F | RANK_RT <- Q         #
#   Alimenta al Módulo 5 (Parametria): D<-F, E<-Q, H<-D.                        #
#                                                                             #
###############################################################################

GYP_SHEET_DETALLADO = "Detallado"

# Letras de columna en 'Detallado' (referencia; sobrescribibles si cambian).
GYP_COL_SBS = "B"          # llave del MATCH (SBS)
GYP_COL_NOMBRE = "D"       # -> Parametria H (Nombre)
GYP_COL_ASSET_CLASS = "F"  # -> Parametria D (Asset Class)
GYP_COL_RANK_RT = "Q"      # -> Parametria E (Rank Rt)

GYP_HEADER_ROWS = 1        # nº de filas de encabezado a saltar en Detallado


def _col_letter_to_idx(letter: str) -> int:
    """Convierte letra de columna Excel a índice 1-based ('A'->1, 'B'->2, ...)."""
    letter = str(letter).strip().upper()
    idx = 0
    for ch in letter:
        if not ("A" <= ch <= "Z"):
            raise ValueError(f"Letra de columna inválida: {letter!r}")
        idx = idx * 26 + (ord(ch) - ord("A") + 1)
    return idx


class GyPDetalladoLoader:
    """Extrae de G&P_MLab (hoja Detallado) las 4 columnas que consume Parametria.

    Devuelve un DataFrame con: SBS (str, llave), NOMBRE, ASSET_CLASS, RANK_RT.
    Deduplicado por SBS (keep='first') para replicar la semántica de MATCH.
    """

    def __init__(self, config: Config, verbose: bool = True,
                 col_sbs: str = GYP_COL_SBS,
                 col_nombre: str = GYP_COL_NOMBRE,
                 col_asset_class: str = GYP_COL_ASSET_CLASS,
                 col_rank_rt: str = GYP_COL_RANK_RT,
                 header_rows: int = GYP_HEADER_ROWS):
        self.config = config
        self.verbose = verbose
        self.path = getattr(config, "path_gyp", None)
        # Índices 1-based de las columnas requeridas.
        self._cols = {
            "SBS": _col_letter_to_idx(col_sbs),
            "NOMBRE": _col_letter_to_idx(col_nombre),
            "ASSET_CLASS": _col_letter_to_idx(col_asset_class),
            "RANK_RT": _col_letter_to_idx(col_rank_rt),
        }
        self.header_rows = header_rows
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        self._guard_file()

        import openpyxl

        # Ventana de lectura: del mínimo al máximo índice requerido (B..Q).
        min_col = min(self._cols.values())
        max_col = max(self._cols.values())
        # Offset dentro de la tupla acotada (0-based).
        offsets = {name: (idx - min_col) for name, idx in self._cols.items()}

        if self.verbose:
            print(f"  [Módulo 4] Abriendo G&P (read_only), acotado a columnas "
                  f"{min_col}..{max_col}. Esto puede tardar por el tamaño (~120MB)...")

        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            real_sheet = self._resolve_sheet(wb.sheetnames, GYP_SHEET_DETALLADO)
            if real_sheet is None:
                wb.close()
                raise ValueError(
                    f"G&P: no existe la hoja '{GYP_SHEET_DETALLADO}'. "
                    f"Hojas disponibles: {wb.sheetnames}"
                )
            ws = wb[real_sheet]

            registros = []
            header_preview = None
            for i, row in enumerate(
                ws.iter_rows(min_col=min_col, max_col=max_col, values_only=True)
            ):
                if i < self.header_rows:
                    if i == self.header_rows - 1:
                        header_preview = {
                            name: (row[off] if off < len(row) else None)
                            for name, off in offsets.items()
                        }
                    continue
                sbs = row[offsets["SBS"]] if offsets["SBS"] < len(row) else None
                sbs = _to_string(sbs)
                if sbs in (None, ""):
                    continue  # sin llave -> fila basura
                registros.append({
                    "SBS": sbs,
                    "NOMBRE": row[offsets["NOMBRE"]] if offsets["NOMBRE"] < len(row) else None,
                    "ASSET_CLASS": row[offsets["ASSET_CLASS"]] if offsets["ASSET_CLASS"] < len(row) else None,
                    "RANK_RT": row[offsets["RANK_RT"]] if offsets["RANK_RT"] < len(row) else None,
                })
        finally:
            wb.close()

        if self.verbose and header_preview is not None:
            print(f"  [Módulo 4] Encabezado detectado en fila {self.header_rows} "
                  f"(verifica que B/D/F/Q alineen): {header_preview}")

        df = pd.DataFrame(registros, columns=["SBS", "NOMBRE", "ASSET_CLASS", "RANK_RT"])
        antes = len(df)
        df = df.drop_duplicates("SBS", keep="first").reset_index(drop=True)
        if self.verbose:
            dups = antes - len(df)
            print(f"  [Módulo 4] Detallado -> {len(df)} SBS únicos"
                  + (f" ({dups} duplicados descartados, se tomó el primero)" if dups else "")
                  + ".")
        self.df = df
        return df

    def as_lookup(self) -> Dict[str, dict]:
        """Dict SBS -> {NOMBRE, ASSET_CLASS, RANK_RT} para el Módulo 5."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_lookup().")
        return self.df.set_index("SBS").to_dict("index")

    # ---- Blindaje / helpers ------------------------------------------------
    def _guard_file(self) -> None:
        mmyyyy = getattr(self.config, "mmyyyy", "MMYYYY")
        if not self.path:
            raise ValueError("Config no define path_gyp.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(
                f"No encuentro el G&P del semestre. Es tu tarea manual: deposita\n"
                f"  'G&P_MLab_{mmyyyy}.xlsm'\n"
                f"en la ruta:\n  {self.path}"
            )

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None












###############################################################################
#                                                                             #
#   MÓDULO 5 — PARAMETRIA BUILDER                                             #
#   Replica las fórmulas de la hoja Parametria a partir del G&P (Módulo 4).    #
#   Llave: SBS (col C). MATCH contra Detallado!B (ya resuelto en Módulo 4).    #
#                                                                             #
#   Mapeo exacto (R3):                                                         #
#     H (Nombre)      <- Detallado!D   (NOMBRE)                                #
#     D (Asset Class) <- Detallado!F   (ASSET_CLASS)                           #
#     E (Rank Rt)     <- Detallado!Q   (RANK_RT)                              #
#     G (Codigo)      = LEFT(C,2) & E                                          #
#     J (RANKEST)     = IF(E="ALT", LEFT(E,3), LEFT(E,3) & F)                  #
#     F (Riesgos)     = valor manual/lista (NO viene de Detallado)             #
#                                                                             #
#   Alimenta Valorización: G(<-H), AM(<-G), AN(<-F), AO(<-J).                  #
#                                                                             #
###############################################################################

class ParametriaBuilder:
    """Construye el DataFrame Parametria (llave SBS) desde el lookup de G&P.

    Nota sobre F (Riesgos): en el Excel es un valor manual/lista que NO proviene
    de Detallado, pero J (RANKEST) lo usa en su rama else. Se acepta un
    'riesgos_map' opcional {SBS -> valor}; si no se provee, F queda vacío y J
    concatena LEFT(E,3) con cadena vacía (documentado abajo).
    """

    def __init__(self, gyp_lookup: Dict[str, dict],
                 sbs_list: Optional[List[str]] = None,
                 riesgos_map: Optional[Dict[str, str]] = None,
                 verbose: bool = True):
        """
        gyp_lookup : dict SBS -> {NOMBRE, ASSET_CLASS, RANK_RT}  (Módulo 4.as_lookup())
        sbs_list   : universo de SBS a materializar. Si None, usa las llaves del
                     lookup. (Puedes pasar los CODIGO_SBS de Valorización para
                     construir solo lo necesario.)
        riesgos_map: opcional, SBS -> Riesgos (col F). Manual/lista.
        """
        self.gyp = gyp_lookup
        self.sbs_list = sbs_list
        self.riesgos_map = riesgos_map or {}
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        sbs_universe = (
            [_to_string(s) for s in self.sbs_list]
            if self.sbs_list is not None
            else list(self.gyp.keys())
        )
        # Únicos, preservando orden.
        seen = set()
        sbs_universe = [s for s in sbs_universe
                        if s not in (None, "") and not (s in seen or seen.add(s))]

        registros = []
        no_encontrados = []
        for sbs in sbs_universe:
            info = self.gyp.get(sbs)
            if info is None:
                no_encontrados.append(sbs)
                nombre = asset_class = rank_rt = None
            else:
                nombre = info.get("NOMBRE")
                asset_class = info.get("ASSET_CLASS")
                rank_rt = info.get("RANK_RT")

            e = _to_string(rank_rt)          # E (Rank Rt)
            f = self.riesgos_map.get(sbs)    # F (Riesgos), manual
            g = self._codigo(sbs, e)         # G = LEFT(C,2)&E
            j = self._rankest(e, f)          # J = IF(E="ALT",LEFT(E,3),LEFT(E,3)&F)

            registros.append({
                "SBS": sbs,          # C (llave)
                "ASSET_CLASS": asset_class,  # D
                "RANK_RT": e,        # E
                "RIESGOS": f,        # F
                "CODIGO": g,         # G  -> Valorización.AM
                "NOMBRE": nombre,    # H  -> Valorización.G
                "RANKEST": j,        # J  -> Valorización.AO
            })

        df = pd.DataFrame(
            registros,
            columns=["SBS", "ASSET_CLASS", "RANK_RT", "RIESGOS",
                     "CODIGO", "NOMBRE", "RANKEST"],
        )
        self.df = df

        if self.verbose:
            print(f"  [Módulo 5] Parametria -> {len(df)} filas (SBS).")
            if no_encontrados:
                muestra = no_encontrados[:10]
                print(f"  [AVISO] {len(no_encontrados)} SBS sin match en G&P "
                      f"(Nombre/Asset/Rank quedan vacíos). Ejemplos: {muestra}")
        return df

    # ---- Fórmulas Parametria ----------------------------------------------
    @staticmethod
    def _codigo(sbs: Optional[str], e: Optional[str]) -> Optional[str]:
        """G = LEFT(C,2) & E."""
        c = _to_string(sbs) or ""
        e = e or ""
        left2 = c[:2]
        if not left2 and not e:
            return None
        return f"{left2}{e}"

    @staticmethod
    def _rankest(e: Optional[str], f: Optional[str]) -> Optional[str]:
        """J = IF(E="ALT", LEFT(E,3), LEFT(E,3) & F).

        Si E está vacío -> None. Si F (Riesgos) no fue provisto, la rama else
        concatena LEFT(E,3) con cadena vacía (equivale a J = LEFT(E,3)).
        """
        e = _to_string(e)
        if e in (None, ""):
            return None
        left3 = e[:3]
        if e.upper() == "ALT":
            return left3
        f = _to_string(f) or ""
        return f"{left3}{f}"

    def as_lookup(self) -> Dict[str, dict]:
        """Dict SBS -> {CODIGO, NOMBRE, RIESGOS, RANKEST, ...} para Módulo 10.

        Valorización usará: G<-NOMBRE, AM<-CODIGO, AN<-RIESGOS, AO<-RANKEST.
        """
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_lookup().")
        return self.df.set_index("SBS").to_dict("index")















###############################################################################
#                                                                             #
#   MÓDULO 6 — BD(MSCI) BUILDER                                              #
#   Construye BD(MSCI) desde Base MSCI (Sob+ETF+BU).xlsx, hoja del periodo.    #
#   Estructura destino (spec):                                                #
#     A(deriv) | B..V = fuente A..U (Nombre..CAT) | W Plus | X Plus_1          #
#   Derivaciones:                                                             #
#     A      = RIGHT(LEFT(client1,6),4)          [client1 = fuente col C]      #
#     W(Plus)= IF(CAT="ETF_ETY","ETF", IF(CAT="ETF_SOV","ETF",                 #
#                IF(CAT="RF_SOV","SOV", IF(CAT="-","Cuestionario Integra",     #
#                "Portafolio"))))                                             #
#     X(Plus_1)= IF(CAT="ETF_ETY","Otros ETFs", IF(CAT="ETF_SOV","Soberanos", #
#                  W))                                                        #
#   Llave: Client_ID (ISIN). Col sobrescrita luego por proxies: Intensidad.   #
#   REUTILIZABLE por Módulo 7 (T-1): mismo builder, sheet distinta.           #
#                                                                             #
###############################################################################

# Orden EXACTO de las 21 columnas de la fuente Base MSCI (A:U), headers FILA 1.
BASE_MSCI_SOURCE_COLS: List[str] = [
    "Nombre", "Client_ID", "client1", "client2", "Valor", "País", "Sector",
    "EVIC", "CO2", "CO2/EVIC", "ESG", "E", "S", "G", "Controversia",
    "Co2/Sales", "Gov_pctl", "Rating", "CO2/Debt(Intensidad)", "%DebtPub", "CAT",
]

# Alias para VALIDAR por nombre que la fuente no cambió de orden (solo aviso).
BASE_MSCI_ALIASES: Dict[str, List[str]] = {
    "Nombre": ["nombre"], "Client_ID": ["client_id", "clientid", "isin"],
    "client1": ["client1", "cliente1"], "client2": ["client2", "cliente2"],
    "Valor": ["valor"], "País": ["pais", "país", "country"], "Sector": ["sector"],
    "EVIC": ["evic"], "CO2": ["co2"], "CO2/EVIC": ["co2evic", "co2/evic"],
    "ESG": ["esg"], "E": ["e"], "S": ["s"], "G": ["g"],
    "Controversia": ["controversia"], "Co2/Sales": ["co2sales", "co2/sales"],
    "Gov_pctl": ["govpctl", "gov_pctl"], "Rating": ["rating"],
    "CO2/Debt(Intensidad)": ["co2debtintensidad", "co2/debt", "intensidad"],
    "%DebtPub": ["debtpub", "%debtpub"], "CAT": ["cat"],
}

# Nombre de la col A derivada (sin nombre en Excel) y de la col de intensidad.
BD_COL_A = "A_MSCI"
BD_COL_INTENSIDAD = "CO2/Debt(Intensidad)"
BD_COL_CLIENT_ID = "Client_ID"
BD_COL_CLIENT1 = "client1"
BD_COL_CAT = "CAT"
BD_COL_PLUS = "Plus"
BD_COL_PLUS_1 = "Plus_1"

# Orden final de columnas de BD(MSCI): A(deriv) + fuente + W/X.
BD_MSCI_COLS: List[str] = [BD_COL_A] + BASE_MSCI_SOURCE_COLS + [BD_COL_PLUS, BD_COL_PLUS_1]

# Coerción mínima en BD (el resto se deja como lo entregó openpyxl).
BD_STRING_COLS = {BD_COL_A, BD_COL_CLIENT_ID, BD_COL_CLIENT1, "client2",
                  "Nombre", "País", "Sector", "Rating", BD_COL_CAT,
                  BD_COL_PLUS, BD_COL_PLUS_1}
BD_NUMERIC_COLS = {"Valor", BD_COL_INTENSIDAD}


class BDMSCIBuilder:
    """Construye el DataFrame BD(MSCI) desde una hoja de Base MSCI.

    Reutilizable: pásale la hoja del periodo (Módulo 6) o la de T-1 (Módulo 7).
    Resuelve por POSICIÓN (A:U, orden fijo del export MSCI) pero VALIDA por
    nombre y avisa fuerte si detecta un reordenamiento entre semestres.
    """

    def __init__(self, config: Config, sheet: Optional[str] = None,
                 verbose: bool = True):
        self.config = config
        self.path = getattr(config, "path_base_msci", None)
        self.sheet = sheet if sheet is not None else getattr(config, "base_msci_sheet", None)
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        self._guard_file()

        import openpyxl

        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            real_sheet = self._resolve_sheet(wb.sheetnames, self.sheet)
            if real_sheet is None:
                wb.close()
                raise ValueError(
                    f"Base MSCI: no existe la hoja '{self.sheet}' (match exacto, R11). "
                    f"Hojas disponibles: {wb.sheetnames}"
                )
            ws = wb[real_sheet]
            rows = list(ws.iter_rows(values_only=True))
        finally:
            wb.close()

        if not rows:
            raise ValueError(f"Base MSCI hoja '{self.sheet}' está vacía.")

        header = list(rows[0])
        data_rows = rows[1:]

        n_src = len(BASE_MSCI_SOURCE_COLS)  # 21
        if len(header) < n_src:
            raise ValueError(
                f"Base MSCI hoja '{self.sheet}': tiene {len(header)} columnas, "
                f"se esperaban al menos {n_src} (A:U). ¿Hoja correcta?"
            )

        self._validate_header_order(header)

        # Construir registros: fuente A:U por posición + derivadas.
        registros = []
        idx_client1 = BASE_MSCI_SOURCE_COLS.index("client1")   # 2
        idx_cat = BASE_MSCI_SOURCE_COLS.index("CAT")           # 20
        for row in data_rows:
            src = [row[i] if i < len(row) else None for i in range(n_src)]
            client_id = _to_string(src[BASE_MSCI_SOURCE_COLS.index("Client_ID")])
            if client_id in (None, ""):
                continue  # sin ISIN -> fila basura
            cat = src[idx_cat]
            reg = {BD_COL_A: self._deriv_a(src[idx_client1])}
            for name, val in zip(BASE_MSCI_SOURCE_COLS, src):
                reg[name] = val
            reg[BD_COL_PLUS] = self._plus(cat)
            reg[BD_COL_PLUS_1] = self._plus1(cat, reg[BD_COL_PLUS])
            registros.append(reg)

        df = pd.DataFrame(registros, columns=BD_MSCI_COLS)

        # Coerción mínima.
        for col in df.columns:
            if col in BD_STRING_COLS:
                df[col] = df[col].map(_to_string)
            elif col in BD_NUMERIC_COLS:
                df[col] = df[col].map(_to_number)

        # Aviso si hay Client_ID duplicados (afecta el MATCH de Valorización).
        if self.verbose:
            dup = df[BD_COL_CLIENT_ID].duplicated().sum()
            if dup:
                print(f"  [AVISO] BD(MSCI) hoja '{self.sheet}': {dup} Client_ID "
                      f"duplicados (el MATCH tomará el primero).")

        self.df = df
        if self.verbose:
            print(f"  [Módulo 6] BD(MSCI) hoja '{self.sheet}' -> {df.shape[0]} filas "
                  f"x {df.shape[1]} cols.")
        return df

    # ---- Derivaciones (fórmulas col A / W / X) -----------------------------
    @staticmethod
    def _deriv_a(client1) -> Optional[str]:
        """A = RIGHT(LEFT(client1,6),4)."""
        s = _to_string(client1)
        if s in (None, ""):
            return None
        return s[:6][-4:]  # LEFT 6, luego RIGHT 4

    @staticmethod
    def _plus(cat) -> str:
        c = (_to_string(cat) or "").upper()
        if c in ("ETF_ETY", "ETF_SOV"):
            return "ETF"
        if c == "RF_SOV":
            return "SOV"
        if c == "-":
            return "Cuestionario Integra"
        return "Portafolio"

    @staticmethod
    def _plus1(cat, w: str) -> str:
        c = (_to_string(cat) or "").upper()
        if c == "ETF_ETY":
            return "Otros ETFs"
        if c == "ETF_SOV":
            return "Soberanos"
        return w

    # ---- Lookups para consumidores (Valorización / T-1) --------------------
    def as_intensidad_lookup(self) -> Dict[str, float]:
        """Client_ID -> CO2/Debt(Intensidad). Base para Valorización.AJ y para
        que los proxies sobrescriban por Client_ID (Módulo 9)."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_intensidad_lookup().")
        tmp = self.df[[BD_COL_CLIENT_ID, BD_COL_INTENSIDAD]].dropna(
            subset=[BD_COL_CLIENT_ID]).drop_duplicates(BD_COL_CLIENT_ID, keep="first")
        return dict(zip(tmp[BD_COL_CLIENT_ID], tmp[BD_COL_INTENSIDAD]))

    def as_plus_lookup(self) -> Dict[str, dict]:
        """Client_ID -> {Plus, Plus_1}. Para Valorización.AQ/AR."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_plus_lookup().")
        tmp = self.df[[BD_COL_CLIENT_ID, BD_COL_PLUS, BD_COL_PLUS_1]].dropna(
            subset=[BD_COL_CLIENT_ID]).drop_duplicates(BD_COL_CLIENT_ID, keep="first")
        return tmp.set_index(BD_COL_CLIENT_ID).to_dict("index")

    # ---- Blindaje / validación --------------------------------------------
    def _validate_header_order(self, header: List) -> None:
        """Compara los headers detectados vs el orden esperado A:U y avisa."""
        if not self.verbose:
            return
        problemas = []
        for pos, canon in enumerate(BASE_MSCI_SOURCE_COLS):
            detectado = _normalize(header[pos]) if pos < len(header) else ""
            aliases = {_normalize(canon)} | {_normalize(a) for a in BASE_MSCI_ALIASES.get(canon, [])}
            ok = any(a and (a == detectado or a in detectado or detectado in a) for a in aliases)
            if not ok:
                problemas.append(f"pos {pos} (col {chr(65+pos) if pos < 26 else '?'}): "
                                 f"esperaba '{canon}', encontré '{header[pos]}'")
        if problemas:
            print("  [AVISO] BD(MSCI): el orden de columnas de Base MSCI podría haber "
                  "cambiado. Revisa (construyo por posición A:U):")
            for p in problemas:
                print(f"          - {p}")

    def _guard_file(self) -> None:
        if not self.path:
            raise ValueError("Config no define path_base_msci.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(
                f"No encuentro Base MSCI (Sob+ETF+BU).xlsx en:\n  {self.path}"
            )

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        # R11: match EXACTO de hoja (yyyymm). Sin fuzzy para no tomar un semestre erróneo.
        return wanted if wanted in available else None


























###############################################################################
#                                                                             #
#   MÓDULO 7 — BD MSCI (T-1)                                                  #
#   Reutiliza BDMSCIBuilder sobre la hoja del semestre ANTERIOR (base_msci_    #
#   sheet_t1, p.ej. 202512). Lo único que consume Valorización.AS es la        #
#   intensidad por Client_ID, así que se expone ese lookup.                    #
#     AS (CO2 T-1) = IFERROR(INDEX('BD MSCI (T-1)'!T, MATCH(CODIGO_ISIN...)),  #
#                            MATCH(CODIGO_SBS...))                             #
#   NOTA: los proxies NO se aplican al T-1 (es la foto histórica cerrada).     #
#                                                                             #
###############################################################################

class BDMSCITMinus1:
    """BD(MSCI) del semestre anterior. Fina capa sobre BDMSCIBuilder.

    Devuelve el DataFrame completo (por si se quiere exportar/auditar) pero su
    salida principal es as_intensidad_lookup(): Client_ID -> Intensidad T-1,
    que alimenta Valorización.AS. No se le aplican proxies.
    """

    def __init__(self, config: Config, verbose: bool = True):
        self.config = config
        self.sheet_t1 = getattr(config, "base_msci_sheet_t1", None)
        self.verbose = verbose
        self._builder: Optional[BDMSCIBuilder] = None
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        if self.verbose:
            print(f"  [Módulo 7] BD MSCI (T-1): usando hoja '{self.sheet_t1}' "
                  f"(semestre anterior).")
        # Reutiliza el Módulo 6 apuntando a la hoja T-1.
        self._builder = BDMSCIBuilder(self.config, sheet=self.sheet_t1,
                                      verbose=self.verbose)
        self.df = self._builder.build()
        return self.df

    def as_intensidad_lookup(self) -> Dict[str, float]:
        """Client_ID -> CO2/Debt(Intensidad) del T-1. Alimenta Valorización.AS."""
        if self._builder is None:
            raise RuntimeError("Llama build() antes de as_intensidad_lookup().")
        return self._builder.as_intensidad_lookup()















