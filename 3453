#                                                                             #
#   MÓDULO 12 — PRESENTACIÓN (pivots del comité + Market Cap AUM)             #
#                                                                             #
#   (A) MarketCapLoader: lee Market Cap.xlsx (hojas MKT=CUR_MKT_CAP y          #
#       Assets=FUND_TOTAL_ASSETS). Headers de tickers en FILA 2; col A FECHA = #
#       EOMONTH(B,-1)+1 pero se usa col B como FECHA EFECTIVA. R10: tomar la    #
#       fila de CIERRE del semestre (30-jun / 31-dic) por col B.               #
#       Tickers benchmark: IEMG/CEMB/ILF/ACWI/EEM/EMB/SWDA US Equity.          #
#                                                                             #
#   (B) PresentacionBuilder: cortes sobre Valorización para los charts (R9):    #
#       - Serie temporal Huella/Intensidad (métricas y metas)                 #
#       - Por SECTOR y por PAÍS (portafolio local)  [COLUMN_STACKED]          #
#       - Benchmark por PAÍS (usa AUM de Market Cap)                          #
#       - Rating ASG (LEADER/AVERAGE/LAGGARD/No coberturado) + cobertura IN/EX  #
#       - Menores contribuyentes al rating por emisor [COLUMN_CLUSTERED]       #
#       - Controversias e Inversión Temática [PIE]                            #
#                                                                             #
###############################################################################

MKT_SHEET_CAP = "MKT"        # CUR_MKT_CAP
MKT_SHEET_ASSETS = "Assets"  # FUND_TOTAL_ASSETS
MKT_HEADER_ROW = 2           # tickers en fila 2
MKT_DATE_COL_EFECTIVA = "B"  # fecha efectiva (col B)

# Benchmarks de interés (se resuelven por contains sobre el header del ticker).
BENCHMARK_TICKERS = ["IEMG", "CEMB", "ILF", "ACWI", "EEM", "EMB", "SWDA"]


class MarketCapLoader:
    """Extrae el AUM (market cap / total assets) de benchmarks en la fila de
    cierre del semestre. Devuelve {ticker -> valor} para MKT y para Assets."""

    def __init__(self, config: Config, verbose: bool = True):
        self.config = config
        self.path = getattr(config, "path_market_cap", None)
        self.semestre = getattr(config, "semestre", None)
        self.b1 = getattr(config, "b1_yyyymmdd", None)   # yyyymmdd del cierre
        self.verbose = verbose
        self.mkt_cap: Dict[str, float] = {}
        self.assets: Dict[str, float] = {}

    def build(self) -> "MarketCapLoader":
        self._guard_file()
        import openpyxl
        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            s_cap = self._resolve_sheet(wb.sheetnames, MKT_SHEET_CAP)
            s_ast = self._resolve_sheet(wb.sheetnames, MKT_SHEET_ASSETS)
            if s_cap is not None:
                self.mkt_cap = self._read_sheet_closing_row(wb[s_cap], "MKT")
            elif self.verbose:
                print(f"  [Módulo 12] [AVISO] No hay hoja '{MKT_SHEET_CAP}'.")
            if s_ast is not None:
                self.assets = self._read_sheet_closing_row(wb[s_ast], "Assets")
            elif self.verbose:
                print(f"  [Módulo 12] [AVISO] No hay hoja '{MKT_SHEET_ASSETS}'.")
        finally:
            wb.close()
        if self.verbose:
            print(f"  [Módulo 12] Market Cap: {len(self.mkt_cap)} tickers MKT, "
                  f"{len(self.assets)} tickers Assets (fila cierre {self.b1}).")
        return self

    def _read_sheet_closing_row(self, ws, tag: str) -> Dict[str, float]:
        """Ubica la fila cuyo col B == cierre del semestre y extrae los tickers."""
        rows = list(ws.iter_rows(values_only=True))
        if len(rows) <= MKT_HEADER_ROW:
            return {}
        header = list(rows[MKT_HEADER_ROW - 1])
        data_rows = rows[MKT_HEADER_ROW:]

        # Fecha objetivo (cierre del semestre) desde b1_yyyymmdd.
        target = None
        if self.b1 and len(self.b1) == 8:
            target = date(int(self.b1[:4]), int(self.b1[4:6]), int(self.b1[6:8]))

        # Mapear tickers de interés -> índice de columna (por contains).
        col_of = {}
        for i, h in enumerate(header):
            hn = _normalize(h)
            for tk in BENCHMARK_TICKERS:
                if _normalize(tk) in hn and tk not in col_of:
                    col_of[tk] = i
        idx_b = _col_letter_to_idx(MKT_DATE_COL_EFECTIVA) - 1  # col B efectiva (0-based)

        # Buscar la fila de cierre; si no hay match exacto, usar la última con datos.
        chosen = None
        last_valid = None
        for row in data_rows:
            fecha = _to_date(row[idx_b]) if idx_b < len(row) else None
            if fecha is not None:
                last_valid = row
                if target is not None and isinstance(fecha, date) and fecha == target:
                    chosen = row
                    break
        if chosen is None:
            if self.verbose:
                print(f"  [Módulo 12] [AVISO] {tag}: no encontré fila con fecha "
                      f"{target}; uso la última fila con fecha válida.")
            chosen = last_valid
        if chosen is None:
            return {}

        out = {}
        for tk, i in col_of.items():
            val = _to_number(chosen[i]) if i < len(chosen) else None
            if val is not None:
                out[tk] = val
        return out

    def get_aum(self, ticker: str, source: str = "MKT") -> Optional[float]:
        d = self.mkt_cap if source.upper() == "MKT" else self.assets
        return d.get(ticker.upper())

    def _guard_file(self) -> None:
        if not self.path:
            raise ValueError("Config no define path_market_cap.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(f"No encuentro Market Cap.xlsx en:\n  {self.path}")

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None


class PresentacionBuilder:
    """Cortes sobre Valorización para los gráficos del comité (R9).

    Cada método devuelve un DataFrame listo para el dashboard (Módulo 14).
    Los buckets de sector/país/rating se parametrizan para poder ajustarlos
    sin tocar la lógica.
    """

    # Buckets del spec (case-insensitive; el resto cae en 'Otros'/'No coberturado').
    SECTOR_BUCKETS = ["Materials", "Utilities", "RF", "RF Proxies"]
    PAIS_LOCAL_BUCKETS = ["Perú", "Brasil", "México", "Chile"]
    PAIS_BENCH_BUCKETS = ["Perú", "EEUU", "Brasil", "Colombia"]
    RATING_BUCKETS = ["LEADER", "AVERAGE", "LAGGARD", "No coberturado"]

    def __init__(self, df_val: pd.DataFrame,
                 market_cap: Optional[MarketCapLoader] = None,
                 verbose: bool = True,
                 huella_col: str = V_AK, intensidad_col: str = V_AL,
                 sector_col: str = "Sector", pais_col: str = "País",
                 rating_col: str = "Rating", emisor_col: str = "GRUPO_ECONOMICO",
                 controversia_col: str = "Controversia"):
        self.df = df_val
        self.mkt = market_cap
        self.verbose = verbose
        self.huella_col = huella_col
        self.intensidad_col = intensidad_col
        self.sector_col = sector_col
        self.pais_col = pais_col
        self.rating_col = rating_col
        self.emisor_col = emisor_col
        self.controversia_col = controversia_col
        self.out: Dict[str, pd.DataFrame] = {}

    # ---- helpers de bucketing ---------------------------------------------
    @staticmethod
    def _bucket(value, buckets: List[str], default: str = "Otros") -> str:
        v = _to_string(value)
        if v is None:
            return default
        vn = _normalize(v)
        for b in buckets:
            if _normalize(b) == vn or _normalize(b) in vn:
                return b
        return default

    def _stacked_by(self, dim_col: str, buckets: List[str], default="Otros") -> pd.DataFrame:
        """Huella e Intensidad apiladas por bucket de una dimensión."""
        if dim_col not in self.df.columns:
            if self.verbose:
                print(f"  [Módulo 12] [AVISO] falta '{dim_col}'; corte omitido.")
            return pd.DataFrame(columns=["bucket", "Huella", "Intensidad"])
        df = self.df.copy()
        df["_bucket"] = df[dim_col].map(lambda x: self._bucket(x, buckets, default))
        g = df.groupby("_bucket").agg(
            Huella=(self.huella_col, lambda s: pd.to_numeric(s, errors="coerce").sum()),
            Intensidad=(self.intensidad_col, lambda s: pd.to_numeric(s, errors="coerce").sum()),
        ).reset_index().rename(columns={"_bucket": "bucket"})
        # Orden: buckets definidos primero, luego el default.
        orden = {b: i for i, b in enumerate(buckets + [default])}
        g["_o"] = g["bucket"].map(lambda b: orden.get(b, 999))
        return g.sort_values("_o").drop(columns="_o").reset_index(drop=True)

    # ---- cortes del comité -------------------------------------------------
    def portafolio_por_sector(self) -> pd.DataFrame:
        d = self._stacked_by(self.sector_col, self.SECTOR_BUCKETS)
        self.out["local_por_sector"] = d
        return d

    def portafolio_por_pais(self) -> pd.DataFrame:
        d = self._stacked_by(self.pais_col, self.PAIS_LOCAL_BUCKETS)
        self.out["local_por_pais"] = d
        return d

    def rating_asg(self, cobertura_col: Optional[str] = None) -> pd.DataFrame:
        """Huella/Intensidad por bucket de Rating + cobertura IN/EX si se indica."""
        d = self._stacked_by(self.rating_col, self.RATING_BUCKETS,
                             default="No coberturado")
        self.out["rating_asg"] = d
        return d

    def menores_contribuyentes(self, top_n: int = 10) -> pd.DataFrame:
        """Emisores con menor rating/mayor contribución negativa (clustered)."""
        if self.emisor_col not in self.df.columns:
            return pd.DataFrame(columns=["emisor", "Huella", "Intensidad"])
        df = self.df.copy()
        g = df.groupby(self.emisor_col).agg(
            Huella=(self.huella_col, lambda s: pd.to_numeric(s, errors="coerce").sum()),
            Intensidad=(self.intensidad_col, lambda s: pd.to_numeric(s, errors="coerce").sum()),
        ).reset_index().rename(columns={self.emisor_col: "emisor"})
        g = g.sort_values("Huella", ascending=False).head(top_n).reset_index(drop=True)
        self.out["menores_contribuyentes"] = g
        return g

    def controversias(self) -> pd.DataFrame:
        """Distribución para PIE de controversias."""
        if self.controversia_col not in self.df.columns:
            return pd.DataFrame(columns=["categoria", "conteo"])
        s = self.df[self.controversia_col].map(_to_string).fillna("Sin dato")
        g = s.value_counts().reset_index()
        g.columns = ["categoria", "conteo"]
        self.out["controversias"] = g
        return g

    def benchmark_por_pais(self, ticker: str = "EMB",
                           pais_pesos: Optional[Dict[str, float]] = None) -> pd.DataFrame:
        """Vista de benchmark por país escalada por su AUM (Market Cap).

        pais_pesos: composición %país del benchmark (input externo). Si None,
        solo devuelve el AUM total del ticker para que el dashboard lo use.
        """
        aum = self.mkt.get_aum(ticker) if self.mkt else None
        if aum is None and self.verbose:
            print(f"  [Módulo 12] [AVISO] Sin AUM para '{ticker}' en Market Cap.")
        if not pais_pesos:
            d = pd.DataFrame([{"ticker": ticker, "AUM": aum}])
        else:
            d = pd.DataFrame([
                {"ticker": ticker, "pais": self._bucket(p, self.PAIS_BENCH_BUCKETS),
                 "peso": w, "AUM_pais": (aum * w if aum is not None else None)}
                for p, w in pais_pesos.items()
            ])
        self.out[f"benchmark_{ticker}_por_pais"] = d
        return d

    def build_all(self) -> Dict[str, pd.DataFrame]:
        self.portafolio_por_sector()
        self.portafolio_por_pais()
        self.rating_asg()
        self.menores_contribuyentes()
        self.controversias()
        if self.mkt is not None:
            self.benchmark_por_pais()
        if self.verbose:
            print(f"  [Módulo 12] Presentación: {len(self.out)} cortes listos "
                  f"para el dashboard.")
        return self.out

    def as_dict(self) -> Dict[str, pd.DataFrame]:
        return self.out

