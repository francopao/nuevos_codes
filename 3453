#                                                                             #
#   MÓDULO 8 — PERDIERON HUELLA (INPUT MANUAL)                                #
#   Bloque tipo reporte BD(MSCI), SIN header. Orden de columnas FIJO (R7).     #
#   Vive como hoja 'Perdieron Huella' dentro del workbook (.xlsm).             #
#   Datos desde FILA 1. Se lee por POSICIÓN, no se infiere por contenido.      #
#                                                                             #
#   ORDEN FIJO DOCUMENTADO (23 columnas, igual que el bloque BD(MSCI) fuente): #
#     0 Nombre | 1 Client_ID(ISIN) | 2 client1 | 3 client2 | 4 Valor |         #
#     5 País | 6 Sector | 7 EVIC | 8 CO2 | 9 CO2/EVIC | 10 ESG | 11 E |         #
#     12 S | 13 G | 14 Controversia | 15 Co2/Sales | 16 Gov_pctl | 17 Rating | #
#     18 CO2/Debt(Intensidad) | 19 %DebtPub | 20 CAT | 21 Plus | 22 Plus_1     #
#   (ej. fila: 2051 | Cementos Pacasmayo | US15126Q2084 | ... | 2525.98)       #
#   Llaves de salida: Client_ID (ISIN) -> CO2/Debt(Intensidad).                #
#   Si la hoja/archivo no existe: DataFrame vacío + aviso (no aborta).         #
#                                                                             #
###############################################################################

SHEET_PERDIERON_HUELLA = "Perdieron Huella"

# Orden FIJO documentado (R7). NO se resuelve por nombre: input manual sin header.
PERDIERON_HUELLA_COLS: List[str] = [
    "Nombre", "Client_ID", "client1", "client2", "Valor", "País", "Sector",
    "EVIC", "CO2", "CO2/EVIC", "ESG", "E", "S", "G", "Controversia",
    "Co2/Sales", "Gov_pctl", "Rating", "CO2/Debt(Intensidad)", "%DebtPub",
    "CAT", "Plus", "Plus_1",
]
PH_COL_CLIENT_ID = "Client_ID"
PH_COL_INTENSIDAD = "CO2/Debt(Intensidad)"


class PerdieronHuellaLoader:
    """Lee la hoja 'Perdieron Huella' (input manual, sin header, orden fijo).

    Devuelve un DataFrame con las 23 columnas documentadas. Si la hoja no existe
    o está vacía, devuelve un DataFrame vacío con esas columnas y avisa: el
    pipeline debe poder correr sin este input (es opcional/manual).
    """

    def __init__(self, config: Config, verbose: bool = True,
                 sheet: str = SHEET_PERDIERON_HUELLA,
                 first_data_row: int = 1):
        self.config = config
        self.path = getattr(config, "path_workbook", None)
        self.sheet = sheet
        self.first_data_row = first_data_row  # datos desde fila 1 (sin header)
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        empty = pd.DataFrame(columns=PERDIERON_HUELLA_COLS)

        if not self.path or not os.path.exists(self.path):
            if self.verbose:
                print(f"  [Módulo 8] [AVISO] Workbook ausente; 'Perdieron Huella' "
                      f"se omite (DataFrame vacío).")
            self.df = empty
            return self.df

        import openpyxl

        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            real_sheet = self._resolve_sheet(wb.sheetnames, self.sheet)
            if real_sheet is None:
                wb.close()
                if self.verbose:
                    print(f"  [Módulo 8] [AVISO] No existe la hoja "
                          f"'{self.sheet}'. Si tienes instrumentos que perdieron "
                          f"huella, créala con el orden fijo documentado. "
                          f"Continúo con DataFrame vacío.")
                self.df = empty
                return self.df
            ws = wb[real_sheet]
            rows = list(ws.iter_rows(values_only=True))
        finally:
            wb.close()

        data_rows = rows[self.first_data_row - 1:]
        n = len(PERDIERON_HUELLA_COLS)
        registros = []
        for row in data_rows:
            # Recorta/rellena a las 23 posiciones fijas.
            vals = [row[i] if i < len(row) else None for i in range(n)]
            client_id = _to_string(vals[PERDIERON_HUELLA_COLS.index(PH_COL_CLIENT_ID)])
            if client_id in (None, ""):
                continue  # sin ISIN -> fila vacía/basura
            registros.append(dict(zip(PERDIERON_HUELLA_COLS, vals)))

        df = pd.DataFrame(registros, columns=PERDIERON_HUELLA_COLS)
        if not df.empty:
            df[PH_COL_CLIENT_ID] = df[PH_COL_CLIENT_ID].map(_to_string)
            df[PH_COL_INTENSIDAD] = df[PH_COL_INTENSIDAD].map(_to_number)

        self.df = df
        if self.verbose:
            print(f"  [Módulo 8] 'Perdieron Huella' -> {len(df)} instrumentos "
                  f"(input manual, orden fijo).")
        return df

    def as_intensidad_lookup(self) -> Dict[str, float]:
        """Client_ID -> CO2/Debt(Intensidad). Vacío si no hay input."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_intensidad_lookup().")
        if self.df.empty:
            return {}
        tmp = self.df[[PH_COL_CLIENT_ID, PH_COL_INTENSIDAD]].dropna(
            subset=[PH_COL_CLIENT_ID]).drop_duplicates(PH_COL_CLIENT_ID, keep="first")
        return dict(zip(tmp[PH_COL_CLIENT_ID], tmp[PH_COL_INTENSIDAD]))

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None

















###############################################################################
#                                                                             #
#   MÓDULO 9 — PROXY ENGINE (proxies + herencia por emisor)                   #
#   Archivo: Nueva Lista Proxies (corte MMYYYY).xlsx                          #
#                                                                             #
#   (A) Hojas TD / Alts / BU: bloque "Formato Reporte huella", headers FILA 3, #
#       POSICIÓN NO FIJA -> se matchea por NOMBRE de header.                   #
#       De cada fila se toma: Client_ID (ISIN) y CO2/Debt(Intensidad).         #
#   (B) Hoja MSCI (headers FILA 1): tabla de referencia ETF-ISIN -> intensidad.#
#       XLOOKUP (R6): si la intensidad de una fila TD/Alts/BU viene vacía y hay #
#       una col de ETF-proxy, se resuelve contra MSCI por ISIN del ETF.        #
#       En CAMINO 3 el XLOOKUP ya está materializado en CO2/Debt, así que esto #
#       es fallback; la tabla MSCI se carga igual para auditoría.             #
#   (C) Sobrescritura: reemplaza BD(MSCI).T (Intensidad) por Client_ID.        #
#   (D) Herencia por emisor (R4, capa Valorización): instrumento sin huella    #
#       cuyo GRUPO_ECONOMICO ya tiene huella en otro ISIN -> hereda. Registra  #
#       histórico exportable.                                                  #
#                                                                             #
###############################################################################

PROXY_SHEETS_TDALTS = ["TD", "Alts"]   # headers fila 3
PROXY_SHEET_BU = "BU"                  # headers fila 3
PROXY_SHEET_MSCI = "MSCI"              # headers fila 1 (tabla ETF de referencia)
PROXY_HEADER_ROW = 3
PROXY_MSCI_HEADER_ROW = 1

# Schema mínimo para las hojas TD/Alts/BU (match por nombre; posición no fija).
PROXY_SCHEMA: Dict[str, List[str]] = {
    "Client_ID":              ["client_id", "clientid", "isin"],
    "CO2/Debt(Intensidad)":   ["co2/debt(intensidad)", "co2debtintensidad",
                               "co2/debt", "co2debt", "intensidad"],
    "Nombre":                 ["nombre"],  # solo para el histórico de herencia
}

# Schema para la hoja MSCI de referencia (ETF-ISIN -> intensidad).
PROXY_MSCI_SCHEMA: Dict[str, List[str]] = {
    "ISIN":         ["client_id", "isin", "clientid"],
    "Intensidad":   ["co2/debt(intensidad)", "co2debtintensidad", "co2/debt",
                     "intensidad"],
}


class ProxyEngine:
    """Aplica la metodología de proxies y la herencia por emisor.

    Uso:
        px = ProxyEngine(cfg).load()
        intensidad_post = px.apply_to_bd(bd.as_intensidad_lookup())
        # más tarde, en Módulo 10 (sobre Valorización):
        serie_aj, hist = px.apply_inheritance(df_val, intensidad_col="CO2-H")
    """

    def __init__(self, config: Config, verbose: bool = True,
                 etf_ref_col: Optional[str] = None):
        """
        etf_ref_col : nombre (canónico o alias) de la columna en TD/Alts/BU que
                      contiene el ISIN del ETF-proxy para el XLOOKUP contra MSCI.
                      Si None, se usa solo la intensidad ya materializada.
        """
        self.config = config
        self.path = getattr(config, "path_proxies", None)
        self.verbose = verbose
        self.etf_ref_col = etf_ref_col
        self.proxy_overrides: Dict[str, float] = {}   # Client_ID -> intensidad
        self.msci_ref: Dict[str, float] = {}          # ETF-ISIN -> intensidad
        self.df_inherited: Optional[pd.DataFrame] = None
        self._nombre_by_isin: Dict[str, str] = {}

    # ======================================================================
    # (A)+(B) Carga del archivo de proxies
    # ======================================================================
    def load(self) -> "ProxyEngine":
        self._guard_file()
        import openpyxl

        if self.etf_ref_col:
            PROXY_SCHEMA["_ETF_REF"] = [self.etf_ref_col]

        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            # (B) tabla MSCI de referencia (para XLOOKUP fallback / auditoría).
            msci_sheet = self._resolve_sheet(wb.sheetnames, PROXY_SHEET_MSCI)
            if msci_sheet is not None:
                self.msci_ref = self._read_msci_ref(wb[msci_sheet])
                if self.verbose:
                    print(f"  [Módulo 9] Hoja MSCI (referencia ETF): "
                          f"{len(self.msci_ref)} ISIN.")
            elif self.verbose:
                print("  [Módulo 9] [AVISO] No hay hoja 'MSCI' en el archivo de "
                      "proxies; XLOOKUP fallback deshabilitado.")

            # (A) hojas TD / Alts / BU.
            overrides: Dict[str, float] = {}
            xlookup_hits = 0
            for sheet_wanted in PROXY_SHEETS_TDALTS + [PROXY_SHEET_BU]:
                real = self._resolve_sheet(wb.sheetnames, sheet_wanted)
                if real is None:
                    if self.verbose:
                        print(f"  [Módulo 9] [AVISO] Falta la hoja '{sheet_wanted}' "
                              f"en proxies; se omite.")
                    continue
                filas, hits = self._read_proxy_sheet(wb[real], sheet_wanted)
                xlookup_hits += hits
                for cid, intens, nombre in filas:
                    if cid in overrides:
                        if self.verbose:
                            print(f"  [AVISO] Client_ID {cid} repetido entre hojas de "
                                  f"proxies; conservo el primero.")
                        continue
                    overrides[cid] = intens
                    if nombre:
                        self._nombre_by_isin[cid] = nombre
            self.proxy_overrides = overrides
        finally:
            wb.close()

        if self.verbose:
            print(f"  [Módulo 9] Overrides de proxies: {len(self.proxy_overrides)} "
                  f"Client_ID"
                  + (f" ({xlookup_hits} resueltos por XLOOKUP contra MSCI)."
                     if xlookup_hits else "."))
        return self

    def _read_proxy_sheet(self, ws, sheet_name: str) -> Tuple[list, int]:
        """Devuelve [(client_id, intensidad, nombre), ...] y nº de XLOOKUP usados."""
        rows = list(ws.iter_rows(values_only=True))
        if len(rows) < PROXY_HEADER_ROW:
            return [], 0
        header = list(rows[PROXY_HEADER_ROW - 1])
        data_rows = rows[PROXY_HEADER_ROW:]

        mapping, faltan = _resolve_headers(header, PROXY_SCHEMA)
        # índice -> canónico invertido
        canon_to_idx = {canon: i for i, canon in mapping.items()}
        need = ["Client_ID", "CO2/Debt(Intensidad)"]
        if any(k not in canon_to_idx for k in need):
            if self.verbose:
                print(f"  [Módulo 9] [AVISO] Hoja '{sheet_name}': no ubico "
                      f"{[k for k in need if k not in canon_to_idx]} por header. "
                      f"Faltantes del schema: {faltan}")
            return [], 0

        i_cid = canon_to_idx["Client_ID"]
        i_int = canon_to_idx["CO2/Debt(Intensidad)"]
        i_nom = canon_to_idx.get("Nombre")
        i_etf = canon_to_idx.get("_ETF_REF")

        out, hits = [], 0
        for row in data_rows:
            cid = _to_string(row[i_cid]) if i_cid < len(row) else None
            if cid in (None, ""):
                continue
            intens = _to_number(row[i_int]) if i_int < len(row) else None
            # XLOOKUP fallback (R6): intensidad vacía + col ETF-ref + tabla MSCI.
            if intens is None and i_etf is not None and self.msci_ref:
                etf_isin = _to_string(row[i_etf]) if i_etf < len(row) else None
                if etf_isin and etf_isin in self.msci_ref:
                    intens = self.msci_ref[etf_isin]
                    hits += 1
            if intens is None:
                continue  # sin intensidad resoluble -> no override
            nombre = _to_string(row[i_nom]) if (i_nom is not None and i_nom < len(row)) else None
            out.append((cid, intens, nombre))
        return out, hits

    def _read_msci_ref(self, ws) -> Dict[str, float]:
        rows = list(ws.iter_rows(values_only=True))
        if len(rows) < PROXY_MSCI_HEADER_ROW:
            return {}
        header = list(rows[PROXY_MSCI_HEADER_ROW - 1])
        data_rows = rows[PROXY_MSCI_HEADER_ROW:]
        mapping, _ = _resolve_headers(header, PROXY_MSCI_SCHEMA)
        canon_to_idx = {canon: i for i, canon in mapping.items()}
        if "ISIN" not in canon_to_idx or "Intensidad" not in canon_to_idx:
            return {}
        i_isin, i_int = canon_to_idx["ISIN"], canon_to_idx["Intensidad"]
        ref = {}
        for row in data_rows:
            isin = _to_string(row[i_isin]) if i_isin < len(row) else None
            if isin in (None, ""):
                continue
            val = _to_number(row[i_int]) if i_int < len(row) else None
            if val is not None and isin not in ref:
                ref[isin] = val
        return ref

    # ======================================================================
    # (C) Sobrescritura de BD(MSCI).T por Client_ID
    # ======================================================================
    def apply_to_bd(self, bd_intensidad_lookup: Dict[str, float]) -> Dict[str, float]:
        """Devuelve un NUEVO dict = BD(MSCI) base con overrides de proxies aplicados.

        No muta el input (permite backtesting comparando antes/después).
        """
        merged = dict(bd_intensidad_lookup)
        nuevos = sobrescritos = 0
        for cid, val in self.proxy_overrides.items():
            if cid in merged:
                sobrescritos += 1
            else:
                nuevos += 1
            merged[cid] = val
        if self.verbose:
            print(f"  [Módulo 9] BD(MSCI).T tras proxies: {sobrescritos} "
                  f"sobrescritos, {nuevos} nuevos Client_ID. Total: {len(merged)}.")
        return merged

    # ======================================================================
    # (D) Herencia por emisor — capa Valorización (R4)
    # ======================================================================
    def apply_inheritance(
        self,
        df_val: pd.DataFrame,
        intensidad_col: str = "CO2-H",
        isin_col: str = "CODIGO_ISIN",
        grupo_col: str = "GRUPO_ECONOMICO",
        nombre_col: str = "TITULO",
    ) -> Tuple[pd.Series, pd.DataFrame]:
        """Rellena intensidades faltantes heredando de otro ISIN del mismo
        GRUPO_ECONOMICO que sí tenga huella. Devuelve (serie_intensidad, hist).

        - Donante por grupo = primera intensidad no nula (orden estable).
        - Solo hereda filas con intensidad nula y grupo con donante.
        - Grupos vacíos/None no heredan.
        - Registra histórico exportable (self.df_inherited).
        """
        for col in (intensidad_col, isin_col, grupo_col):
            if col not in df_val.columns:
                raise ValueError(f"apply_inheritance: falta la columna '{col}'.")

        serie = df_val[intensidad_col].copy()

        # Donante por grupo: primera intensidad no nula.
        donantes: Dict[str, dict] = {}
        multi_valor = []
        for grupo, sub in df_val.groupby(grupo_col, dropna=True):
            g = _to_string(grupo)
            if g in (None, ""):
                continue
            con_huella = sub[sub[intensidad_col].notna()]
            if con_huella.empty:
                continue
            distintos = con_huella[intensidad_col].nunique()
            if distintos > 1:
                multi_valor.append(g)
            fila0 = con_huella.iloc[0]
            donantes[g] = {
                "intensidad": fila0[intensidad_col],
                "isin_donante": _to_string(fila0.get(isin_col)),
            }

        registros = []
        for idx, row in df_val.iterrows():
            if pd.notna(row[intensidad_col]):
                continue
            g = _to_string(row.get(grupo_col))
            if g in (None, "") or g not in donantes:
                continue
            d = donantes[g]
            serie.at[idx] = d["intensidad"]
            registros.append({
                "GRUPO_ECONOMICO": g,
                "ISIN_heredado": _to_string(row.get(isin_col)),
                "Nombre": _to_string(row.get(nombre_col)),
                "ISIN_donante": d["isin_donante"],
                "Intensidad_heredada": d["intensidad"],
            })

        hist = pd.DataFrame(
            registros,
            columns=["GRUPO_ECONOMICO", "ISIN_heredado", "Nombre",
                     "ISIN_donante", "Intensidad_heredada"],
        )
        self.df_inherited = hist

        if self.verbose:
            print(f"  [Módulo 9] Herencia por emisor: {len(hist)} instrumentos "
                  f"heredaron huella de su GRUPO_ECONOMICO.")
            if multi_valor:
                print(f"  [AVISO] {len(multi_valor)} grupos tienen intensidades "
                      f"distintas entre sus ISIN; heredé la primera. Ej: "
                      f"{multi_valor[:5]}")
        return serie, hist

    def get_inherited_history(self) -> pd.DataFrame:
        """Histórico exportable de instrumentos que heredaron huella."""
        return self.df_inherited if self.df_inherited is not None \
            else pd.DataFrame(columns=["GRUPO_ECONOMICO", "ISIN_heredado",
                                       "Nombre", "ISIN_donante",
                                       "Intensidad_heredada"])

    # ---- Blindaje / helpers ------------------------------------------------
    def _guard_file(self) -> None:
        mmyyyy = getattr(self.config, "mmyyyy", "MMYYYY")
        if not self.path:
            raise ValueError("Config no define path_proxies.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(
                f"No encuentro el archivo de proxies (tu tarea manual): deposita\n"
                f"  'Nueva Lista Proxies (corte {mmyyyy}).xlsx'\n"
                f"en la ruta:\n  {self.path}"
            )

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None
























###############################################################################
#                                                                             #
#   MÓDULO 11 — FINAL (pivots sobre Valorización)                             #
#   Replica las pivot tables de la hoja 'Final'. Campos-valor (R8):            #
#     'Sum of Inv MM$'        = SUM(Inv MM$ / AD)                              #
#     'Emisiones Financiadas' = SUM(Huella / AK)      (col existente, renombre)#
#     ' Intensidad'           = SUM(Intensidad / AL)  (OJO: espacio inicial)   #
#   Ejes del spec: Plus x Plus_1  y  PORTAFOLIO (IN-FONDO0..3).                #
#   GETPIVOTDATA del Excel apunta a estos cruces; aquí se materializan como     #
#   DataFrames independientes para exportar y para el dashboard.              #
#                                                                             #
###############################################################################

# Campos-valor (columna origen en Valorización -> nombre en el pivot, R8).
FINAL_VALUE_FIELDS = {
    V_AD: "Sum of Inv MM$",          # Inv MM$
    V_AK: "Emisiones Financiadas",   # Huella   (renombre)
    V_AL: " Intensidad",             # Intensidad (con ESPACIO inicial, tal cual spec)
}


class FinalPivots:
    """Construye los pivots de 'Final' a partir del DataFrame Valorización.

    Salidas (todas DataFrames):
      by_plus         : índice Plus x columnas Plus_1, para cada campo-valor.
      by_portafolio   : índice PORTAFOLIO, para cada campo-valor.
      by_plus_flat    : versión long (Plus, Plus_1, campo, valor) para el dashboard.
      totales         : fila de totales por campo-valor (incluye AU4 = total Huella).
    """

    def __init__(self, df_val: pd.DataFrame,
                 plus_col: str = V_AQ, plus1_col: str = V_AR,
                 portafolio_col: str = "PORTAFOLIO",
                 verbose: bool = True):
        self.df = df_val
        self.plus_col = plus_col
        self.plus1_col = plus1_col
        self.portafolio_col = portafolio_col
        self.verbose = verbose
        self.by_plus: Dict[str, pd.DataFrame] = {}
        self.by_portafolio: Optional[pd.DataFrame] = None
        self.by_plus_flat: Optional[pd.DataFrame] = None
        self.totales: Optional[pd.DataFrame] = None

    def build(self) -> "FinalPivots":
        self._require([self.plus_col, self.plus1_col, self.portafolio_col,
                       V_AD, V_AK, V_AL])
        df = self.df.copy()

        # Asegurar numéricos en los campos-valor.
        for src in FINAL_VALUE_FIELDS:
            df[src] = pd.to_numeric(df[src], errors="coerce")

        # --- Pivot Plus x Plus_1, un DataFrame por campo-valor --------------
        for src, nombre in FINAL_VALUE_FIELDS.items():
            piv = pd.pivot_table(
                df, index=self.plus_col, columns=self.plus1_col,
                values=src, aggfunc="sum", fill_value=0.0, margins=True,
                margins_name="Total",
            )
            self.by_plus[nombre] = piv

        # --- Pivot por PORTAFOLIO ------------------------------------------
        self.by_portafolio = pd.pivot_table(
            df, index=self.portafolio_col,
            values=list(FINAL_VALUE_FIELDS.keys()),
            aggfunc="sum", fill_value=0.0, margins=True, margins_name="Total",
        ).rename(columns=FINAL_VALUE_FIELDS)

        # --- Versión long (para dashboard/exports) -------------------------
        flats = []
        for src, nombre in FINAL_VALUE_FIELDS.items():
            g = (df.groupby([self.plus_col, self.plus1_col], dropna=False)[src]
                   .sum().reset_index())
            g["campo"] = nombre
            g = g.rename(columns={src: "valor"})
            flats.append(g[[self.plus_col, self.plus1_col, "campo", "valor"]])
        self.by_plus_flat = pd.concat(flats, ignore_index=True)

        # --- Totales por campo (incluye AU4 = total Huella) ----------------
        tot = {nombre: float(df[src].sum()) for src, nombre in FINAL_VALUE_FIELDS.items()}
        self.totales = pd.DataFrame([tot])
        if self.verbose:
            print(f"  [Módulo 11] Final: pivots Plus×Plus_1 y por PORTAFOLIO. "
                  f"Total Huella (AU4) = {tot['Emisiones Financiadas']:,.2f}")
        return self

    def getpivotdata(self, campo: str, plus: str, plus_1: str) -> float:
        """Emula GETPIVOTDATA(campo, Plus, Plus_1) del Excel. 0.0 si no existe."""
        piv = self.by_plus.get(campo)
        if piv is None:
            raise ValueError(f"Campo desconocido '{campo}'. Usa: "
                             f"{list(FINAL_VALUE_FIELDS.values())}")
        try:
            return float(piv.loc[plus, plus_1])
        except (KeyError, TypeError):
            return 0.0

    def as_dict(self) -> Dict[str, pd.DataFrame]:
        """Bundle para el Módulo 13 (exports) y Módulo 14 (dashboard)."""
        out = {f"Final_{k}": v for k, v in self.by_plus.items()}
        out["Final_by_PORTAFOLIO"] = self.by_portafolio
        out["Final_flat"] = self.by_plus_flat
        out["Final_totales"] = self.totales
        return out

    def _require(self, cols: List[str]) -> None:
        faltan = [c for c in cols if c not in self.df.columns]
        if faltan:
            raise ValueError(f"FinalPivots: faltan columnas {faltan}. "
                             f"¿Corriste el Módulo 10? Disponibles: {list(self.df.columns)}")


























