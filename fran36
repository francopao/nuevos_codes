## AJUSTE A — El que arregla el dashboard vacío (Parametria directa)

Este es el crítico. **Paso A1:** agrega el método al Módulo 5 (dentro de `class ParametriaBuilder`):

```python
    @staticmethod
    def leer_parametria_directa(config, verbose: bool = True) -> Dict[str, dict]:
        """Lee Parametria (input MANUAL) directo del workbook por SBS.
        {SBS -> {NOMBRE(H), CODIGO(G), RIESGOS(F), RANKEST(J)}}. Datos fila 9+."""
        path = getattr(config, "path_workbook", None)
        out: Dict[str, dict] = {}
        if not path or not os.path.exists(path):
            if verbose:
                print("  [Módulo 5] [AVISO] Sin workbook; Parametria directa vacía.")
            return out
        import openpyxl
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        try:
            if "Parametria" not in wb.sheetnames:
                return out
            ws = wb["Parametria"]
            for row in ws.iter_rows(min_row=9, values_only=True):
                sbs = _to_string(row[2]) if len(row) > 2 else None   # C
                if not sbs:
                    continue
                out.setdefault(sbs, {
                    "RIESGOS": _to_string(row[5]) if len(row) > 5 else None,   # F
                    "CODIGO":  _to_string(row[6]) if len(row) > 6 else None,   # G
                    "NOMBRE":  row[7] if len(row) > 7 else None,               # H
                    "RANKEST": _to_string(row[9]) if len(row) > 9 else None,   # J
                })
        finally:
            wb.close()
        if verbose:
            print(f"  [Módulo 5] Parametria directa (manual): {len(out)} SBS.")
        return out
```

