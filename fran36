## AJUSTE C — BD(MSCI) también se alimenta de Nueva Lista Proxies (Alts/BU/TD)

Este es el cambio estructural nuevo. Las filas de proxies se **agregan** a BD(MSCI). Te doy un método nuevo para el Módulo 6 y su uso.

**Paso C1:** en el Módulo 6, agrega estas constantes antes de `class BDMSCIBuilder`:

```python
# Proxies -> filas que se AGREGAN a BD(MSCI). Bloque tipo BD, headers fila 3.
# Alts/TD empiezan en col V; BU empieza en col U. Match por header (robusto).
PROXY_BD_SHEETS = {"Alts": "V", "TD": "V", "BU": "U"}
```

**Paso C2:** agrega este método dentro de `class BDMSCIBuilder`:

```python
    def append_proxies(self, proxies_path: str, verbose: bool = True) -> "BDMSCIBuilder":
        """Agrega a BD(MSCI) las filas de proxies (hojas Alts/BU/TD, bloque V:AR/U:AQ).
        Reproduce el pegado manual de esas columnas en B:V de BD(MSCI), luego
        recalcula A/W/X. Debe llamarse DESPUÉS de build()."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de append_proxies().")
        if not proxies_path or not os.path.exists(proxies_path):
            if verbose:
                print(f"  [Módulo 6] [AVISO] Proxies no encontrado; BD sin proxies.")
            return self
        import openpyxl
        wb = openpyxl.load_workbook(proxies_path, read_only=True, data_only=True)
        nuevas = []
        try:
            for sheet, _start in PROXY_BD_SHEETS.items():
                real = self._resolve_sheet_generic(wb.sheetnames, sheet)
                if real is None:
                    continue
                ws = wb[real]
                rows = list(ws.iter_rows(min_row=3, values_only=True))
                if not rows:
                    continue
                header = list(rows[0])
                # Resolver las 21 columnas fuente por NOMBRE (robusto a posición)
                mapping, _ = _resolve_headers(header, {c: [c] for c in BASE_MSCI_SOURCE_COLS})
                idx = {canon: i for i, canon in mapping.items()}
                if "Client_ID" not in idx:
                    if verbose:
                        print(f"  [Módulo 6] [AVISO] Hoja proxies '{sheet}' sin Client_ID; omito.")
                    continue
                for row in rows[1:]:
                    cid = _to_string(row[idx["Client_ID"]]) if idx["Client_ID"] < len(row) else None
                    if cid in (None, ""):
                        continue
                    reg = {}
                    for name in BASE_MSCI_SOURCE_COLS:
                        i = idx.get(name)
                        reg[name] = row[i] if (i is not None and i < len(row)) else None
                    cat = reg.get("CAT")
                    reg[BD_COL_A] = self._deriv_a(reg.get("client1"))
                    reg[BD_COL_PLUS] = self._plus(cat)
                    reg[BD_COL_PLUS_1] = self._plus1(cat, reg[BD_COL_PLUS])
                    nuevas.append(reg)
        finally:
            wb.close()
        if nuevas:
            df_new = pd.DataFrame(nuevas, columns=BD_MSCI_COLS)
            for col in df_new.columns:
                if col in BD_STRING_COLS:
                    df_new[col] = df_new[col].map(_to_string)
                elif col in BD_NUMERIC_COLS:
                    df_new[col] = df_new[col].map(_to_number)
            # Agregar; si un Client_ID ya existe en BD, el de proxies MANDA (keep last)
            self.df = pd.concat([self.df, df_new], ignore_index=True)
            self.df = self.df.drop_duplicates(BD_COL_CLIENT_ID, keep="last").reset_index(drop=True)
        if verbose:
            print(f"  [Módulo 6] Proxies agregados a BD(MSCI): +{len(nuevas)} filas "
                  f"-> total {len(self.df)}.")
        return self

    @staticmethod
    def _resolve_sheet_generic(available, wanted):
        if wanted in available:
            return wanted
        t = _normalize(wanted)
        for n in available:
            if _normalize(n) == t:
                return n
        return None
```

