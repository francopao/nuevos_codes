# PARCHE 4 — MarketCapLoader: leer la hoja MKT DEL WORKBOOK, no de Market Cap.xlsx
# -----------------------------------------------------------------------------
# DÓNDE: reemplazar el cuerpo del MarketCapLoader existente.
# REGLA CONFIRMADA: se toma la fila cuya col B (fecha efectiva) cae en el
#        cierre del semestre (30-jun o 31-dic). Los valores YA están en
#        USD millones -> no dividir ni multiplicar por nada.
# =============================================================================

class MarketCapLoader:
    """AUM de los benchmarks desde la hoja MKT del workbook único."""

    def __init__(self, cfg: "Config", verbose: bool = True):
        self.cfg = cfg
        self.verbose = verbose
        self.aum: Dict[str, float] = {}      # alias (ILF/EMB/ACWI/CEMB) -> USD MM
        self.fecha_usada = None

    def _fecha_cierre(self) -> pd.Timestamp:
        s = str(self.cfg.semestre)
        anio, mm = int(s[:4]), int(s[4:6])
        return (pd.Timestamp(anio, 6, 30) if mm == 6 else pd.Timestamp(anio, 12, 31))

    def build(self) -> "MarketCapLoader":
        df = pd.read_excel(self.cfg.path_workbook, sheet_name=HOJA_MKT,
                           skiprows=FILA_HEADERS_MKT - 1, engine="openpyxl")
        df.columns = [str(c).strip() for c in df.columns]
        col_fecha = df.columns[1]                      # col B
        df[col_fecha] = pd.to_datetime(df[col_fecha], errors="coerce")
        objetivo = self._fecha_cierre()

        validas = df[df[col_fecha].notna() & (df[col_fecha] <= objetivo)]
        if validas.empty:
            if self.verbose:
                print(f"  [MarketCap] [AVISO] sin filas <= {objetivo.date()}")
            return self
        fila = validas.loc[validas[col_fecha].idxmax()]
        self.fecha_usada = fila[col_fecha]

        for ticker, alias in TICKER_A_ALIAS.items():
            if ticker in df.columns:
                v = pd.to_numeric(fila.get(ticker), errors="coerce")
                if pd.notna(v):
                    self.aum[alias] = float(v)          # ya viene en USD MM
        if self.verbose:
            print(f"  [MarketCap] fila {self.fecha_usada.date()} | AUM MM: {self.aum}")
        return self


