    PORTAFOLIOS_MULTIFONDO = ["IN-FONDO1", "IN-FONDO2", "IN-FONDO3"]

    def patrimonio_multifondos(self) -> float:
        """K7 = SUM(K4:K6): patrimonio en soles de los fondos 1, 2 y 3."""
        m = self.as_map()
        return float(sum(m.get(p, 0.0) or 0.0 for p in self.PORTAFOLIOS_MULTIFONDO))

    def aum_multifondos_mm(self, usd_rate: float) -> float:
        """K10 = (K7 / TC) / 1e6 -> AUM en USD millones. Denominador oficial."""
        if not usd_rate:
            return 0.0
        return self.patrimonio_multifondos() / float(usd_rate) / 1_000_000

