# ISIN -> ticker de Market Cap (equivalencias confirmadas)
ISIN_A_TICKER = {
    "US4642873909": "ILF US Equity",
    "US4642882819": "EMB US Equity",
    "US4642882579": "ACWI US Equity",
    "US4642862514": "CEMB US Equity",
}
TICKER_A_ALIAS = {
    "ILF US Equity": "ILF", "EMB US Equity": "EMB",
    "ACWI US Equity": "ACWI", "CEMB US Equity": "CEMB",
}


class ComparablesLoader:
    """Intensidad de carbono de los ETF comparables (ACWI, ILF, CEMB, EMB)."""

    COL_ISIN = "FUND_ISIN"
    COL_INTENSIDAD = "FUND_FINANCED_CARBON_EMISSIONS"   # <- ver NOTA abajo
    COL_INTENSIDAD_ALT = "FUND_WEIGHTED_AVG_SOV_CARBON_INTEN"

    def __init__(self, cfg: "Config", usar_columna_sov: bool = False,
                 verbose: bool = True):
        self.cfg = cfg
        self.col_valor = (self.COL_INTENSIDAD_ALT if usar_columna_sov
                          else self.COL_INTENSIDAD)
        self.verbose = verbose
        self.intensidades: Dict[str, float] = {}   # alias -> intensidad

    def _elegir_hoja(self, hojas: List[str]) -> str:
        """Hoja del semestre; si no existe exacta, la más reciente <= semestre."""
        s = str(self.cfg.semestre)
        if s in hojas:
            return s
        candidatas = sorted([h for h in hojas if h.isdigit() and h <= s])
        if candidatas:
            if self.verbose:
                print(f"  [Comparables] [AVISO] no existe la hoja {s}; "
                      f"se usa {candidatas[-1]}.")
            return candidatas[-1]
        raise KeyError(f"Comparables: ninguna hoja utilizable para {s}. "
                       f"Hojas disponibles: {hojas}")

    def build(self) -> "ComparablesLoader":
        ruta = self.cfg.path_comparables
        if not FsPath(ruta).exists():
            if self.verbose:
                print(f"  [Comparables] [AVISO] no se encuentra {ruta}")
            return self
        hojas = pd.ExcelFile(ruta, engine="openpyxl").sheet_names
        hoja = self._elegir_hoja(hojas)
        df = pd.read_excel(ruta, sheet_name=hoja, engine="openpyxl")
        df.columns = [str(c).strip() for c in df.columns]
        for _, r in df.iterrows():
            isin = str(r.get(self.COL_ISIN, "")).strip()
            ticker = ISIN_A_TICKER.get(isin)
            if not ticker:
                continue
            val = pd.to_numeric(r.get(self.col_valor), errors="coerce")
            if pd.notna(val):
                self.intensidades[TICKER_A_ALIAS[ticker]] = float(val)
        if self.verbose:
            print(f"  [Comparables] hoja {hoja} | {len(self.intensidades)} "
                  f"comparables: {self.intensidades}")
        return self


