class CajaLoader:
    """Lookup PORTAFOLIO -> PATRIMONIO (semántica MATCH: primera coincidencia)."""

    def __init__(self, df_caja: pd.DataFrame, verbose: bool = True):
        self.df = df_caja
        self.verbose = verbose
        self.patrimonio_by_portafolio: Dict[str, float] = {}

    def build(self) -> "CajaLoader":
        if "PORTAFOLIO" not in self.df.columns or "PATRIMONIO" not in self.df.columns:
            raise ValueError(
                "CajaLoader: faltan 'PORTAFOLIO'/'PATRIMONIO'. "
                f"Columnas: {list(self.df.columns)}")
        tmp = self.df[["PORTAFOLIO", "PATRIMONIO"]].copy()
        tmp["PORTAFOLIO"] = tmp["PORTAFOLIO"].map(_to_string)
        tmp = tmp.dropna(subset=["PORTAFOLIO"]).drop_duplicates("PORTAFOLIO", keep="first")
        self.patrimonio_by_portafolio = dict(zip(tmp["PORTAFOLIO"], tmp["PATRIMONIO"]))
        if self.verbose:
            print(f"  [Módulo 2] CajaLoader: {len(self.patrimonio_by_portafolio)} portafolios.")
        return self

    def get_patrimonio(self, portafolio) -> Optional[float]:
        return self.patrimonio_by_portafolio.get(_to_string(portafolio))

    def as_map(self) -> Dict[str, float]:
        return self.patrimonio_by_portafolio

    # --- Réplica de K4:K10 de la hoja 'Cálculo Caja' -------------------------
    # VALIDADO: la col AB de Valorización es SOLO este lookup por PORTAFOLIO
    # (INDEX col F / MATCH col A). No existe ningún ajuste de caja.
    PORTAFOLIOS_MULTIFONDO = ("IN-FONDO1", "IN-FONDO2", "IN-FONDO3")

    def patrimonio_multifondos(self) -> float:
        """K7 = SUM(K4:K6): patrimonio en soles de los fondos 1, 2 y 3."""
        m = self.patrimonio_by_portafolio
        return float(sum(float(m.get(p) or 0.0) for p in self.PORTAFOLIOS_MULTIFONDO))

    def aum_multifondos_mm(self, usd_rate: float) -> float:
        """K10 = (K7 / TC) / 1e6 -> AUM en USD MM. Denominador de Intensidad-M.

        En el Excel, Intensidad-M dividía entre $AT$4, una constante escrita a
        mano (11,322.67) desalineada del AUM real (AT5 = 11,038.86).
        """
        if not usd_rate:
            return 0.0
        return self.patrimonio_multifondos() / float(usd_rate) / 1_000_000


