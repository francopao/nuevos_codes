BENCHMARK_TICKERS = ["IEMG", "CEMB", "ILF", "ACWI", "EEM", "EMB", "SWDA"]


# ISIN de Comparables -> ticker de la hoja MKT (equivalencias confirmadas)
ISIN_A_TICKER = {
    "US4642873909": "ILF US Equity",
    "US4642882819": "EMB US Equity",
    "US4642882579": "ACWI US Equity",
    "US4642862514": "CEMB US Equity",
}
TICKER_A_ALIAS = {
    "ILF US Equity": "ILF", "EMB US Equity": "EMB",
    "ACWI US Equity": "ACWI", "CEMB US Equity": "CEMB",
}


class MarketCapLoader:
    """AUM de benchmarks desde la hoja MKT del workbook único.

    Regla confirmada (R10): se toma la fila cuya col B (fecha efectiva) cae en
    el cierre del semestre (30-jun / 31-dic); si no existe esa fila exacta, la
    más reciente anterior. Los valores YA vienen en USD millones: no se escalan.
    """

    def __init__(self, config: Config, verbose: bool = True):
        self.config = config
        self.path = getattr(config, "path_workbook", None)
        self.verbose = verbose
        self.aum: Dict[str, float] = {}      # alias (ILF/EMB/ACWI/CEMB) -> USD MM
        self.fecha_usada = None

    def _fecha_cierre(self) -> pd.Timestamp:
        s = str(self.config.semestre)
        anio, mm = int(s[:4]), int(s[4:6])
        return pd.Timestamp(anio, 6, 30) if mm == 6 else pd.Timestamp(anio, 12, 31)

    def build(self) -> "MarketCapLoader":
        if not self.path or not os.path.exists(self.path):
            if self.verbose:
                print("  [MarketCap] [AVISO] workbook no encontrado; sin AUM.")
            return self
        try:
            df = pd.read_excel(self.path, sheet_name=HOJA_MKT,
                               skiprows=FILA_HEADERS_MKT - 1, engine="openpyxl")
        except Exception as exc:
            if self.verbose:
                print(f"  [MarketCap] [AVISO] no se pudo leer la hoja "
                      f"{HOJA_MKT}: {exc}")
            return self

        df.columns = [str(c).strip() for c in df.columns]
        col_fecha = df.columns[1]                       # col B = fecha efectiva
        df[col_fecha] = pd.to_datetime(df[col_fecha], errors="coerce")
        objetivo = self._fecha_cierre()

        validas = df[df[col_fecha].notna() & (df[col_fecha] <= objetivo)]
        if validas.empty:
            if self.verbose:
                print(f"  [MarketCap] [AVISO] sin filas <= {objetivo.date()}.")
            return self
        fila = validas.loc[validas[col_fecha].idxmax()]
        self.fecha_usada = fila[col_fecha]

        for ticker, alias in TICKER_A_ALIAS.items():
            if ticker in df.columns:
                v = pd.to_numeric(fila.get(ticker), errors="coerce")
                if pd.notna(v):
                    self.aum[alias] = float(v)          # ya está en USD MM
        if self.verbose:
            print(f"  [MarketCap] fila {self.fecha_usada.date()} | "
                  f"AUM MM: { {k: round(v, 1) for k, v in self.aum.items()} }")
        return self


