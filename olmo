#   Nueva Lista Proxies: overrides de intensidad por Client_ID + herencia por  #
#   GRUPO_ECONOMICO en la capa Valorización (R4).                             #
#                                                                             #
###############################################################################

PROXY_SHEETS_TDALTS = ["TD", "Alts"]
PROXY_SHEET_BU = "BU"
PROXY_SHEET_MSCI = "MSCI"
PROXY_HEADER_ROW = 3
PROXY_MSCI_HEADER_ROW = 1
PROXY_SCHEMA: Dict[str, List[str]] = {
    "Client_ID":            ["client_id", "clientid", "isin"],
    "CO2/Debt(Intensidad)": ["co2/debt(intensidad)", "co2debtintensidad",
                             "co2/debt", "co2debt", "intensidad"],
    "Nombre":               ["nombre"],
}
PROXY_MSCI_SCHEMA: Dict[str, List[str]] = {
    "ISIN":       ["client_id", "isin", "clientid"],
    "Intensidad": ["co2/debt(intensidad)", "co2debtintensidad", "co2/debt", "intensidad"],
}


class ProxyEngine:
    """Proxies (override intensidad por Client_ID) + herencia por emisor."""

    def __init__(self, config: Config, verbose: bool = True,
                 etf_ref_col: Optional[str] = None):
        self.config = config
        self.path = getattr(config, "path_proxies", None)
        self.verbose = verbose
        self.etf_ref_col = etf_ref_col
        self.proxy_overrides: Dict[str, float] = {}
        self.msci_ref: Dict[str, float] = {}
        self.df_inherited: Optional[pd.DataFrame] = None

    def load(self) -> "ProxyEngine":
        self._guard_file()
        import openpyxl
        if self.etf_ref_col:
            PROXY_SCHEMA["_ETF_REF"] = [self.etf_ref_col]
        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            msci_sheet = self._resolve_sheet(wb.sheetnames, PROXY_SHEET_MSCI)
            if msci_sheet is not None:
                self.msci_ref = self._read_msci_ref(wb[msci_sheet])
            overrides: Dict[str, float] = {}
            for sheet_wanted in PROXY_SHEETS_TDALTS + [PROXY_SHEET_BU]:
                real = self._resolve_sheet(wb.sheetnames, sheet_wanted)
                if real is None:
                    if self.verbose:
                        print(f"  [Módulo 9] [AVISO] Falta hoja '{sheet_wanted}' en proxies.")
                    continue
                for cid, intens in self._read_proxy_sheet(wb[real]):
                    overrides.setdefault(cid, intens)
            self.proxy_overrides = overrides
        finally:
            wb.close()
        if self.verbose:
            print(f"  [Módulo 9] Overrides de proxies: {len(self.proxy_overrides)} Client_ID.")
        return self

    def _read_proxy_sheet(self, ws):
        rows = list(ws.iter_rows(values_only=True))
        if len(rows) < PROXY_HEADER_ROW:
            return []
        header = list(rows[PROXY_HEADER_ROW - 1])
        data_rows = rows[PROXY_HEADER_ROW:]
        mapping, _ = _resolve_headers(header, PROXY_SCHEMA)
        canon_to_idx = {canon: i for i, canon in mapping.items()}
        if "Client_ID" not in canon_to_idx or "CO2/Debt(Intensidad)" not in canon_to_idx:
            return []
        i_cid = canon_to_idx["Client_ID"]
        i_int = canon_to_idx["CO2/Debt(Intensidad)"]
        i_etf = canon_to_idx.get("_ETF_REF")
        out = []
        for row in data_rows:
            cid = _to_string(row[i_cid]) if i_cid < len(row) else None
            if cid in (None, ""):
                continue
            intens = _to_number(row[i_int]) if i_int < len(row) else None
            if intens is None and i_etf is not None and self.msci_ref:
                etf = _to_string(row[i_etf]) if i_etf < len(row) else None
                if etf and etf in self.msci_ref:
                    intens = self.msci_ref[etf]
            if intens is None:
                continue
            out.append((cid, intens))
        return out

    def _read_msci_ref(self, ws) -> Dict[str, float]:
        rows = list(ws.iter_rows(values_only=True))
        if len(rows) < PROXY_MSCI_HEADER_ROW:
            return {}
        header = list(rows[PROXY_MSCI_HEADER_ROW - 1])
        data_rows = rows[PROXY_MSCI_HEADER_ROW:]
        mapping, _ = _resolve_headers(header, PROXY_MSCI_SCHEMA)
        c2i = {canon: i for i, canon in mapping.items()}
        if "ISIN" not in c2i or "Intensidad" not in c2i:
            return {}
        i_isin, i_int = c2i["ISIN"], c2i["Intensidad"]
        ref = {}
        for row in data_rows:
            isin = _to_string(row[i_isin]) if i_isin < len(row) else None
            if isin in (None, ""):
                continue
            val = _to_number(row[i_int]) if i_int < len(row) else None
            if val is not None:
                ref.setdefault(isin, val)
        return ref

    def apply_to_bd(self, bd_intensidad_lookup: Dict[str, float]) -> Dict[str, float]:
        merged = dict(bd_intensidad_lookup)
        for cid, val in self.proxy_overrides.items():
            merged[cid] = val
        if self.verbose:
            print(f"  [Módulo 9] BD(MSCI).T tras proxies: {len(merged)} Client_ID.")
        return merged

    def apply_inheritance(self, df_val: pd.DataFrame, intensidad_col: str = "CO2-H",
                          isin_col: str = "CODIGO_ISIN", grupo_col: str = "GRUPO_ECONOMICO",
                          nombre_col: str = "TITULO"):
        for col in (intensidad_col, isin_col, grupo_col):
            if col not in df_val.columns:
                raise ValueError(f"apply_inheritance: falta '{col}'.")
        serie = df_val[intensidad_col].copy()
        donantes: Dict[str, dict] = {}
        for grupo, sub in df_val.groupby(grupo_col, dropna=True):
            g = _to_string(grupo)
            if g in (None, ""):
                continue
            con = sub[sub[intensidad_col].notna()]
            if con.empty:
                continue
            fila0 = con.iloc[0]
            donantes[g] = {"intensidad": fila0[intensidad_col],
                           "isin_donante": _to_string(fila0.get(isin_col))}
        registros = []
        for idx, row in df_val.iterrows():
            if pd.notna(row[intensidad_col]):
                continue
            g = _to_string(row.get(grupo_col))
            if g in (None, "") or g not in donantes:
                continue
            d = donantes[g]
            serie.at[idx] = d["intensidad"]
            registros.append({
                "GRUPO_ECONOMICO": g, "ISIN_heredado": _to_string(row.get(isin_col)),
                "Nombre": _to_string(row.get(nombre_col)),
                "ISIN_donante": d["isin_donante"], "Intensidad_heredada": d["intensidad"],
            })
        hist = pd.DataFrame(registros, columns=["GRUPO_ECONOMICO", "ISIN_heredado",
                                                "Nombre", "ISIN_donante", "Intensidad_heredada"])
        self.df_inherited = hist
        if self.verbose:
            print(f"  [Módulo 9] Herencia por emisor: {len(hist)} instrumentos heredaron.")
        return serie, hist

    def get_inherited_history(self) -> pd.DataFrame:
        return self.df_inherited if self.df_inherited is not None else pd.DataFrame(
            columns=["GRUPO_ECONOMICO", "ISIN_heredado", "Nombre",
                     "ISIN_donante", "Intensidad_heredada"])

    def _guard_file(self) -> None:
        mmyyyy = getattr(self.config, "mmyyyy", "MMYYYY")
        if not self.path:
            raise ValueError("Config no define path_proxies.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(
                f"No encuentro el archivo de proxies (tarea manual): deposita\n"
                f"  'Nueva Lista Proxies (corte {mmyyyy}).xlsx'\nen:\n  {self.path}")

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None


###############################################################################
#                                                                             #
#   MÓDULO 10 — VALORIZACIÓN BUILDER (columnas formuladas G, AA:AS)           #
#   Corazón: construye en orden de dependencia integrando 2,3,5,6,7,8,9.       #
#                                                                             #
###############################################################################

V_G = "Nombre"; V_AA = "Column1"; V_AB = "Patrimonio"; V_AC = "Weight"; V_AD = "Inv MM$"
V_AE, V_AF, V_AG, V_AH = "F0", "F1", "F2", "F3"
V_AI = "M (MM$)"; V_AJ = "CO2-H"; V_AK = "Huella"; V_AL = "Intensidad"
V_AM = "Categoria"; V_AN = "Estrategia"; V_AO = "Rank_rt"; V_AP = "Intensidad-M"
V_AQ = "Plus"; V_AR = "Plus_1"; V_AS = "CO2 T-1"
V_FORMULATED_COLS = [V_G, V_AA, V_AB, V_AC, V_AD, V_AE, V_AF, V_AG, V_AH, V_AI,
                     V_AJ, V_AK, V_AL, V_AM, V_AN, V_AO, V_AP, V_AQ, V_AR, V_AS]
FONDOS = {V_AE: "IN-FONDO0", V_AF: "IN-FONDO1", V_AG: "IN-FONDO2", V_AH: "IN-FONDO3"}


class ValorizacionBuilder:
    """Construye las columnas formuladas de Valorización (el objeto central)."""

    def __init__(self, df_val: pd.DataFrame, *, caja_map: Dict[str, float],
                 usd_rate: Optional[float], parametria_lookup: Dict[str, dict],
                 intensidad_post: Dict[str, float], plus_lookup: Dict[str, dict],
                 intensidad_t1: Dict[str, float], proxy_engine=None,
                 perdieron_lookup: Optional[Dict[str, float]] = None,
                 perdieron_mode: str = "fill", attrs_lookup: Optional[Dict[str, dict]] = None,
                 isin_col: str = "CODIGO_ISIN", sbs_col: str = "CODIGO_SBS",
                 portafolio_col: str = "PORTAFOLIO", vvl_col: str = "VALOR_VECTOR_LOCAL",
                 grupo_col: str = "GRUPO_ECONOMICO",
                 aum_multifondos_mm: Optional[float] = None,
                 verbose: bool = True):
        self.df = df_val.copy()
        self.caja_map = caja_map
        self.usd_rate = usd_rate
        self.parametria = parametria_lookup
        self.intensidad_post = intensidad_post
        self.plus_lookup = plus_lookup
        self.intensidad_t1 = intensidad_t1
        self.proxy_engine = proxy_engine
        self.perdieron_lookup = perdieron_lookup or {}
        self.perdieron_mode = perdieron_mode
        self.attrs_lookup = attrs_lookup or {}
        self.isin_col = isin_col
        self.sbs_col = sbs_col
        self.portafolio_col = portafolio_col
        self.vvl_col = vvl_col
        self.grupo_col = grupo_col
        self.verbose = verbose
        # Denominador de Intensidad-M. En el Excel era $AT$4, una constante
        # escrita a mano (11,322.67) desalineada del AUM real (AT5).
        self.aum_multifondos_mm = aum_multifondos_mm
        self.au4_total_huella: Optional[float] = None
        self.no_match_report = None
        self.inherited_history: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        df = self.df
        # Filtro de negocio: excluir IN-FONDO0 (solo informativo),
        # GRUPO que empiece con DPZ (DPZ, DPZ6B, ...) y GRUPO = CDLP.
        _port = df[self.portafolio_col].map(lambda p: (_to_string(p) or "").upper())
        if "GRUPO" in df.columns:
            _grupo = df["GRUPO"].map(lambda g: (_to_string(g) or "").upper())
            _excluir = (_port == "IN-FONDO0") | _grupo.str.startswith("DPZ") | (_grupo == "CDLP")
        else:
            _excluir = (_port == "IN-FONDO0")
        n_excl = int(_excluir.sum())
        df = df[~_excluir].reset_index(drop=True)
        self.df = df
        if self.verbose:
            print(f"  [Módulo 10] Filtro exclusión (IN-FONDO0 / DPZ* / CDLP): "
                  f"{n_excl} filas excluidas, quedan {len(df)}.")
        self._require([self.isin_col, self.sbs_col, self.portafolio_col, self.vvl_col])
        # Las columnas formuladas que vengan materializadas del Excel se DESCARTAN:
        # Python las recalcula. (Ya no se preservan como __xlsx.)
        _drop = [c for c in V_FORMULATED_COLS if c in df.columns]
        if _drop:
            df = df.drop(columns=_drop, errors="ignore")
            if self.verbose:
                print(f"  [Módulo 10] Descartadas {len(_drop)} col(s) formuladas del "
                      f"Excel (se recalculan en Python).")

        sbs = df[self.sbs_col].map(_to_string)
        df[V_G]  = sbs.map(lambda s: self._param(s, "NOMBRE"))
        df[V_AM] = sbs.map(lambda s: self._param(s, "CODIGO"))
        df[V_AN] = sbs.map(lambda s: self._param(s, "RIESGOS"))
        df[V_AO] = sbs.map(lambda s: self._param(s, "RANKEST"))
        df[V_AA] = sbs.map(lambda s: (s[6:7] if isinstance(s, str) and len(s) >= 7 else None))

        df[V_AB] = df[self.portafolio_col].map(lambda p: self.caja_map.get(_to_string(p)))
        vvl = pd.to_numeric(df[self.vvl_col], errors="coerce")
        df[V_AC] = self._safe_div(vvl, pd.to_numeric(df[V_AB], errors="coerce"))
        if self.usd_rate in (None, 0):
            if self.verbose:
                print("  [Módulo 10] [AVISO] usd_rate ausente/0: 'Inv MM$' (AD) = NaN.")
            df[V_AD] = pd.NA
        else:
            df[V_AD] = (vvl / float(self.usd_rate)) / 1_000_000.0

        port_up = df[self.portafolio_col].map(lambda p: (_to_string(p) or "").upper())
        inv = pd.to_numeric(df[V_AD], errors="coerce")
        for col, fondo in FONDOS.items():
            df[col] = inv.where(port_up == fondo, other=0.0)
        f123 = (pd.to_numeric(df[V_AF], errors="coerce").fillna(0)
                + pd.to_numeric(df[V_AG], errors="coerce").fillna(0)
                + pd.to_numeric(df[V_AH], errors="coerce").fillna(0))
        df[V_AI] = f123.groupby(sbs).transform("sum")

        isin = df[self.isin_col].map(_to_string)
        df[V_AJ] = [self._lookup_id(self.intensidad_post, i, s) for i, s in zip(isin, sbs)]
        self._apply_perdieron(df, isin, sbs)
        self._apply_inheritance(df)

        # Diagnóstico ANTES de forzar 0: separar "cero legítimo" de "cero problemático".
        _co2 = pd.to_numeric(df[V_AJ], errors="coerce")
        _inv = pd.to_numeric(df[V_AD], errors="coerce").fillna(0.0)
        _sin_match = _co2.isna()
        _con_exposicion = _inv.abs() > 1e-9
        _problematicos = _sin_match & _con_exposicion          # SÍ invertido, NO matcheó
        self.no_match_report = df.loc[_problematicos, [
            self.sbs_col, self.isin_col, self.portafolio_col, V_AD
        ]].copy() if _problematicos.any() else df.iloc[0:0][[
            self.sbs_col, self.isin_col, self.portafolio_col, V_AD]].copy()
        if "TITULO" in df.columns:
            self.no_match_report.insert(0, "TITULO", df.loc[_problematicos, "TITULO"])

        # Fallback: TODO lo sin intensidad -> 0.0 (legítimos y problemáticos por igual)
        df[V_AJ] = _co2.fillna(0.0)

        if self.verbose:
            n_prob = len(self.no_match_report)
            n_leg = int((_sin_match & ~_con_exposicion).sum())
            print(f"  [Módulo 10] CO2-H sin match -> 0. "
                  f"Legítimos (sin exposición): {n_leg}. "
                  f"PROBLEMÁTICOS (con exposición, revisar): {n_prob}.")
            if n_prob:
                print(f"  [Módulo 10] [ATENCIÓN] {n_prob} instrumentos con inversión "
                      f"pero sin huella. Ver reporte 'NoMatch_conExposicion'.")


        # Lo que sigue sin intensidad tras BD+proxies+perdieron+herencia -> 0.0
        # (equivale al 3er IFERROR de la fórmula del Excel; los soberanos ya
        #  matchean por ISIN si Base MSCI está completo).
        df[V_AJ] = pd.to_numeric(df[V_AJ], errors="coerce").fillna(0.0)

        aj_num = pd.to_numeric(df[V_AJ], errors="coerce")
        df[V_AK] = aj_num * pd.to_numeric(df[V_AD], errors="coerce")
        df[V_AL] = aj_num * pd.to_numeric(df[V_AC], errors="coerce")

        self.au4_total_huella = float(pd.to_numeric(df[V_AK], errors="coerce").sum())
        # Intensidad-M = Huella / AUM multifondos (USD MM). Si no se inyectó el
        # AUM, se cae al comportamiento antiguo (dividir entre la huella total).
        _den = self.aum_multifondos_mm or self.au4_total_huella
        df[V_AP] = (pd.to_numeric(df[V_AK], errors="coerce") / _den
                    if _den else pd.NA)
        if self.verbose:
            print(f"  [Módulo 10] AU4 (SUM Huella) = {self.au4_total_huella:,.2f}")

        df[V_AQ] = [self._plus(i, s, df[V_AO].iat[k], "Plus")
                    for k, (i, s) in enumerate(zip(isin, sbs))]
        df[V_AR] = [self._plus(i, s, df[V_AO].iat[k], "Plus_1")
                    for k, (i, s) in enumerate(zip(isin, sbs))]
        df[V_AS] = [self._lookup_id(self.intensidad_t1, i, s) for i, s in zip(isin, sbs)]

        # Enriquecimiento opcional para M12 (Sector/País/Rating desde BD por ISIN).
        if self.attrs_lookup:
            df["Sector_BD"] = isin.map(lambda i: (self.attrs_lookup.get(i) or {}).get("Sector"))
            df["Pais_BD"] = isin.map(lambda i: (self.attrs_lookup.get(i) or {}).get("País"))
            df["Rating_BD"] = isin.map(lambda i: (self.attrs_lookup.get(i) or {}).get("Rating"))
            df["Controversia_BD"] = isin.map(lambda i: (self.attrs_lookup.get(i) or {}).get("Controversia"))

        if self.verbose:
            print(f"  [Módulo 10] Valorización formulada -> {df.shape[0]}x{df.shape[1]}.")
        self.df = df
        return self

    def _apply_perdieron(self, df, isin, sbs):
        if not self.perdieron_lookup:
            return
        aj = df[V_AJ].tolist()
        n = 0
        for k, (i, s) in enumerate(zip(isin, sbs)):
            hit = self._lookup_id(self.perdieron_lookup, i, s)
            if hit is None:
                continue
            if self.perdieron_mode == "override":
                aj[k] = hit; n += 1
            elif aj[k] is None or (isinstance(aj[k], float) and pd.isna(aj[k])):
                aj[k] = hit; n += 1
        df[V_AJ] = aj
        if self.verbose and n:
            print(f"  [Módulo 10] Perdieron Huella ({self.perdieron_mode}): {n} aplicadas.")

    def _apply_inheritance(self, df):
        if self.proxy_engine is None or self.grupo_col not in df.columns:
            return
        serie, hist = self.proxy_engine.apply_inheritance(
            df, intensidad_col=V_AJ, isin_col=self.isin_col,
            grupo_col=self.grupo_col, nombre_col="TITULO")
        df[V_AJ] = serie
        self.inherited_history = hist

    def _param(self, sbs, field):
        info = self.parametria.get(sbs) if sbs else None
        return info.get(field) if info else None

    @staticmethod
    def _lookup_id(d, isin, sbs):
        if isin and isin in d:
            return d[isin]
        if sbs and sbs in d:
            return d[sbs]
        return None

    def _plus(self, isin, sbs, rank_rt, which):
        info = None
        if isin and isin in self.plus_lookup:
            info = self.plus_lookup[isin]
        elif sbs and sbs in self.plus_lookup:
            info = self.plus_lookup[sbs]
        if info is not None and info.get(which) is not None:
            return info[which]
        return "Cash" if (_to_string(rank_rt) == "Cash") else "Cuestionario Integra"

    @staticmethod
    def _safe_div(num, den):
        den = den.replace({0: pd.NA})
        return num / den

    def _require(self, cols):
        faltan = [c for c in cols if c not in self.df.columns]
        if faltan:
            raise ValueError(f"ValorizacionBuilder: faltan columnas base {faltan}.")

    def get_au4(self):
        return self.au4_total_huella

    def get_inherited_history(self):
        return self.inherited_history if self.inherited_history is not None else pd.DataFrame(
            columns=["GRUPO_ECONOMICO", "ISIN_heredado", "Nombre",
                     "ISIN_donante", "Intensidad_heredada"])



