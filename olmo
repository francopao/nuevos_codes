# NOTA: NO existe ajuste de caja. La col AB de Valorización es únicamente
# INDEX('Cálculo Caja'!F, MATCH(PORTAFOLIO, 'Cálculo Caja'!A, 0)).
# ==============================================================================


# ==============================================================================
# HELPERS
# ==============================================================================
def _base(df: pd.DataFrame) -> pd.DataFrame:
    """Universo base común a todas las pivots: multifondos 1-2-3."""
    out = df[df[COL["portafolio"]].isin(PORTAFOLIOS_VALIDOS)].copy()
    for c in METRICAS + [COL["intensidad"]]:
        if c in out.columns:
            out[c] = pd.to_numeric(out[c], errors="coerce").fillna(0.0)
    for c in [COL["plus"], COL["plus_1"], COL["estrategia"], COL["rank_rt"],
              COL["tipo_renta"], COL["nombre"]]:
        if c in out.columns:
            out[c] = out[c].astype(str).str.strip()
    return out


def _sin_huella_cero(df: pd.DataFrame) -> pd.DataFrame:
    if EXCLUIR_HUELLA_CERO:
        return df[df[COL["huella"]] != 0]
    return df


def _agg(df: pd.DataFrame, keys: list[str], metricas: list[str] | None = None) -> pd.DataFrame:
    metricas = metricas or METRICAS
    metricas = [m for m in metricas if m in df.columns]
    if df.empty:
        return pd.DataFrame(columns=keys + metricas)
    out = (df.groupby(keys, dropna=False)[metricas]
             .sum()
             .reset_index()
             .sort_values(metricas[0], ascending=False, ignore_index=True))
    return out


# ==============================================================================
# PIVOTS — cada función replica una PivotTable de la hoja "Presentacion"
# ==============================================================================
class PresentacionBuilder:
    """Construye todos los objetos que antes vivían en la hoja 'Presentacion'."""

    def __init__(self, df_valorizacion: pd.DataFrame, fecha_corte: str,
                 sector_lookup: dict | None = None,
                 intensidades_comp: dict | None = None,
                 aum_comp: dict | None = None):
        """
        df_valorizacion   : DataFrame de M10 (columnas formuladas ya construidas)
        fecha_corte       : 'yyyymm' o 'yyyy-mm-dd'
        sector_lookup     : {Nombre -> Sector} de Parametria (col O -> col P)
        intensidades_comp : {alias -> intensidad} de ComparablesLoader
        aum_comp          : {alias -> AUM USD MM} de MarketCapLoader (hoja MKT)
        """
        self.fecha_corte = str(fecha_corte)
        self.df = _base(df_valorizacion)
        self.sector_lookup = sector_lookup or {}
        self.intensidades_comp = intensidades_comp or {}
        self.aum_comp = aum_comp or {}
        self.objetos: dict[str, pd.DataFrame] = {}

    # --------------------------------------------------------------------------
    # PivotTable1 (Z3:AA14) — AUM por Rank_rt  -> charts 2/4/5 (composición AUM)
    # --------------------------------------------------------------------------
    def aum_por_rank(self) -> pd.DataFrame:
        out = _agg(self.df, [COL["rank_rt"]], [COL["inv"]])
        total = out[COL["inv"]].sum()
        out["% AUM"] = np.where(total, out[COL["inv"]] / total, 0.0)
        return out.sort_values(COL["inv"], ascending=False, ignore_index=True)

    # --------------------------------------------------------------------------
    # PivotTable4 (AE4:AF37) — AUM por Rank_rt x Plus_1  -> chart1
    # Reemplaza los ~30 GETPIVOTDATA de la columna AJ
    # --------------------------------------------------------------------------
    def aum_rank_x_plus1(self) -> pd.DataFrame:
        out = _agg(self.df, [COL["rank_rt"], COL["plus_1"]], [COL["inv"]])
        total = out[COL["inv"]].sum()
        out["% AUM"] = np.where(total, out[COL["inv"]] / total, 0.0)
        return out

    # --------------------------------------------------------------------------
    # PivotTable3 (AQ52:AS187) — mejores/peores contribuyentes BU + TD
    # Filtros: Estrategia in {BU, TD} ; Plus_1 not in {SOV, Alts} ; Huella != 0
    # --------------------------------------------------------------------------
    def contribuyentes_bu_td(self, top_n: int = 15) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
        d = self.df[
            self.df[COL["estrategia"]].isin(["BU", "TD"])
            & ~self.df[COL["plus_1"]].isin(["SOV", "Alts"])
        ]
        d = _sin_huella_cero(d)
        full = _agg(d, [COL["nombre"]], [COL["huella"], COL["intensidad_m"], COL["inv"]])
        total = full[COL["huella"]].sum()
        full["% Huella"] = np.where(total, full[COL["huella"]] / total, 0.0)
        full["Ranking"] = full[COL["huella"]].rank(ascending=False, method="first").astype(int)
        peores = full.head(top_n).reset_index(drop=True)
        mejores = full.tail(top_n).sort_values(COL["huella"]).reset_index(drop=True)
        return full, peores, mejores

    # --------------------------------------------------------------------------
    # PivotTable5 (Z80:AC88) — exposición a soberanos
    # Filtros: Plus in {ETF, SOV} ; Plus_1 == 'SOV' ; Huella != 0
    # --------------------------------------------------------------------------
    def soberanos(self) -> pd.DataFrame:
        d = self.df[
            self.df[COL["plus"]].isin(["ETF", "SOV"])
            & (self.df[COL["plus_1"]] == "SOV")
        ]
        d = _sin_huella_cero(d)
        out = _agg(d, [COL["nombre"]], METRICAS)
        tot_h = out[COL["huella"]].sum()
        tot_i = out[COL["inv"]].sum()
        out["% Huella"] = np.where(tot_h, out[COL["huella"]] / tot_h, 0.0)
        out["% AUM"] = np.where(tot_i, out[COL["inv"]] / tot_i, 0.0)
        # Intensidad implícita del emisor soberano (Tn CO2 / USD MM)
        out["Intensidad implícita"] = np.where(
            out[COL["inv"]] != 0, out[COL["huella"]] / out[COL["inv"]], 0.0)
        return out

    # --------------------------------------------------------------------------
    # PivotTable2 (Z110:AB115) — informativo: Estrategia x Plus_1
    # Filtros: Plus not in {Cash, #N/A, Cuestionario Integra} ; Huella != 0
    # --------------------------------------------------------------------------
    def estrategia_x_plus1(self) -> pd.DataFrame:
        d = self.df[~self.df[COL["plus"]].isin(["Cash", "#N/A", "nan", "Cuestionario Integra"])]
        d = _sin_huella_cero(d)
        return _agg(d, [COL["estrategia"], COL["plus_1"]],
                    [COL["huella"], COL["intensidad_m"], COL["inv"]])

    # --------------------------------------------------------------------------
    # PivotTable8 (ED50:EF241) — peores contribuyentes GENERAL (sin filtro de huella)
    # Filtros: Plus not in {Cash, Cuestionario Integra}
    # --------------------------------------------------------------------------
    def contribuyentes_general(self, top_n: int = 20) -> tuple[pd.DataFrame, pd.DataFrame]:
        d = self.df[~self.df[COL["plus"]].isin(["Cash", "Cuestionario Integra"])]
        full = _agg(d, [COL["nombre"]], [COL["huella"], COL["inv"]])
        total = full[COL["huella"]].sum()
        full["% Huella"] = np.where(total, full[COL["huella"]] / total, 0.0)
        full["Intensidad implícita"] = np.where(
            full[COL["inv"]] != 0, full[COL["huella"]] / full[COL["inv"]], 0.0)
        full["Ranking"] = full[COL["huella"]].rank(ascending=False, method="first").astype(int)
        return full, full.head(top_n).reset_index(drop=True)

    # --------------------------------------------------------------------------
    # PivotTables 10/13/14/16/17 (BH60, BN60, BT60, BZ60, CF61)
    # Bloques de resumen que alimentaban DP80:DT84 -> charts 14/15/16/17
    # --------------------------------------------------------------------------
    def _bloque(self, nombre: str, mask: pd.Series, por_tipo_renta: bool) -> pd.DataFrame:
        d = _sin_huella_cero(self.df[mask])
        keys = ([COL["tipo_renta"], COL["nombre"]] if por_tipo_renta else [COL["nombre"]])
        det = _agg(d, keys, METRICAS)
        det.insert(0, "Bloque", nombre)
        return det

    def bloques_estrategia(self) -> dict[str, pd.DataFrame]:
        f = self.df
        specs = {
            "BU Portafolio": (f[COL["estrategia"]].eq("BU") & f[COL["plus"]].eq("Portafolio"), False),
            "BU Proxies": (f[COL["estrategia"]].eq("BU") & f[COL["plus"]].eq("Proxies"), False),
            "TD Portafolio/ETF": (f[COL["estrategia"]].eq("TD")
                                  & f[COL["plus"]].isin(["ETF", "Portafolio"])
                                  & ~f[COL["plus_1"]].isin(["BU", "Alts"]), True),
            "TD Proxies": (f[COL["estrategia"]].eq("TD") & f[COL["plus"]].eq("Proxies")
                           & ~f[COL["plus_1"]].isin(["BU", "Alts"]), True),
            "ALT Proxies": (f[COL["estrategia"]].eq("ALT") & f[COL["plus"]].eq("Proxies")
                            & f[COL["plus_1"]].eq("Alts"), True),
        }
        return {k: self._bloque(k, m, tr) for k, (m, tr) in specs.items()}

    def resumen_bloques(self) -> pd.DataFrame:
        """Equivalente al bloque DP53:DU84 (Huella en miles Tn + Intensidad)."""
        filas = []
        for nombre, det in self.bloques_estrategia().items():
            if det.empty:
                filas.append({"Bloque": nombre, "Huella": 0.0,
                              "Huella (miles Tn)": 0.0, "Intensidad": 0.0,
                              "Intensidad-M": 0.0, "Inv MM$": 0.0})
                continue
            filas.append({
                "Bloque": nombre,
                "Huella": det[COL["huella"]].sum(),
                "Huella (miles Tn)": det[COL["huella"]].sum() / 1000,
                "Intensidad": det[COL["intensidad"]].sum(),
                "Intensidad-M": det[COL["intensidad_m"]].sum(),
                "Inv MM$": det[COL["inv"]].sum(),
            })
        out = pd.DataFrame(filas)
        out.loc[len(out)] = {
            "Bloque": "TOTAL",
            "Huella": out["Huella"].sum(),
            "Huella (miles Tn)": out["Huella (miles Tn)"].sum(),
            "Intensidad": out["Intensidad"].sum(),
            "Intensidad-M": out["Intensidad-M"].sum(),
            "Inv MM$": out["Inv MM$"].sum(),
        }
        return out

    # --------------------------------------------------------------------------
    # Vistas adicionales para el dashboard (sector / país / tipo de renta)
    # Reemplazan los bloques hardcodeados AD54:AE94 del Excel
    # --------------------------------------------------------------------------
    def por_dimension(self, col_dim: str, etiqueta: str) -> pd.DataFrame:
        if col_dim not in self.df.columns:
            return pd.DataFrame(columns=[etiqueta] + METRICAS)
        d = _sin_huella_cero(self.df)
        out = _agg(d, [col_dim], METRICAS).rename(columns={col_dim: etiqueta})
        tot = out[COL["huella"]].sum()
        out["% Huella"] = np.where(tot, out[COL["huella"]] / tot, 0.0)
        return out


    # --------------------------------------------------------------------------
    # Charts 52 y 63 (bloque DN53:DU68) — Huella / Intensidad por categoría,
    # partida en MSCI vs Proxies.
    # Materials y Utilities salen del sector de Parametria (col O -> col P);
    # "Otros" es el residuo del BU; RF/RV vienen de TD por TIPO_RENTA;
    # Alts de la estrategia ALT.
    # --------------------------------------------------------------------------
    def sector_msci_vs_proxies(self) -> pd.DataFrame:
        d = _sin_huella_cero(self.df)
        met = [COL["huella"], COL["intensidad"], COL["intensidad_m"], COL["inv"]]
        met = [m for m in met if m in d.columns]

        def suma(sub) -> dict:
            return {m: float(sub[m].sum()) for m in met}

        bu = d[d[COL["estrategia"]].eq("BU")]
        bu_msci = bu[bu[COL["plus"]].eq("Portafolio")].copy()
        bu_prox = bu[bu[COL["plus"]].eq("Proxies")].copy()
        for sub in (bu_msci, bu_prox):
            if not sub.empty:
                sub["__sector"] = (sub[COL["nombre"]].map(self.sector_lookup)
                                   .fillna("Otros"))
            else:
                sub["__sector"] = pd.Series(dtype=object)

        td = d[d[COL["estrategia"]].eq("TD")
               & ~d[COL["plus_1"]].isin(["BU", "Alts"])]
        td_msci = td[td[COL["plus"]].isin(["ETF", "Portafolio"])]
        td_prox = td[td[COL["plus"]].eq("Proxies")]
        alt = d[d[COL["estrategia"]].eq("ALT")
                & d[COL["plus"]].eq("Proxies")
                & d[COL["plus_1"]].eq("Alts")]

        filas = []

        def agrega(bloque, categoria, sub):
            filas.append({"Bloque": bloque, "Categoria": categoria, **suma(sub)})

        for bloque, base in (("MSCI", bu_msci), ("Proxies", bu_prox)):
            tot = suma(base)
            for cat in ("Materials", "Utilities"):
                agrega(bloque, cat, base[base["__sector"].eq(cat)])
            usados = base[base["__sector"].isin(["Materials", "Utilities"])]
            filas.append({"Bloque": bloque, "Categoria": "Otros",
                          **{m: tot[m] - float(usados[m].sum()) for m in met}})

        agrega("MSCI", "RF", td_msci[td_msci[COL["tipo_renta"]].eq("RENTA FIJA")])
        agrega("Proxies", "RF Proxies",
               td_prox[td_prox[COL["tipo_renta"]].eq("RENTA FIJA")])
        agrega("MSCI", "RV", td_msci[td_msci[COL["tipo_renta"]].eq("RENTA VARIABLE")])
        agrega("Proxies", "RV Proxies",
               td_prox[td_prox[COL["tipo_renta"]].eq("RENTA VARIABLE")])
        agrega("Proxies", "Alts", alt)

        out = pd.DataFrame(filas)
        # DIM_1 = Categoria, DIM_2 = Bloque (así lo consume el dashboard).
        out = out[["Categoria", "Bloque"] + met]
        out["__ord"] = out["Categoria"].map(
            {c: i for i, c in enumerate(CATEGORIAS_SECTOR)}).fillna(99)
        return (out.sort_values(["__ord", "Bloque"])
                   .drop(columns="__ord").reset_index(drop=True))

    # --------------------------------------------------------------------------
    # Charts 49, 48 y 39 — portafolio vs benchmarks.
    # Huella comparable = Intensidad del ETF x AUM del ETF (USD MM). Sin escalar
    # (el Market Cap de la hoja MKT ya viene en millones).
    # --------------------------------------------------------------------------
    def comparables(self) -> pd.DataFrame:
        d = _sin_huella_cero(self.df)
        filas = [{
            "Serie": "Integra",
            COL["huella"]: float(d[COL["huella"]].sum()),
            COL["intensidad"]: float(d[COL["intensidad"]].sum()),
            "AUM MM": float(d[COL["inv"]].sum()),
        }]
        for alias in ("ACWI", "ILF", "CEMB", "EMB"):
            if alias not in self.intensidades_comp:
                continue
            inten = float(self.intensidades_comp[alias])
            aum = float(self.aum_comp.get(alias, 0.0))
            filas.append({"Serie": alias,
                          COL["huella"]: aum * inten,
                          COL["intensidad"]: inten,
                          "AUM MM": aum})
        return pd.DataFrame(filas)

    # --------------------------------------------------------------------------
    # Chart 58 (y 55 / 57) — soberanos por país: top N + "Otros".
    # --------------------------------------------------------------------------
    def soberanos_por_pais(self, top_n: int = 4) -> pd.DataFrame:
        sob = self.soberanos()
        if sob.empty:
            return pd.DataFrame(columns=["Pais"] + METRICAS)
        sob = sob.copy()
        sob["Pais"] = sob[COL["nombre"]].map(PAIS_POR_EMISOR_SOBERANO).fillna("Otros")
        met = [m for m in [COL["huella"], COL["intensidad"],
                           COL["intensidad_m"], COL["inv"]] if m in sob.columns]
        out = (sob.groupby("Pais", dropna=False)[met].sum()
                  .sort_values(COL["huella"], ascending=False).reset_index())
        if len(out) > top_n:
            cabeza = out.head(top_n).copy()
            resto = out.tail(len(out) - top_n)
            cabeza.loc[len(cabeza)] = {"Pais": "Otros",
                                       **{m: float(resto[m].sum()) for m in met}}
            out = cabeza
        return out.reset_index(drop=True)

    # --------------------------------------------------------------------------
    # ORQUESTADOR
    # --------------------------------------------------------------------------
    def build_all(self) -> dict[str, pd.DataFrame]:
        full_bu_td, peores_bu_td, mejores_bu_td = self.contribuyentes_bu_td()
        full_gen, peores_gen = self.contribuyentes_general()

        o = {
            "AUM_por_Rank": self.aum_por_rank(),
            "AUM_Rank_x_Plus1": self.aum_rank_x_plus1(),
            "Contrib_BU_TD": full_bu_td,
            "Contrib_BU_TD_Peores": peores_bu_td,
            "Contrib_BU_TD_Mejores": mejores_bu_td,
            "Soberanos": self.soberanos(),
            "Estrategia_x_Plus1": self.estrategia_x_plus1(),
            "Contrib_General": full_gen,
            "Contrib_General_Peores": peores_gen,
            "Resumen_Bloques": self.resumen_bloques(),
            "Detalle_Bloques": pd.concat(self.bloques_estrategia().values(), ignore_index=True),
            "Por_Tipo_Renta": self.por_dimension(COL["tipo_renta"], "Tipo de Renta"),
            "Por_Estrategia": self.por_dimension(COL["estrategia"], "Estrategia"),
            "Por_Grupo_Economico": self.por_dimension(COL["grupo_econ"], "Grupo Económico"),
            "Sector_MSCI_Proxies": self.sector_msci_vs_proxies(),
            "Comparables": self.comparables(),
            "Soberanos_Por_Pais": self.soberanos_por_pais(),
        }
        for k, v in o.items():
            v.insert(0, "FECHA_CORTE", self.fecha_corte)
        self.objetos = o
        return o

    # --------------------------------------------------------------------------
    # Formato LARGO (tidy) — es lo que hace el histórico realmente explotable
    # FECHA_CORTE | OBJETO | DIM_1 | DIM_2 | METRICA | VALOR
    # --------------------------------------------------------------------------
    def to_long(self) -> pd.DataFrame:
        if not self.objetos:
            self.build_all()
        filas = []
        for nombre, df in self.objetos.items():
            if df.empty:
                continue
            metricas = [c for c in df.columns
                        if pd.api.types.is_numeric_dtype(df[c]) and c != "FECHA_CORTE"]
            dims = [c for c in df.columns if c not in metricas + ["FECHA_CORTE"]]
            tmp = df.melt(id_vars=["FECHA_CORTE"] + dims,
                          value_vars=metricas, var_name="METRICA", value_name="VALOR")
            tmp["OBJETO"] = nombre
            tmp["DIM_1"] = tmp[dims[0]].astype(str) if len(dims) >= 1 else ""
            tmp["DIM_2"] = tmp[dims[1]].astype(str) if len(dims) >= 2 else ""
            tmp["DIM_3"] = tmp[dims[2]].astype(str) if len(dims) >= 3 else ""
            filas.append(tmp[["FECHA_CORTE", "OBJETO", "DIM_1", "DIM_2", "DIM_3",
                              "METRICA", "VALOR"]])
        return pd.concat(filas, ignore_index=True) if filas else pd.DataFrame()


# ==============================================================================
# EXPORTADOR HISTÓRICO
# Una hoja por fecha de corte + hoja HISTORICO acumulada (formato largo)
# Idempotente: reescribe la hoja del corte si ya existe, nunca duplica
# ==============================================================================
class HistoricoExporter:

    HOJA_HISTORICO = "HISTORICO"
    HOJA_META = "_META"

    def __init__(self, ruta_excel: str):
        self.ruta = ruta_excel

    def _leer_existente(self) -> dict[str, pd.DataFrame]:
        if not os.path.exists(self.ruta):
            return {}
        try:
            return pd.read_excel(self.ruta, sheet_name=None, engine="openpyxl")
        except Exception:
            return {}

    def exportar(self, builder: PresentacionBuilder) -> str:
        corte = builder.fecha_corte
        largo_nuevo = builder.to_long()
        hojas = self._leer_existente()

        # --- HISTORICO acumulado: se purga el corte y se reinserta ---
        hist_prev = hojas.get(self.HOJA_HISTORICO, pd.DataFrame())
        if not hist_prev.empty and "FECHA_CORTE" in hist_prev.columns:
            hist_prev = hist_prev[hist_prev["FECHA_CORTE"].astype(str) != corte]
        historico = (pd.concat([hist_prev, largo_nuevo], ignore_index=True)
                     if not hist_prev.empty else largo_nuevo)
        historico = historico.sort_values(
            ["FECHA_CORTE", "OBJETO", "METRICA"], ignore_index=True)

        # --- Hoja ancha del corte (todos los objetos apilados) ---
        hoja_corte = largo_nuevo.copy()

        # --- Metadata de trazabilidad ---
        meta_prev = hojas.get(self.HOJA_META, pd.DataFrame())
        if not meta_prev.empty and "FECHA_CORTE" in meta_prev.columns:
            meta_prev = meta_prev[meta_prev["FECHA_CORTE"].astype(str) != corte]
        meta_new = pd.DataFrame([{
            "FECHA_CORTE": corte,
            "GENERADO": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "N_REGISTROS_FUENTE": len(builder.df),
            "HUELLA_TOTAL": builder.df[COL["huella"]].sum(),
            "AUM_TOTAL_MM": builder.df[COL["inv"]].sum(),
            "EXCLUIR_HUELLA_CERO": EXCLUIR_HUELLA_CERO,
            "PORTAFOLIOS": ", ".join(PORTAFOLIOS_VALIDOS),
        }])
        meta = pd.concat([meta_prev, meta_new], ignore_index=True) if not meta_prev.empty else meta_new

        # --- Reescritura completa preservando cortes previos ---
        otros = {k: v for k, v in hojas.items()
                 if k not in (self.HOJA_HISTORICO, self.HOJA_META, corte)}

        with pd.ExcelWriter(self.ruta, engine="openpyxl") as xw:
            historico.to_excel(xw, sheet_name=self.HOJA_HISTORICO, index=False)
            meta.to_excel(xw, sheet_name=self.HOJA_META, index=False)
            hoja_corte.to_excel(xw, sheet_name=str(corte)[:31], index=False)
            for nombre, df in sorted(otros.items(), reverse=True):
                df.to_excel(xw, sheet_name=str(nombre)[:31], index=False)

        return self.ruta

    def cargar_historico(self) -> pd.DataFrame:
        """Insumo directo del dashboard (M14): serie completa en formato largo."""
        hojas = self._leer_existente()
        return hojas.get(self.HOJA_HISTORICO, pd.DataFrame())


