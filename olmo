def construir_valorizacion(cfg: "Config", verbose: bool = True):
    """Módulos 1..10 de Huella1. Devuelve (df_valorizacion, contexto)."""
    reader = QueryReader(cfg)
    data = reader.read_all()

    caja = CajaLoader(data.caja).build()                       # Módulo 2
    tc = TipoCambioLoader(data.tipo_cambio).build()            # Módulo 3
    aum_mm = caja.aum_multifondos_mm(tc.usd_rate())            # K10 de la hoja
    if verbose:
        print(f"  [Módulo 2] AUM multifondos = {aum_mm:,.2f} USD MM "
              f"(TC {tc.usd_rate()})")

    # Módulo 5 (Parametria se lee directa del workbook; input manual)
    parametria_lookup = ParametriaBuilder.leer_parametria_directa(cfg)
    try:
        sector_lookup = ParametriaBuilder.leer_sector_buckets(cfg)
    except Exception:
        sector_lookup = {}

    bd = BDMSCIBuilder(cfg).build()                            # Módulo 6
    bd.append_proxies(cfg.path_proxies)
    bd_t1 = BDMSCITMinus1(cfg).build()                         # Módulo 7

    perd = PerdieronHuellaLoader(cfg).build()                  # Módulo 8
    perd_lookup = perd.as_intensidad_lookup() if not perd.df.empty else {}

    px = ProxyEngine(cfg).load()                               # Módulo 9
    intensidad_post = px.apply_to_bd(bd.as_intensidad_lookup())

    vb = ValorizacionBuilder(                                  # Módulo 10
        data.valorizacion,
        caja_map=caja.as_map(),
        usd_rate=tc.usd_rate(),
        parametria_lookup=parametria_lookup,
        intensidad_post=intensidad_post,
        plus_lookup=bd.as_plus_lookup(),
        intensidad_t1=bd_t1.as_intensidad_lookup(),
        proxy_engine=px,
        perdieron_lookup=perd_lookup,
        perdieron_mode="fill",
        attrs_lookup=bd.as_attrs_lookup(),
        aum_multifondos_mm=aum_mm,
        verbose=verbose,
    )
    vb.build()

    ctx = {
        "config": cfg, "caja": caja, "tipo_cambio": tc, "bd": bd, "bd_t1": bd_t1,
        "proxies": px, "perdieron": perd, "sector_lookup": sector_lookup,
        "aum_multifondos_mm": aum_mm,
        "valorizacion_builder": vb,
        "market_cap_loader": _market_cap_seguro(cfg, verbose),
        "herencias": vb.get_inherited_history(),
    }
    return vb.df, ctx


def _market_cap_seguro(cfg: "Config", verbose: bool = True):
    """MarketCapLoader sobre la hoja MKT. No debe abortar el pipeline."""
    try:
        return MarketCapLoader(cfg, verbose=verbose).build()
    except Exception as exc:
        if verbose:
            print(f"  [MarketCap] [AVISO] no disponible: {exc}")
        return None


def run_pipeline(semestre: str,
                 output_dir: str = OUTPUT_DIR_DEFAULT,
                 ruta_historico: Optional[str] = None,
                 ruta_dashboard: Optional[str] = None,
                 verbose: bool = True):
    """Corrida completa de punta a punta para un semestre."""
    out = FsPath(str(output_dir))
    out.mkdir(parents=True, exist_ok=True)
    ruta_historico = ruta_historico or str(out / NOMBRE_HISTORICO)
    ruta_dashboard = ruta_dashboard or str(out / NOMBRE_DASHBOARD)

    cfg = Config.from_semestre(semestre)
    if verbose:
        print(cfg.summary())
        cfg.print_refresh_reminder()
    faltantes = cfg.check_paths(verbose=verbose)
    cfg.validate_workbook_b1(verbose=verbose)
    if "path_workbook" in faltantes:
        raise SystemExit(">>> Falta el workbook refrescado. Deposítalo y reintenta.")

    # --- Módulos 1..10 -------------------------------------------------------
    val, ctx = construir_valorizacion(cfg, verbose=verbose)

    # --- Módulo 12: pivots (PresentacionBuilder de Huella2) ------------------
    comp = ComparablesLoader(cfg, verbose=verbose).build()
    mkt = ctx.get("market_cap_loader")
    pres = PresentacionBuilder(
        val, cfg.semestre,
        sector_lookup=ctx.get("sector_lookup", {}),
        intensidades_comp=comp.intensidades,
        aum_comp=(mkt.aum if mkt is not None else {}),
    )
    objetos = pres.build_all()
    if verbose:
        print(f"  [Módulo 12] {len(objetos)} objetos construidos "
              f"({len(pres.df)} registros tras filtros de pivot).")

    # --- Módulo 13: histórico estructurado (una hoja por corte) --------------
    exp = HistoricoExporter(ruta_historico)
    exp.exportar(pres)
    if verbose:
        print(f"  [Módulo 13] Histórico -> {ruta_historico}")

    # --- Módulo 14: dashboard ------------------------------------------------
    construir_dashboard(ruta_historico, ruta_dashboard)

    return {"config": cfg, "valorizacion": val, "objetos": objetos,
            "historico": exp.cargar_historico(), "contexto": ctx,
            "ruta_historico": ruta_historico, "ruta_dashboard": ruta_dashboard}


if __name__ == "__main__":

    # ===================== AJUSTES DEL USUARIO ==============================
    SEMESTRE = "202606"                 # semestre en revisión (yyyymm)
    OUTPUT_DIR = OUTPUT_DIR_DEFAULT     # Z:\...\Python\Output
    # ========================================================================

    resultado = run_pipeline(SEMESTRE, output_dir=OUTPUT_DIR)
    print("\nListo:")
    print("  Histórico :", resultado["ruta_historico"])
    print("  Dashboard :", resultado["ruta_dashboard"])
