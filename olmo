def _semestre_anterior(semestre: str) -> str:
    """Misma alternancia 06<->12 que Config.semestre_t1 (Módulo 0 de Huella1)."""
    s = str(semestre)
    try:
        anio, mm = int(s[:4]), s[4:6]
    except Exception:
        return s
    return f"{anio - 1}12" if mm == "06" else f"{anio}06"


