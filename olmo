#   COMPARABLES LOADER — intensidad de los ETF benchmark                      #
#   Fuente: Comparables MSCI - Huella.xlsx (una hoja por semestre).           #
#   Columna usada: C = FUND_FINANCED_CARBON_EMISSIONS (confirmado contra el   #
#   valor del ILF, 109.30923404, del reporte). ISIN en la columna E.          #
#                                                                             #
###############################################################################

class ComparablesLoader:
    """Intensidad de carbono de ACWI, ILF, CEMB y EMB para el semestre."""

    COL_ISIN = "FUND_ISIN"
    COL_INTENSIDAD = "FUND_FINANCED_CARBON_EMISSIONS"          # col C (oficial)
    COL_INTENSIDAD_ALT = "FUND_WEIGHTED_AVG_SOV_CARBON_INTEN"  # col D (alterna)

    def __init__(self, config: Config, usar_columna_sov: bool = False,
                 verbose: bool = True):
        self.config = config
        self.path = getattr(config, "path_comparables", None)
        self.col_valor = (self.COL_INTENSIDAD_ALT if usar_columna_sov
                          else self.COL_INTENSIDAD)
        self.verbose = verbose
        self.intensidades: Dict[str, float] = {}   # alias -> intensidad
        self.hoja_usada: Optional[str] = None

    def _elegir_hoja(self, hojas: List[str]) -> str:
        """Hoja del semestre; si no existe, la más reciente que no lo supere."""
        s = str(self.config.semestre)
        if s in hojas:
            return s
        candidatas = sorted([h for h in hojas if str(h).isdigit() and str(h) <= s])
        if candidatas:
            if self.verbose:
                print(f"  [Comparables] [AVISO] no existe la hoja {s}; "
                      f"se usa {candidatas[-1]}.")
            return candidatas[-1]
        raise KeyError(f"Comparables: ninguna hoja utilizable para {s}. "
                       f"Disponibles: {hojas}")

    def build(self) -> "ComparablesLoader":
        if not self.path or not os.path.exists(self.path):
            if self.verbose:
                print(f"  [Comparables] [AVISO] no se encuentra {self.path}")
            return self
        hojas = pd.ExcelFile(self.path, engine="openpyxl").sheet_names
        self.hoja_usada = self._elegir_hoja([str(h) for h in hojas])
        df = pd.read_excel(self.path, sheet_name=self.hoja_usada, engine="openpyxl")
        df.columns = [str(c).strip() for c in df.columns]
        if self.col_valor not in df.columns:
            raise KeyError(f"Comparables: falta la columna {self.col_valor}. "
                           f"Columnas: {list(df.columns)}")
        for _, r in df.iterrows():
            isin = str(r.get(self.COL_ISIN, "")).strip()
            ticker = ISIN_A_TICKER.get(isin)
            if not ticker:
                continue
            val = pd.to_numeric(r.get(self.col_valor), errors="coerce")
            if pd.notna(val):
                self.intensidades[TICKER_A_ALIAS[ticker]] = float(val)
        if self.verbose:
            print(f"  [Comparables] hoja {self.hoja_usada} | "
                  f"{ {k: round(v, 2) for k, v in self.intensidades.items()} }")
        return self


