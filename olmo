            print(f"  [Módulo 8] 'Perdieron Huella' -> {len(df)} instrumentos.")
        return self

    def as_intensidad_lookup(self) -> Dict[str, float]:
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        if self.df.empty:
            return {}
        tmp = self.df[[PH_COL_CLIENT_ID, PH_COL_INTENSIDAD]].dropna(
            subset=[PH_COL_CLIENT_ID]).drop_duplicates(PH_COL_CLIENT_ID, keep="first")
        return dict(zip(tmp[PH_COL_CLIENT_ID], tmp[PH_COL_INTENSIDAD]))

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None


