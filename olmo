#                                                                             #
#   MÓDULO 4 — G&P DETALLADO LOADER                                           #
#   Lee G&P_MLab_MMYYYY.xlsm hoja 'Detallado' en read_only, SOLO cols B/D/F/Q. #
#   Archivo ~120MB; se acota la ventana de columnas (R3).                     #
#     SBS<-B (llave) | NOMBRE<-D | ASSET_CLASS<-F | RANK_RT<-Q                 #
#                                                                             #
###############################################################################

GYP_SHEET_DETALLADO = "Detallado"
GYP_COL_SBS = "B"
GYP_COL_NOMBRE = "D"
GYP_COL_ASSET_CLASS = "F"
GYP_COL_RANK_RT = "Q"
GYP_HEADER_ROWS = 1


def _col_letter_to_idx(letter: str) -> int:
    """'A'->1, 'B'->2, ... (1-based)."""
    letter = str(letter).strip().upper()
    idx = 0
    for ch in letter:
        if not ("A" <= ch <= "Z"):
            raise ValueError(f"Letra inválida: {letter!r}")
        idx = idx * 26 + (ord(ch) - ord("A") + 1)
    return idx


class GyPDetalladoLoader:
    """Extrae de G&P (Detallado) las 4 columnas que consume Parametria."""

    def __init__(self, config: Config, verbose: bool = True,
                 col_sbs: str = GYP_COL_SBS, col_nombre: str = GYP_COL_NOMBRE,
                 col_asset_class: str = GYP_COL_ASSET_CLASS,
                 col_rank_rt: str = GYP_COL_RANK_RT, header_rows: int = GYP_HEADER_ROWS):
        self.config = config
        self.verbose = verbose
        self.path = getattr(config, "path_gyp", None)
        self._cols = {
            "SBS": _col_letter_to_idx(col_sbs),
            "NOMBRE": _col_letter_to_idx(col_nombre),
            "ASSET_CLASS": _col_letter_to_idx(col_asset_class),
            "RANK_RT": _col_letter_to_idx(col_rank_rt),
        }
        self.header_rows = header_rows
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        self._guard_file()
        import openpyxl
        min_col = min(self._cols.values())
        max_col = max(self._cols.values())
        offsets = {name: (idx - min_col) for name, idx in self._cols.items()}
        if self.verbose:
            print(f"  [Módulo 4] Abriendo G&P (read_only), cols {min_col}..{max_col}. "
                  f"Puede tardar (~120MB)...")
        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            real = self._resolve_sheet(wb.sheetnames, GYP_SHEET_DETALLADO)
            if real is None:
                wb.close()
                raise ValueError(f"G&P: no existe hoja '{GYP_SHEET_DETALLADO}'. "
                                 f"Hojas: {wb.sheetnames}")
            ws = wb[real]
            registros = []
            for i, row in enumerate(
                    ws.iter_rows(min_col=min_col, max_col=max_col, values_only=True)):
                if i < self.header_rows:
                    continue
                sbs = row[offsets["SBS"]] if offsets["SBS"] < len(row) else None
                sbs = _to_string(sbs)
                if sbs in (None, ""):
                    continue
                registros.append({
                    "SBS": sbs,
                    "NOMBRE": row[offsets["NOMBRE"]] if offsets["NOMBRE"] < len(row) else None,
                    "ASSET_CLASS": row[offsets["ASSET_CLASS"]] if offsets["ASSET_CLASS"] < len(row) else None,
                    "RANK_RT": row[offsets["RANK_RT"]] if offsets["RANK_RT"] < len(row) else None,
                })
        finally:
            wb.close()
        df = pd.DataFrame(registros, columns=["SBS", "NOMBRE", "ASSET_CLASS", "RANK_RT"])
        df = df.drop_duplicates("SBS", keep="first").reset_index(drop=True)
        if self.verbose:
            print(f"  [Módulo 4] Detallado -> {len(df)} SBS únicos.")
        self.df = df
        return self

    def as_lookup(self) -> Dict[str, dict]:
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_lookup().")
        return self.df.set_index("SBS").to_dict("index")

    def _guard_file(self) -> None:
        mmyyyy = getattr(self.config, "mmyyyy", "MMYYYY")
        if not self.path:
            raise ValueError("Config no define path_gyp.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(
                f"No encuentro el G&P (tarea manual del usuario): deposita\n"
                f"  'G&P_MLab_{mmyyyy}.xlsm'\nen:\n  {self.path}")

    @staticmethod
    def _resolve_sheet(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None


###############################################################################
#                                                                             #
#   MÓDULO 5 — PARAMETRIA BUILDER                                             #
#   Replica fórmulas de Parametria desde G&P (Módulo 4). Llave SBS.            #
#     H(Nombre)<-Detallado!D | D(Asset)<-F | E(Rank)<-Q                        #
#     G(Codigo)=LEFT(C,2)&E | J(RANKEST)=IF(E="ALT",LEFT(E,3),LEFT(E,3)&F)     #
#   Además: leer_sector_buckets() -> tabla Name->Sector (cols O:P) para M12.   #
#                                                                             #
###############################################################################

class ParametriaBuilder:
    """DataFrame Parametria (llave SBS) desde el lookup de G&P."""

    def __init__(self, gyp_lookup: Dict[str, dict],
                 sbs_list: Optional[List[str]] = None,
                 riesgos_map: Optional[Dict[str, str]] = None,
                 verbose: bool = True):
        self.gyp = gyp_lookup
        self.sbs_list = sbs_list
        self.riesgos_map = riesgos_map or {}
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        sbs_universe = ([_to_string(s) for s in self.sbs_list]
                        if self.sbs_list is not None else list(self.gyp.keys()))
        seen = set()
        sbs_universe = [s for s in sbs_universe
                        if s not in (None, "") and not (s in seen or seen.add(s))]
        registros, no_encontrados = [], []
        for sbs in sbs_universe:
            info = self.gyp.get(sbs)
            if info is None:
                no_encontrados.append(sbs)
                nombre = asset_class = rank_rt = None
            else:
                nombre = info.get("NOMBRE")
                asset_class = info.get("ASSET_CLASS")
                rank_rt = info.get("RANK_RT")
            e = _to_string(rank_rt)
            f = self.riesgos_map.get(sbs)
            registros.append({
                "SBS": sbs, "ASSET_CLASS": asset_class, "RANK_RT": e,
                "RIESGOS": f, "CODIGO": self._codigo(sbs, e),
                "NOMBRE": nombre, "RANKEST": self._rankest(e, f),
            })
        df = pd.DataFrame(registros, columns=["SBS", "ASSET_CLASS", "RANK_RT",
                                              "RIESGOS", "CODIGO", "NOMBRE", "RANKEST"])
        self.df = df
        if self.verbose:
            print(f"  [Módulo 5] Parametria -> {len(df)} filas (SBS).")
            if no_encontrados:
                print(f"  [AVISO] {len(no_encontrados)} SBS sin match en G&P. "
                      f"Ej: {no_encontrados[:8]}")
        return self

    @staticmethod
    def _codigo(sbs, e):
        c = _to_string(sbs) or ""
        e = e or ""
        left2 = c[:2]
        return f"{left2}{e}" if (left2 or e) else None

    @staticmethod
    def _rankest(e, f):
        e = _to_string(e)
        if e in (None, ""):
            return None
        left3 = e[:3]
        if e.upper() == "ALT":
            return left3
        return f"{left3}{_to_string(f) or ''}"

    def as_lookup(self) -> Dict[str, dict]:
        if self.df is None:
            raise RuntimeError("Llama build() antes de as_lookup().")
        return self.df.set_index("SBS").to_dict("index")

    @staticmethod
    def leer_parametria_directa(config, verbose: bool = True) -> Dict[str, dict]:
        """Lee Parametria (INPUT MANUAL del usuario) directo del workbook, por SBS.
        Devuelve {SBS -> {NOMBRE(H), CODIGO(G), RIESGOS(F), RANKEST(J)}}.
        Headers fila 8, datos fila 9+. Cols: C=SBS, F=Riesgos(Estrategia),
        G=Codigo(Categoria), H=Nombre, J=RANKEST(Rank_rt).
        Se lee directo (no se recalcula) porque Parametria es responsabilidad
        manual del usuario y sus valores son la fuente de verdad."""
        path = getattr(config, "path_workbook", None)
        out: Dict[str, dict] = {}
        if not path or not os.path.exists(path):
            if verbose:
                print("  [Módulo 5] [AVISO] Sin workbook; Parametria directa vacía.")
            return out
        import openpyxl
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        try:
            if "Parametria" not in wb.sheetnames:
                if verbose:
                    print("  [Módulo 5] [AVISO] No existe la hoja 'Parametria'.")
                return out
            ws = wb["Parametria"]
            for row in ws.iter_rows(min_row=9, values_only=True):
                sbs = _to_string(row[2]) if len(row) > 2 else None      # C
                if not sbs:
                    continue
                out.setdefault(sbs, {
                    "RIESGOS": _to_string(row[5]) if len(row) > 5 else None,   # F
                    "CODIGO":  _to_string(row[6]) if len(row) > 6 else None,   # G
                    "NOMBRE":  row[7] if len(row) > 7 else None,               # H
                    "RANKEST": _to_string(row[9]) if len(row) > 9 else None,   # J
                })
        finally:
            wb.close()
        if verbose:
            print(f"  [Módulo 5] Parametria directa (input manual): {len(out)} SBS.")
        return out

    @staticmethod
    def leer_sector_buckets(config, verbose: bool = True) -> Dict[str, str]:
        """Tabla Name->Sector de Parametria (cols O:P, fila 9+).
        Devuelve {nombre_emisor_normalizado -> sector_crudo}."""
        path = getattr(config, "path_workbook", None)
        out: Dict[str, str] = {}
        if not path or not os.path.exists(path):
            if verbose:
                print("  [Módulo 5] [AVISO] Sin workbook; sector-buckets vacío.")
            return out
        import openpyxl
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        try:
            if "Parametria" not in wb.sheetnames:
                return out
            ws = wb["Parametria"]
            for row in ws.iter_rows(min_row=9, values_only=True):
                name = row[14] if len(row) > 14 else None   # col O
                sect = row[15] if len(row) > 15 else None    # col P
                n = _normalize(name)
                if n and sect:
                    out.setdefault(n, _to_string(sect))
        finally:
            wb.close()
        if verbose:
            print(f"  [Módulo 5] Sector-buckets (Name->Sector): {len(out)} emisores.")
        return out


###############################################################################
#                                                                             #
#   MÓDULO 6 — BD(MSCI) BUILDER                                              #
#   Base MSCI (hoja periodo): prepend A, B:V=A:U fuente, append W/X desde CAT. #
#   Reutilizable por Módulo 7 (T-1) con otra hoja.                            #
#                                                                             #
###############################################################################

BASE_MSCI_SOURCE_COLS: List[str] = [
    "Nombre", "Client_ID", "client1", "client2", "Valor", "País", "Sector",
    "EVIC", "CO2", "CO2/EVIC", "ESG", "E", "S", "G", "Controversia",
    "Co2/Sales", "Gov_pctl", "Rating", "CO2/Debt(Intensidad)", "%DebtPub", "CAT",
]
BD_COL_A = "A_MSCI"
BD_COL_INTENSIDAD = "CO2/Debt(Intensidad)"
BD_COL_CLIENT_ID = "Client_ID"
BD_COL_PLUS = "Plus"
BD_COL_PLUS_1 = "Plus_1"
BD_MSCI_COLS: List[str] = [BD_COL_A] + BASE_MSCI_SOURCE_COLS + [BD_COL_PLUS, BD_COL_PLUS_1]
BD_STRING_COLS = {BD_COL_A, BD_COL_CLIENT_ID, "client1", "client2", "Nombre",
                  "País", "Sector", "Rating", "CAT", BD_COL_PLUS, BD_COL_PLUS_1}
BD_NUMERIC_COLS = {"Valor", BD_COL_INTENSIDAD}


# Proxies -> filas que se AGREGAN a BD(MSCI) (además de sobrescribir intensidad).
# Bloque tipo reporte BD, headers FILA 3. Alts/TD en col V; BU en col U.
# Se resuelve por NOMBRE de header (robusto a cambios de posición).
PROXY_BD_SHEETS = ["Alts", "TD", "BU"]


class BDMSCIBuilder:
    """DataFrame BD(MSCI) desde Base MSCI (hoja periodo) + filas de Proxies."""

    def __init__(self, config: Config, sheet: Optional[str] = None, verbose: bool = True):
        self.config = config
        self.path = getattr(config, "path_base_msci", None)
        self.sheet = sheet if sheet is not None else getattr(config, "base_msci_sheet", None)
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        self._guard_file()
        import openpyxl
        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            if self.sheet not in wb.sheetnames:  # R11: match exacto
                wb.close()
                raise ValueError(f"Base MSCI: no existe hoja '{self.sheet}' (match exacto). "
                                 f"Hojas: {wb.sheetnames}")
            ws = wb[self.sheet]
            rows = list(ws.iter_rows(values_only=True))
        finally:
            wb.close()
        if not rows:
            raise ValueError(f"Base MSCI hoja '{self.sheet}' vacía.")
        data_rows = rows[1:]
        n_src = len(BASE_MSCI_SOURCE_COLS)
        idx_client1 = BASE_MSCI_SOURCE_COLS.index("client1")
        idx_cat = BASE_MSCI_SOURCE_COLS.index("CAT")
        idx_cid = BASE_MSCI_SOURCE_COLS.index("Client_ID")
        registros = []
        for row in data_rows:
            src = [row[i] if i < len(row) else None for i in range(n_src)]
            client_id = _to_string(src[idx_cid])
            if client_id in (None, ""):
                continue
            cat = src[idx_cat]
            reg = {BD_COL_A: self._deriv_a(src[idx_client1])}
            for name, val in zip(BASE_MSCI_SOURCE_COLS, src):
                reg[name] = val
            reg[BD_COL_PLUS] = self._plus(cat)
            reg[BD_COL_PLUS_1] = self._plus1(cat, reg[BD_COL_PLUS])
            registros.append(reg)
        df = pd.DataFrame(registros, columns=BD_MSCI_COLS)
        for col in df.columns:
            if col in BD_STRING_COLS:
                df[col] = df[col].map(_to_string)
            elif col in BD_NUMERIC_COLS:
                df[col] = df[col].map(_to_number)
        self.df = df
        if self.verbose:
            print(f"  [Módulo 6] BD(MSCI) hoja '{self.sheet}' -> {df.shape[0]}x{df.shape[1]}.")
        return self

    @staticmethod
    def _deriv_a(client1):
        s = _to_string(client1)
        return s[:6][-4:] if s not in (None, "") else None

    @staticmethod
    def _plus(cat):
        c = (_to_string(cat) or "").upper()
        if c in ("ETF_ETY", "ETF_SOV"):
            return "ETF"
        if c == "RF_SOV":
            return "SOV"
        if c == "-":
            return "Cuestionario Integra"
        return "Portafolio"

    @staticmethod
    def _plus1(cat, w):
        c = (_to_string(cat) or "").upper()
        if c == "ETF_ETY":
            return "Otros ETFs"
        if c == "ETF_SOV":
            return "Soberanos"
        return w

    def append_proxies(self, proxies_path: Optional[str] = None,
                       verbose: bool = True) -> "BDMSCIBuilder":
        """Agrega a BD(MSCI) las filas de Nueva Lista Proxies (hojas Alts/BU/TD).

        Reproduce el pegado manual del bloque V:AR (Alts/TD) o U:AQ (BU) en las
        columnas B:V de BD(MSCI), y recalcula A/W/X desde CAT. Si un Client_ID
        ya existe en BD, la fila de proxies MANDA (keep='last').
        Llamar DESPUÉS de build()."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de append_proxies().")
        path = proxies_path or getattr(self.config, "path_proxies", None)
        if not path or not os.path.exists(path):
            if verbose:
                print("  [Módulo 6] [AVISO] Proxies no encontrado; BD queda sin proxies.")
            return self
        import openpyxl
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        nuevas = []
        try:
            for sheet in PROXY_BD_SHEETS:
                real = self._resolve_sheet_generic(wb.sheetnames, sheet)
                if real is None:
                    if verbose:
                        print(f"  [Módulo 6] [AVISO] Proxies sin hoja '{sheet}'; omito.")
                    continue
                rows = list(wb[real].iter_rows(min_row=3, values_only=True))
                if len(rows) < 2:
                    continue
                header = list(rows[0])
                mapping, _ = _resolve_headers(
                    header, {c: [c] for c in BASE_MSCI_SOURCE_COLS})
                idx = {canon: i for i, canon in mapping.items()}
                if "Client_ID" not in idx:
                    if verbose:
                        print(f"  [Módulo 6] [AVISO] Hoja '{sheet}': sin Client_ID; omito.")
                    continue
                n_sheet = 0
                for row in rows[1:]:
                    i_cid = idx["Client_ID"]
                    cid = _to_string(row[i_cid]) if i_cid < len(row) else None
                    if cid in (None, ""):
                        continue
                    reg = {}
                    for name in BASE_MSCI_SOURCE_COLS:
                        i = idx.get(name)
                        reg[name] = row[i] if (i is not None and i < len(row)) else None
                    cat = reg.get("CAT")
                    reg[BD_COL_A] = self._deriv_a(reg.get("client1"))
                    reg[BD_COL_PLUS] = self._plus(cat)
                    reg[BD_COL_PLUS_1] = self._plus1(cat, reg[BD_COL_PLUS])
                    nuevas.append(reg)
                    n_sheet += 1
                if verbose:
                    print(f"  [Módulo 6] Proxies hoja '{sheet}': +{n_sheet} filas.")
        finally:
            wb.close()

        if nuevas:
            df_new = pd.DataFrame(nuevas, columns=BD_MSCI_COLS)
            for col in df_new.columns:
                if col in BD_STRING_COLS:
                    df_new[col] = df_new[col].map(_to_string)
                elif col in BD_NUMERIC_COLS:
                    df_new[col] = df_new[col].map(_to_number)
            antes = len(self.df)
            self.df = pd.concat([self.df, df_new], ignore_index=True)
            self.df = self.df.drop_duplicates(
                BD_COL_CLIENT_ID, keep="last").reset_index(drop=True)
            if verbose:
                print(f"  [Módulo 6] BD(MSCI) con proxies: {antes} -> {len(self.df)} filas "
                      f"({len(nuevas)} de proxies, los repetidos sobrescriben).")
        return self

    @staticmethod
    def _resolve_sheet_generic(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None

    def as_intensidad_lookup(self) -> Dict[str, float]:
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        tmp = self.df[[BD_COL_CLIENT_ID, BD_COL_INTENSIDAD]].dropna(
            subset=[BD_COL_CLIENT_ID]).drop_duplicates(BD_COL_CLIENT_ID, keep="first")
        return dict(zip(tmp[BD_COL_CLIENT_ID], tmp[BD_COL_INTENSIDAD]))

    def as_plus_lookup(self) -> Dict[str, dict]:
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        tmp = self.df[[BD_COL_CLIENT_ID, BD_COL_PLUS, BD_COL_PLUS_1]].dropna(
            subset=[BD_COL_CLIENT_ID]).drop_duplicates(BD_COL_CLIENT_ID, keep="first")
        return tmp.set_index(BD_COL_CLIENT_ID).to_dict("index")

    def as_attrs_lookup(self) -> Dict[str, dict]:
        """Client_ID -> {Sector, País, Rating, Controversia} para enriquecer M12."""
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        cols = [BD_COL_CLIENT_ID, "Sector", "País", "Rating", "Controversia"]
        cols = [c for c in cols if c in self.df.columns]
        tmp = self.df[cols].dropna(subset=[BD_COL_CLIENT_ID]).drop_duplicates(
            BD_COL_CLIENT_ID, keep="first")
        return tmp.set_index(BD_COL_CLIENT_ID).to_dict("index")

    def _guard_file(self) -> None:
        if not self.path:
            raise ValueError("Config no define path_base_msci.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(f"No encuentro Base MSCI en:\n  {self.path}")


