def construir_dashboard(ruta_historico, ruta_salida) -> str:
    """Genera el HTML autocontenido a partir del HISTORICO acumulado."""
    hist = HistoricoExporter(str(ruta_historico)).cargar_historico()
    if hist.empty:
        raise ValueError("El histórico está vacío: ejecutar M11/M12 primero.")

    hist = hist.copy()
    hist["FECHA_CORTE"] = hist["FECHA_CORTE"].astype(str)
    for c in ["DIM_1", "DIM_2", "DIM_3", "OBJETO", "METRICA"]:
        if c in hist.columns:
            hist[c] = hist[c].fillna("").astype(str)
    hist["VALOR"] = pd.to_numeric(hist["VALOR"], errors="coerce").fillna(0.0).round(6)

    lista_cortes = sorted(hist["FECHA_CORTE"].unique(), reverse=True)
    corte_actual = lista_cortes[0]
    t1_map = {c: _semestre_anterior(c) for c in lista_cortes}
    comp_default = t1_map.get(corte_actual)
    if comp_default not in lista_cortes:
        comp_default = lista_cortes[1] if len(lista_cortes) > 1 else corte_actual

    bloques = sorted(
        hist.loc[(hist["OBJETO"] == "Resumen_Bloques") & (hist["DIM_1"] != "TOTAL"),
                 "DIM_1"].unique().tolist())

    cfg_js = {
        "paleta": PALETA, "paleta_pie": PALETA_PIE,
        "color_actual": COLOR_ACTUAL, "color_compara": COLOR_COMPARA,
        "color_acento": COLOR_ACENTO, "color_texto": COLOR_TEXTO,
        "color_grid": COLOR_GRID, "fuente": FUENTE,
        "alto": ALTO_GRAFICO, "bargap": BARGAP_EXCEL, "t1_map": t1_map,
        "categorias_sector": CATEGORIAS_SECTOR,
        "metrica_intensidad": "Intensidad",
    }

    datos_js = json.dumps(
        hist[["FECHA_CORTE", "OBJETO", "DIM_1", "DIM_2", "DIM_3", "METRICA", "VALOR"]]
        .to_dict(orient="records"), ensure_ascii=False)

    js = (JS_DASHBOARD
          .replace("__DATA__", datos_js)
          .replace("__CFG__", json.dumps(cfg_js, ensure_ascii=False)))

    # Se embebe plotly.js una sola vez: de los <script> que genera to_html,
    # el de la librería es el más grande (~4.7 MB). Tomar otro deja el HTML mudo.
    _tmp = pio.to_html(go.Figure(), include_plotlyjs=True, full_html=False)
    _bloques = re.findall(r"<script[^>]*>.*?</script>", _tmp, flags=re.S)
    plotly_js = max(_bloques, key=len)

    def opts(valores, sel):
        return "".join(
            f'<option value="{v}"{" selected" if v == sel else ""}>{v}</option>'
            for v in valores)

    tarjetas = [
        ("gSerie", "Métricas y Metas — evolución de Huella e Intensidad", True),
        ("gHuellaBloque", "Huella por bloque de estrategia — comparación entre cortes", False),
        ("gIntBloque", "Intensidad por bloque de estrategia — comparación entre cortes", False),
        ("gEstrategia", "Huella por Estrategia (TD / BU / ALT / GOB) — comparación entre cortes", False),
        ("gAUM", "Composición del AUM por Rank_rt — actual vs comparación", True),
        ("gSoberanos", "Exposición soberana por emisor — comparación entre cortes", True),
        ("gTipoRenta", "Huella por tipo de renta — comparación entre cortes", False),
        ("gGrupoEcon", "Huella por grupo económico (top 12) — comparación entre cortes", False),
        ("gSector52", "Huella por categoría — MSCI vs Proxies (Chart 52)", True),
        ("gSector63", "Intensidad por categoría — MSCI vs Proxies (Chart 63)", True),
        ("gComp49", "Huella: Integra vs benchmarks (Charts 49 y 39)", False),
        ("gComp48", "Intensidad: Integra vs benchmarks (Chart 48)", False),
        ("gSobPais", "Huella soberana por país (Chart 58)", False),
        ("gIntEstrategia", "Intensidad por Estrategia — comparación entre cortes", False),
        ("gContribBUTD", "Mayores contribuyentes BU + TD (solo corte seleccionado)", False),
        ("gContribGral", "Mayores contribuyentes general (solo corte seleccionado)", False),
    ]
    cards = "".join(
        f'<div class="card{" full" if full else ""}"><h3>{titulo}</h3>'
        f'<div id="{cid}" class="plot"></div></div>'
        for cid, titulo, full in tarjetas)

    html = f"""<!DOCTYPE html><html lang="es"><head><meta charset="utf-8">
<title>Huella de Carbono — Dashboard</title>{CSS_DASHBOARD}{plotly_js}</head><body>
<header>
  <h1>Huella de Carbono e Intensidad — Portafolio de Inversiones</h1>
  <p>AFP Integra · Multifondos 1, 2 y 3 · generado por el pipeline Python
     (reemplaza la hoja «Presentacion»)</p>
</header>
<div class="controles">
  <div class="control"><label>Corte</label>
    <select id="selCorte">{opts(lista_cortes, corte_actual)}</select></div>
  <div class="control"><label>Corte de comparación (T-1 por defecto)</label>
    <select id="selCorteComparacion">{opts(lista_cortes, comp_default)}</select></div>
  <div class="control"><label>Bloques (selección múltiple)</label>
    <select id="selBloques" multiple>
      {"".join(f'<option value="{b}">{b}</option>' for b in bloques)}
    </select></div>
  <div class="leyenda">
    <span class="chip"><i style="background:{COLOR_ACTUAL}"></i>
      Corte <b id="lblActual"></b></span>
    <span class="chip"><i style="background:{COLOR_COMPARA}"></i>
      Comparación <b id="lblCompara"></b></span>
  </div>
</div>
<div class="grid">{cards}</div>
<footer>Fuente: Valorización de Instrumentos (Módulo 10) → pivots del Módulo 12 →
histórico acumulado. Los rankings de emisores no se comparan entre fechas.</footer>
{js}</body></html>"""

    ruta = FsPath(str(ruta_salida))
    ruta.parent.mkdir(parents=True, exist_ok=True)
    ruta.write_text(html, encoding="utf-8")
    print(f"  [Módulo 14] Dashboard -> {ruta}")
    return str(ruta)



