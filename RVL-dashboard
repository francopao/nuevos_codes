/* ---------------- Multi-select generico ---------------- */
function buildMultiSelect(container, label, options, selected, onChange){
  const wrap = document.createElement('div');
  wrap.className = 'multisel';
  wrap.innerHTML = `<div class="label">${label} (${selected.length}/${options.length}) \u25BE</div>
    <div class="panel">${options.map(o=>`<label class="opt"><input type="checkbox" value="${o}" ${selected.includes(o)?'checked':''}> ${o}</label>`).join('')}</div>`;
  container.appendChild(wrap);
  wrap.querySelector('.label').addEventListener('click', (e)=>{ wrap.classList.toggle('open'); e.stopPropagation(); });
  document.addEventListener('click', (e)=>{ if(!wrap.contains(e.target)) wrap.classList.remove('open'); });
  wrap.querySelectorAll('input[type=checkbox]').forEach(cb=>{
    cb.addEventListener('change', ()=>{
      const chosen = [...wrap.querySelectorAll('input:checked')].map(c=>c.value);
      wrap.querySelector('.label').textContent = `${label} (${chosen.length}/${options.length}) \u25BE`;
      onChange(chosen);
    });
  });
  return wrap;
}

