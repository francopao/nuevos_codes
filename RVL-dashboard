(function(){
  const el = document.getElementById('view-alpha');
  const funds = ['F1','F2','F3'];
  let currentFund = 'F1';
  const allStocks = REND.sectors.filter(s=>s.sector!=='Del Benchmark').flatMap(s=>s.stocks);
  let selectedSectors = [...new Set(allStocks.map(s=>s.sector))];

  const toolbar = document.createElement('div'); toolbar.className='toolbar';
  const seg = document.createElement('div'); seg.className='segctl';
  seg.innerHTML = funds.map((f,i)=>`<button data-f="${f}" class="${i===0?'active':''}">${f}</button>`).join('');
  toolbar.appendChild(seg);
  buildMultiSelect(toolbar, 'Sectores', selectedSectors.slice(), selectedSectors, (c)=>{selectedSectors=c; render();});
  el.appendChild(toolbar);

  const section = document.createElement('section'); section.className='block';
  section.innerHTML = `<h2><span class="dot"></span>Ranking de Alpha vs. Sistema por accion</h2><div class="hint" style="margin-bottom:10px">Ordenado de mayor a menor alpha (retorno de la accion en el portafolio menos el retorno del Sistema, al ultimo corte)</div><div class="tablewrap"></div>`;
  el.appendChild(section);
  const wrap = section.querySelector('.tablewrap');

  function render(){
    let stocks = allStocks.filter(s=>selectedSectors.includes(s.sector));
    stocks = stocks.map(s=>({...s, a: s.alpha_sis[currentFund]}))
                    .filter(s=>typeof s.a === 'number')
                    .sort((a,b)=>b.a-a.a);
    const maxAbs = Math.max(0.001, ...stocks.map(s=>Math.abs(s.a)));
    let html = `<table><thead><tr><th class="left">Instrumento</th><th class="left">Sector</th><th>Alpha vs. Sistema (${currentFund})</th></tr></thead><tbody>`;
    stocks.forEach(s=>{
      html += `<tr><td class="left">${s.nombre} <span class="ticker">${s.ticker||''}</span></td><td class="left" style="color:var(--gray);font-size:11.5px">${s.sector}</td><td>${barCell(Math.max(s.a,0), maxAbs, s.a>=0?'var(--green)':'var(--red)') }</td></tr>`;
    });
    html += `</tbody></table>`;
    wrap.innerHTML = html;
  }
  seg.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click', ()=>{ seg.querySelectorAll('button').forEach(x=>x.classList.remove('active')); b.classList.add('active'); currentFund=b.dataset.f; render(); });
  });
  render();
})();

