"""
build_rvl_dashboard.py
=======================
Genera un dashboard HTML interactivo (autocontenido, sin dependencias externas)
a partir del export de la hoja "BD" de Rendimiento RVL.xlsm (Mesa de Inversiones
- AFP Integra), replicando las hojas "Resumen", "Rendimiento" y "Posicionamiento",
mas tres vistas nuevas:

    1. Ranking de Alpha vs. Sistema por accion
    2. Mapa de over/underweight (peso portafolio vs. benchmark) por accion
    3. Serie historica de retorno acumulado por instrumento (multi-seleccion)

Uso:
    python build_rvl_dashboard.py --input BD_output4.xlsx --output dashboard.html

Requiere: openpyxl  (pip install openpyxl --break-system-packages)
"""

import argparse
import datetime
import json
import openpyxl


# ---------------------------------------------------------------------------
# 1. PALETA INSTITUCIONAL (AFP Integra / Grupo SURA)
# ---------------------------------------------------------------------------
# Interpretada del theme oficial ("SURA") y de los colores srgbClr usados con
# mayor frecuencia en las diapositivas del Comite de Inversiones adjunto.
# Los colores marcados como "fuera de paleta" no aparecen en el theme/deck;
# se agregan por convencion financiera (rojo para perdidas) o de utilidad
# (grises neutros), y quedan aislados en COLORS['extra'] para que sean faciles
# de reemplazar si la Mesa ya tiene un estandar propio para ellos.
COLORS = {
    # Paleta institucional (theme "SURA" + colores recurrentes del PPTX)
    "navy":       "#1F497D",  # color mas usado en el deck (texto/headers)
    "navy_dark":  "#002060",  # navy oscuro, usado en tablas/encabezados
    "indigo":     "#1E2E6E",  # acento oscuro alterno
    "teal":       "#3494BA",  # acento (cercano a accent3 del theme #00AEC7)
    "gold":       "#FFC000",  # acento calido (resaltados, KPIs)
    "sky_light":  "#CEDBE6",  # fondo/bordes suaves
    "sky_paler":  "#D4EAF3",  # hover / fondos muy claros
    "green":      "#78BE20",  # accent6 del theme SURA (uso: positivo)
    "white":      "#FFFFFF",
    # Fuera de la paleta institucional (agregados por convencion, no del PPTX)
    "extra": {
        "red":      "#C0392B",  # perdidas / alpha o gap negativo
        "red_soft": "#E74C3C",
        "gray":     "#8B93A0",  # texto secundario / neutro
        "gray_bg":  "#F4F6F8",  # fondo de secciones sobre blanco
        "border":   "#E3E8EE",
    },
}

# ---------------------------------------------------------------------------
# 2. EXTRACCION DE DATOS
# ---------------------------------------------------------------------------

def _val(v):
    if isinstance(v, datetime.datetime):
        return v.strftime("%Y-%m-%d")
    return v


def load_workbook(path):
    return openpyxl.load_workbook(path, data_only=True, read_only=True)


def extract_resumen(wb):
    ws = wb["Resumen"]
    rows = {i + 1: r for i, r in enumerate(
        ws.iter_rows(min_row=1, max_row=133, max_col=20, values_only=True))}

    def fund_block(row, start):
        return {"label": row[start], "day": row[start + 1], "wtd": row[start + 2],
                "mtd": row[start + 3], "aggr": row[start + 4]}

    retorno, alpha = {}, {}
    for fund, start in [("F1", 1), ("F2", 7), ("F3", 13)]:
        retorno[fund], alpha[fund] = {}, {}
        for r in range(27, 34):
            b = fund_block(rows[r], start)
            if b["label"]:
                retorno[fund][b["label"]] = {k: b[k] for k in ("day", "wtd", "mtd", "aggr")}
        for r in range(36, 42):
            b = fund_block(rows[r], start)
            if b["label"]:
                alpha[fund][b["label"]] = {k: b[k] for k in ("day", "wtd", "mtd", "aggr")}

    top5, bottom5 = {}, {}
    for fund, start in [("F1", 1), ("F2", 7), ("F3", 13)]:
        hdr = rows[45]
        cols = [hdr[start + i] for i in range(5)]
        t5, b5 = [], []
        for r in range(46, 51):
            row = rows[r]
            name = row[start]
            if not name:
                continue
            t5.append({"rank": row[start - 1] if start > 1 else row[0], "nombre": name,
                       "aggr": row[start + 1], "c1": row[start + 2], "c2": row[start + 3], "c3": row[start + 4]})
        for r in range(55, 60):
            row = rows[r]
            name = row[start]
            if not name:
                continue
            b5.append({"rank": row[start - 1] if start > 1 else row[0], "nombre": name,
                       "aggr": row[start + 1], "c1": row[start + 2], "c2": row[start + 3], "c3": row[start + 4]})
        top5[fund] = {"cols": cols, "rows": t5}
        bottom5[fund] = {"cols": cols, "rows": b5}

    sector_pos = {}
    for fund, start in [("F1", 2), ("F2", 8), ("F3", 14)]:
        sp = []
        for r in range(64, 70):
            row = rows[r]
            sector = row[start]
            if not sector:
                continue
            sp.append({"sector": sector, "portafolio": row[start + 1],
                       "sistema": row[start + 2], "benchmark": row[start + 3]})
        sector_pos[fund] = sp

    return {
        "fecha_inicio": _val(rows[4][3]), "fecha_corte": _val(rows[4][9]),
        "retorno": retorno, "alpha": alpha, "top5": top5, "bottom5": bottom5,
        "sector_pos": sector_pos,
    }


def extract_rendimiento(wb):
    """Sectores > acciones con YTD por fondo (4 cortes) + Alpha vs Sistema por accion."""
    ws = wb["Rendimiento"]
    data = list(ws.iter_rows(min_row=1, max_row=109, max_col=52, values_only=True))
    fecha_corte = _val(data[6][5])
    dates = [_val(data[6][c]) for c in (7, 8, 9, 10)]

    ret_starts = {"F1": 12, "F2": 16, "F3": 20}         # YTD retorno por fecha
    alpha_sis_idx = {"F1": 33, "F2": 41, "F3": 49}      # Alpha vs SIS-Fn (ultimo corte)

    sectors, current = [], None
    for r in range(8, 109):
        if r - 1 >= len(data):
            break
        row = data[r - 1]
        tag, ticker_id, name_or_sector, ticker = row[0], row[3], row[4], row[5]

        if ticker_id == "Total" or name_or_sector == "Del Benchmark":
            current = {"sector": name_or_sector, "ytd": {}, "stocks": []}
            for fund, start in ret_starts.items():
                current["ytd"][fund] = {d: row[start + i] for i, d in enumerate(dates)}
            sectors.append(current)
        elif tag == "Ret_IN_" and current is not None and name_or_sector:
            stock = {"nombre": name_or_sector, "ticker": ticker, "codigo": ticker_id,
                     "sector": current["sector"], "ytd": {}, "alpha_sis": {}}
            for fund, start in ret_starts.items():
                stock["ytd"][fund] = {d: row[start + i] for i, d in enumerate(dates)}
                stock["alpha_sis"][fund] = row[alpha_sis_idx[fund]]
            current["stocks"].append(stock)

    return {"fecha_corte": fecha_corte, "dates": dates, "sectors": sectors}


def extract_posicionamiento(wb):
    """Sectores > acciones con pesos IN/HA/PF/RI/SIS por fondo + benchmark (para gaps)."""
    ws = wb["Posicionamiento"]
    data = list(ws.iter_rows(min_row=1, max_row=108, max_col=23, values_only=True))
    fecha_corte = _val(data[5][5])
    w_starts = {"F1": 7, "F2": 12, "F3": 17}
    tipos = ["IN", "HA", "PF", "RI", "SIS"]

    sectors, current = [], None
    for r in range(7, 108):
        if r - 1 >= len(data):
            break
        row = data[r - 1]
        tag, ticker_id, name_or_sector, ticker = row[0], row[3], row[4], row[5]

        if ticker_id == "Total" or name_or_sector == "Del Benchmark":
            current = {"sector": name_or_sector, "weights": {}, "benchmark": row[22], "stocks": []}
            for fund, start in w_starts.items():
                current["weights"][fund] = {t: row[start + i] for i, t in enumerate(tipos)}
            sectors.append(current)
        elif tag == "weight_IN_" and current is not None and name_or_sector:
            stock = {"nombre": name_or_sector, "ticker": ticker, "codigo": ticker_id,
                     "sector": current["sector"], "weights": {}, "benchmark": row[22]}
            for fund, start in w_starts.items():
                stock["weights"][fund] = {t: row[start + i] for i, t in enumerate(tipos)}
            current["stocks"].append(stock)

    return {"fecha_corte": fecha_corte, "tipos": tipos, "sectors": sectors}


def extract_series_historicas(wb, codigos, fecha_inicio, funds=("F1", "F2", "F3")):
    """
    Retorno acumulado diario por instrumento y fondo, desde `fecha_inicio` (str
    'YYYY-MM-DD') hasta el ultimo dato disponible en la hoja BD. Usa las columnas
    'Ret_IN_F{n}_O_{codigo}' (retorno NO acumulado diario), y las cumula en
    Python: cum[t] = prod(1+r) - 1. Solo se piden las columnas de los
    instrumentos presentes en Rendimiento/Posicionamiento para mantener el
    JSON liviano (evita cargar las ~7,700 columnas de BD).
    """
    ws = wb["BD"]
    header = next(ws.iter_rows(min_row=1, max_row=1, values_only=True))
    name_to_idx = {h: i for i, h in enumerate(header) if h}

    wanted = {}  # idx -> (codigo, fund)
    for codigo in codigos:
        for fund in funds:
            col = f"Ret_IN_{fund}_O_{codigo}"
            idx = name_to_idx.get(col)
            if idx is not None:
                wanted[idx] = (codigo, fund)

    fecha_dt = datetime.datetime.strptime(fecha_inicio, "%Y-%m-%d")
    series = {codigo: {f: [] for f in funds} for codigo in codigos}
    cum = {codigo: {f: 1.0 for f in funds} for codigo in codigos}
    dates_out = []

    max_col = max(wanted.keys(), default=0) + 1
    for row in ws.iter_rows(min_row=2, max_col=max_col, values_only=True):
        fecha = row[0]
        if not isinstance(fecha, datetime.datetime) or fecha < fecha_dt:
            continue
        dates_out.append(_val(fecha))
        for idx, (codigo, fund) in wanted.items():
            r = row[idx] if idx < len(row) else None
            r = r if isinstance(r, (int, float)) else 0.0
            cum[codigo][fund] *= (1 + r)
            series[codigo][fund].append(round(cum[codigo][fund] - 1, 6))

    return {"dates": dates_out, "series": series}


# ---------------------------------------------------------------------------
# 3. ENSAMBLADO
# ---------------------------------------------------------------------------

def build(input_path, output_path, historial_desde=None):
    wb = load_workbook(input_path)

    resumen = extract_resumen(wb)
    rendimiento = extract_rendimiento(wb)
    posicionamiento = extract_posicionamiento(wb)

    codigos = sorted({s["codigo"] for sec in rendimiento["sectors"] for s in sec["stocks"]
                       if sec["sector"] != "Del Benchmark"
                       and isinstance(s["codigo"], str) and s["codigo"].isdigit()})
    nombres = {s["codigo"]: f'{s["nombre"]} {s["ticker"] or ""}'.strip()
               for sec in rendimiento["sectors"] for s in sec["stocks"]}

    fecha_desde = historial_desde or resumen.get("fecha_inicio") or "2026-01-01"
    historicas = extract_series_historicas(wb, codigos, fecha_desde)

    data_blob = json.dumps({
        "resumen": resumen, "rendimiento": rendimiento, "posicionamiento": posicionamiento,
        "historicas": historicas, "nombres": nombres, "colors": COLORS,
    }, ensure_ascii=False)

    html = HTML_TEMPLATE.replace("__DATA__", data_blob)
    with open(output_path, "w", encoding="utf-8") as f:
        f.write(html)
    print(f"OK -> {output_path} ({len(html):,} bytes) | "
          f"{len(codigos)} instrumentos | historial desde {fecha_desde} "
          f"({len(historicas['dates'])} fechas)")


