<script>
const DATA = JSON.parse(document.getElementById('DATA').textContent);
const RES = DATA.resumen, REND = DATA.rendimiento, POS = DATA.posicionamiento,
      HIST = DATA.historicas, NOMBRES = DATA.nombres;
const C = { pos:'var(--green)', neg:'var(--red)', navy:'var(--navy)', teal:'var(--teal)', gold:'var(--gold)' };

function pct(v, dec=2){
  if(v===null||v===undefined||typeof v!=='number'||isNaN(v)) return '&mdash;';
  return (v*100).toFixed(dec)+'%';
}
function colorFor(v, scale=0.15){
  if(typeof v!=='number'||isNaN(v)) return null;
  const t = Math.max(-1, Math.min(1, v/scale));
  if(t>=0) return `rgba(120,190,32,${0.10+0.35*t})`;   // verde institucional
  return `rgba(192,57,43,${0.10+0.35*(-t)})`;           // rojo (fuera de paleta)
}
function valCell(v, opts={}){
  const dec = opts.dec ?? 2, scale = opts.scale ?? 0.15;
  const bg = colorFor(v, scale);
  const txt = (typeof v==='number'&&v<0) ? 'color:var(--red)' : (typeof v==='number'&&v>0 ? 'color:var(--green)':'color:var(--gray)');
  return `<span class="cell-val" style="background:${bg||'transparent'};${txt}">${pct(v,dec)}</span>`;
}
function barCell(v, max, color){
  const w = max>0 ? Math.min(100, Math.max(0,(v/max)*100)) : 0;
  return `<span class="cell-val bar"><span class="fill" style="width:${w}%;background:${color}"></span><span>${pct(v,2)}</span></span>`;
}
function gapCell(v, maxAbs){
  const half = Math.min(50, Math.abs(v)/maxAbs*50);
  const color = v>=0 ? 'var(--navy)' : 'var(--red)';
  const left = v>=0 ? 50 : 50-half;
  return `<span class="cell-val bar" style="min-width:110px">
    <span class="fill" style="left:${left}%;width:${half}%;background:${color}"></span>
    <span>${pct(v,2)}</span></span>`;
}
