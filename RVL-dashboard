(function(){
  const el = document.getElementById('view-resumen');
  const funds = ['F1','F2','F3'];
  function kpis(){
    let html = '<div class="kpirow">';
    funds.forEach(f=>{
      const inRet = RES.retorno[f]['IN'];
      html += `<div class="kpi"><div class="l">${f} &middot; IN Aggr.</div><div class="v" style="color:${inRet.aggr>=0?'var(--green)':'var(--red)'}">${pct(inRet.aggr)}</div></div>`;
    });
    return html+'</div>';
  }
  function matrix(title, obj){
    let html = `<section class="block"><h2><span class="dot"></span>${title}</h2><div class="grid3">`;
    funds.forEach(f=>{
      const rows = obj[f];
      html += `<div><div class="hint" style="margin-bottom:6px">${f}</div><table><thead><tr><th class="left">Tipo</th><th>Day</th><th>WTD</th><th>MTD</th><th>Aggr.</th></tr></thead><tbody>`;
      Object.keys(rows).forEach(k=>{
        const r = rows[k];
        html += `<tr><td class="left">${k}</td><td>${valCell(r.day,{scale:.02})}</td><td>${valCell(r.wtd,{scale:.03})}</td><td>${valCell(r.mtd,{scale:.06})}</td><td>${valCell(r.aggr,{scale:.15})}</td></tr>`;
      });
      html += `</tbody></table></div>`;
    });
    return html+'</div></section>';
  }
  function performers(title, obj){
    let html = `<section class="block"><h2><span class="dot"></span>${title}</h2><div class="grid3">`;
    funds.forEach(f=>{
      const d = obj[f];
      html += `<div><div class="hint" style="margin-bottom:6px">${f}</div><table><thead><tr><th class="left">${d.cols[0]}</th><th>${d.cols[1]}</th><th>${d.cols[2]}</th><th>${d.cols[3]}</th><th>${d.cols[4]}</th></tr></thead><tbody>`;
      d.rows.forEach(r=>{
        html += `<tr><td class="left">${r.nombre}</td><td>${valCell(r.aggr,{scale:.3})}</td><td>${valCell(r.c1,{scale:.03})}</td><td>${valCell(r.c2,{scale:.03})}</td><td>${valCell(r.c3,{scale:.03})}</td></tr>`;
      });
      html += `</tbody></table></div>`;
    });
    return html+'</div></section>';
  }
  function sectorPos(){
    let html = `<section class="block"><h2><span class="dot"></span>Posicionamiento Sectorial</h2><div class="grid3">`;
    funds.forEach(f=>{
      const rows = RES.sector_pos[f];
      const max = Math.max(...rows.map(r=>Math.max(r.portafolio||0,r.sistema||0,r.benchmark||0)));
      html += `<div><div class="hint" style="margin-bottom:6px">${f} &middot; peso sectorial</div><table><thead><tr><th class="left">Sector</th><th>Portafolio</th><th>Sistema</th><th>Benchmark</th></tr></thead><tbody>`;
      rows.forEach(r=>{
        html += `<tr><td class="left">${r.sector}</td><td>${barCell(r.portafolio,max,'var(--gold)')}</td><td>${barCell(r.sistema,max,'var(--teal)')}</td><td>${barCell(r.benchmark,max,'var(--gray)')}</td></tr>`;
      });
      html += `</tbody></table></div>`;
    });
    return html+'</div><div class="legend"><span class="swatch" style="background:var(--gold)"></span>Portafolio <span class="swatch" style="background:var(--teal)"></span>Sistema <span class="swatch" style="background:var(--gray)"></span>Benchmark</div></section>';
  }
  el.innerHTML = kpis()+matrix('Retorno &middot; Day / WTD / MTD / Aggr.', RES.retorno)
    + matrix('Alpha vs. Benchmarks', RES.alpha)
    + performers('Top 5 Performers vs. Sistema (ex Integra)', RES.top5)
    + performers('Bottom 5 Performers vs. Sistema (ex Integra)', RES.bottom5)
    + sectorPos();
})();

/* ==================================================================
   TABLA AGRUPADA POR SECTOR (Rendimiento / Posicionamiento) - reutilizable
   ================================================================== */
function buildGroupedView(containerId, dataset, opts){
  const el = document.getElementById(containerId);
  const funds = ['F1','F2','F3'];
  let currentFund = 'F1', sortKey=null, sortDir=1;
  let selectedSectors = dataset.sectors.filter(s=>s.sector!=='Total').map(s=>s.sector);

  const toolbar = document.createElement('div'); toolbar.className='toolbar';
  const segwrap = document.createElement('div'); segwrap.className='segctl'; segwrap.id=containerId+'-fund';
  segwrap.innerHTML = funds.map((f,i)=>`<button data-f="${f}" class="${i===0?'active':''}">${f}</button>`).join('');
  toolbar.appendChild(segwrap);
  buildMultiSelect(toolbar, 'Sectores', selectedSectors.slice(), selectedSectors, (chosen)=>{ selectedSectors=chosen; render(); });
  const search = document.createElement('input'); search.className='search'; search.id=containerId+'-search'; search.placeholder='Buscar ticker o nombre...';
  toolbar.appendChild(search);
  const hint = document.createElement('span'); hint.className='hint';
  hint.textContent = `${dataset.sectors.length} sectores \u00b7 ${dataset.sectors.reduce((a,s)=>a+s.stocks.length,0)} instrumentos`;
  toolbar.appendChild(hint);

  const section = document.createElement('section'); section.className='block';
  section.innerHTML = `<h2><span class="dot"></span>${opts.title} &mdash; corte ${dataset.fecha_corte}</h2><div class="tablewrap"></div>`;
  el.appendChild(toolbar); el.appendChild(section);
  const wrap = section.querySelector('.tablewrap');

  function render(){
    const cols = opts.columns;
    let html = `<table><thead><tr><th class="left">Instrumento</th>`;
    cols.forEach(c=>html+=`<th data-key="${c.key}">${c.label}<span class="arrow">\u25BC</span></th>`);
    html += `</tr></thead><tbody>`;
    dataset.sectors.forEach((sec,si)=>{
      if(sec.sector==='Total' || !selectedSectors.includes(sec.sector)) return;
      const sectorVal = opts.sectorRow(sec, currentFund);
      html += `<tr class="sector-row" data-sec="${si}"><td>${sec.sector}</td>`;
      cols.forEach(c=>{ html += `<td>${opts.cellFmt(sectorVal[c.key], c, true)}</td>`; });
      html += `</tr>`;
      let stocks = sec.stocks.slice();
      if(sortKey){
        stocks.sort((a,b)=>{
          const va = opts.rowVal(a,currentFund)[sortKey] ?? -Infinity;
          const vb = opts.rowVal(b,currentFund)[sortKey] ?? -Infinity;
          return (va-vb)*sortDir;
        });
      }
      stocks.forEach(st=>{
        const rv = opts.rowVal(st, currentFund);
        html += `<tr class="stock-row" data-sec="${si}" data-name="${(st.nombre+' '+st.ticker).toLowerCase()}"><td>${st.nombre} <span class="ticker">${st.ticker||''}</span></td>`;
        cols.forEach(c=>{ html += `<td>${opts.cellFmt(rv[c.key], c, false)}</td>`; });
        html += `</tr>`;
      });
    });
    html += `</tbody></table>`;
    wrap.innerHTML = html;
    wrap.querySelectorAll('thead th[data-key]').forEach(th=>{
      th.addEventListener('click', ()=>{
        const k = th.dataset.key;
        if(sortKey===k){ sortDir*=-1; } else { sortKey=k; sortDir=-1; }
        wrap.querySelectorAll('thead th').forEach(t=>t.classList.remove('sorted'));
        th.classList.add('sorted'); th.querySelector('.arrow').textContent = sortDir===1?'\u25B2':'\u25BC';
        render();
      });
    });
    wrap.querySelectorAll('tr.sector-row').forEach(tr=>{
      tr.addEventListener('click', ()=>{
        tr.classList.toggle('collapsed');
        wrap.querySelectorAll(`tr.stock-row[data-sec="${tr.dataset.sec}"]`).forEach(r=>r.classList.toggle('hidden'));
      });
    });
    applyFilter();
  }
  function applyFilter(){
    const q = search.value.trim().toLowerCase();
    wrap.querySelectorAll('tr.stock-row').forEach(r=>{ r.style.display = (!q || r.dataset.name.includes(q)) ? '' : 'none'; });
  }
  segwrap.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click', ()=>{
      segwrap.querySelectorAll('button').forEach(x=>x.classList.remove('active'));
      b.classList.add('active'); currentFund=b.dataset.f; render();
    });
  });
  search.addEventListener('input', applyFilter);
  render();
}

