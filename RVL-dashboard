  buildMultiSelect(toolbar, 'Tipos', POS.tipos.slice(), selectedTipos, (c)=>{selectedTipos=c.length?c:['IN']; render();});
  buildMultiSelect(toolbar, 'Sectores', selectedSectors.slice(), selectedSectors, (c)=>{selectedSectors=c; render();});
  el.appendChild(toolbar);

  const section = document.createElement('section'); section.className='block';
  section.innerHTML = `<h2><span class="dot"></span>Over / Underweight vs. Benchmark</h2><div class="hint" style="margin-bottom:10px">Peso en el portafolio menos peso en el benchmark, por tipo de fondo seleccionado. Azul = sobreponderado, rojo = subponderado.</div><div class="tablewrap"></div>`;
  el.appendChild(section);
  const wrap = section.querySelector('.tablewrap');

  function render(){
    const stocks = allStocks.filter(s=>selectedSectors.includes(s.sector));
    let html = `<table><thead><tr><th class="left">Instrumento</th><th class="left">Sector</th>`;
    selectedTipos.forEach(t=>html+=`<th>${t}</th>`);
    html += `</tr></thead><tbody>`;
    const gaps = {};
    selectedTipos.forEach(t=>{ gaps[t] = stocks.map(s=>(s.weights[currentFund][t]||0) - (s.benchmark||0)); });
    const maxAbs = Math.max(0.001, ...selectedTipos.flatMap(t=>gaps[t].map(Math.abs)));
    stocks.forEach((s,i)=>{
      html += `<tr><td class="left">${s.nombre} <span class="ticker">${s.ticker||''}</span></td><td class="left" style="color:var(--gray);font-size:11.5px">${s.sector}</td>`;
      selectedTipos.forEach(t=>{ html += `<td>${gapCell(gaps[t][i], maxAbs)}</td>`; });
      html += `</tr>`;
    });
    html += `</tbody></table>`;
    wrap.innerHTML = html;
  }
  seg.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click', ()=>{ seg.querySelectorAll('button').forEach(x=>x.classList.remove('active')); b.classList.add('active'); currentFund=b.dataset.f; render(); });
  });
  render();
})();

/* ==================================================================
   NUEVO 3: SERIE HISTORICA DE RETORNO ACUMULADO POR INSTRUMENTO
   ================================================================== */
(function(){
  const el = document.getElementById('view-historico');
  const funds = ['F1','F2','F3'];
  let currentFund = 'F1';
  const codigos = Object.keys(HIST.series);
  const palette = ['var(--navy)','var(--teal)','var(--gold)','var(--green)','var(--red)','var(--indigo)'];
  let selected = codigos.slice(0, Math.min(3, codigos.length));

  const toolbar = document.createElement('div'); toolbar.className='toolbar';
  const seg = document.createElement('div'); seg.className='segctl';
  seg.innerHTML = funds.map((f,i)=>`<button data-f="${f}" class="${i===0?'active':''}">${f}</button>`).join('');
  toolbar.appendChild(seg);
  buildMultiSelect(toolbar, 'Instrumentos', codigos.map(c=>NOMBRES[c]||c), selected.map(c=>NOMBRES[c]||c),
    (chosenNames)=>{ selected = codigos.filter(c=>chosenNames.includes(NOMBRES[c]||c)); render(); });
  el.appendChild(toolbar);

  const section = document.createElement('section'); section.className='block';
  section.innerHTML = `<h2><span class="dot"></span>Retorno acumulado por instrumento (${HIST.dates[0]||''} &rarr; ${HIST.dates[HIST.dates.length-1]||''})</h2><div class="chartwrap"></div><div class="legend"></div>`;
  el.appendChild(section);
  const chartwrap = section.querySelector('.chartwrap');
  const legend = section.querySelector('.legend');

  function render(){
    const W=1000,H=340,padL=50,padR=16,padT=16,padB=26;
    const dates = HIST.dates;
    if(!dates.length || !selected.length){ chartwrap.innerHTML='<div class="hint">Sin datos para el rango/fondo seleccionado.</div>'; legend.innerHTML=''; return; }
    const series = selected.map(c=>HIST.series[c][currentFund]||[]);
    const allVals = series.flat().filter(v=>typeof v==='number');
    const maxV = Math.max(0.02, ...allVals), minV = Math.min(-0.02, ...allVals);
    const x = i => padL + (i/(dates.length-1))*(W-padL-padR);
    const y = v => padT + (1-(v-minV)/(maxV-minV))*(H-padT-padB);

    let svg = `<svg class="chart" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">`;
    [0,0.25,0.5,0.75,1].forEach(f=>{
      const yy = padT + f*(H-padT-padB);
      svg += `<line class="gridline" x1="${padL}" x2="${W-padR}" y1="${yy}" y2="${yy}"/>`;
      const val = maxV - f*(maxV-minV);
      svg += `<text x="4" y="${yy+3}">${(val*100).toFixed(1)}%</text>`;
    });
    svg += `<line class="zeroline" x1="${padL}" x2="${W-padR}" y1="${y(0)}" y2="${y(0)}"/>`;
    series.forEach((s,si)=>{
      if(!s.length) return;
      let path = s.map((v,i)=> (i===0?'M':'L') + x(i).toFixed(1) + ',' + y(v).toFixed(1)).join(' ');
      svg += `<path d="${path}" fill="none" stroke="${palette[si%palette.length]}" stroke-width="1.8"/>`;
    });
    const step = Math.max(1, Math.floor(dates.length/8));
    for(let i=0;i<dates.length;i+=step){
      svg += `<text x="${x(i)}" y="${H-8}" text-anchor="middle">${dates[i].slice(5)}</text>`;
    }
    svg += `</svg>`;
    chartwrap.innerHTML = svg;
    legend.innerHTML = selected.map((c,i)=>{
      const last = HIST.series[c][currentFund]?.slice(-1)[0];
      return `<span class="swatch" style="background:${palette[i%palette.length]}"></span>${NOMBRES[c]||c} (${pct(last)})`;
    }).join('  ');
  }
  seg.querySelectorAll('button').forEach(b=>{
    b.addEventListener('click', ()=>{ seg.querySelectorAll('button').forEach(x=>x.classList.remove('active')); b.classList.add('active'); currentFund=b.dataset.f; render(); });
  });
  render();
})();
</script>
</body>
</html>
"""


