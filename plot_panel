    # La fuente puede venir en ISO (AAAA-MM-DD) o DD/MM/AAAA: parseo robusto.
    TC["Fecha"] = _parse_fechas(TC["Fecha"])
    TC = TC.set_index("Fecha")
    TC = TC.replace("ND", 0).fillna(0).astype(np.float64)
    return TC


# ---------------------------------------------------------------------------
# Precios (con / sin dividendos)
# ---------------------------------------------------------------------------
def _resolver_codigos_sbs(precios_rvl, fila_codigos, fila_ticker, bbg2sbs, raiz2sbs):
    """Devuelve la fila de códigos SBS por columna de la hoja RVL.

    - Si la fila de códigos (fila_codigos) ya trae los SBS, se usan tal cual.
    - Si está vacía, se reconstruye mapeando el ticker Bloomberg (fila_ticker):
      primero por coincidencia exacta y, si falla, por la raíz del ticker
      (primer token) cuando es inequívoca en la parametría.
    Si algún instrumento no logra mapear, se levanta un error listándolos, para
    corregir la parametría (o repoblar la fila de SBS) en vez de perder datos.
    """
    fila_actual = precios_rvl.iloc[fila_codigos]
    if not fila_actual.dropna().empty:
        return fila_actual  # la hoja ya trae los SBS: camino directo

    etiquetas = precios_rvl.iloc[2]           # fila de labels (Px_last / TOT_RETURN)
    tickers = precios_rvl.iloc[fila_ticker]   # fila de tickers Bloomberg
    marcadores = {"Px_last", "TOT_RETURN_INDEX_GROSS_DVDS"}

    def _norm(x):
        if x is None or (isinstance(x, float) and pd.isna(x)):
            return None
        s = str(x).strip()
        return s[:-7].strip() if s.endswith(" Equity") else s

    codigos = {}
    faltan = []
    for col in precios_rvl.columns:
        lab = etiquetas[col]
        if lab not in marcadores:
            codigos[col] = None
            continue
        tk = _norm(tickers[col])
        if tk is None or tk in marcadores:   # columna de fecha del bloque
            codigos[col] = None
            continue
        if tk in bbg2sbs:
            codigos[col] = bbg2sbs[tk]
        elif tk.split()[0] in raiz2sbs:
            codigos[col] = raiz2sbs[tk.split()[0]]
        else:
            codigos[col] = None
            faltan.append(tk)

    if faltan:
        faltan = sorted(set(faltan))
        raise ValueError(
            "La hoja 'RVL' no trae los códigos SBS en su fila de encabezado y "
            "no se pudo mapear automáticamente el ticker Bloomberg a SBS para "
            f"estos {len(faltan)} instrumentos: {faltan}. "
            "Corrige el nombre Bloomberg de estos instrumentos en la hoja "
            "'Parametria' (columna Bloomberg) para que coincida con el de RVL, "
            "o repobla la fila de códigos SBS de la hoja 'RVL'."
        )

    return pd.Series(codigos)


def _armar_precios(precios_rvl, fechas_diarias, etiqueta, fila_codigos=3):
    bloque = precios_rvl.loc[:, precios_rvl.iloc[2] == etiqueta]
    columnas = bloque.loc[fila_codigos].tolist()[1:]
    out = bloque[5:].iloc[:, 1:].copy()
    out.columns = columnas
    out = out.fillna(0)
    out.insert(0, "Fecha", fechas_diarias)
    out = out.set_index("Fecha")
    for token in ("#N/A N/A", "NM", "(Invalid Formula Name)", "NA"):
        out = out.replace(token, 0)
    return _to_float(out)


def cargar_precios(path, fecha_corte, parametria, fila_codigos=3, fila_ticker=4,
                   col_fecha=1):
    """Lee la hoja RVL con openpyxl (preserva los códigos SBS como texto).

    - fila_codigos: índice (0-based) de la fila con los códigos SBS. Layout
      original = 3 (fila 4 de Excel).
    - fila_ticker: índice (0-based) de la fila con el ticker Bloomberg, usada
      SOLO como fallback si fila_codigos viene vacía. Layout actual = 4 (fila 5).
    - col_fecha: índice (0-based) de la columna de fechas diarias. Original = 1.

    openpyxl evita perder códigos tipo '5460042E8427' (calamine los convertía a
    número) y no revienta por memoria en hojas con rango usado gigante.
    """
    precios_rvl = _read_openpyxl(path, "RVL", nrows=4600).copy()

    # Códigos SBS por columna: de la fila de encabezado, o mapeados desde el
    # ticker Bloomberg si esa fila está vacía (con parada clara si algo no casa).
    precios_rvl.iloc[fila_codigos] = _resolver_codigos_sbs(
        precios_rvl, fila_codigos, fila_ticker,
        parametria["bbg2sbs"], parametria["raiz2sbs"],
    ).values

    fechas_diarias = _parse_fechas(precios_rvl[col_fecha][5:]).dropna()

    con_div = _armar_precios(
        precios_rvl, fechas_diarias, "TOT_RETURN_INDEX_GROSS_DVDS", fila_codigos
    )
    con_div = con_div.loc[:fecha_corte].copy()

    sin_div = _armar_precios(precios_rvl, fechas_diarias, "Px_last", fila_codigos)

    return con_div, sin_div


# ---------------------------------------------------------------------------
# Qs de Integra por fondo
# ---------------------------------------------------------------------------
def _q_integra(base_integra, fondo, lista_isins):
    df = base_integra[base_integra["Fondo"].str.contains(f"IN-FONDO{fondo}")]
    df = df.drop(["Dato", "SBS"], axis=1)
    df = df.reindex(columns=["Fecha"] + lista_isins).fillna(0).copy()
    df["Fecha"] = pd.to_datetime(df["Fecha"])
    df = df.set_index("Fecha").astype(np.float64)
    return df


# ---------------------------------------------------------------------------
# Qs del Sistema por AFP/fondo
# ---------------------------------------------------------------------------
def _q_sistema(base_sistema_f, afp, fondo, lista_isins):
    df = base_sistema_f[base_sistema_f["AFP-Fondo"].str.contains(f"{afp}-FONDO{fondo}")]
    df = df.drop(["AFP-Fondo"], axis=1)
    df = df.reindex(columns=lista_isins).fillna(0).copy()
    return df


# ---------------------------------------------------------------------------
# PxQ  (precio con dividendos * cantidad), sin fechas duplicadas
# ---------------------------------------------------------------------------
def _pxq(precios, q, dedup=True):
    out = precios.mul(q, axis=0).dropna(axis=0, how="all").copy()
    if dedup:
        out = out[~out.index.duplicated(keep="first")]
    return out


# ---------------------------------------------------------------------------
# Rezago de weights (shift -1 en el índice de fechas, se descarta la última)
#
# IMPORTANTE: se mantiene el mismo patrón de mutación en sitio del índice que el
# original, porque otras variables (weight_XX_Fn) comparten el mismo objeto y el
# export de la hoja "BD" depende de ese aliasing para quedar alineado.
# ---------------------------------------------------------------------------
def _rezagar(dic_weights):
    for afp in dic_weights:
        dic_weights[afp].index = (
            dic_weights[afp].reset_index(names="Fecha")["Fecha"].shift(-1)
        )
        dic_weights[afp] = dic_weights[afp].iloc[:-1].copy()


# ---------------------------------------------------------------------------
# Weights de benchmark (EPU / ETFPERU)
# ---------------------------------------------------------------------------
def _limpiar_benchmark(weights_benchmark, etiqueta, index_ref):
    cols = weights_benchmark.columns[
        weights_benchmark.iloc[0].isin(["Benchmark", etiqueta])
    ]
    limpio = weights_benchmark[cols].copy()[4:].reset_index(drop=True)
    limpio.columns = limpio.iloc[0]
    limpio = limpio.drop(0).reset_index(drop=True)
    limpio = limpio.rename(columns={limpio.columns[0]: "Fecha"})
    limpio["Fecha"] = pd.to_datetime(limpio["Fecha"], errors="coerce")
    limpio = limpio.set_index("Fecha")
    limpio = limpio.replace("-", 0)
    limpio = limpio.apply(pd.to_numeric, errors="coerce")
    limpio = limpio.reindex(index_ref).ffill()
    return limpio


