def DQ_IN(df1, DQ_IN_BD, ListaIN, ListaUsados):
    # Se eliminan las primeras filas del documento que no serán usadas
    df1 = df1.drop(df1.index[list(range(0, 10))])
    df1 = df1.transpose()
    df1 = df1.rename(columns={10: "Isins"})
    filtrada = df1[df1["Isins"].isin(ListaIN)]
    filtrada = filtrada.transpose()
    filtrada.columns = filtrada.iloc[0].to_list()
    filtrada = filtrada[1:]

    DQ_IN_FECHAS = DQ_IN_BD["Fecha"][::-1].copy()
    DQ_IN_UltimaFecha = DQ_IN_FECHAS.iloc[0]
    print("DQ IN: " + str(DQ_IN_UltimaFecha))

    Qest_DQ_IN_Fechas = filtrada["Fecha"].values.tolist()
    ubifechas = Qest_DQ_IN_Fechas.index(DQ_IN_UltimaFecha) + 9

    nuevos = filtrada[ubifechas::].reset_index(drop=True)
    nuevos = nuevos.loc[nuevos["Dato"] == "Q"]

    return pd.concat([DQ_IN_BD, nuevos]).reset_index(drop=True)


# ---------------------------------------------------------------------------
# DQ_SIS  (integración de nuevas fechas del Sistema: HA/PF/RI)
# ---------------------------------------------------------------------------
def DQ_SIS(df2, DQ_SIS_BD, ListaEx):
    # Se eliminan las filas iniciales que no son de nuestro interés
    df3 = df2.drop(df2.index[list(range(0, 11))])
    df3 = df3.transpose()
    df3 = df3.rename(columns={13: "Isins"})
    filtrada_sis = df3[df3["Isins"].isin(ListaEx)]
    filtrada_sis = filtrada_sis.transpose()
    filtrada_sis = filtrada_sis.reset_index(drop=True)
    filtrada_sis = filtrada_sis.dropna(how="all")
    filtrada_sis.columns = filtrada_sis.iloc[2].to_list()
    filtrada_sis = filtrada_sis.drop(2)
    filtrada_sis = filtrada_sis.drop(["Fondo"], axis=1)

    DQ_SIS_BD.columns = DQ_SIS_BD.iloc[0].to_list()
    DQ_SIS_BD_H = DQ_SIS_BD.drop(0)
    DQ_SIS_BD_H_F = DQ_SIS_BD_H[2::]

    DQ_SIS_FECHAS = DQ_SIS_BD_H_F["Fecha"][::-1].drop_duplicates()
    DQ_SIS_UltimaFecha = DQ_SIS_FECHAS.iloc[5]
    print("DQ SIS: " + str(DQ_SIS_UltimaFecha))

    Qest_DQ_SIS_Fechas = filtrada_sis["Fecha"].values.tolist()
    ubifechas_SIS = Qest_DQ_SIS_Fechas.index(DQ_SIS_UltimaFecha)

    nuevos = filtrada_sis[ubifechas_SIS::].reset_index(drop=True)
    nuevos = nuevos.dropna(how="all")

    DQ_SIS_BD_Final = DQ_SIS_BD_H.iloc[:ubifechas_SIS]
    return pd.concat([DQ_SIS_BD_Final, nuevos])


