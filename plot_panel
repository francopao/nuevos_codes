    sheet_sis = wb1.sheets["DQ_SIS"]
    sheet_sis["A2"].options(pd.DataFrame, header=None, index=False).value = Base_Sistema

    # ----- AUM ------------------------------------------------------------
    df_Aum = _pl_read(
        AUM,
        "DataHistórica",
        has_header=False,
        engine="calamine",
        read_options={"use_columns": "B:V", "skip_rows": 0, "n_rows": 22000},
    )
    df_AUM_Share = calculo_Aum(df_Aum, FONDOS, AFPS)
    ultfechadisp = df_AUM_Share.index[-1]

    # ----- Tipo de cambio: AUM se lleva a USD -----------------------------
    TC_F = cargar_tc(BDPRECIOS)
    df_AUM_Share = (
        df_AUM_Share.div(TC_F["USDPEN"], axis=0).dropna(axis=0, how="all").copy()
    )

    # ----- Precios --------------------------------------------------------
    Precios_Con_Dividendos_R, Precios_Sin_Dividendos_R = cargar_precios(
        MONITOR_RENTABILIDAD, Fecha_Corte, par
    )
    Dividendos = Precios_Con_Dividendos_R - Precios_Sin_Dividendos_R  # noqa: F841

    # EPU / ETFPERU acumulados (para los gráficos)
    EPU = Precios_Con_Dividendos_R["5460042E8427"].dropna()
    EPU_Var = EPU.pct_change(fill_method=None).copy()
    EPU_Var_Acum = (1 + EPU_Var).cumprod() * 100

    ETFPERU = Precios_Con_Dividendos_R["5076822E0800"].dropna()
    ETFPERU = ETFPERU.pct_change(fill_method=None).copy()
    ETFPERU_Var_Acum = (1 + ETFPERU).cumprod() * 100

    # ----- Qs Integra -----------------------------------------------------
    DQ_IN_F1_O = _q_integra(Base_Integra, 1, lista_isins)
    DQ_IN_F2_O = _q_integra(Base_Integra, 2, lista_isins)
    DQ_IN_F3_O = _q_integra(Base_Integra, 3, lista_isins)
    DQ_IN_M_O = DQ_IN_F1_O + DQ_IN_F2_O + DQ_IN_F3_O

    # ----- Qs Sistema -----------------------------------------------------
    Base_Sistema_ = Base_Sistema.copy()
    Base_Sistema_[["AFP-Fondo", "Fecha_Dia"]] = Base_Sistema_["Fondo_Fecha"].str.split(
        "[_]", expand=True
    )
    Base_Sistema_ = Base_Sistema_.drop(columns=["Fecha", "Fondo_Fecha"])
    # Fecha_Dia sale de partir "Fondo_Fecha"; típicamente DD/MM/AAAA.
    Base_Sistema_["Fecha_Dia"] = _parse_fechas(
        Base_Sistema_["Fecha_Dia"], prefer_dayfirst=True
    )
    Base_Sistema_ = Base_Sistema_.set_index("Fecha_Dia")
    Base_Sistema_F = Base_Sistema_[2:].fillna(0).copy()

    DQ_HA_F1_O = _q_sistema(Base_Sistema_F, "HA", 1, lista_isins)
    DQ_PF_F1_O = _q_sistema(Base_Sistema_F, "PF", 1, lista_isins)
    DQ_RI_F1_O = _q_sistema(Base_Sistema_F, "RI", 1, lista_isins)
    DQ_HA_F2_O = _q_sistema(Base_Sistema_F, "HA", 2, lista_isins)
    DQ_PF_F2_O = _q_sistema(Base_Sistema_F, "PF", 2, lista_isins)
    DQ_RI_F2_O = _q_sistema(Base_Sistema_F, "RI", 2, lista_isins)
    DQ_HA_F3_O = _q_sistema(Base_Sistema_F, "HA", 3, lista_isins)
    DQ_PF_F3_O = _q_sistema(Base_Sistema_F, "PF", 3, lista_isins)
    DQ_RI_F3_O = _q_sistema(Base_Sistema_F, "RI", 3, lista_isins)

    for df in (
        DQ_HA_F1_O, DQ_HA_F2_O, DQ_HA_F3_O,
        DQ_PF_F1_O, DQ_PF_F2_O, DQ_PF_F3_O,
        DQ_RI_F1_O, DQ_RI_F2_O, DQ_RI_F3_O,
    ):
        _to_float(df)

    DQ_HA_M_O = DQ_HA_F1_O + DQ_HA_F2_O + DQ_HA_F3_O
    DQ_PF_M_O = DQ_PF_F1_O + DQ_PF_F2_O + DQ_PF_F3_O
    DQ_RI_M_O = DQ_RI_F1_O + DQ_RI_F2_O + DQ_RI_F3_O

    DQ_EXSIS_F1_O = DQ_HA_F1_O + DQ_PF_F1_O + DQ_RI_F1_O
    DQ_EXSIS_F2_O = DQ_HA_F2_O + DQ_PF_F2_O + DQ_RI_F2_O
    DQ_EXSIS_F3_O = DQ_HA_F3_O + DQ_PF_F3_O + DQ_RI_F3_O

    # ----- PxQ ------------------------------------------------------------
    PxQ_IN_F1_O = _pxq(Precios_Con_Dividendos_R, DQ_IN_F1_O, dedup=False)
    PxQ_IN_F2_O = _pxq(Precios_Con_Dividendos_R, DQ_IN_F2_O, dedup=False)
    PxQ_IN_F3_O = _pxq(Precios_Con_Dividendos_R, DQ_IN_F3_O, dedup=False)
    PxQ_IN_M_O = _pxq(Precios_Con_Dividendos_R, DQ_IN_M_O, dedup=False)

    PxQ_HA_F1_O = _pxq(Precios_Con_Dividendos_R, DQ_HA_F1_O)
    PxQ_HA_F2_O = _pxq(Precios_Con_Dividendos_R, DQ_HA_F2_O)
    PxQ_HA_F3_O = _pxq(Precios_Con_Dividendos_R, DQ_HA_F3_O)
    PxQ_HA_M_O = _pxq(Precios_Con_Dividendos_R, DQ_HA_M_O)

    PxQ_PF_F1_O = _pxq(Precios_Con_Dividendos_R, DQ_PF_F1_O)
    PxQ_PF_F2_O = _pxq(Precios_Con_Dividendos_R, DQ_PF_F2_O)
    PxQ_PF_F3_O = _pxq(Precios_Con_Dividendos_R, DQ_PF_F3_O)
    PxQ_PF_M_O = _pxq(Precios_Con_Dividendos_R, DQ_PF_M_O)

    PxQ_RI_F1_O = _pxq(Precios_Con_Dividendos_R, DQ_RI_F1_O)
    PxQ_RI_F2_O = _pxq(Precios_Con_Dividendos_R, DQ_RI_F2_O)
    PxQ_RI_F3_O = _pxq(Precios_Con_Dividendos_R, DQ_RI_F3_O)
    PxQ_RI_M_O = _pxq(Precios_Con_Dividendos_R, DQ_RI_M_O)

    PxQ_EXSIS_F1_O = _pxq(Precios_Con_Dividendos_R, DQ_EXSIS_F1_O)
    PxQ_EXSIS_F2_O = _pxq(Precios_Con_Dividendos_R, DQ_EXSIS_F2_O)
    PxQ_EXSIS_F3_O = _pxq(Precios_Con_Dividendos_R, DQ_EXSIS_F3_O)

    # ----- Weights (participación dentro del portafolio RVL de cada AFP) --
    def _w(pxq):
        return pxq.div(pxq.sum(axis=1), axis=0)

    weight_IN_F1, weight_IN_F2 = _w(PxQ_IN_F1_O), _w(PxQ_IN_F2_O)
    weight_IN_F3, weight_IN_M = _w(PxQ_IN_F3_O), _w(PxQ_IN_M_O)

    weight_HA_F1, weight_HA_F2 = _w(PxQ_HA_F1_O), _w(PxQ_HA_F2_O)
    weight_HA_F3, weight_HA_M = _w(PxQ_HA_F3_O), _w(PxQ_HA_M_O)

    weight_PF_F1, weight_PF_F2 = _w(PxQ_PF_F1_O), _w(PxQ_PF_F2_O)
    weight_PF_F3, weight_PF_M = _w(PxQ_PF_F3_O), _w(PxQ_PF_M_O)

    weight_RI_F1, weight_RI_F2 = _w(PxQ_RI_F1_O), _w(PxQ_RI_F2_O)
    weight_RI_F3, weight_RI_M = _w(PxQ_RI_F3_O), _w(PxQ_RI_M_O)

    weight_EXSIS_F1 = _w(PxQ_EXSIS_F1_O)
    weight_EXSIS_F2 = _w(PxQ_EXSIS_F2_O)
    weight_EXSIS_F3 = _w(PxQ_EXSIS_F3_O)

    F1s = {"IN": weight_IN_F1, "HA": weight_HA_F1, "PF": weight_PF_F1,
           "RI": weight_RI_F1, "EXSIS": weight_EXSIS_F1}
    F2s = {"IN": weight_IN_F2, "HA": weight_HA_F2, "PF": weight_PF_F2,
           "RI": weight_RI_F2, "EXSIS": weight_EXSIS_F2}
    F3s = {"IN": weight_IN_F3, "HA": weight_HA_F3, "PF": weight_PF_F3,
           "RI": weight_RI_F3, "EXSIS": weight_EXSIS_F3}
    Ms = {"IN": weight_IN_M, "HA": weight_HA_M, "PF": weight_PF_M, "RI": weight_RI_M}

    _rezagar(F1s)
    _rezagar(F2s)
    _rezagar(F3s)
    _rezagar(Ms)

    # ----- Weights por sector --------------------------------------------
    def _sector_weights(fs, sufijo, renormalizar):
        out = {}
        for afp, weights in fs.items():
            for nombre_sector, isins in agrupados_sectores.items():
                key = f"{afp}_{nombre_sector}_{sufijo}"
                sub = weights.loc[:, weights.columns.intersection(isins)]
                if renormalizar:
                    sub = sub.div(sub.sum(axis=1), axis=0)
                out[key] = sub
        return out

    Sectores_Weight_F1 = _sector_weights(F1s, "F1", renormalizar=True)
    Sectores_Weight_F2 = _sector_weights(F2s, "F2", renormalizar=True)
    Sectores_Weight_F3 = _sector_weights(F3s, "F3", renormalizar=True)
    Sectores_Weight_M = _sector_weights(Ms, "M", renormalizar=True)

    # ----- Weights Benchmark (EPU / ETFPERU) -----------------------------
    # openpyxl: preserva los códigos SBS (incluidos los tipo '5460042E8427').
    Weights_Benchmark = _read_openpyxl(MONITOR_RENTABILIDAD, "Benchmark", nrows=4600).copy()

    EPU_Limpio = _limpiar_benchmark(Weights_Benchmark, "EPU", PxQ_IN_F1_O.index)
    PxQ_EPU = (
        Precios_Con_Dividendos_R.mul(EPU_Limpio, axis=0)
        .dropna(axis=0, how="all")
        .dropna(axis=1, how="all")
        .copy()
    )
    weight_EPU = PxQ_EPU.div(PxQ_EPU.sum(axis=1), axis=0)
    weight_EPU.index = weight_EPU.reset_index()["Fecha"].shift(-1)
    weight_EPU = weight_EPU.iloc[:-1].copy()

    # ETFPERU entrega N° de acciones -> se pondera igual que arriba
    ETFPERU_Limpio = _limpiar_benchmark(Weights_Benchmark, "ETFPERU", PxQ_IN_F1_O.index)
    PxQ_ETFPERU = (
        Precios_Con_Dividendos_R.mul(ETFPERU_Limpio, axis=0)
        .dropna(axis=0, how="all")
        .dropna(axis=1, how="all")
        .copy()
    )
    weight_ETFPERU = PxQ_ETFPERU.div(PxQ_ETFPERU.sum(axis=1), axis=0)
    weight_ETFPERU.index = weight_ETFPERU.reset_index()["Fecha"].shift(-1)
    weight_ETFPERU = weight_ETFPERU.iloc[:-1].copy()

    weights_etfs = {"Weight_EPU": weight_EPU, "Weight_ETFPERU": weight_ETFPERU}

    # ----- Retornos diarios de precios -----------------------------------
    # Equivalente exacto al loop columna-a-columna original (los precios ya
    # vienen sin NaN, por eso fill_method=None no altera el resultado).
    Precios_Con_Dividendos_Var = (
        Precios_Con_Dividendos_R.pct_change(fill_method=None).fillna(0)
    )

    # ----- Weighted Returns ----------------------------------------------
    def _ret(weights):
        return Precios_Con_Dividendos_Var.mul(weights, axis=0).dropna(
            axis=0, how="all"
        ).copy()

    Ret_IN_F1_O = _ret(F1s["IN"])
    Ret_IN_F2_O = _ret(F2s["IN"])
    Ret_IN_F3_O = _ret(F3s["IN"])
    Ret_IN_M_O = _ret(Ms["IN"])

    Ret_HA_F1_O = _ret(weight_HA_F1)
    Ret_HA_F2_O = _ret(weight_HA_F2)
    Ret_HA_F3_O = _ret(weight_HA_F3)
    Ret_HA_M_O = _ret(weight_HA_M)

    Ret_RI_F1_O = _ret(weight_RI_F1)
    Ret_RI_F2_O = _ret(weight_RI_F2)
    Ret_RI_F3_O = _ret(weight_RI_F3)
    Ret_RI_M_O = _ret(weight_RI_M)

    Ret_PF_F1_O = _ret(weight_PF_F1)
    Ret_PF_F2_O = _ret(weight_PF_F2)
    Ret_PF_F3_O = _ret(weight_PF_F3)
    Ret_PF_M_O = _ret(weight_PF_M)

    Ret_EXSIS_F1_O = _ret(weight_EXSIS_F1)
    Ret_EXSIS_F2_O = _ret(weight_EXSIS_F2)
    Ret_EXSIS_F3_O = _ret(weight_EXSIS_F3)

    Ret_EPU_O = (
        Precios_Con_Dividendos_Var.mul(weight_EPU, axis=0)
        .dropna(axis=0, how="all")
        .dropna(axis=1, how="all")
        .fillna(0)
    )
    Ret_ETFPERU_O = (
        Precios_Con_Dividendos_Var.mul(weight_ETFPERU, axis=0)
        .dropna(axis=0, how="all")
        .dropna(axis=1, how="all")
        .fillna(0)
    )
    Ret_ETFs = {"Ret_EPU": Ret_EPU_O, "Ret_ETFPERU": Ret_ETFPERU_O}

    Retornos_Agregados_RVL = {
        "Ret_IN_F1_O": Ret_IN_F1_O, "Ret_IN_F2_O": Ret_IN_F2_O,
        "Ret_IN_F3_O": Ret_IN_F3_O, "Ret_IN_M_O": Ret_IN_M_O,
        "Ret_HA_F1_O": Ret_HA_F1_O, "Ret_HA_F2_O": Ret_HA_F2_O,
        "Ret_HA_F3_O": Ret_HA_F3_O, "Ret_HA_M_O": Ret_HA_M_O,
        "Ret_PF_F1_O": Ret_PF_F1_O, "Ret_PF_F2_O": Ret_PF_F2_O,
        "Ret_PF_F3_O": Ret_PF_F3_O, "Ret_PF_M_O": Ret_PF_M_O,
        "Ret_RI_F1_O": Ret_RI_F1_O, "Ret_RI_F2_O": Ret_RI_F2_O,
        "Ret_RI_F3_O": Ret_RI_F3_O, "Ret_RI_M_O": Ret_RI_M_O,
        "Ret_EXSIS_F1_O": Ret_EXSIS_F1_O, "Ret_EXSIS_F2_O": Ret_EXSIS_F2_O,
        "Ret_EXSIS_F3_O": Ret_EXSIS_F3_O,
    }

    Nombres_Fondos_ind = ["F1", "F2", "F3", "M"]
    Retornos_Agregados_Acum_RVL = {}
    for nombre, df in Retornos_Agregados_RVL.items():
        # se añade "Total" in-place (el export No-Acum incluye esa columna)
        Retornos_Agregados_RVL[nombre]["Total"] = Retornos_Agregados_RVL[nombre].sum(
            axis=1
        )
        Retornos_Agregados_Acum_RVL[nombre] = (
            (1 + Retornos_Agregados_RVL[nombre].replace([np.inf, -np.inf], np.nan).fillna(0)).cumprod()
            * 100
        )

    # Totales por fondo (construcción directa -> mismas columnas/orden IN,HA,PF,RI)
    Retornos_Agregados_Acum_RVL_Totales = {}
    for fondo in Nombres_Fondos_ind:
        cols = {
            nombre.split("_")[1]: df["Total"]
            for nombre, df in Retornos_Agregados_Acum_RVL.items()
            if nombre.split("_")[2] == fondo
        }
        Retornos_Agregados_Acum_RVL_Totales[fondo] = pd.DataFrame(cols)

    Ret_Acum_ETFs = {}
    for nombre in Ret_ETFs:
        Ret_ETFs[nombre]["Total"] = Ret_ETFs[nombre].sum(axis=1)
        Ret_Acum_ETFs[nombre] = (
            (1 + Ret_ETFs[nombre].replace([np.inf, -np.inf], np.nan).fillna(0)).cumprod()
            * 100
        )

    # ----- Weighted Returns por sector -----------------------------------
    Lista_Weights_Sectores_Fondos = [
        Sectores_Weight_F1, Sectores_Weight_F2, Sectores_Weight_F3, Sectores_Weight_M,
    ]
    # Reconstrucción de Sectores_Weight_F1 SIN renormalizar (idéntico al original)
    Sectores_Weight_F1 = _sector_weights(F1s, "F1", renormalizar=False)
    Lista_Weights_Sectores_Fondos[0] = Sectores_Weight_F1

    Retornos_Weighted_Sectores_AFP = {}
    Retornos_Acumulados_Sectorial = {}
    for fondo in Lista_Weights_Sectores_Fondos:
        for afp_sector, weights in fondo.items():
            key = f"Ret_{afp_sector}"
            ret = (
                Precios_Con_Dividendos_Var.mul(weights, axis=0)
                .dropna(axis=0, how="all")
                .dropna(axis=1, how="all")
                .copy()
            )
            ret["Total"] = ret.sum(axis=1)
            Retornos_Weighted_Sectores_AFP[key] = ret
            Retornos_Acumulados_Sectorial[f"Ret_Acum_{afp_sector}"] = (
                (1 + ret.replace([np.inf, -np.inf], np.nan).fillna(0)).cumprod() * 100
            )

    # Totales sectoriales (construcción directa; orden de inserción preservado)
    Solo_Totales_Retornos_Sectoriales = {}
    for sector in lista_sectores:
        for nombre, ret_acum in Retornos_Acumulados_Sectorial.items():
            partes = nombre.split("_")
            key = f"{sector}_{partes[4]}"
            if key not in Solo_Totales_Retornos_Sectoriales:
                Solo_Totales_Retornos_Sectoriales[key] = {}
            if partes[3] == sector:
                Solo_Totales_Retornos_Sectoriales[key][partes[2]] = ret_acum["Total"]
    Solo_Totales_Retornos_Sectoriales = {
        k: pd.DataFrame(v) for k, v in Solo_Totales_Retornos_Sectoriales.items()
    }

    # ----- Construcción de df_final (hoja "BD") --------------------------
    df_exportar = []

    for nombre, df in Retornos_Agregados_RVL.items():
        renombrados = df.copy()
        renombrados.columns = [f"{nombre}_{col}" for col in renombrados.columns]
        df_exportar.append(renombrados)

    for nombre, df in Retornos_Agregados_Acum_RVL.items():
        renombrados = df.copy()
        renombrados.columns = [f"acum_{nombre}_{col}" for col in renombrados.columns]
        df_exportar.append(renombrados)

    renombrados_P = (
        (1 + Precios_Con_Dividendos_Var.replace([np.inf, -np.inf], np.nan).fillna(0)).cumprod()
        * 100
    )
    renombrados_P.columns = [f"Retorno_Precios_{col}" for col in renombrados_P.columns]
    df_exportar.append(renombrados_P)

    renombrados_P = Precios_Con_Dividendos_Var.copy()
    renombrados_P.columns = [
        f"Retorno_Precios_No_Acum_{col}" for col in renombrados_P.columns
    ]
    df_exportar.append(renombrados_P)

    Totales_AUM_RVL = {
        "IN_F1": PxQ_IN_F1_O, "IN_F2": PxQ_IN_F2_O, "IN_F3": PxQ_IN_F3_O, "IN_M": PxQ_IN_M_O,
        "HA_F1": PxQ_HA_F1_O, "HA_F2": PxQ_HA_F2_O, "HA_F3": PxQ_HA_F3_O, "HA_M": PxQ_HA_M_O,
        "PF_F1": PxQ_PF_F1_O, "PF_F2": PxQ_PF_F2_O, "PF_F3": PxQ_PF_F3_O, "PF_M": PxQ_PF_M_O,
        "RI_F1": PxQ_RI_F1_O, "RI_F2": PxQ_RI_F2_O, "RI_F3": PxQ_RI_F3_O, "RI_M": PxQ_RI_M_O,
        "EXSIS_F1": PxQ_EXSIS_F1_O, "EXSIS_F2": PxQ_EXSIS_F2_O, "EXSIS_F3": PxQ_EXSIS_F3_O,
    }
    PD_Final = pd.DataFrame()
    for nombre, df in Totales_AUM_RVL.items():
        PD_Final[f"AUM_RVL_{nombre}"] = df.sum(axis=1)
    df_exportar.append(PD_Final)

    Matriz_Weights = {
        "weight_IN_F1_": weight_IN_F1, "weight_IN_F2_": weight_IN_F2,
        "weight_IN_F3_": weight_IN_F3, "weight_IN_M_": weight_IN_M,
        "weight_HA_F1_": weight_HA_F1, "weight_HA_F2_": weight_HA_F2,
        "weight_HA_F3_": weight_HA_F3, "weight_HA_M_": weight_HA_M,
        "weight_RI_F1_": weight_RI_F1, "weight_RI_F2_": weight_RI_F2,
        "weight_RI_F3_": weight_RI_F3, "weight_RI_M_": weight_RI_M,
        "weight_PF_F1_": weight_PF_F1, "weight_PF_F2_": weight_PF_F2,
        "weight_PF_F3_": weight_PF_F3, "weight_PF_M_": weight_PF_M,
        "weight_EXSIS_F1_": weight_EXSIS_F1, "weight_EXSIS_F2_": weight_EXSIS_F2,
        "weight_EXSIS_F3_": weight_EXSIS_F3,
    }
    for prefijo, df in Matriz_Weights.items():
        renombrados = df.iloc[:-1].copy()
        renombrados.columns = [f"{prefijo}{col}" for col in renombrados.columns]
        df_exportar.append(renombrados)

    for nombre, df in Ret_ETFs.items():
        renombrados = df.copy()
        renombrados.columns = [f"{nombre}_{col}" for col in renombrados.columns]
        df_exportar.append(renombrados)

    for nombre, df in Ret_Acum_ETFs.items():
        renombrados = df.copy()
        renombrados.columns = [f"{nombre}_Acum_{col}" for col in renombrados.columns]
        df_exportar.append(renombrados)

    for nombre, df in weights_etfs.items():
        renombrados = df.copy()
        renombrados.columns = [f"{nombre}_{col}" for col in renombrados.columns]
        df_exportar.append(renombrados)

    df_final = pd.concat(df_exportar, axis=1)

    # ----- Export a la hoja "BD" (output crítico) ------------------------
    sheet_bd = wb1.sheets["BD"]
    sheet_bd["A1"].options(pd.DataFrame).value = df_final

    # ----- PDFs -----------------------------------------------------------
    ctx = {
        "EPU_Var_Acum": EPU_Var_Acum,
        "ETFPERU_Var_Acum": ETFPERU_Var_Acum,
        "Retornos_Agregados_Acum_RVL_Totales": Retornos_Agregados_Acum_RVL_Totales,
        "Solo_Totales_Retornos_Sectoriales": Solo_Totales_Retornos_Sectoriales,
        "Precios_Con_Dividendos_R": Precios_Con_Dividendos_R,
        "lista_sectores": lista_sectores,
        "diccionario_par": diccionario_par,
    }
    graficar_completo(PDF, ctx)
    graficar_reducido(PDFS, ctx)

    return df_final


