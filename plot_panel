_COLORS = ["#3e63ad", "#00B0F0", "#FF0000", "#FFA500"]
_LABELS = {"IN": "Integra", "HA": "Habitat", "PF": "Profuturo", "RI": "Prima"}


def _fmt_ax(ax, titulo, fontsize):
    ax.set_title(titulo)
    ax.title.set_fontsize(12)
    ax.title.set_fontname("Trebuchet MS")
    ax.legend()
    ax.tick_params(axis="x", rotation=90, labelsize=fontsize)
    ax.tick_params(axis="y", labelsize=fontsize)
    ax.xaxis.set_major_formatter(mdates.DateFormatter("%d-%b-%y"))


def _plot_panel(ax, df, ctx, titulo, series, fontsize):
    ax.plot(ctx["EPU_Var_Acum"], color="grey", label="EPU")
    ax.plot(ctx["ETFPERU_Var_Acum"], color="green", label="ETF Peru")
    for afp in series:
        ax.plot(df[afp], color=_COLORS[["IN", "HA", "PF", "RI"].index(afp)],
                label=_LABELS[afp])
    _fmt_ax(ax, titulo, fontsize)


_POS = {"F1": (0, 0), "F2": (0, 1), "F3": (1, 0), "M": (1, 1)}
_TITULOS = {"F1": "Fondo 1", "F2": "Fondo 2", "F3": "Fondo 3", "M": "Multifondo"}


def _plot_precios(pdf, ctx):
    cols = ctx["Precios_Con_Dividendos_R"].columns
    paginas = len(cols) // 8
    contador = 0
    for _ in range(0, paginas + 1):
        fig, axis = plt.subplots(4, 2, figsize=(22, 17))
        fig.suptitle("Precios", fontsize=20, fontweight="bold", color="#000000")
        plt.tight_layout(pad=5)
        plt.subplots_adjust(top=0.95)
        for y in range(0, 4):
            for x in (0, 1):
                if contador == len(cols):
                    break
                isin = cols[contador]
                axis[y, x].plot(
                    ctx["Precios_Con_Dividendos_R"][isin], color="#3e63ad"
                )
                axis[y, x].set_title(ctx["diccionario_par"][isin])
                axis[y, x].title.set_fontsize(12)
                axis[y, x].title.set_fontname("Trebuchet MS")
                axis[y, x].tick_params(axis="x", rotation=90, labelsize=12)
                axis[y, x].tick_params(axis="y", labelsize=12)
                axis[y, x].xaxis.set_major_formatter(mdates.DateFormatter("%b-%y"))
                contador += 1
        pdf.savefig(fig)
        plt.close(fig)


def graficar_completo(ruta_pdf, ctx):
    """PDF completo: Portafolio + Sectores (IN, HA, PF, RI) + Precios."""
    fontsize = 10
    series = ["IN", "HA", "PF", "RI"]
    with PdfPages(ruta_pdf) as pdf:
        # Portafolio
        fig, axis = plt.subplots(2, 2, figsize=(22, 17))
        fig.suptitle("Rendimientos Acunulados - Portafolio RVL",
                     fontsize=20, fontweight="bold", color="#000000")
        plt.tight_layout(pad=5)
        plt.subplots_adjust(top=0.95)
        for nombre, df in ctx["Retornos_Agregados_Acum_RVL_Totales"].items():
            r, c = _POS[nombre]
            _plot_panel(axis[r, c], df, ctx, _TITULOS[nombre], series, fontsize)
        pdf.savefig(fig)
        plt.close(fig)

        # Sectores
        for sector in ctx["lista_sectores"]:
            fig, axis = plt.subplots(2, 2, figsize=(22, 17))
            fig.suptitle(f"Rendimiento Acumulado: {sector}",
                         fontsize=20, fontweight="bold", color="#000000")
            plt.tight_layout(pad=5)
            plt.subplots_adjust(top=0.95)
            for nombre, df in ctx["Solo_Totales_Retornos_Sectoriales"].items():
                s, fondo = nombre.split("_")[0], nombre.split("_")[1]
                if s == sector and fondo in _POS:
                    r, c = _POS[fondo]
                    _plot_panel(axis[r, c], df, ctx, _TITULOS[fondo], series, fontsize)
            pdf.savefig(fig)
            plt.close(fig)

        # Precios
        _plot_precios(pdf, ctx)


