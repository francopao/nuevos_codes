def _pl_read(path, sheet, *, has_header=True, read_options=None, engine=None):
    """Wrapper de polars.read_excel que devuelve un pandas.DataFrame.

    Se usa para hojas 'sanas' (DQ, AUM, TC) donde calamine es rápido y no hay
    códigos que se confundan con notación científica. Para RVL y Benchmark ver
    _read_openpyxl (calamine ahí corrompe códigos como '5460042E8427' y puede
    reventar por memoria si el rango usado de la hoja es enorme).
    """
    kwargs = {"sheet_name": sheet, "has_header": has_header}
    if engine is not None:
        kwargs["engine"] = engine
    if read_options is not None:
        kwargs["read_options"] = read_options
    return pl.read_excel(path, **kwargs).to_pandas()


def _read_openpyxl(path, sheet, nrows):
    """Lee una hoja con openpyxl SIN inferir tipos.

    openpyxl devuelve el valor tal cual está guardado en la celda: los códigos
    de texto (incluidos los que 'parecen' notación científica como
    '5460042E8427') se conservan como str, los números como número y las fechas
    como datetime. Además, al leer con nrows acotado, no revienta aunque el
    rango usado de la hoja llegue hasta el final del Excel.

    Devuelve columnas con índice entero 0..N-1 (equivalente posicional a las
    'column_1', 'column_2'... de polars: column_k  <->  columna entera k-1).
    """
    return pd.read_excel(
        path, sheet_name=sheet, header=None, nrows=nrows, engine="openpyxl"
    )


def _to_float(df):
    """Convierte a float64 (NaN->0) toda columna que no sea numérica ni fecha.

    Se evita select_dtypes(include='object') porque en pandas 3 las columnas de
    texto pasan a dtype 'str' y quedarían fuera (Pandas4Warning). Aquí se
    seleccionan por exclusión de numéricas/fechas, lo que funciona en pandas 2 y 3.
    """
    for column in df.columns:
        dt = df[column].dtype
        if pd.api.types.is_numeric_dtype(dt) or pd.api.types.is_datetime64_any_dtype(dt):
            continue
        df[column] = (
            pd.to_numeric(df[column], errors="coerce").fillna(0).astype("float64")
        )
    return df


def _parse_fechas(serie, prefer_dayfirst=False):
    """Parseo de fechas robusto ante distintos formatos de la fuente.

    - Si ya es datetime, se devuelve tal cual.
    - Intenta primero el orden preferido (ISO por defecto, o DD/MM si el
      origen usa día-primero) y, si la mayoría queda como NaT, reintenta con
      el orden opuesto. Así el código no se rompe si la fuente cambia entre
      'AAAA-MM-DD' y 'DD/MM/AAAA'.
    """
    if pd.api.types.is_datetime64_any_dtype(serie):
        return serie

    primero = pd.to_datetime(serie, dayfirst=prefer_dayfirst, errors="coerce")
    if primero.isna().mean() > 0.5:
        segundo = pd.to_datetime(serie, dayfirst=not prefer_dayfirst, errors="coerce")
        if segundo.isna().mean() < primero.isna().mean():
            return segundo
    return primero


