def cargar_parametria(path):
    base = pd.read_excel(path, sheet_name="Parametria", header=None)

    validos = base.dropna(axis=0)
    lista_isins = validos.iloc[:, 2].tolist()
    lista_nombres = validos.iloc[:, 0].tolist()
    diccionario = dict(zip(lista_isins, lista_nombres))

    sectores_df = base.iloc[:, 2:4].dropna()
    sectores_df.columns = ["ISIN", "Sector"]
    lista_sectores = sectores_df["Sector"].unique().tolist()
    agrupados = {
        sector: sectores_df.loc[sectores_df["Sector"] == sector, "ISIN"].tolist()
        for sector in lista_sectores
    }

    lista_in = ["Fondo", "Dato", "Fecha", "SBS"] + lista_isins
    lista_usados = ["Fondo", "Dato", "Fecha", "SBS"] + lista_isins
    lista_ex = ["Fondo", "Fecha", "Fondo_Fecha"] + lista_isins

    # Mapa Bloomberg (col A) -> SBS (col C) para el fallback cuando la hoja RVL
    # no trae los códigos SBS en su fila de encabezado.
    from collections import Counter
    pares = [
        (str(a).strip(), str(c))
        for a, c in zip(base.iloc[:, 0], base.iloc[:, 2])
        if pd.notna(a) and pd.notna(c)
    ]
    bbg2sbs = dict(pares)
    _raices = Counter(b.split()[0] for b, _ in pares if b.split())
    raiz2sbs = {
        b.split()[0]: c for b, c in pares if b.split() and _raices[b.split()[0]] == 1
    }

    return {
        "isins": lista_isins,
        "nombres": lista_nombres,
        "diccionario": diccionario,
        "sectores": lista_sectores,
        "agrupados": agrupados,
        "lista_in": lista_in,
        "lista_usados": lista_usados,
        "lista_ex": lista_ex,
        "bbg2sbs": bbg2sbs,
        "raiz2sbs": raiz2sbs,
    }


