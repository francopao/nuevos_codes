def crear_txt(df1: pd.DataFrame, df2: pd.DataFrame, ruta: Path,
              excluir_fondos: list[str] | None = None) -> None:
    dfT = pd.concat([df1, df2]).sort_index(ignore_index=True)
    dfT = dfT[["ISIN", "Weight", "Fondo", "Rank Rt", "Strategy"]]
    dfT.columns = ["SECURITY_ID", "WEIGHT", "fondo", "class", "Strategy"]
    if excluir_fondos:
        dfT = dfT[~dfT["fondo"].isin(excluir_fondos)]
    ruta.parent.mkdir(parents=True, exist_ok=True)
    dfT.to_csv(ruta, sep=",", index=False)
    log.info("Generado: %s (%d filas)", ruta.name, len(dfT))


def plantilla_etf(ruta: Path, sbs: str) -> pd.DataFrame:
    """Expande un ETF a las 5 AFP x 4 fondos (antes: doble bucle con concat)."""
    df = CACHE.hoja(ruta, 0)
    df.columns = df.iloc[0]
    df = df.drop(df.index[0])

    col_mv = next((c for c in df.columns if str(c).strip().startswith("Market Value")), None)
    if col_mv is None:
        raise KeyError(f"[{ruta.name}] No se encontró columna 'Market Value...'. "
                       f"Columnas: {list(df.columns)}")

    df = df[df["ISIN"].notna() & df[col_mv].notna()]
    base = pd.DataFrame({
        "ISIN": df["ISIN"].values,
        "Market Value (%) (P)": (pd.to_numeric(df[col_mv], errors="coerce") / 100).fillna(0).values,
    })

    combos = pd.MultiIndex.from_product(
        [["Integra", "Habitat", "Prima", "Profuturo", "Ex_Integra"],
         ["F1", "F2", "F3", "Multifondos"]],
        names=["AFP", "Fondo"],
    ).to_frame(index=False)

    out = base.merge(combos, how="cross")
    out = out[["ISIN", "Market Value (%) (P)", "Fondo", "AFP"]]
    out["SBS"] = sbs
    out["key1"] = out["SBS"] + out["Fondo"] + out["AFP"]
    log.info("[%s] plantilla ETF: %d filas.", ruta.name, len(out))
    return out.reset_index(drop=True)


def generar_relacion(epu: pd.DataFrame, bd: pd.DataFrame) -> pd.DataFrame:
    epu = epu.copy()
    dicBD = bd.set_index("key1").to_dict()
    for col in ["Weight", "assetclass", "Strategy", "AUM", "Tipo",
                "Precio", "Q", "Nombre", "Fecha", "codEmisor"]:
        epu[col] = epu["key1"].map(dicBD[col])

    epu = epu.dropna(subset=["Weight"])
    epu["peso"] = epu["Market Value (%) (P)"] * epu["Weight"]
    epu = epu.drop(columns=["Market Value (%) (P)", "key1", "Weight"])
    return epu.rename(columns={"peso": "Weight"})


# ==========================================================================
# 8. PROCESO PRINCIPAL
# ==========================================================================
def main(dia: str = DIA, mes: str = MES, anio: str = ANIO,
         escenario: str = ESCENARIO_INPUT) -> pd.DataFrame:
    t0 = time.time()
    fecha_input = f"{anio}-{mes}-{dia}"
    fecha_aum = fecha_input
    fecha_nueva = f"{dia}/{mes}/{anio}"
    log.info("=== BD G&P %s%s | corte %s | escenario '%s' ===", anio, mes,
             fecha_input, escenario)

    # ---------- Lecturas que requieren Excel vivo (una sola sesión) ----------
    with excel_dedicado() as app:
        df = leer_gp(escenario, mes, anio, app)
        valor, dic_moneda = leer_tipo_cambio(fecha_input, app)
    # A partir de aquí ya no queda ningún Excel abierto por el proceso.

    (auminf1, auminf2, auminf3, aumhaf1, aumhaf2, aumhaf3,
     aumrif1, aumrif2, aumrif3, aumpff1, aumpff2, aumpff3) = leer_aum(fecha_aum)
    aumsif1 = aumhaf1 + aumpff1 + aumrif1
    aumsif2 = aumhaf2 + aumpff2 + aumrif2
    aumsif3 = aumhaf3 + aumpff3 + aumrif3

    # ---------- G&P a Excel ----------
    ruta_gp = RUTAS.gp_output(mes, anio)
    ruta_gp.parent.mkdir(parents=True, exist_ok=True)
    df.to_excel(ruta_gp, index=False)
    log.info("Generado: %s", ruta_gp.name)

    # ---------- BU / TD por AFP ----------
    df_temporal = operaciones(df)
    df_BU = filtrar_BU(df_temporal)
    df_TD = filtrar_TD(df_temporal)

    afps = [("INF", "Integra"), ("HAF", "Habitat"), ("PFF", "Profuturo"),
            ("RIF", "Prima"), ("SIF", "Ex_Integra")]
    BU_ = {n: X_AFP(f"{p}1", f"{p}2", f"{p}3", df_BU, n, "BU") for p, n in afps}
    TD_ = {n: X_AFP(f"{p}1", f"{p}2", f"{p}3", df_TD, n, "TD") for p, n in afps}

    aum = {
        "Integra": (auminf1, auminf2, auminf3),
        "Habitat": (aumhaf1, aumhaf2, aumhaf3),
        "Profuturo": (aumpff1, aumpff2, aumpff3),
        "Prima": (aumrif1, aumrif2, aumrif3),
        "Ex_Integra": (aumsif1, aumsif2, aumsif3),
    }
    PORT = {n: BU_TD_AFP(BU_[n], TD_[n], *aum[n]) for _, n in afps}
    MULTI = {n: X_AFP_(PORT[n], *aum[n]) for _, n in afps}

    Portafolio = pd.concat(PORT.values()).sort_index(ignore_index=True)
    Multifondos = pd.concat(MULTI.values()).sort_index(ignore_index=True)
    input1 = pd.concat([Portafolio, Multifondos]).sort_index(ignore_index=True)
    input1.insert(0, "Fecha", fecha_nueva)

    # ---------- TXT Base Alerta ----------
    pref = f"{mes}{anio}BUIN_"
    crear_txt(BU_["Integra"], MULTI["Integra"], RUTAS.base_alerta(f"{pref}.txt"))
    crear_txt(TD_["Integra"], MULTI["Integra"], RUTAS.base_alerta(f"TDIN_{mes}{anio}.txt"))
    for suf, excl in [("F1 INBU", ["F3", "F2", "Multifondos"]),
                      ("F2 INBU", ["F1", "F3", "Multifondos"]),
                      ("F3 INBU", ["F1", "F2", "Multifondos"]),
                      ("M INBU", ["F1", "F2", "F3"])]:
        crear_txt(BU_["Integra"], MULTI["Integra"],
                  RUTAS.base_alerta(f"{pref}{suf}.txt"), excluir_fondos=excl)

    # ---------- Cantidades (Q) ----------
    dq_in, dq_rv, dq_rf = leer_qest()
    dq_in.columns = dq_in.iloc[10]
    dq_in = dq_in.drop(dq_in.index[10])
    dic_sbs = filtrar_por_fecha(
        dq_in, "Fecha", datetime.fromisoformat(fecha_aum + " 00:00:00"),
        "QEST_BD!DQ_IN", mask_extra=(dq_in["Dato"] == "Q")).transpose()
    dic_sbs.columns = dic_sbs.iloc[0]
    dic_sbs = dic_sbs.to_dict()

    IN_PORT = Q_integra(Portafolio, dic_sbs, solo_integra=True)
    IN_M = Q_integra(MULTI["Integra"], dic_sbs, solo_integra=False)
    df_IN = pd.concat([IN_PORT, IN_M]).sort_index(ignore_index=True)
    df_IN = df_IN[df_IN["Afp"] == "Integra"]

    otras = {abr: Q_otras_afp(PORT[n], MULTI[n], dq_rv, dq_rf, fecha_nueva, abr)
             for abr, n in [("HA", "Habitat"), ("PF", "Profuturo"), ("RI", "Prima")]}

    PORT_M_TOTAL = pd.concat([df_IN, *otras.values()]).sort_index(ignore_index=True)

    # Ex_Integra = suma de HA + PF + RI
    ex = pd.concat(otras.values()).sort_index(ignore_index=True)
    ex["Key"] = ex["SBS"] + ex["ISIN"] + ex["Fondo"] + ex["Strategy"]
    suma_q = ex.groupby("Key")["Q"].sum()

    EX_IN = input1[input1["Afp"] == "Ex_Integra"].sort_index(ignore_index=True).copy()
    EX_IN["Q"] = (EX_IN["SBS"] + EX_IN["ISIN"] + EX_IN["Fondo"] + EX_IN["Strategy"]).map(suma_q)

    PORT_M_TOTAL = pd.concat([PORT_M_TOTAL, EX_IN]).sort_index(ignore_index=True)
    PORT_M_TOTAL = PORT_M_TOTAL.drop(columns=["Fecha"])
    PORT_M_TOTAL["codEmisor"] = PORT_M_TOTAL["SBS"].astype(str).str[2:6]

    # ---------- Nombres, precios y tipo de cambio ----------
    par_sbs = leer_parametria("SBS")
    df_p_m = PORT_M_TOTAL.copy()
    name_p = df_p_m["SBS"].map(par_sbs["Name"])
    df_p_m["Nombre"] = np.where(df_p_m["Strategy"] == "BU", name_p, df_p_m["Nombre"])
    df_p_m["Tipo"] = valor
    df_p_m["Fecha"] = fecha_nueva
    df_p_m = df_p_m.rename(columns={"Rank Rt": "assetclass"})
    df_p_m = df_p_m[["SBS", "ISIN", "Weight", "Fondo", "assetclass", "Strategy",
                     "Afp", "AUM", "Tipo", "Q", "Nombre", "Fecha", "codEmisor"]]

    # Precios
    dfp = CACHE.hoja(RUTAS.precios, "BDat_Act")
    dfp.columns = dfp.iloc[13]
    dfp = dfp.drop(dfp.index[13])
    dic_precio = filtrar_por_fecha(
        dfp, "Fecha", datetime.fromisoformat(fecha_aum + " 00:00:00"),
        "BDPrecios!BDat_Act", mask_extra=(dfp["Campo"] == "P")).transpose()
    dic_precio.columns = dic_precio.iloc[0]
    df_p_m["Precio"] = df_p_m["SBS"].map(dic_precio.to_dict()["P"])

    df_p_m["Fecha"] = datetime.strptime(f"01/{mes}/{anio}", "%d/%m/%Y")
    df_p_m["Tipo"] = df_p_m["SBS"].str.get(6).map(dic_moneda)
    df_p_m["Inversión"] = df_p_m["Precio"] * df_p_m["Q"] * df_p_m["Tipo"]

    ruta_bd1 = RUTAS.intermedio(f"{anio}{mes} BD1.xlsx")
    ruta_bd1.parent.mkdir(parents=True, exist_ok=True)
    df_p_m.to_excel(ruta_bd1, index=False)
    log.info("Generado: %s (%d filas)", ruta_bd1.name, len(df_p_m))

    # ---------- Incorporar EPU / ETF Perú ----------
    plantilla = pd.concat([
        plantilla_etf(RUTAS.comparables(f"{anio}{mes} EPU US.xlsx"), "5460042E8427"),
        plantilla_etf(RUTAS.comparables(f"{anio}{mes} ETF Perú.xlsx"), "5076822E0800"),
    ])

    # BD1 se relee UNA vez (antes: 3 aperturas vía xlwings)
    bd1 = pd.read_excel(ruta_bd1)
    sbs2 = recor(bd1["SBS"])

    bd_etf = bd1[sbs2.isin(["54", "50"])].sort_index(ignore_index=True).copy()
    bd_etf["Strategy"] = "BU"
    bd_etf["key1"] = bd_etf["SBS"] + bd_etf["Fondo"] + bd_etf["Afp"]
    epu = generar_relacion(plantilla, bd_etf)

    resto = bd1[~sbs2.isin(["54", "50"])].copy()
    resto["key1"] = (resto["ISIN"] + resto["Fondo"] + resto["Afp"]
                     + resto["assetclass"] + resto["Strategy"])
    epu_key = (epu["ISIN"] + epu["Fondo"] + epu["AFP"]
               + epu["assetclass"] + epu["Strategy"])
    epu_ind = epu.assign(key1=epu_key)

    resto["Weight"] = resto["Weight"].fillna(0)
    w2 = resto["key1"].map(epu_ind.set_index("key1")["Weight"].to_dict()).fillna(0)
    resto.insert(2, "Weight_T", resto["Weight"] + w2)
    df_port_epu = (resto.drop(columns=["Weight"])
                        .rename(columns={"Weight_T": "Weight", "Afp": "AFP"}))

    ya_esta = epu_key.isin(set(resto["key1"]))
    df_solo_epu = epu_ind[~ya_esta].drop(columns=["key1"]).assign(key1=epu_key[~ya_esta])

    df_total = pd.concat([df_port_epu, df_solo_epu])

    # ---------- Nombre / Empresa desde Parametría (por ISIN) ----------
    par_isin = leer_parametria("ISIN")
    vp = CACHE.hoja(RUTAS.vp, "CalcP").iloc[4:, [3, 4]]
    vp.columns = vp.iloc[0]
    vp = vp.drop(vp.index[0]).set_index("ISIN")

    dic_p1 = df_total.copy()
    es_bu = dic_p1["Strategy"] == "BU"
    dic_p1.loc[es_bu, "Nombre"] = dic_p1.loc[es_bu, "ISIN"].map(par_isin["Nombre"])
    dic_p1["Empresa"] = dic_p1["Nombre"]
    id_map = dic_p1["ISIN"].map(par_isin.get("ID", {}))
    dic_p1["Empresa"] = np.where(es_bu & id_map.notna(), id_map, dic_p1["Empresa"])

    dic_p1 = dic_p1[["SBS", "ISIN", "Weight", "Fondo", "assetclass", "Strategy",
                     "AFP", "AUM", "Tipo", "Precio", "Q", "Inversión", "Nombre",
                     "Empresa", "Fecha", "codEmisor", "key1"]]

    ruta_port = RUTAS.intermedio(f"{anio}{mes} Portafolio.xlsx")
    dic_p1.to_excel(ruta_port, index=False)
    log.info("Generado: %s (%d filas)", ruta_port.name, len(dic_p1))

    # ---------- Nuevos instrumentos -> Para.xlsx ----------
    par = CACHE.hoja(RUTAS.parametria, "BU")
    par.columns = par.iloc[0]
    par = par.drop(par.index[0])
    par = par.drop(par.loc[par["ISIN"].isin([None])].index)

    pbu = pd.read_excel(ruta_port)
    pbu = pbu[pbu["Strategy"] == "BU"]
    nuevos = pbu[~pbu["ISIN"].isin(set(par["ISIN"]))]
    nuevos = nuevos[["ISIN", "SBS", "codEmisor", "Nombre"]].copy()
    nuevos.columns = ["ISIN", "SBS", "Cod.Emisor", "Nombre"]

    dic3 = leer_parametria("Cod.Emisor")
    for pos, (col, origen) in enumerate(
        [("Moneda", "moneda"), ("Sector", "Sector"), ("Pais", "País"),
         ("Region", "Region"), ("Mercado", "mercado")], start=4
    ):
        nuevos.insert(pos, col, nuevos["Cod.Emisor"].map(dic3[origen]))

    df_Total = pd.concat([par, nuevos])
    ruta_para = RUTAS.dataset / "Para.xlsx"
    df_Total.to_excel(ruta_para, index=False)
    log.info("Generado: %s (%d filas, %d nuevos instrumentos)",
             ruta_para.name, len(df_Total), len(nuevos))

    log.info("=== Proceso terminado en %.1f min ===", (time.time() - t0) / 60)
    return dic_p1


if __name__ == "__main__":
    resultado = main()
    print(resultado.head())
