def _a_fecha(serie: pd.Series) -> pd.Series:
    """Normaliza a fecha (sin hora) tolerando texto, datetime y serial de Excel."""
    return pd.to_datetime(serie, errors="coerce").dt.normalize()


def filtrar_por_fecha(df: pd.DataFrame, col: str, fecha: datetime,
                      contexto: str, mask_extra: pd.Series | None = None) -> pd.DataFrame:
    """
    Filtra por fecha avisando de inmediato si no hay data, en lugar de dejar
    que el proceso siga y falle 5 minutos después con un KeyError opaco.
    """
    fechas = _a_fecha(df[col])
    mask = fechas == pd.Timestamp(fecha).normalize()
    if mask_extra is not None:
        mask = mask & mask_extra

    if not mask.any():
        disponibles = (fechas.dropna().drop_duplicates()
                       .sort_values().dt.strftime("%d/%m/%Y").tolist())
        raise ValueError(
            f"[{contexto}] No hay registros para {fecha:%d/%m/%Y}. "
            f"Últimas fechas disponibles: {disponibles[-8:]}. "
            "Verifique que la fuente esté actualizada o corra con una fecha de corte cargada."
        )

    log.info("[%s] %d fila(s) para %s.", contexto, int(mask.sum()), fecha.date())
    return df[mask]


