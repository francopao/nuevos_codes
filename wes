def operaciones(df: pd.DataFrame) -> pd.DataFrame:
    for a, b in zip(
        ["HAF1", "RIF1", "PFF1", "SIF1", "HAF2", "RIF2", "PFF2", "SIF2",
         "HAF3", "RIF3", "PFF3", "SIF3"],
        ["INF1", "INF1", "INF1", "INF1", "INF2", "INF2", "INF2", "INF2",
         "INF3", "INF3", "INF3", "INF3"],
    ):
        df[a] = df[b] - df[a + "GAP"]
    return df.loc[df["Asset Class"].isin(["Renta Fija", "Renta Variable"])]


def filtrar_BU(df: pd.DataFrame) -> pd.DataFrame:
    """Mismos filtros que la función BU() original, en una sola máscara."""
    cat_gob = (df["Cat"].isin(["Gobierno"])
               | df["SubCat"].isin(["Gobierno"])
               | df["Sub Cat2"].isin(["Gobierno"]))
    es_fm = df["Categoría"].astype(str).str.contains("FM", regex=False, na=False)
    ac_ok = df["AC Dir"].isin(["PE", "PEC", "EMC", "INTER"])
    sbs_excl = df["SBS2"].isin(["52", "54", "50", "48", "PR", "08", "01", "FT", "PT"])

    out = df.loc[~cat_gob & ~es_fm & ac_ok & ~sbs_excl].copy()
    out["Categoría"] = out["Categoría"].astype(object)
    log.info("BU: %d posiciones tras filtros.", len(out))
    return out


