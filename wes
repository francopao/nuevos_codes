@contextmanager
def excel_dedicado():
    """
    Abre una instancia de Excel EXCLUSIVA para el proceso, invisible y sin
    libro en blanco. Al salir se cierran sus libros y se termina esa instancia.
    Los Excel que el usuario tenga abiertos en su sesión no se tocan.
    """
    import xlwings as xw

    app = xw.App(visible=False, add_book=False)
    app.display_alerts = False
    app.screen_updating = False
    try:
        yield app
    finally:
        try:
            for wb in list(app.books):
                wb.close()
        except Exception as e:  # pragma: no cover
            log.warning("No se pudieron cerrar todos los libros: %s", e)
        try:
            app.quit()
        except Exception as e:  # pragma: no cover
            log.warning("No se pudo cerrar la instancia de Excel: %s", e)
        log.info("Instancia dedicada de Excel cerrada.")


def esperar_calculo(app, timeout: int = TIMEOUT_CALCULO) -> None:
    """
    Espera activa hasta que Excel termina de calcular (xlDone = 0), en lugar
    de un sleep fijo. Si el driver no expone CalculationState, cae a un sleep.
    """
    time.sleep(ESPERA_MINIMA)
    inicio = time.time()
    try:
        while app.api.CalculationState != 0:
            if time.time() - inicio > timeout:
                log.warning("Excel sigue calculando tras %ds; se continúa.", timeout)
                return
            time.sleep(0.25)
    except Exception:
        time.sleep(5)
    log.debug("Cálculo terminado en %.1fs", time.time() - inicio)


def leer_libro(ruta: Path, hojas: list[str | int]) -> dict[str | int, pd.DataFrame]:
    """
    Abre el archivo UNA sola vez y devuelve todas las hojas pedidas replicando
    exactamente lo que entrega `xw.sheets[...].used_range.value` (mismo recorte
    de filas y columnas), pero con openpyxl: sin abrir Excel y sin releer el
    archivo por cada hoja.

    Nota: lee los valores cacheados de las fórmulas, que es lo mismo que
    devuelve xlwings sobre un libro que no se recalcula.
    """
    from openpyxl import load_workbook

    if not ruta.exists():
        raise FileNotFoundError(f"No se encuentra el archivo: {ruta}")

    t0 = time.time()
    wb = load_workbook(ruta, read_only=True, data_only=True)
    salida: dict[str | int, pd.DataFrame] = {}
    try:
        for hoja in hojas:
            ws = wb[hoja] if isinstance(hoja, str) else wb[wb.sheetnames[hoja]]
            filas = list(
                ws.iter_rows(
                    min_row=ws.min_row, max_row=ws.max_row,
                    min_col=ws.min_column, max_col=ws.max_column,
                    values_only=True,
                )
            )
            salida[hoja] = pd.DataFrame(filas)
    finally:
        wb.close()  # <- siempre se cierra

    log.info("Leído %s %s -> %s (%.1fs)", ruta.name, list(hojas),
             {k: v.shape for k, v in salida.items()}, time.time() - t0)
    return salida


class CacheExcel:
    """Cada archivo se abre una sola vez por corrida, aunque se pidan N hojas."""

    def __init__(self) -> None:
        self._data: dict[tuple[str, str | int], pd.DataFrame] = {}

    def hojas(self, ruta: Path, hojas: list[str | int]) -> dict[str | int, pd.DataFrame]:
        faltantes = [h for h in hojas if (str(ruta), h) not in self._data]
        if faltantes:
            for h, df in leer_libro(ruta, faltantes).items():
                self._data[(str(ruta), h)] = df
        return {h: self._data[(str(ruta), h)].copy() for h in hojas}

    def hoja(self, ruta: Path, hoja: str | int) -> pd.DataFrame:
        return self.hojas(ruta, [hoja])[hoja]


