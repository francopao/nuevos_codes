def Q_integra(df: pd.DataFrame, dic_sbs: dict, solo_integra: bool) -> pd.DataFrame:
    """
    Reemplaza Q_AFP()/QM_AFP() originales.
      solo_integra=True  -> Portafolio  (Q solo si Fondo coincide y Afp == Integra)
      solo_integra=False -> Multifondos (Q = suma de los 3 fondos)
    """
    out = df.copy()
    f = [pd.to_numeric(out["SBS"].map(dic_sbs[f"IN-FONDO{i}"]), errors="coerce")
         for i in (1, 2, 3)]

    if solo_integra:
        es_in = out["Afp"] == "Integra"
        q = sum(v.where(es_in & (out["Fondo"] == f"F{i}"), 0).fillna(0)
                for i, v in zip((1, 2, 3), f))
    else:
        q = sum(f)

    out.insert(9, "Q", q)
    return out


def Q_X_OPE(df: pd.DataFrame, fecha: str, afp: str) -> pd.DataFrame:
    df = df.copy()
    df.columns = df.iloc[15]
    df = df.drop(df.index[15])
    filtros = [f"{afp}-FONDO{i}_{fecha}" for i in (1, 2, 3)]
    res = df[df["Fondo_Fecha"].isin(filtros)].transpose()
    res.columns = res.iloc[0]
    return res


def Q_otras_afp(port: pd.DataFrame, multi: pd.DataFrame,
                df_rv: pd.DataFrame, df_rf: pd.DataFrame,
                fecha_nueva: str, abr: str) -> pd.DataFrame:
    """Reemplaza el segundo Q_AFP() (Habitat / Profuturo / Prima)."""
    dic = pd.concat([Q_X_OPE(df_rv, fecha_nueva, abr),
                     Q_X_OPE(df_rf, fecha_nueva, abr)]).to_dict()

    out = pd.concat([port, multi])
    f = [pd.to_numeric(out["SBS"].map(dic[f"{abr}-FONDO{i}"]), errors="coerce").fillna(0)
         for i in (1, 2, 3)]

    es_multi = out["Fondo"] == "Multifondos"
    multi_q = (f[0] + f[1] + f[2]).where(es_multi, 0)
    propios = sum(v.where(out["Fondo"] == f"F{i}", 0)
                  for i, v in zip((1, 2, 3), f))

    out.insert(9, "Q", propios + multi_q)
    return out


