def df_result(fondo: str, data: pd.DataFrame) -> pd.DataFrame:
    df = data.loc[data[fondo] > 0, ["SBS", "ISIN", "Nombre", "Rank Rt", fondo]].copy()
    df["Fondo"] = fondo[-2:]
    return df.rename(columns={fondo: "Weight"})


def X_AFP(f1: str, f2: str, f3: str, data: pd.DataFrame,
          nombre: str, tipo: str) -> pd.DataFrame:
    df = pd.concat([df_result(f, data) for f in (f1, f2, f3)]).sort_index(
        ignore_index=True)
    df["Strategy"] = tipo
    df["Afp"] = nombre
    return df


def BU_TD_AFP(df1: pd.DataFrame, df2: pd.DataFrame,
              aum1: float, aum2: float, aum3: float) -> pd.DataFrame:
    df = pd.concat([df1, df2]).sort_index(ignore_index=True)
    df["AUM"] = (aum1 * _fondo_dummy(df["Fondo"], "F1")
                 + aum2 * _fondo_dummy(df["Fondo"], "F2")
                 + aum3 * _fondo_dummy(df["Fondo"], "F3"))
    return df


def X_AFP_(df: pd.DataFrame, aum1: float, aum2: float, aum3: float) -> pd.DataFrame:
    df = df.copy()
    df["USD"] = df["Weight"] * (aum1 * _fondo_dummy(df["Fondo"], "F1")
                                + aum2 * _fondo_dummy(df["Fondo"], "F2")
                                + aum3 * _fondo_dummy(df["Fondo"], "F3"))
    df = df.drop(columns=["Fondo", "AUM", "Weight"]).sort_index(ignore_index=True)

    df = df.groupby(["SBS", "ISIN", "Nombre", "Rank Rt", "Strategy", "Afp"]).sum()
    aum = aum1 + aum2 + aum3
    df["AUM"] = aum
    df["Weight"] = df["USD"] / aum
    df = df.drop(columns=["USD"])
    df["Fondo"] = "Multifondos"
    return df.reset_index()


