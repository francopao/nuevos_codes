def recor(serie: pd.Series) -> pd.Series:
    """Primeros 2 caracteres del SBS; conserva los nulos (equivale a recor())."""
    return serie.where(serie.isna(), serie.astype(str).str[:2])


def _fondo_dummy(fondo: pd.Series, cual: str) -> pd.Series:
    """Reemplazo vectorizado de usd_f1 / usd_f2 / usd_f3."""
    return (fondo == cual).astype(int)


