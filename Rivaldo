def _fmt_pct(x):
    return "-" if (x is None or (isinstance(x, float) and np.isnan(x))) else f"{x*100:,.2f}%"


def _fmt_money(x):
    return "-" if (x is None or (isinstance(x, float) and np.isnan(x))) else f"{x:,.0f}"


def _tabla_resumen_html(resumen):
    rows = ""
    for afp in AFPS:
        sub = resumen[resumen["AFP"] == afp]
        if sub.empty:
            continue
        rows += f'<tr class="afp"><td colspan="6">{html.escape(AFP_LABEL[afp])}</td></tr>'
        for _, r in sub.iterrows():
            def cls(v):
                return "pos" if (isinstance(v, float) and v > 0) else ("neg" if (isinstance(v, float) and v < 0) else "")
            rows += (f'<tr><td class="lab">{r.Fondo}</td>'
                     f'<td class="{cls(r.Day)}">{_fmt_pct(r.Day)}</td>'
                     f'<td class="{cls(r.WTD)}">{_fmt_pct(r.WTD)}</td>'
                     f'<td class="{cls(r.MTD)}">{_fmt_pct(r.MTD)}</td>'
                     f'<td class="{cls(r.YTD)}">{_fmt_pct(r.YTD)}</td></tr>')
    return (f'<table class="grid"><thead><tr><th>Fondo</th><th>Day</th>'
            f'<th>WTD</th><th>MTD</th><th>YTD (Aggr.)</th></tr></thead><tbody>{rows}</tbody></table>')


def _tabla_corrobora_html(corrobora, d_corte):
    rows = ""
    for _, r in corrobora.iterrows():
        mismatch = (r.FechaFinExcel != d_corte)
        badge = (f'<span class="warn">{r.FechaFinExcel}</span>' if mismatch
                 else f'<span class="ok">{r.FechaFinExcel}</span>')
        dcls = "neg" if r.Delta < 0 else ("pos" if r.Delta > 0 else "")
        rows += (f'<tr><td class="lab">{r.AFP} {r.Fondo}</td>'
                 f'<td>{_fmt_pct(r.YTD_correcto)}</td>'
                 f'<td>{_fmt_pct(r.YTD_excel)}</td>'
                 f'<td class="{dcls}">{_fmt_pct(r.Delta)}</td>'
                 f'<td>{badge}</td></tr>')
    return (f'<table class="grid"><thead><tr><th>AFP/Fondo</th>'
            f'<th>YTD correcto<br><small>(por fechas)</small></th>'
            f'<th>YTD Excel<br><small>(OFFSET/NETWORKDAYS)</small></th>'
            f'<th>&Delta;</th><th>Excel termina en</th></tr></thead><tbody>{rows}</tbody></table>')


def _pos_html(pos, detalle, afp_sel="IN", fondo_sel="F1"):
    d = pos.get(afp_sel, {}).get(fondo_sel, {})
    tot = sum(d.values()) or 1.0
    rows = ""
    for sector, w in sorted(d.items(), key=lambda kv: -kv[1]):
        rows += f'<tr><td class="lab">{html.escape(sector)}</td><td>{_fmt_pct(w)}</td></tr>'
    rows += f'<tr class="afp"><td class="lab">Total invertido</td><td>{_fmt_pct(tot)}</td></tr>'
    top = sorted(detalle.get(afp_sel, {}).get(fondo_sel, []), key=lambda t: -t[2])[:10]
    trows = "".join(f'<tr><td class="lab">{html.escape(n)}</td>'
                    f'<td><small>{html.escape(s)}</small></td><td>{_fmt_pct(w)}</td></tr>'
                    for n, s, w in top)
    return (f'<div class="two"><div><h4>Pesos por sector &mdash; {afp_sel} {fondo_sel}</h4>'
            f'<table class="grid">{rows}</table></div>'
            f'<div><h4>Top 10 posiciones &mdash; {afp_sel} {fondo_sel}</h4>'
            f'<table class="grid">{trows}</table></div></div>')


