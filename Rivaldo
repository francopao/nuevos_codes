def main():
    log.info("Leyendo libro: %s", LIBRO)
    if not os.path.exists(LIBRO):
        log.error("No se encontro el libro. Revisa la variable LIBRO.")
        raise FileNotFoundError(LIBRO)

    code2name, code2sector = _leer_parametria(LIBRO)
    idx, ret_total, aum, header, weight_idx, weight_rows, fechas = _leer_bd(LIBRO)

    d_corte = FECHA_CORTE or max(fechas)
    if isinstance(d_corte, dt.datetime):
        d_corte = d_corte.date()
    d_inicio = FECHA_INICIO or dt.date(d_corte.year, 1, 1)
    if isinstance(d_inicio, dt.datetime):
        d_inicio = d_inicio.date()
    log.info("Ventana: inicio=%s  corte=%s", d_inicio, d_corte)

    resumen, curvas, corrobora, aum, aum_ultimo, d_wtd, d_mtd, fechas_ord = \
        calcular(idx, ret_total, aum, fechas, d_inicio, d_corte)
    log.info("Retornos calculados para %d combinaciones AFP x Fondo.", len(resumen))

    pos, detalle = posicionamiento(header, weight_idx, weight_rows, fechas, d_corte,
                                   code2name, code2sector)
    n_pos = sum(len(v) for a in detalle.values() for v in a.values())
    log.info("Posicionamiento: %d posiciones (instrumento x AFP x Fondo) al corte.", n_pos)

    # --- reporte de corroboracion en consola ---
    desalineados = corrobora[corrobora["FechaFinExcel"] != d_corte]
    log.info("Corroboracion: %d/%d series donde el metodo Excel NO aterriza en el corte.",
             len(desalineados), len(corrobora))
    if len(desalineados):
        ej = desalineados.iloc[0]
        log.info("  Ej. %s %s -> Excel termina en %s (deberia ser %s). "
                 "YTD correcto=%.2f%%  vs  YTD Excel=%.2f%%  (delta=%.2f pp).",
                 ej.AFP, ej.Fondo, ej.FechaFinExcel, d_corte,
                 ej.YTD_correcto * 100, ej.YTD_excel * 100, ej.Delta * 100)

    html_out = construir_html(resumen, curvas, corrobora, aum, aum_ultimo, pos, detalle,
                              d_inicio, d_corte, d_wtd, d_mtd)
    os.makedirs(os.path.dirname(SALIDA_HTML) or ".", exist_ok=True)
    with open(SALIDA_HTML, "w", encoding="utf-8") as fh:
        fh.write(html_out)
    log.info("Dashboard generado: %s  (%.1f KB)", SALIDA_HTML, len(html_out) / 1024)
    log.info("Listo. Abre el archivo en tu navegador.")


if __name__ == "__main__":
    main()
