# 1) LECTURA DE BD Y PARAMETRIA
# ============================================================================
def _leer_parametria(ruta):
    """code -> (nombre, sector) desde la hoja Parametria (C=code, A=ticker, D=sector)."""
    wb = load_workbook(ruta, read_only=True, data_only=True)
    ws = wb["Parametria"]
    code2name, code2sector = {}, {}
    for row in ws.iter_rows(min_row=3, values_only=True):
        ticker = row[0] if len(row) > 0 else None
        code = row[2] if len(row) > 2 else None       # col C
        sector = row[3] if len(row) > 3 else None      # col D
        if code is None:
            continue
        code = str(code).strip()
        code2name[code] = str(ticker).strip() if ticker is not None else code
        code2sector[code] = str(sector).strip() if sector is not None else "Otros"
    wb.close()
    log.info("Parametria: %d instrumentos mapeados.", len(code2name))
    return code2name, code2sector


def _leer_bd(ruta):
    """
    Lee la hoja BD en streaming (read_only) y devuelve:
      - fechas (list[date])
      - ret_total: DataFrame de retornos DIARIOS por 'Ret_<AFP>_<F>_O_Total'
      - aum:       DataFrame de niveles 'AUM_RVL_<AFP>_<F>'
      - header, weight_idx: para leer pesos por fila cuando se necesite
    Solo materializa las familias necesarias (no las 7,897 columnas).
    """
    wb = load_workbook(ruta, read_only=True, data_only=True)
    ws = wb["BD"]
    it = ws.iter_rows(values_only=True)
    header = list(next(it))

    def _cols(pred):
        return {header[j]: j for j in range(len(header))
                if isinstance(header[j], str) and pred(header[j])}

    ret_cols = _cols(lambda h: h.startswith("Ret_") and h.endswith("_O_Total"))
    aum_cols = _cols(lambda h: h.startswith("AUM_RVL_"))
    weight_idx = {header[j]: j for j in range(len(header))
                  if isinstance(header[j], str) and header[j].startswith("weight_")}

    fechas, ret_rows, aum_rows, weight_rows = [], [], [], []
    for row in it:
        d = row[0]
        if not isinstance(d, dt.datetime):
            continue
        fechas.append(d.date())
        ret_rows.append([row[j] if isinstance(row[j], (int, float)) else np.nan
                         for j in ret_cols.values()])
        aum_rows.append([row[j] if isinstance(row[j], (int, float)) else np.nan
                         for j in aum_cols.values()])
        # guardamos la fila completa de pesos (para el snapshot de posicionamiento)
        weight_rows.append(row)
    wb.close()

    idx = pd.to_datetime(fechas)
    ret_total = pd.DataFrame(ret_rows, index=idx, columns=list(ret_cols.keys())).sort_index()
    aum = pd.DataFrame(aum_rows, index=idx, columns=list(aum_cols.keys())).sort_index()
    log.info("BD: %d filas de fecha, %d cols Ret_*_O_Total, %d cols AUM_RVL_*, %d cols weight_*.",
             len(fechas), len(ret_cols), len(aum_cols), len(weight_idx))
    log.info("BD: rango de fechas %s -> %s.", idx.min().date(), idx.max().date())
    return idx, ret_total, aum, header, weight_idx, weight_rows, fechas


# ============================================================================
# 2) VENTANAS DE FECHA (igual criterio que Resumen: Day / WTD / MTD / YTD)
# ============================================================================
def _primer_habil_mes(fecha):
    primero = fecha.replace(day=1)
    while np.is_busday(primero) == False:  # noqa: E712
        primero += dt.timedelta(days=1)
    return primero


def _inicio_semana(fecha):
    # lunes de la semana de la fecha de corte (WEEKDAY(...,2) -> ISO)
    return fecha - dt.timedelta(days=fecha.weekday())


# ============================================================================
# 3) ACUMULACION: metodo CORRECTO (por fechas) y metodo EXCEL (OFFSET)
# ============================================================================
def compound_por_fechas(serie_diaria, d0, d1, incluir_d0=False):
    """PRODUCT(1+r)-1 sobre las fechas reales en (d0, d1] (o [d0,d1] si incluir_d0)."""
    s = serie_diaria.dropna()
    if incluir_d0:
        mask = (s.index.date >= d0) & (s.index.date <= d1)
    else:
        mask = (s.index.date > d0) & (s.index.date <= d1)
    fac = (1.0 + s[mask]).prod()
    return fac - 1.0


def compound_excel_offset(serie_diaria, fechas_ordenadas, d_start, d_cut):
    """
    Replica EXACTA de la formula de Excel:
        PRODUCT(1+OFFSET(BD!A1, fila(d_start)-1, col-1, NETWORKDAYS(d_start,d_cut)))-1
    Arranca en la FILA de d_start y toma NETWORKDAYS filas consecutivas hacia abajo.
    Devuelve (retorno, alto_usado, fecha_en_la_que_realmente_termina).
    """
    s = serie_diaria
    # localizar la fila de d_start (o la primera fila >= d_start)
    try:
        si = fechas_ordenadas.index(d_start)
    except ValueError:
        si = next((k for k, dd in enumerate(fechas_ordenadas) if dd >= d_start), None)
        if si is None:
            return np.nan, 0, None
    alto = int(np.busday_count(d_start, d_cut)) + 1   # NETWORKDAYS inclusivo
    fac, ultima = 1.0, fechas_ordenadas[si]
    for k in range(si, min(si + alto, len(fechas_ordenadas))):
        v = s.iloc[k]
        if isinstance(v, (int, float)) and not np.isnan(v):
            fac *= (1.0 + v)
        ultima = fechas_ordenadas[k]
    return fac - 1.0, alto, ultima


# ============================================================================
# 4) CALCULOS DEL DASHBOARD
# ============================================================================
def calcular(idx, ret_total, aum, fechas, d_inicio, d_corte):
    fechas_ord = sorted(fechas)
    d_wtd = _inicio_semana(d_corte)
    d_mtd = _primer_habil_mes(d_corte)

    resumen = []          # filas: AFP, Fondo, Day, WTD, MTD, YTD
    curvas = {}           # 'AFP_F' -> Series (indice acumulado base 100)
    corrobora = []        # AFP, Fondo, YTD_correcto, YTD_excel, delta, fecha_excel

    for afp in AFPS:
        for f in FONDOS:
            col = f"Ret_{afp}_{f}_O_Total"
            if col not in ret_total.columns:
                continue
            s = ret_total[col]
            if s.dropna().empty:
                continue

            day = float(s.dropna().iloc[-1]) if not s.dropna().empty else np.nan
            # ventana de corte: valor del dia de corte exacto si existe
            if pd.Timestamp(d_corte) in s.index:
                day = float(s.loc[pd.Timestamp(d_corte)])

            ytd = compound_por_fechas(s, d_inicio, d_corte)
            wtd = compound_por_fechas(s, d_wtd, d_corte)
            mtd = compound_por_fechas(s, d_mtd, d_corte)
            resumen.append([afp, f, day, wtd, mtd, ytd])

            # curva acumulada (base 100) en la ventana YTD
            mask = (s.index.date > d_inicio) & (s.index.date <= d_corte)
            curva = (1.0 + s[mask].fillna(0)).cumprod() * 100.0
            curvas[f"{afp}_{f}"] = curva

            # corroboracion: metodo excel vs fechas (solo YTD/Aggr)
            ytd_excel, alto, fecha_fin = compound_excel_offset(s, fechas_ord, d_inicio, d_corte)
            corrobora.append([afp, f, ytd, ytd_excel, ytd_excel - ytd, fecha_fin, alto])

    resumen = pd.DataFrame(resumen, columns=["AFP", "Fondo", "Day", "WTD", "MTD", "YTD"])
    corrobora = pd.DataFrame(corrobora, columns=["AFP", "Fondo", "YTD_correcto",
                                                 "YTD_excel", "Delta", "FechaFinExcel", "AltoFilas"])
    # niveles de AUM (ultimo)
    aum_ultimo = aum.loc[:pd.Timestamp(d_corte)].dropna(how="all")
    aum_ultimo = aum_ultimo.iloc[-1] if len(aum_ultimo) else pd.Series(dtype=float)

    return resumen, curvas, corrobora, aum, aum_ultimo, d_wtd, d_mtd, fechas_ord


def posicionamiento(header, weight_idx, weight_rows, fechas, d_corte,
                    code2name, code2sector):
    """Snapshot de pesos en la fecha de corte -> por AFP/Fondo, agregado por sector."""
    # fila del corte
    try:
        ri = fechas.index(d_corte)
    except ValueError:
        ri = max(range(len(fechas)), key=lambda k: fechas[k] if fechas[k] <= d_corte else dt.date.min)
    fila = weight_rows[ri]

    pat = re.compile(r"^weight_(IN|HA|PF|RI|EXSIS)_(F1|F2|F3|M)_(.+)$")
    # estructura: pos[afp][f] = {sector: peso, ...}, y detalle por instrumento
    pos = {a: {f: {} for f in FONDOS} for a in AFPS}
    detalle = {a: {f: [] for f in FONDOS} for a in AFPS}
    for name, j in weight_idx.items():
        m = pat.match(name)
        if not m:
            continue
        afp, f, code = m.group(1), m.group(2), m.group(3)
        v = fila[j] if j < len(fila) else None
        if not isinstance(v, (int, float)) or v == 0 or (isinstance(v, float) and np.isnan(v)):
            continue
        sector = code2sector.get(code, "Otros")
        nombre = code2name.get(code, code)
        pos[afp][f][sector] = pos[afp][f].get(sector, 0.0) + float(v)
        detalle[afp][f].append((nombre, sector, float(v)))
    return pos, detalle


