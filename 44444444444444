        if r > hrow + 1:
            ws.auto_filter.ref = f"A{hrow}:{get_column_letter(len(cols))}{r-1}"

    # ======================================================================
    # NUEVO: HOJA "Cobertura" — checklist de emisores directo-Local.
    # Universo esperado = filas de Valorización cuya "Clasificación ERR" (col AA)
    # sea Equity/Deuda directo - Local. Se resuelve el nombre (col AE, formulado)
    # a canónico y se marca si el script lo consideró (score + AUM + activo físico).
    # ======================================================================
    try:
        ERR_OBJETIVO = {"EQUITY DIRECTO - LOCAL", "DEUDA CORPORATIVA DIRECTA - LOCAL"}

        # 1) Leer Valorización: nombre (AE) + Clasificación ERR (AA)
        _raw = pd.read_excel(risk_path, sheet_name=sheet_val, header=None)
        _hdr, _ = detect_header_row(_raw, ["Nombre (G&P)", "VALOR_VECTOR_LOCAL"], max_scan=10)
        _dfv = pd.read_excel(risk_path, sheet_name=sheet_val, header=_hdr).dropna(how="all")
        _spec = {"nombre": (["Nombre (G&P)", "Nombre G P", "Nombre"], "AE"),
                 "err":    (["Clasificación ERR", "Clasificacion ERR", "ERR"], "AA")}
        _c = resolve_columns(_dfv.columns, _spec)
        _dfv = _dfv.rename(columns={_c["nombre"]: "_nom", _c["err"]: "_err"})
        _dfv["_errn"] = _dfv["_err"].astype(str).str.strip().apply(lambda x: norm(x))
        _obj = _dfv[_dfv["_errn"].isin({norm(e) for e in ERR_OBJETIVO})].copy()

        # 2) Universo esperado: por NOMBRE tal cual aparece (se repite por instrumento).
        #    Guardamos las ERR distintas de cada nombre (un emisor puede tener varias).
        _errs_por_nombre = {}
        for _, _rr in _obj.iterrows():
            _nm = str(_rr["_nom"]).strip()
            if _nm and _nm.lower() != "nan":
                _errs_por_nombre.setdefault(_nm, set()).add(str(_rr["_err"]).strip())

        # 3) Mapeo nombre -> canónico (el mismo del resto del script)
        _eqn = {norm(k): v for k, v in (equiv_canonico or {}).items()}

        # 4) Señales de cobertura (ya calculadas arriba en esta función):
        #    - aum_emp_tot: emisores con AUM ponderado > 0 (implica geografía + activo).
        #    - scores: dict canónico -> {mm,inu,seq,global}; score>0 = tiene score.
        _canon_con_aum = set(aum_emp_tot.keys())
        _canon_con_score = {e for e, sc in scores.items()
                            if (sc.get("global", 0) or 0) > 0}

        # 5) Construir filas de la hoja
        _rows_cob = []
        for _nm in sorted(_errs_por_nombre.keys(), key=lambda x: x.lower()):
            _cat = "; ".join(sorted(_errs_por_nombre[_nm]))
            _canon = _eqn.get(norm(_nm))
            if _canon is None:
                _cob, _com = "No", ("El nombre no está en el mapeo de equivalencias "
                                    "(EQUIV/EMPRESAS canónicas); el script no lo reconoce "
                                    "como emisor analizable. Revisar alias en CONFIG.")
            else:
                _tiene_aum = _canon in _canon_con_aum
                _tiene_score = _canon in _canon_con_score
                if _tiene_aum and _tiene_score:
                    _cob, _com = "Sí", ""
                elif _tiene_aum and not _tiene_score:
                    _cob, _com = "No", ("Tiene AUM y activos mapeados, pero ninguno de sus "
                                        "distritos tiene score CENEPRED válido.")
                elif (not _tiene_aum) and _tiene_score:
                    _cob, _com = "No", ("Reconocido y con score, pero sin AUM/activo físico "
                                        "mapeado (falta geografía o exposición efectiva).")
                else:
                    _com_extra = ("" if _canon == _nm.strip()
                                  else f" (mapea a canónico '{_canon}')")
                    _cob, _com = "No", ("Reconocido pero sin AUM ni activo físico mapeado: "
                                        "no llegó a 'districts'. Posible falta de geografía "
                                        "(sin hoja de activos / sin producción / sin banca) "
                                        "o exposición nula." + _com_extra)
            _rows_cob.append((_nm, _canon or "—", _cat, _cob, _com))

        # 6) Escribir la hoja
        ws_cob = wb.create_sheet(title="Cobertura")
        ws_cob.sheet_view.showGridLines = False
        _n_esp = len(_rows_cob)
        _n_si = sum(1 for x in _rows_cob if x[3] == "Sí")
        ws_cob["A1"] = "Cobertura de emisores directo - Local (Equity / Deuda corporativa)"
        ws_cob["A1"].font = F_TIT
        ws_cob["A2"] = (f"Emisores esperados: {_n_esp} · Con cobertura: {_n_si} · "
                        f"Sin cobertura: {_n_esp - _n_si} · Periodo {periodo}")
        ws_cob["A2"].font = F_SUB

        _headers = ["Emisor (Valorización)", "Emisor canónico",
                    "Clasificación ERR", "Cobertura", "Comentario"]
        _hr = 4
        for _j, _t in enumerate(_headers, start=1):
            _cc = ws_cob.cell(row=_hr, column=_j, value=_t)
            _cc.font = F_HEAD; _cc.fill = FILL_HEAD; _cc.alignment = A_C; _cc.border = BORDER

        _rr2 = _hr + 1
        for _nm, _canon, _cat, _cob, _com in _rows_cob:
            _vals = [_nm, _canon, _cat, _cob, _com]
            for _j, _v in enumerate(_vals, start=1):
                _cc = ws_cob.cell(row=_rr2, column=_j, value=_v)
                _cc.font = F_BODY; _cc.border = BORDER
                if _j in (1, 2, 3, 5):
                    _cc.alignment = A_LW
                else:
                    _cc.alignment = A_C
                    if _cob == "Sí":
                        _cc.fill = PatternFill("solid", fgColor="D4EDDA")
                    else:
                        _cc.fill = PatternFill("solid", fgColor="F8D7DA")
            _rr2 += 1

        for _col, _w in zip("ABCDE", (30, 24, 42, 12, 60)):
            ws_cob.column_dimensions[_col].width = _w
        ws_cob.freeze_panes = "A5"
        if _rr2 > _hr + 1:
            ws_cob.auto_filter.ref = f"A{_hr}:E{_rr2 - 1}"
        logfn(f"[Activos] Hoja 'Cobertura': {_n_esp} emisores esperados, "
              f"{_n_si} con cobertura, {_n_esp - _n_si} sin.")
    except Exception as _e_cob:
        logfn(f"[Activos] No se pudo generar la hoja 'Cobertura': {_e_cob}")

    os.makedirs(out_dir, exist_ok=True)
