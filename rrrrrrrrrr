def _find_metalica():
    """Todos los 'Producción metálica *.xlsx' disponibles (unión de años)."""
    hits = []
    for pat in METALICA_PATTERNS:
        hits += glob.glob(os.path.join(METALICA_DIR, pat))
    hits = sorted(set(h for h in hits if not os.path.basename(h).startswith("~$")))
    return hits


def _read_metalica(path):
    """Lee 'INFORMACION GENERAL' con header dinámico y columnas por nombre EXACTO.
    Devuelve (filas, colmap) donde colmap indexa MINERAL/UM/TITULAR/UNIDAD/DEP/PROV/DIST."""
    import openpyxl
    wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
    ws = next((wb[s] for s in wb.sheetnames
               if "INFORMACION" in norm(s) or "GENERAL" in norm(s)), wb[wb.sheetnames[0]])
    scan = [[c.value for c in r] for r in ws.iter_rows(min_row=1, max_row=12)]
    hr, _ = detect_header_row(pd.DataFrame(scan),
                              ["TITULAR", "UNIDAD", "DEPARTAMENTO", "DISTRITO"])
    hdr = [norm(x) for x in scan[hr]]
    filas = list(ws.iter_rows(min_row=hr + 2, values_only=True))
    wb.close()
    col = lambda nm: next((i for i, h in enumerate(hdr) if h == nm), None)
    cm = {"MINERAL": col("MINERAL"), "UM": col("UNIDAD DE MEDIDA"),
          "TITULAR": col("TITULAR"), "UNIDAD": col("UNIDAD"),
          "DEP": col("DEPARTAMENTO"), "PROV": col("PROVINCIA"), "DIST": col("DISTRITO")}
    return filas, cm


def _mapa_mineral_um(met_paths):
    """MINERAL (norm) -> unidad de medida (norm_unidad), leído de metálica. 1:1."""
    m = {}
    for p in met_paths:
        filas, cm = _read_metalica(p)
        if cm["MINERAL"] is None or cm["UM"] is None:
            continue
        for r in filas:
            mineral, um = r[cm["MINERAL"]], r[cm["UM"]]
            if mineral and um and norm_unidad(um) in UNIDAD_A_TMF:
                m[norm(mineral)] = norm_unidad(um)
    return m


def _geo_metalica(met_paths):
    """(canónico, UNIDAD norm) -> (DEP, PROV, DIST). Canoniza TITULAR legal con
    EQUIV_EMPRESAS_PRODUCCION. La geografía viene en MAYÚSCULAS (la maneja geocode)."""
    eq_leg = {norm(k): v for k, v in EQUIV_EMPRESAS_PRODUCCION.items()}
    geo = {}
    for p in met_paths:
        filas, cm = _read_metalica(p)
        if None in (cm["TITULAR"], cm["UNIDAD"], cm["DEP"]):
            continue
        for r in filas:
            tit, uni, dep = r[cm["TITULAR"]], r[cm["UNIDAD"]], r[cm["DEP"]]
            can = eq_leg.get(norm(tit))
            if can and uni and dep:
                geo.setdefault((can, norm(uni)),
                               (str(dep).strip(),
                                str(r[cm["PROV"]]).strip(), str(r[cm["DIST"]]).strip()))
    return geo


def load_produccion(bd_path, geo_idx=None, scores=None):
    """Producción minera con DOS fuentes:
      • BD Prod (BD_Mineria.xlsm) -> peso TMF por (TITULAR, UNIDAD) sumando el
        semestre en curso (misma ventana del pipeline; fallback a 6m recientes).
      • Producción metálica <año> -> geografía (DEP/PROV/DIST) por (TITULAR, UNIDAD).
    Devuelve (df_prod, hoja) con las columnas que consume build_model."""
    import openpyxl, datetime
    met_paths = _find_metalica()
    if not met_paths:
        log(f"No se encontró 'Producción metálica *.xlsx' en {METALICA_DIR}; "
            f"la minería quedará sin geografía.", "WARN")
    ummap = _mapa_mineral_um(met_paths) if met_paths else {}
    geo = _geo_metalica(met_paths) if met_paths else {}

    wb = openpyxl.load_workbook(bd_path, data_only=True)
    sheet = next((s for s in wb.sheetnames if "BD PROD" in norm(s)), wb.sheetnames[-1])
    ws = wb[sheet]

    # --- header dinámico (no asumir fila 1) ---
    scan = pd.DataFrame([[ws.cell(r, c).value for c in range(1, 13)]
                         for r in range(1, 13)])
    hrow, sc = detect_header_row(scan, ["MINERAL", "ETAPA", "TITULAR", "UNIDAD"])
    hrow += 1  # a 1-based
    hdr = {norm(ws.cell(hrow, c).value): c for c in range(1, ws.max_column + 1)
           if isinstance(ws.cell(hrow, c).value, str)}
    cMin, cEt = hdr.get("MINERAL"), hdr.get("ETAPA")
    cTit, cUni = hdr.get("TITULAR"), hdr.get("UNIDAD")
    if not all([cMin, cTit, cUni]):
        fatal(f"BD Prod: no se ubicaron MINERAL/TITULAR/UNIDAD en la fila {hrow} "
              f"(score={sc}). Revisa la hoja '{sheet}'.")

    # --- ventana de meses = semestre en curso; fallback a 6m recientes con datos ---
    fcols = [(c, ws.cell(hrow, c).value) for c in range(1, ws.max_column + 1)
             if isinstance(ws.cell(hrow, c).value, datetime.datetime)]
    obj = set(_meses_semestre_anterior())
    def _datos(c):
        return any(isinstance(ws.cell(rr, c).value, (int, float)) and ws.cell(rr, c).value
                   for rr in range(hrow + 1, ws.max_row + 1))
    inwin = [(c, d) for c, d in fcols if (d.year, d.month) in obj and _datos(c)]
    if not inwin:
        con = sorted([(c, d) for c, d in fcols if _datos(c)], key=lambda x: x[1])
        inwin = con[-6:]
        if inwin:
            log(f"BD Prod: ventana semestral sin datos; se usan los 6 meses recientes "
                f"{inwin[0][1].date()}..{inwin[-1][1].date()}.", "WARN")
    wcols = [c for c, _ in inwin]

    eq_bd = {norm(k): v for k, v in EQUIV_MINERAS_MENSUAL.items()}
    proc_ok = {norm(p) for p in PROCESOS_VALIDOS}
    filas = []
    for r in range(hrow + 1, ws.max_row + 1):
        tit, uni, mineral = ws.cell(r, cTit).value, ws.cell(r, cUni).value, ws.cell(r, cMin).value
        if not tit or not uni:
            continue
        if cEt and norm(ws.cell(r, cEt).value) not in proc_ok:   # solo CONCENTRACIÓN
            continue
        can = eq_bd.get(norm(tit))
        if not can:                                              # fuera del universo
            continue
        mn = EQUIV_MINERAL.get(norm(mineral), norm(mineral))
        um = ummap.get(mn, MINERAL_UM_FALLBACK.get(mn, "tmf"))
        acum = sum(v for c in wcols for v in [ws.cell(r, c).value]
                   if isinstance(v, (int, float)))
        filas.append({"empresa": can, "unidad_minera": str(uni).strip(),
                      "mineral": str(mineral).strip(), "unidad_norm": um,
                      "factor": UNIDAD_A_TMF[um], "acum": float(acum),
                      "tmf": float(acum) * UNIDAD_A_TMF[um]})
    wb.close()
    df = pd.DataFrame(filas)
    if df.empty:
        fatal("BD Prod: no se acumuló producción del universo (revisa ETAPA/TITULAR "
              "y EQUIV_MINERAS_MENSUAL).")

    # --- geografía por (canónico, UNIDAD) con override manual ---
    u2name = geo_idx[2] if geo_idx else {}
    deps, provs, dists, sin_geo = [], [], [], []
    for _, r in df.iterrows():
        key = (r["empresa"], norm(r["unidad_minera"]))
        if key in geo:
            d = geo[key]
        elif key in OVERRIDE_UNIDAD_UBIGEO and OVERRIDE_UNIDAD_UBIGEO[key] in u2name:
            d = u2name[OVERRIDE_UNIDAD_UBIGEO[key]]
        else:
            d = (None, None, None)
            sin_geo.append((r["empresa"], r["unidad_minera"]))
        deps.append(d[0]); provs.append(d[1]); dists.append(d[2])
    df["depto"], df["prov"], df["dist"] = deps, provs, dists
    df["unidad"] = df["unidad_norm"].map(lambda u: UNIDAD_LABEL.get(u, u))

    # --- AVISO 1: unidades SIN geografía en metálica (candidatas a override) ---
    if sin_geo:
        uu = sorted(set(sin_geo))
        log(f"Producción: {len(uu)} unidad(es) minera(s) SIN geografía en metálica "
            f"(se excluyen; agrégalas a OVERRIDE_UNIDAD_UBIGEO):", "WARN")
        for e, un in uu:
            log(f"      {e} · {un}", "WARN")

    # --- AVISO 2: unidades con geografía pero SIN cobertura CENEPRED (Score 's/d') ---
    if geo_idx is not None and scores is not None:
        sin_cen = []
        for _, r in df[df["depto"].notna()].iterrows():
            u, _mot = geocode(r["depto"], r["prov"], r["dist"], geo_idx)
            if u is None or u not in scores:
                sin_cen.append((r["empresa"], r["unidad_minera"], u))
        if sin_cen:
            uu = sorted(set(sin_cen))
            log(f"Producción: {len(uu)} unidad(es) con ubigeo pero SIN cobertura "
                f"CENEPRED (su Score Global saldrá 's/d'):", "WARN")
            for e, un, u in uu:
                log(f"      {e} · {un}  [ubigeo={u or 'no geocodificado'}]", "WARN")

    df = df.dropna(subset=["depto"]).copy()
    log(f"Producción (BD Prod + metálica): {len(df)} fila(s), "
        f"{df['empresa'].nunique()} empresa(s) del universo con geografía.")
    return df, sheet
