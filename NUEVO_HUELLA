SECTOR_MOSTRAR = {"materials": "Materials", "utilities": "Utilities"}
EMISOR_SUFIJOS = ["adr", "cm", "milpo", "saa", "sa", "ltd", "corp", "inc", "plc"]
EMISOR_EQUIVALENCIA = {
    "nexaperu": "Nexa", "nexa": "Nexa",
    # agrega equivalencias: "variantenormalizada": "Nombre Padre",
}
ISIN_PAIS = {"PE": "Perú", "US": "EEUU", "BR": "Brasil", "MX": "México",
             "CL": "Chile", "CO": "Colombia"}
PAIS_ORDEN = ["Perú", "Brasil", "México", "Chile", "Colombia", "EEUU", "Otros"]
ESTRATEGIAS_PORTAFOLIO = {"BU", "TD", "ALT"}


def _emisor_padre(nombre: Optional[str]) -> Optional[str]:
    if not nombre:
        return None
    import re
    s = str(nombre).strip()
    s = re.sub(r"\(.*?\)", "", s)
    s = re.sub(r"[\-]", " ", s)
    toks = s.split()
    while toks and re.sub(r"[^a-z]", "", toks[-1].lower()) in EMISOR_SUFIJOS:
        toks.pop()
    base = " ".join(toks).strip().rstrip(".").strip()
    return EMISOR_EQUIVALENCIA.get(_normalize(base), base)


class PresentacionBuilder:
    """Cortes sobre Valorización para los gráficos del comité."""

    def __init__(self, df_val: pd.DataFrame, sector_lookup: Optional[Dict[str, str]] = None,
                 verbose: bool = True, nombre_col: str = "Nombre", huella_col: str = "Huella",
                 intensidad_col: str = "Intensidad", estrategia_col: str = "Estrategia",
                 rank_col: str = "Rank_rt", plus_col: str = "Plus", plus1_col: str = "Plus_1",
                 isin_col: str = "CODIGO_ISIN"):
        self.df = df_val.copy()
        self.sector_lookup = sector_lookup or {}
        self.verbose = verbose
        self.c_nombre = nombre_col; self.c_huella = huella_col; self.c_intens = intensidad_col
        self.c_estr = estrategia_col; self.c_rank = rank_col; self.c_plus = plus_col
        self.c_plus1 = plus1_col; self.c_isin = isin_col
        self.out: Dict[str, pd.DataFrame] = {}
        self._prep()

    def _prep(self):
        df = self.df
        df[self.c_huella] = pd.to_numeric(df[self.c_huella], errors="coerce").fillna(0.0)
        df[self.c_intens] = pd.to_numeric(df[self.c_intens], errors="coerce").fillna(0.0)
        df["_emisor"] = df[self.c_nombre].map(_emisor_padre)
        df["_serie"] = df[self.c_plus].map(
            lambda p: "Proxies" if _to_string(p) == "Proxies" else "MSCI")
        df["_eje_sector"] = df.apply(self._eje_sector, axis=1)
        df["_pais"] = df[self.c_isin].map(self._pais_isin)

    def _sector_de(self, emisor, nombre):
        raw = self.sector_lookup.get(_normalize(emisor)) or self.sector_lookup.get(_normalize(nombre))
        return _to_string(raw) if raw else ""

    def _eje_sector(self, row):
        plus = _to_string(row.get(self.c_plus))
        plus1 = _to_string(row.get(self.c_plus1))
        rank = _to_string(row.get(self.c_rank)) or ""
        if plus == "SOV" or plus1 in ("SOV", "Soberanos"):
            return "ETF Sobs"
        if plus == "ETF" or plus1 == "Otros ETFs":
            return "RV"
        if plus1 == "Alts":
            return "Alts"
        if rank.upper().startswith("RF"):
            return "RF"
        if rank.upper().startswith("RV"):
            sec = self._sector_de(row.get("_emisor"), row.get(self.c_nombre))
            return SECTOR_MOSTRAR.get(_normalize(sec), "Otros")
        sec = self._sector_de(row.get("_emisor"), row.get(self.c_nombre))
        return SECTOR_MOSTRAR.get(_normalize(sec), "Otros")

    @staticmethod
    def _pais_isin(isin):
        s = _to_string(isin)
        if s and len(s) >= 2:
            return ISIN_PAIS.get(s[:2].upper(), "Otros")
        return "Otros"

    def _agg(self, df, dim):
        return (df.groupby([dim, "_serie"])
                  .agg(Huella=(self.c_huella, "sum"), Intensidad=(self.c_intens, "sum"))
                  .reset_index().rename(columns={dim: "bucket", "_serie": "serie"}))

    def por_sector(self, estrategias: Optional[set] = None) -> pd.DataFrame:
        estr = estrategias or ESTRATEGIAS_PORTAFOLIO
        df = self.df[self.df[self.c_estr].map(lambda e: _to_string(e) in estr)]
        d = self._agg(df, "_eje_sector")
        self.out["por_sector"] = d
        if self.verbose:
            tot = d.groupby("bucket")["Huella"].sum()
            print(f"  [Módulo 12] por_sector (TD+BU+Alts): {dict(tot.round(0).astype(int))}")
        return d

    def soberanos_por_sector(self) -> pd.DataFrame:
        df = self.df[self.df[self.c_estr].map(lambda e: _to_string(e) == "GOB")]
        d = self._agg(df, "_eje_sector")
        self.out["soberanos"] = d
        return d

    def por_pais(self, solo_soberanos: bool = False) -> pd.DataFrame:
        df = self.df
        if solo_soberanos:
            df = df[df[self.c_estr].map(lambda e: _to_string(e) == "GOB")]
        g = (df.groupby(["_pais", "_serie"])
               .agg(Huella=(self.c_huella, "sum"), Intensidad=(self.c_intens, "sum"))
               .reset_index().rename(columns={"_pais": "bucket", "_serie": "serie"}))
        rank = {b: i for i, b in enumerate(PAIS_ORDEN)}
        g["_o"] = g["bucket"].map(lambda b: rank.get(b, 999))
        g = g.sort_values("_o").drop(columns="_o").reset_index(drop=True)
        self.out["por_pais_soberanos" if solo_soberanos else "por_pais_todos"] = g
        return g

    def emisores_top(self, top_n: int = 10) -> pd.DataFrame:
        g = (self.df.groupby("_emisor")
               .agg(Huella=(self.c_huella, "sum"), Intensidad=(self.c_intens, "sum"))
               .reset_index().rename(columns={"_emisor": "emisor"})
               .sort_values("Huella", ascending=False).head(top_n).reset_index(drop=True))
        self.out["emisores_top"] = g
        return g

    def build_all(self) -> Dict[str, pd.DataFrame]:
        self.por_sector()
        self.soberanos_por_sector()
        self.por_pais(solo_soberanos=False)
        self.por_pais(solo_soberanos=True)
        self.emisores_top()
        if self.verbose:
            print(f"  [Módulo 12] {len(self.out)} cortes listos.")
        return self.out

    def as_dict(self) -> Dict[str, pd.DataFrame]:
        return self.out


