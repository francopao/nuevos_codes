class DashboardHTML:
    """Dashboard HTML a partir de los cortes del Módulo 12."""

    def __init__(self, config: Config, verbose: bool = True):
        self.config = config
        self.semestre = getattr(config, "semestre", "SEMESTRE")
        self.verbose = verbose
        self._figs: List[Tuple[str, str]] = []

    def build(self, cortes: Dict[str, pd.DataFrame], *,
              au4_total_huella: Optional[float] = None,
              out_path: Optional[str] = None) -> Optional[str]:
        try:
            import plotly.graph_objects as go
            import plotly.io as pio
        except ImportError:
            print("  [Módulo 14] [ERROR] Falta plotly. Instala: pip install plotly")
            return None
        self._go, self._pio = go, pio
        self._add(self._stacked(cortes.get("por_sector"), "Huella",
                  "Huella por Sector (miles Tn CO2) — TD+BU+Alts"))
        self._add(self._stacked(cortes.get("por_sector"), "Intensidad",
                  "Intensidad por Sector (Tn CO2/USD MM)"))
        self._add(self._stacked(cortes.get("por_pais_todos"), "Huella",
                  "Huella por País (miles Tn CO2)"))
        self._add(self._stacked(cortes.get("por_pais_todos"), "Intensidad",
                  "Intensidad por País (Tn CO2/USD MM)"))
        self._add(self._stacked(cortes.get("soberanos"), "Huella",
                  "Soberanos por Sector (Huella)"))
        self._add(self._clustered(cortes.get("emisores_top"),
                  "Mayores contribuyentes por emisor"))
        html = self._assemble(au4_total_huella)
        out = out_path or os.path.join(
            getattr(self.config, "reportes_root", "."),
            f"export_{self.semestre}", f"Dashboard_Huella_{self.semestre}.html")
        os.makedirs(os.path.dirname(out) or ".", exist_ok=True)
        with open(out, "w", encoding="utf-8") as fh:
            fh.write(html)
        if self.verbose:
            print(f"  [Módulo 14] Dashboard -> {out} ({len(self._figs)} gráficos).")
        return out

    def _add(self, div):
        if div:
            self._figs.append(("", div))

    def _to_div(self, fig):
        return self._pio.to_html(fig, full_html=False, include_plotlyjs=False,
                                 config={"displayModeBar": False})

    def _layout(self, fig, title):
        fig.update_layout(
            title=dict(text=title, font=dict(size=15, color="#1f2d3d")),
            template="plotly_white", margin=dict(t=46, l=48, r=20, b=60),
            font=dict(family="Segoe UI, Arial", size=12, color="#333"),
            legend=dict(orientation="h", yanchor="bottom", y=-0.28),
            height=360, barmode="stack", paper_bgcolor="white", plot_bgcolor="white")
        return fig

    def _stacked(self, df, valor, title):
        if df is None or df.empty or valor not in df.columns:
            return None
        go = self._go
        buckets = list(dict.fromkeys(df["bucket"].tolist()))
        fig = go.Figure()
        for serie, color in (("MSCI", COL_MSCI), ("Proxies", COL_PROXY)):
            sub = df[df["serie"] == serie]
            ys = [float(sub[sub["bucket"] == b][valor].sum()) for b in buckets]
            if any(ys):
                fig.add_bar(x=buckets, y=ys, name=serie, marker_color=color)
        return self._to_div(self._layout(fig, title))

    def _clustered(self, df, title):
        if df is None or df.empty:
            return None
        go = self._go
        fig = go.Figure()
        fig.add_bar(x=df["emisor"].astype(str).tolist(),
                    y=pd.to_numeric(df["Huella"], errors="coerce"),
                    name="Huella", marker_color=COL_MSCI)
        fig = self._layout(fig, title)
        fig.update_layout(barmode="group", xaxis_tickangle=-35)
        return self._to_div(fig)

    def _assemble(self, au4):
        plotly_js = self._pio.to_html(
            self._go.Figure(), full_html=False, include_plotlyjs=True
        ).split("<script")[1].split(">", 1)[1].rsplit("</script>", 1)[0]
        kpi = ""
        if au4 is not None:
            kpi = (f'<div class="kpi-row"><div class="kpi">'
                   f'<div class="kpi-val">{au4:,.0f}</div>'
                   f'<div class="kpi-lbl">Huella total (Tn CO2)</div></div></div>')
        charts = "".join(f'<div class="card">{d}</div>' for _, d in self._figs)
        return f"""<!DOCTYPE html><html lang="es"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Huella de Carbono — {self.semestre}</title>
