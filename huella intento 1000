##########################################################################################################################################################
#                                                                             #
#   MÓDULO 12A — COMPARABLES (benchmarks ACWI / ILF / CEMB / EMB)             #
#                                                                             #
#   Fuentes (ambas INPUT MANUAL del usuario):                                 #
#     1) 'Comparables MSCI - Huella.xlsx' -> hoja = SEMESTRE (202606/202512).  #
#        Cols: FUND_ISIN | FUND_NAME | FUND_WEIGHTED_AVG_SOV_CARBON_INTEN      #
#        => de aquí sale la INTENSIDAD de cada benchmark.                      #
#     2) 'Market Cap.xlsx' (hoja MKT) -> market cap por ticker, fila de cierre #
#        del semestre (col B = fecha efectiva).                                #
#                                                                             #
#   Equivalencia FUND_ISIN <-> ticker de Market Cap:                          #
#     US4642873909 = ILF US Equity                                            #
#     US4642882819 = EMB US Equity                                            #
#     US4642882579 = ACWI US Equity                                           #
#     US4642862514 = CEMB US Equity                                           #
#                                                                             #
#   HUELLA del benchmark = MarketCap(MM USD) * Intensidad                       #
#     (Market Cap.xlsx ya viene en millones; no se divide otra vez.)            #
#   INTENSIDAD del benchmark = FUND_WEIGHTED_AVG_SOV_CARBON_INTEN (directa)    #
#                                                                             #
###############################################################################

# Equivalencia ISIN del fondo -> ticker en Market Cap.xlsx -> etiqueta corta.
COMPARABLES_MAP = {
    "US4642873909": ("ILF US Equity",  "ILF"),
    "US4642882819": ("EMB US Equity",  "EMB"),
    "US4642882579": ("ACWI US Equity", "ACWI"),
    "US4642862514": ("CEMB US Equity", "CEMB"),
}
# Benchmark del bloque soberano vs. el del portafolio total.
BENCH_SOBERANOS = ["EMB"]
BENCH_PORTAFOLIO = ["ACWI", "ILF", "CEMB"]

FNAME_COMPARABLES = "Comparables MSCI - Huella.xlsx"


class ComparablesLoader:
    """Huella e Intensidad de los benchmarks (ACWI/ILF/CEMB/EMB).

    Detecta AUTOMÁTICAMENTE la hoja del semestre en revisión dentro de
    'Comparables MSCI - Huella.xlsx' y la cruza con el market cap.
    Devuelve DataFrame: ticker | nombre | Intensidad | MarketCap | Huella.
    """

    def __init__(self, config: Config, verbose: bool = True,
                 path_comparables: Optional[str] = None):
        self.config = config
        self.semestre = getattr(config, "semestre", None)
        self.b1 = getattr(config, "b1_yyyymmdd", None)
        self.path_mkt = getattr(config, "path_market_cap", None)
        # Comparables vive junto a los Proxies (misma carpeta 'Huella Total').
        self.path_cmp = path_comparables or self._default_cmp_path()
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def _default_cmp_path(self) -> str:
        base = os.path.dirname(getattr(self.config, "path_proxies", "") or "")
        return os.path.join(base, FNAME_COMPARABLES) if base else FNAME_COMPARABLES

    def build(self) -> "ComparablesLoader":
        intensidades = self._leer_intensidades()      # ticker -> (nombre, intensidad)
        market_caps = self._leer_market_cap()         # ticker_largo -> market cap
        filas = []
        for isin, (ticker_largo, etiqueta) in COMPARABLES_MAP.items():
            info = intensidades.get(isin)
            if not info:
                if self.verbose:
                    print(f"  [Comparables] [AVISO] Sin intensidad para {etiqueta} "
                          f"({isin}) en la hoja {self.semestre}.")
                continue
            nombre, inten = info
            mc = market_caps.get(ticker_largo)
            if mc is None:
                print(f"  [Comparables] [FALTA] No hay market cap para '{ticker_largo}' "
                      f"en Market Cap.xlsx (hojas MKT/Assets, fila de cierre "
                      f"{self.b1}).\n"
                      f"     -> Agrega la columna '{ticker_largo}' al archivo; "
                      f"sin ella no se puede calcular la Huella de {etiqueta}.")
            # HUELLA = MarketCap * Intensidad  (SIN dividir entre 1e6).
            huella = mc * inten if (mc and inten) else None
            filas.append({
                "ticker": etiqueta, "nombre": nombre, "FUND_ISIN": isin,
                "Intensidad": inten, "MarketCap": mc, "Huella": huella,
            })
        self.df = pd.DataFrame(
            filas, columns=["ticker", "nombre", "FUND_ISIN",
                            "Intensidad", "MarketCap", "Huella"])
        if self.verbose and not self.df.empty:
            for _, r in self.df.iterrows():
                h = f"{r['Huella']:,.0f}" if pd.notna(r["Huella"]) else "s/d"
                print(f"  [Comparables] {r['ticker']:5} Intensidad={r['Intensidad']:.2f} "
                      f"MarketCap={r['MarketCap']:,.0f} -> Huella={h}")
        return self

    def _leer_intensidades(self) -> Dict[str, tuple]:
        """Hoja = SEMESTRE. FUND_ISIN -> (FUND_NAME, INTENSIDAD)."""
        out: Dict[str, tuple] = {}
        if not self.path_cmp or not os.path.exists(self.path_cmp):
            print(f"  [Comparables] [AVISO] No encuentro (input manual):\n"
                  f"     {self.path_cmp}\n"
                  f"     Deposita el archivo con una hoja llamada '{self.semestre}'.")
            return out
        import openpyxl
        wb = openpyxl.load_workbook(self.path_cmp, read_only=True, data_only=True)
        try:
            hoja = self.semestre if self.semestre in wb.sheetnames else None
            if hoja is None:
                print(f"  [Comparables] [AVISO] No existe la hoja '{self.semestre}'. "
                      f"Hojas: {wb.sheetnames}")
                return out
            ws = wb[hoja]
            rows = list(ws.iter_rows(values_only=True))
            if not rows:
                return out
            header = list(rows[0])
            schema = {
                "FUND_ISIN": ["fund_isin", "isin"],
                "FUND_NAME": ["fund_name", "nombre"],
                "INTEN": ["fund_weighted_avg_sov_carbon_inten",
                          "weighted_avg_sov_carbon_inten", "carbon_inten"],
            }
            mapping, _ = _resolve_headers(header, schema)
            c2i = {c: i for i, c in mapping.items()}
            if "FUND_ISIN" not in c2i or "INTEN" not in c2i:
                print(f"  [Comparables] [AVISO] Hoja '{hoja}': faltan FUND_ISIN o "
                      f"FUND_WEIGHTED_AVG_SOV_CARBON_INTEN.")
                return out
            for row in rows[1:]:
                isin = _to_string(row[c2i["FUND_ISIN"]]) if c2i["FUND_ISIN"] < len(row) else None
                if not isin:
                    continue
                inten = _to_number(row[c2i["INTEN"]]) if c2i["INTEN"] < len(row) else None
                nombre = (row[c2i["FUND_NAME"]] if "FUND_NAME" in c2i
                          and c2i["FUND_NAME"] < len(row) else isin)
                if inten is not None:
                    out.setdefault(isin, (_to_string(nombre), inten))
        finally:
            wb.close()
        if self.verbose:
            print(f"  [Comparables] Hoja '{self.semestre}': {len(out)} fondos con intensidad.")
        return out

    def _leer_market_cap(self) -> Dict[str, float]:
        """Market Cap.xlsx hoja MKT: fila de cierre del semestre (col B = fecha)."""
        out: Dict[str, float] = {}
        if not self.path_mkt or not os.path.exists(self.path_mkt):
            print("  [Comparables] [AVISO] Market Cap.xlsx no encontrado.")
            return out
        import openpyxl
        wb = openpyxl.load_workbook(self.path_mkt, read_only=True, data_only=True)
        try:
            hojas = [n for n in wb.sheetnames
                     if _normalize(n) in (_normalize("MKT"), _normalize("Assets"))]
            if not hojas:
                return out
            for hoja in hojas:               # MKT primero; Assets como respaldo
                self._leer_hoja_mkt(wb[hoja], out)
            return out
        finally:
            wb.close()

    def _leer_hoja_mkt(self, ws, out: Dict[str, float]) -> None:
        """Extrae {ticker -> market cap} de una hoja (fila de cierre del semestre)."""
        if True:
            rows = list(ws.iter_rows(values_only=True))
            if len(rows) < 3:
                return
            header = list(rows[1])          # tickers en FILA 2
            target = None
            if self.b1 and len(self.b1) == 8:
                target = date(int(self.b1[:4]), int(self.b1[4:6]), int(self.b1[6:8]))
            elegida, ultima = None, None
            for row in rows[2:]:
                f = _to_date(row[1]) if len(row) > 1 else None   # col B
                if isinstance(f, date):
                    ultima = row
                    if target and f == target:
                        elegida = row
                        break
            elegida = elegida if elegida is not None else ultima
            if elegida is None:
                return
            for i, h in enumerate(header):
                if not h:
                    continue
                v = _to_number(elegida[i]) if i < len(elegida) else None
                if v is not None:
                    out.setdefault(str(h).strip(), v)

    def as_dict(self) -> Dict[str, dict]:
        """{'ACWI': {'Huella':..., 'Intensidad':...}, ...}"""
        if self.df is None or self.df.empty:
            return {}
        return self.df.set_index("ticker")[["Huella", "Intensidad"]].to_dict("index")


###############################################################################
#                                                                             #
#   MÓDULO 12 — PRESENTACIÓN (cortes de negocio)                              #
#                                                                             #
#   FILTROS EXACTOS por Estrategia (definidos por el usuario):                #
#     TD  : Estrategia='TD'  ; Plus in {ETF, Portafolio}                       #
#           Plus_1 in {Cuestionario Integra, Otros ETFs, Portafolio, SOV, TD}  #
#           ; Huella != 0                                                      #
#     BU  : Estrategia='BU'  ; Plus = 'Portafolio' ; Huella != 0               #
#     ALT : Estrategia='ALT' ; Plus = 'Proxies' ; Plus_1 = 'Alts' ; Huella != 0#
#                                                                             #
#   Desglose para las barras apiladas:                                        #
#     TD  -> RV / RF / Otros ETFs / Soberanos                                  #
#     BU  -> Materials / Utilities / Otros (sector del emisor)                #
#     ALT -> Alts                                                             #
#   Soberanos (vs EMB): Estrategia='GOB' o Plus='SOV' (bonos gub. + ETF sob.). #
#                                                                             #
###############################################################################

SECTOR_MOSTRAR = {"materials": "Materials", "utilities": "Utilities"}
EMISOR_SUFIJOS = ["adr", "cm", "milpo", "saa", "sa", "ltd", "corp", "inc", "plc"]
EMISOR_EQUIVALENCIA = {"nexaperu": "Nexa", "nexa": "Nexa"}
ISIN_PAIS = {"PE": "Perú", "US": "EEUU", "BR": "Brasil", "MX": "México",
             "CL": "Chile", "CO": "Colombia"}
PAIS_ORDEN = ["Perú", "Brasil", "México", "Chile", "Colombia", "EEUU", "Otros"]

# Filtros exactos por estrategia (editable si el negocio cambia).
FILTROS_ESTRATEGIA = {
    "TD": {
        "Plus":   {"ETF", "Portafolio"},
        "Plus_1": {"Cuestionario Integra", "Otros ETFs", "Portafolio", "SOV", "TD"},
    },
    "BU": {
        "Plus":   {"Portafolio"},
    },
    "ALT": {
        "Plus":   {"Proxies"},
        "Plus_1": {"Alts"},
    },
}
ESTRATEGIAS_PORTAFOLIO = ["TD", "BU", "ALT"]


def _emisor_padre(nombre: Optional[str]) -> Optional[str]:
    if not nombre:
        return None
    import re
    s = str(nombre).strip()
    s = re.sub(r"\(.*?\)", "", s)
    s = re.sub(r"[\-]", " ", s)
    toks = s.split()
    while toks and re.sub(r"[^a-z]", "", toks[-1].lower()) in EMISOR_SUFIJOS:
        toks.pop()
    base = " ".join(toks).strip().rstrip(".").strip()
    return EMISOR_EQUIVALENCIA.get(_normalize(base), base)


class PresentacionBuilder:
    """Cortes sobre Valorización. Aplica los filtros exactos por estrategia."""

    def __init__(self, df_val: pd.DataFrame, sector_lookup: Optional[Dict[str, str]] = None,
                 comparables: Optional[pd.DataFrame] = None, verbose: bool = True,
                 nombre_col: str = "Nombre", huella_col: str = "Huella",
                 intensidad_col: str = "Intensidad", estrategia_col: str = "Estrategia",
                 rank_col: str = "Rank_rt", plus_col: str = "Plus",
                 plus1_col: str = "Plus_1", isin_col: str = "CODIGO_ISIN",
                 portafolio_col: str = "PORTAFOLIO"):
        self.df = df_val.copy()
        self.sector_lookup = sector_lookup or {}
        self.comparables = comparables
        self.verbose = verbose
        self.c_nombre = nombre_col; self.c_huella = huella_col
        self.c_intens = intensidad_col; self.c_estr = estrategia_col
        self.c_rank = rank_col; self.c_plus = plus_col; self.c_plus1 = plus1_col
        self.c_isin = isin_col; self.c_port = portafolio_col
        self.out: Dict[str, pd.DataFrame] = {}
        self._prep()

    def _prep(self):
        df = self.df
        for c in (self.c_huella, self.c_intens):
            if c in df.columns:
                df[c] = pd.to_numeric(df[c], errors="coerce").fillna(0.0)
        df["_emisor"] = df[self.c_nombre].map(_emisor_padre)
        df["_estrategia"] = df[self.c_estr].map(lambda e: (_to_string(e) or "").upper())
        df["_plus"] = df[self.c_plus].map(lambda v: _to_string(v) or "")
        df["_plus1"] = df[self.c_plus1].map(lambda v: _to_string(v) or "")
        df["_serie"] = df["_plus"].map(lambda p: "Proxies" if p == "Proxies" else "MSCI")
        df["_pais"] = df[self.c_isin].map(self._pais_isin)
        df["_desglose"] = df.apply(self._desglose, axis=1)
        df["_es_soberano"] = df.apply(
            lambda r: (r["_estrategia"] == "GOB") or (r["_plus"] == "SOV"), axis=1)

    def _sector_de(self, emisor, nombre) -> str:
        raw = (self.sector_lookup.get(_normalize(emisor))
               or self.sector_lookup.get(_normalize(nombre)))
        return _to_string(raw) if raw else ""

    def _desglose(self, row) -> str:
        estr = row["_estrategia"]; plus = row["_plus"]
        rank = (_to_string(row.get(self.c_rank)) or "").upper()
        if estr == "ALT":
            return "Alts"
        if estr == "GOB":
            return "ETF Soberanos" if plus == "ETF" else "Bonos Soberanos"
        if estr == "TD":
            if plus == "SOV" or row["_plus1"] == "SOV":
                return "Soberanos"
            if plus == "ETF" or row["_plus1"] == "Otros ETFs":
                return "Otros ETFs"
            if rank.startswith("RV"):
                return "RV"
            if rank.startswith("RF"):
                return "RF"
            return "Otros"
        if estr == "BU":
            sec = self._sector_de(row.get("_emisor"), row.get(self.c_nombre))
            return SECTOR_MOSTRAR.get(_normalize(sec), "Otros")
        return "Otros"

    @staticmethod
    def _pais_isin(isin) -> str:
        s = _to_string(isin)
        if s and len(s) >= 2:
            return ISIN_PAIS.get(s[:2].upper(), "Otros")
        return "Otros"

    # ---- filtro exacto por estrategia --------------------------------------
    def filtrar_estrategia(self, estrategia: str) -> pd.DataFrame:
        """Aplica los filtros EXACTOS definidos por el negocio (Huella != 0)."""
        e = estrategia.upper()
        df = self.df[self.df["_estrategia"] == e]
        reglas = FILTROS_ESTRATEGIA.get(e, {})
        if "Plus" in reglas:
            df = df[df["_plus"].isin(reglas["Plus"])]
        if "Plus_1" in reglas:
            df = df[df["_plus1"].isin(reglas["Plus_1"])]
        df = df[df[self.c_huella] != 0]        # excluir huella cero
        return df

    # ---- cortes ------------------------------------------------------------
    def por_estrategia(self) -> pd.DataFrame:
        """Huella/Intensidad por estrategia (filtros exactos) con desglose."""
        partes = []
        for e in ESTRATEGIAS_PORTAFOLIO:
            sub = self.filtrar_estrategia(e)
            if sub.empty:
                continue
            g = (sub.groupby(["_desglose", "_serie"])
                   .agg(Huella=(self.c_huella, "sum"),
                        Intensidad=(self.c_intens, "sum")).reset_index())
            g.insert(0, "estrategia", e)
            partes.append(g)
        d = (pd.concat(partes, ignore_index=True) if partes
             else pd.DataFrame(columns=["estrategia", "_desglose", "_serie",
                                        "Huella", "Intensidad"]))
        d = d.rename(columns={"_desglose": "desglose", "_serie": "serie"})
        self.out["por_estrategia"] = d
        if self.verbose and not d.empty:
            tot = d.groupby("estrategia")[["Huella", "Intensidad"]].sum()
            for e, r in tot.iterrows():
                print(f"  [Módulo 12] {e}: Huella={r['Huella']:,.0f} "
                      f"Intensidad={r['Intensidad']:,.2f}")
        return d

    def detalle_filtrable(self) -> pd.DataFrame:
        """Detalle fila a fila para el SELECTOR INTERACTIVO del dashboard
        (permite filtrar por Plus, Plus_1 y PORTAFOLIO)."""
        cols = [self.c_port, self.c_estr, self.c_plus, self.c_plus1,
                self.c_huella, self.c_intens]
        cols = [c for c in cols if c in self.df.columns]
        d = self.df[self.df[self.c_huella] != 0][cols + ["_desglose"]].copy()
        d = d.rename(columns={self.c_port: "PORTAFOLIO", self.c_estr: "Estrategia",
                              self.c_plus: "Plus", self.c_plus1: "Plus_1",
                              self.c_huella: "Huella", self.c_intens: "Intensidad",
                              "_desglose": "Desglose"})
        self.out["detalle"] = d
        return d

    def soberanos_por_pais(self) -> pd.DataFrame:
        df = self.df[self.df["_es_soberano"] & (self.df[self.c_huella] != 0)]
        g = (df.groupby("_pais")
               .agg(Huella=(self.c_huella, "sum"), Intensidad=(self.c_intens, "sum"))
               .reset_index().rename(columns={"_pais": "bucket"}))
        rank = {b: i for i, b in enumerate(PAIS_ORDEN)}
        g["_o"] = g["bucket"].map(lambda b: rank.get(b, 999))
        g = g.sort_values("_o").drop(columns="_o").reset_index(drop=True)
        self.out["soberanos_por_pais"] = g
        return g

    def emisores_top(self, top_n: int = 10) -> pd.DataFrame:
        g = (self.df[self.df[self.c_huella] != 0].groupby("_emisor")
               .agg(Huella=(self.c_huella, "sum"), Intensidad=(self.c_intens, "sum"))
               .reset_index().rename(columns={"_emisor": "emisor"})
               .sort_values("Huella", ascending=False).head(top_n).reset_index(drop=True))
        self.out["emisores_top"] = g
        return g

    def vs_comparables(self) -> pd.DataFrame:
        """Cartera (TD+BU+Alts) vs ACWI/ILF/CEMB ; Soberanos vs EMB."""
        port = pd.concat([self.filtrar_estrategia(e) for e in ESTRATEGIAS_PORTAFOLIO],
                         ignore_index=True) if ESTRATEGIAS_PORTAFOLIO else self.df.iloc[0:0]
        sob = self.df[self.df["_es_soberano"] & (self.df[self.c_huella] != 0)]
        filas = [
            {"bloque": "Portafolio", "serie": "Integra",
             "Huella": float(port[self.c_huella].sum()),
             "Intensidad": float(port[self.c_intens].sum())},
            {"bloque": "Soberanos", "serie": "Integra",
             "Huella": float(sob[self.c_huella].sum()),
             "Intensidad": float(sob[self.c_intens].sum())},
        ]
        if self.comparables is not None and not self.comparables.empty:
            for _, r in self.comparables.iterrows():
                bloque = "Soberanos" if r["ticker"] in BENCH_SOBERANOS else "Portafolio"
                filas.append({"bloque": bloque, "serie": r["ticker"],
                              "Huella": r["Huella"], "Intensidad": r["Intensidad"]})
        g = pd.DataFrame(filas)
        self.out["vs_comparables"] = g
        return g

    def build_all(self) -> Dict[str, pd.DataFrame]:
        self.por_estrategia()
        self.detalle_filtrable()
        self.soberanos_por_pais()
        self.emisores_top()
        self.vs_comparables()
        if self.verbose:
            print(f"  [Módulo 12] {len(self.out)} cortes listos.")
        return self.out

    def as_dict(self) -> Dict[str, pd.DataFrame]:
        return self.out


