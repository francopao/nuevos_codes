####
#                                                                             #
#   ORQUESTADOR — corre el pipeline completo (0..14)                          #
#   Ajusta SEMESTRE y OUT_DIR. Manual: refrescar queries + depositar inputs.   #
#                                                                             #
###############################################################################

if __name__ == "__main__":

    # ===================== AJUSTES DEL USUARIO ==============================
    SEMESTRE = "202606"                       # semestre en revisión (yyyymm)
    OUT_DIR  = r"C:\Users\p048546\Desktop\Huella_output"   # carpeta local de salida
    # =======================================================================

    cfg = Config.from_semestre(SEMESTRE)
    print(cfg.summary())
    cfg.print_refresh_reminder()

    faltantes = cfg.check_paths(verbose=True)
    cfg.validate_workbook_b1(verbose=True)
    if "path_workbook" in faltantes:
        raise SystemExit(">>> Falta el workbook refrescado. Deposítalo y reintenta.")

    # --- Módulo 1: lectura de queries (parte MANUAL ya refrescada) ----------
    reader = QueryReader(cfg)
    data = reader.read_all()

    # --- Módulos 2,3 --------------------------------------------------------
    caja = CajaLoader(data.caja).build()
    tc   = TipoCambioLoader(data.tipo_cambio).build()

    # --- Módulo 5: Parametria (INPUT MANUAL -> se lee directo del workbook) --
    #   F=Riesgos(Estrategia), G=Codigo(Categoria), H=Nombre, J=RANKEST(Rank_rt).
    parametria_lookup = ParametriaBuilder.leer_parametria_directa(cfg)
    sector_lookup = ParametriaBuilder.leer_sector_buckets(cfg)

    # --- Módulos 6,7: BD(MSCI) = Base MSCI + filas de Nueva Lista Proxies ----
    bd = BDMSCIBuilder(cfg).build()
    bd.append_proxies(cfg.path_proxies)      # agrega Alts/BU/TD al BD(MSCI)
    bd_t1 = BDMSCITMinus1(cfg).build()

    # --- Módulo 8 (manual, opcional) ---------------------------------------
    perd = PerdieronHuellaLoader(cfg).build()
    perd_lookup = perd.as_intensidad_lookup() if not perd.df.empty else {}

    # --- Módulo 9 -----------------------------------------------------------
    px = ProxyEngine(cfg).load()
    intensidad_post = px.apply_to_bd(bd.as_intensidad_lookup())

    # --- Módulo 10 (corazón) ------------------------------------------------
    vb = ValorizacionBuilder(
        data.valorizacion,
        caja_map=caja.as_map(),
        usd_rate=tc.usd_rate(),
        parametria_lookup=parametria_lookup,
        intensidad_post=intensidad_post,
        plus_lookup=bd.as_plus_lookup(),
        intensidad_t1=bd_t1.as_intensidad_lookup(),
        proxy_engine=px,
        perdieron_lookup=perd_lookup,
        perdieron_mode="fill",
        attrs_lookup=bd.as_attrs_lookup(),
    )
    vb.build()
    val = vb.df                      # DataFrame Valorización completo

    # --- Módulo 11 ----------------------------------------------------------
    final = FinalPivots(val).build()

    # --- Módulo 12 + Comparables --------------------------------------------
    comp = ComparablesLoader(cfg).build()
    pres = PresentacionBuilder(val, sector_lookup=sector_lookup, comparables=comp.df)
    pres_bundle = pres.build_all()

    # --- Headers con SEMESTRE (cosmético, solo para el export) --------------
    #   Métricas llevan sufijo de semestre; las LLAVES (SBS/ISIN/PORTAFOLIO/
    #   Nombre) NO se tocan: un instrumento es el mismo entre semestres.
    _sem, _semT1 = cfg.etiqueta_sem, cfg.etiqueta_sem_t1
    val_export = val.rename(columns={
        "Huella":     f"Huella {_sem}",
        "CO2-H":      f"CO2-H {_sem}",
        "Intensidad": f"Intensidad {_sem}",
        "Inv MM$":    f"Inv MM$ {_sem}",
        "CO2 T-1":    f"CO2-H {_semT1}",
    })

    # --- Módulo 13 (exports Excel) -----------------------------------------
    exporter = ExcelExporter(cfg, out_dir=OUT_DIR)
    rutas = exporter.export_all(
        valorizacion=val_export,
        final_bundle=final.as_dict(),
        presentacion_bundle=pres_bundle,
        bd_msci=bd.df,
        inherited_history=vb.get_inherited_history(),
        perdieron_huella=perd.df,
        no_match=vb.no_match_report,          # NUEVO
    )

    # --- Módulo 14 (dashboard HTML) ----------------------------------------
    dash = DashboardHTML(cfg)
    dash_path = dash.build(
        pres_bundle,
        au4_total_huella=vb.get_au4(),
        out_path=os.path.join(OUT_DIR, f"Dashboard_Huella_{SEMESTRE}.html"),
    )

    print("\n" + "=" * 60)
    print("  PIPELINE COMPLETO")
    print(f"  Excels   : {len(rutas)} archivo(s) en {OUT_DIR}")
    print(f"  Dashboard: {dash_path}")
    print("=" * 60)
