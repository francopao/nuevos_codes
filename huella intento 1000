def _normalize(text) -> str:
    """Normaliza un header/nombre: sin acentos, minúsculas, solo alfanumérico."""
    if text is None:
        return ""
    s = str(text).strip()
    s = unicodedata.normalize("NFKD", s)
    s = "".join(c for c in s if not unicodedata.combining(c))
    s = s.lower()
    return "".join(c for c in s if c.isalnum())


def _resolve_headers(
    actual_headers: List[Optional[str]],
    schema: Dict[str, List[str]],
) -> Tuple[Dict[int, str], List[str]]:
    """Mapea índice_de_columna -> nombre canónico según el schema.

    Estrategia: exact-first sobre alias normalizados; luego contains como
    fallback, respetando el orden del schema y sin reasignar un canónico ya
    tomado. Devuelve (mapping, no_resueltos_canonicos).
    """
    norm_aliases: Dict[str, set] = {}
    for canon, aliases in schema.items():
        s = {_normalize(canon)}
        s.update(_normalize(a) for a in aliases)
        norm_aliases[canon] = {a for a in s if a}

    norm_actual = {
        i: _normalize(h) for i, h in enumerate(actual_headers) if _normalize(h)
    }

    mapping: Dict[int, str] = {}
    used_canon: set = set()

    # Pass 1: exact.
    for i, na in norm_actual.items():
        for canon in schema:
            if canon in used_canon:
                continue
            if na in norm_aliases[canon]:
                mapping[i] = canon
                used_canon.add(canon)
                break

    # Pass 2: contains (solo para canónicos aún no resueltos y cols libres).
    for i, na in norm_actual.items():
        if i in mapping:
            continue
        for canon in schema:
            if canon in used_canon:
                continue
            if any(alias in na or na in alias for alias in norm_aliases[canon]):
                mapping[i] = canon
                used_canon.add(canon)
                break

    no_resueltos = [c for c in schema if c not in used_canon]
    return mapping, no_resueltos


def _to_number(v):
    if v is None or v == "":
        return None
    if isinstance(v, (int, float)):
        return float(v)
    s = str(v).strip().replace(" ", "")
    if s.count(",") and s.count("."):
        s = s.replace(",", "")          # coma = miles
    elif s.count(","):
        s = s.replace(",", ".")         # coma = decimal
    try:
        return float(s)
    except ValueError:
        return None


def _to_date(v):
    if v is None or v == "":
        return None
    if isinstance(v, datetime):
        return v.date()
    if isinstance(v, date):
        return v
    s = str(v).strip()
    for fmt in ("%Y%m%d", "%Y-%m-%d", "%d/%m/%Y", "%m/%d/%Y"):
        try:
            return datetime.strptime(s, fmt).date()
        except ValueError:
            continue
    return v


def _to_string(v):
    if v is None:
        return None
    s = str(v).strip()
    if s.endswith(".0") and s[:-2].isdigit():
        s = s[:-2]
    return s


