class BDMSCIBuilder:
    """DataFrame BD(MSCI) desde Base MSCI (hoja periodo) + filas de Proxies."""

    def __init__(self, config: Config, sheet: Optional[str] = None, verbose: bool = True):
        self.config = config
        self.path = getattr(config, "path_base_msci", None)
        self.sheet = sheet if sheet is not None else getattr(config, "base_msci_sheet", None)
        self.verbose = verbose
        self.df: Optional[pd.DataFrame] = None

    def build(self) -> pd.DataFrame:
        self._guard_file()
        import openpyxl
        wb = openpyxl.load_workbook(self.path, read_only=True, data_only=True)
        try:
            if self.sheet not in wb.sheetnames:  # R11: match exacto
                wb.close()
                raise ValueError(f"Base MSCI: no existe hoja '{self.sheet}' (match exacto). "
                                 f"Hojas: {wb.sheetnames}")
            ws = wb[self.sheet]
            rows = list(ws.iter_rows(values_only=True))
        finally:
            wb.close()
        if not rows:
            raise ValueError(f"Base MSCI hoja '{self.sheet}' vacía.")
        data_rows = rows[1:]
        n_src = len(BASE_MSCI_SOURCE_COLS)
        idx_client1 = BASE_MSCI_SOURCE_COLS.index("client1")
        idx_cat = BASE_MSCI_SOURCE_COLS.index("CAT")
        idx_cid = BASE_MSCI_SOURCE_COLS.index("Client_ID")
        registros = []
        for row in data_rows:
            src = [row[i] if i < len(row) else None for i in range(n_src)]
            client_id = _to_string(src[idx_cid])
            if client_id in (None, ""):
                continue
            cat = src[idx_cat]
            reg = {BD_COL_A: self._deriv_a(src[idx_client1])}
            for name, val in zip(BASE_MSCI_SOURCE_COLS, src):
                reg[name] = val
            reg[BD_COL_PLUS] = self._plus(cat)
            reg[BD_COL_PLUS_1] = self._plus1(cat, reg[BD_COL_PLUS])
            registros.append(reg)
        df = pd.DataFrame(registros, columns=BD_MSCI_COLS)
        for col in df.columns:
            if col in BD_STRING_COLS:
                df[col] = df[col].map(_to_string)
            elif col in BD_NUMERIC_COLS:
                df[col] = df[col].map(_to_number)
        self.df = df
        if self.verbose:
            print(f"  [Módulo 6] BD(MSCI) hoja '{self.sheet}' -> {df.shape[0]}x{df.shape[1]}.")
        return self

    @staticmethod
    def _deriv_a(client1):
        s = _to_string(client1)
        return s[:6][-4:] if s not in (None, "") else None

    @staticmethod
    def _plus(cat):
        c = (_to_string(cat) or "").upper()
        if c in ("ETF_ETY", "ETF_SOV"):
            return "ETF"
        if c == "RF_SOV":
            return "SOV"
        if c == "-":
            return "Cuestionario Integra"
        return "Portafolio"

    @staticmethod
    def _plus1(cat, w):
        c = (_to_string(cat) or "").upper()
        if c == "ETF_ETY":
            return "Otros ETFs"
        if c == "ETF_SOV":
            return "Soberanos"
        return w

    def append_proxies(self, proxies_path: Optional[str] = None,
                       verbose: bool = True) -> "BDMSCIBuilder":
        """Agrega a BD(MSCI) las filas de Nueva Lista Proxies (hojas Alts/BU/TD).

        Reproduce el pegado manual del bloque V:AR (Alts/TD) o U:AQ (BU) en las
        columnas B:V de BD(MSCI), y recalcula A/W/X desde CAT. Si un Client_ID
        ya existe en BD, la fila de proxies MANDA (keep='last').
        Llamar DESPUÉS de build()."""
        if self.df is None:
            raise RuntimeError("Llama build() antes de append_proxies().")
        path = proxies_path or getattr(self.config, "path_proxies", None)
        if not path or not os.path.exists(path):
            if verbose:
                print("  [Módulo 6] [AVISO] Proxies no encontrado; BD queda sin proxies.")
            return self
        import openpyxl
        wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
        nuevas = []
        try:
            for sheet in PROXY_BD_SHEETS:
                real = self._resolve_sheet_generic(wb.sheetnames, sheet)
                if real is None:
                    if verbose:
                        print(f"  [Módulo 6] [AVISO] Proxies sin hoja '{sheet}'; omito.")
                    continue
                rows = list(wb[real].iter_rows(min_row=3, values_only=True))
                if len(rows) < 2:
                    continue
                header = list(rows[0])
                # Se resuelven las 21 cols fuente + Plus (W) + Plus_1 (X):
                # las hojas de proxies YA traen Plus='Proxies' y Plus_1=Alts/TD/BU.
                # Esos valores se toman COMO DADOS (no se recalculan desde CAT).
                _schema = {c: [c] for c in BASE_MSCI_SOURCE_COLS}
                _schema[BD_COL_PLUS] = ["plus"]
                _schema[BD_COL_PLUS_1] = ["plus_1", "plus1"]
                mapping, _ = _resolve_headers(header, _schema)
                idx = {canon: i for i, canon in mapping.items()}
                if "Client_ID" not in idx:
                    if verbose:
                        print(f"  [Módulo 6] [AVISO] Hoja '{sheet}': sin Client_ID; omito.")
                    continue
                n_sheet = 0
                for row in rows[1:]:
                    i_cid = idx["Client_ID"]
                    cid = _to_string(row[i_cid]) if i_cid < len(row) else None
                    if cid in (None, ""):
                        continue
                    reg = {}
                    for name in BASE_MSCI_SOURCE_COLS:
                        i = idx.get(name)
                        reg[name] = row[i] if (i is not None and i < len(row)) else None
                    cat = reg.get("CAT")
                    reg[BD_COL_A] = self._deriv_a(reg.get("client1"))
                    # Plus / Plus_1: se leen del archivo de proxies TAL CUAL.
                    # Solo si faltaran, se derivan de CAT como respaldo.
                    i_p = idx.get(BD_COL_PLUS)
                    i_p1 = idx.get(BD_COL_PLUS_1)
                    plus_src = (_to_string(row[i_p])
                                if (i_p is not None and i_p < len(row)) else None)
                    plus1_src = (_to_string(row[i_p1])
                                 if (i_p1 is not None and i_p1 < len(row)) else None)
                    reg[BD_COL_PLUS] = plus_src or self._plus(cat)
                    reg[BD_COL_PLUS_1] = plus1_src or self._plus1(cat, reg[BD_COL_PLUS])
                    nuevas.append(reg)
                    n_sheet += 1
                if verbose:
                    print(f"  [Módulo 6] Proxies hoja '{sheet}': +{n_sheet} filas.")
        finally:
            wb.close()

        if nuevas:
            df_new = pd.DataFrame(nuevas, columns=BD_MSCI_COLS)
            for col in df_new.columns:
                if col in BD_STRING_COLS:
                    df_new[col] = df_new[col].map(_to_string)
                elif col in BD_NUMERIC_COLS:
                    df_new[col] = df_new[col].map(_to_number)
            antes = len(self.df)
            self.df = pd.concat([self.df, df_new], ignore_index=True)
            self.df = self.df.drop_duplicates(
                BD_COL_CLIENT_ID, keep="last").reset_index(drop=True)
            if verbose:
                print(f"  [Módulo 6] BD(MSCI) con proxies: {antes} -> {len(self.df)} filas "
                      f"({len(nuevas)} de proxies, los repetidos sobrescriben).")
        return self

    @staticmethod
    def _resolve_sheet_generic(available: List[str], wanted: str) -> Optional[str]:
        if wanted in available:
            return wanted
        target = _normalize(wanted)
        for name in available:
            if _normalize(name) == target:
                return name
        return None

    def as_intensidad_lookup(self) -> Dict[str, float]:
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        tmp = self.df[[BD_COL_CLIENT_ID, BD_COL_INTENSIDAD]].dropna(
            subset=[BD_COL_CLIENT_ID]).drop_duplicates(BD_COL_CLIENT_ID, keep="first")
        return dict(zip(tmp[BD_COL_CLIENT_ID], tmp[BD_COL_INTENSIDAD]))

    def as_plus_lookup(self) -> Dict[str, dict]:
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        tmp = self.df[[BD_COL_CLIENT_ID, BD_COL_PLUS, BD_COL_PLUS_1]].dropna(
            subset=[BD_COL_CLIENT_ID]).drop_duplicates(BD_COL_CLIENT_ID, keep="first")
        return tmp.set_index(BD_COL_CLIENT_ID).to_dict("index")

    def as_attrs_lookup(self) -> Dict[str, dict]:
        """Client_ID -> {Sector, País, Rating, Controversia} para enriquecer M12."""
        if self.df is None:
            raise RuntimeError("Llama build() antes.")
        cols = [BD_COL_CLIENT_ID, "Sector", "País", "Rating", "Controversia"]
        cols = [c for c in cols if c in self.df.columns]
        tmp = self.df[cols].dropna(subset=[BD_COL_CLIENT_ID]).drop_duplicates(
            BD_COL_CLIENT_ID, keep="first")
        return tmp.set_index(BD_COL_CLIENT_ID).to_dict("index")

    def _guard_file(self) -> None:
        if not self.path:
            raise ValueError("Config no define path_base_msci.")
        if not os.path.exists(self.path):
            raise FileNotFoundError(f"No encuentro Base MSCI en:\n  {self.path}")


