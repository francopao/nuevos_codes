    <th>Intensidad</th><th>N° instrumentos</th></tr></thead><tbody></tbody></table>
</div>
<script>
const DATA = {payload};
function applyFilters() {{
  const fp = document.getElementById('f_PORTAFOLIO');
  const fu = document.getElementById('f_Plus');
  const f1 = document.getElementById('f_Plus_1');
  const vp = fp ? fp.value : '', vu = fu ? fu.value : '', v1 = f1 ? f1.value : '';
  const rows = DATA.filter(r =>
      (!vp || String(r.PORTAFOLIO) === vp) &&
      (!vu || String(r.Plus) === vu) &&
      (!v1 || String(r.Plus_1) === v1));
  const agg = {{}};
  rows.forEach(r => {{
    const e = r.Estrategia || '(s/e)';
    if (!agg[e]) agg[e] = {{h: 0, i: 0, n: 0}};
    agg[e].h += r.Huella; agg[e].i += r.Intensidad; agg[e].n += 1;
  }});
  const estr = Object.keys(agg).sort();
  const tb = document.querySelector('#selTable tbody');
  tb.innerHTML = estr.map(e =>
    `<tr><td>${{e}}</td><td>${{agg[e].h.toLocaleString(undefined,{{maximumFractionDigits:0}})}}</td>`
    + `<td>${{agg[e].i.toLocaleString(undefined,{{maximumFractionDigits:2}})}}</td>`
    + `<td>${{agg[e].n}}</td></tr>`).join('');
  Plotly.react('selChart', [
    {{x: estr, y: estr.map(e => agg[e].h), type: 'bar', name: 'Huella',
      marker: {{color: '{COL_INTEGRA}'}}}},
    {{x: estr, y: estr.map(e => agg[e].i), type: 'bar', name: 'Intensidad',
      yaxis: 'y2', marker: {{color: '{COL_PROXY}'}}}}
  ], {{
    barmode: 'group', template: 'plotly_white', height: 340,
    margin: {{t: 20, l: 55, r: 55, b: 40}},
    yaxis: {{title: 'Huella'}},
    yaxis2: {{title: 'Intensidad', overlaying: 'y', side: 'right', showgrid: false}},
    legend: {{orientation: 'h', y: -0.2}}
  }}, {{displayModeBar: false}});
}}
['f_PORTAFOLIO','f_Plus','f_Plus_1'].forEach(id => {{
  const el = document.getElementById(id);
  if (el) el.addEventListener('change', applyFilters);
}});
setTimeout(applyFilters, 300);
</script>"""

    # ---- ensamblado --------------------------------------------------------
    def _assemble(self, au4, comparables, selector_html):
        kpis = []
        if au4 is not None:
