class DashboardHTML:
    """Dashboard HTML autocontenido con colores corporativos y selector."""

    def __init__(self, config: Config, verbose: bool = True):
        self.config = config
        self.semestre = getattr(config, "semestre", "SEMESTRE")
        self.etiqueta = getattr(config, "etiqueta_sem", self.semestre)
        self.verbose = verbose
        self._figs: List[str] = []
        self._first = True

    def build(self, cortes: Dict[str, pd.DataFrame], *,
              au4_total_huella: Optional[float] = None,
              out_path: Optional[str] = None) -> Optional[str]:
        try:
            import plotly.graph_objects as go
            import plotly.io as pio
        except ImportError:
            print("  [Módulo 14] [ERROR] Falta plotly. Instala: pip install plotly")
            return None
        self._go, self._pio = go, pio
        self._figs = []
        self._first = True

        self._add(self._estrategia(cortes.get("por_estrategia"), "Huella",
                  f"Huella por Estrategia — {self.etiqueta} (Tn CO2)"))
        self._add(self._estrategia(cortes.get("por_estrategia"), "Intensidad",
                  f"Intensidad por Estrategia — {self.etiqueta} (Tn CO2/USD MM)"))
        self._add(self._comparables(cortes.get("vs_comparables"), "Huella",
                  "Huella: Cartera vs Comparables"))
        self._add(self._comparables(cortes.get("vs_comparables"), "Intensidad",
                  "Intensidad: Cartera vs Comparables"))
        self._add(self._bar(cortes.get("soberanos_por_pais"), "Huella",
                  "Soberanos (Bonos + ETFs) — Huella por País"))
        self._add(self._bar(cortes.get("soberanos_por_pais"), "Intensidad",
                  "Soberanos (Bonos + ETFs) — Intensidad por País"))
        self._add(self._contribuyentes(cortes.get("emisores_top")))

        selector = self._selector(cortes.get("detalle"))
        html = self._assemble(au4_total_huella, cortes.get("vs_comparables"), selector)
        out = out_path or os.path.join(
            getattr(self.config, "reportes_root", "."),
            f"export_{self.semestre}", f"Dashboard_Huella_{self.semestre}.html")
        os.makedirs(os.path.dirname(out) or ".", exist_ok=True)
        with open(out, "w", encoding="utf-8") as fh:
            fh.write(html)
        if self.verbose:
            print(f"  [Módulo 14] Dashboard -> {out} ({len(self._figs)} gráficos + selector).")
        return out

    # ---- helpers -----------------------------------------------------------
    def _add(self, div):
        if div:
            self._figs.append(div)

    def _to_div(self, fig):
        inc = True if self._first else False     # plotly.js embebido 1 sola vez
        self._first = False
        return self._pio.to_html(fig, full_html=False, include_plotlyjs=inc,
                                 config={"displayModeBar": False})

    def _layout(self, fig, title, stack=True):
        fig.update_layout(
            title=dict(text=title, font=dict(size=15, color="#12395C")),
            template="plotly_white", margin=dict(t=50, l=55, r=20, b=70),
            font=dict(family="Segoe UI, Arial", size=12, color="#333"),
            legend=dict(orientation="h", yanchor="bottom", y=-0.30),
            height=380, paper_bgcolor="white", plot_bgcolor="white")
        if stack:
            fig.update_layout(barmode="stack")
        return fig

    # ---- figuras -----------------------------------------------------------
    def _estrategia(self, df, valor, title):
        if df is None or df.empty or valor not in df.columns:
            return None
        go = self._go
        estr = [e for e in ESTRATEGIAS_PORTAFOLIO if e in set(df["estrategia"])]
        desg = list(dict.fromkeys(df["desglose"].tolist()))
        fig = go.Figure()
        for i, d in enumerate(desg):
            ys = []
            for e in estr:
                s = df[(df["estrategia"] == e) & (df["desglose"] == d)]
                ys.append(float(s[valor].sum()) if not s.empty else 0.0)
            if any(ys):
                fig.add_bar(x=estr, y=ys, name=str(d),
                            marker_color=PALETTE[i % len(PALETTE)])
        return self._to_div(self._layout(fig, title))

    def _comparables(self, df, valor, title):
        """Integra vs benchmarks, agrupado por bloque (Portafolio / Soberanos)."""
        if df is None or df.empty or valor not in df.columns:
            return None
        go = self._go
        d = df.dropna(subset=[valor])
        if d.empty:
            return None
        etiquetas, valores, colores = [], [], []
        for _, r in d.iterrows():
            etiquetas.append(f"{r['serie']}<br>({r['bloque']})")
            valores.append(float(r[valor]))
            colores.append(COL_INTEGRA if r["serie"] == "Integra" else COL_BENCH)
        fig = go.Figure(go.Bar(x=etiquetas, y=valores, marker_color=colores,
                               text=[f"{v:,.0f}" for v in valores],
                               textposition="outside"))
        return self._to_div(self._layout(fig, title, stack=False))

    def _bar(self, df, valor, title):
        if df is None or df.empty or valor not in df.columns:
            return None
        go = self._go
        fig = go.Figure(go.Bar(x=df["bucket"].astype(str), y=df[valor],
                               marker_color=PALETTE))
        return self._to_div(self._layout(fig, title, stack=False))

    def _contribuyentes(self, df):
        if df is None or df.empty:
            return None
        go = self._go
        fig = go.Figure(go.Bar(x=df["emisor"].astype(str),
                               y=pd.to_numeric(df["Huella"], errors="coerce"),
                               marker_color=COL_MSCI, name="Huella"))
        fig = self._layout(fig, "Mayores contribuyentes por emisor", stack=False)
        fig.update_layout(xaxis_tickangle=-35)
        return self._to_div(fig)

    # ---- SELECTOR INTERACTIVO (Plus / Plus_1 / PORTAFOLIO) -----------------
    def _selector(self, detalle: Optional[pd.DataFrame]) -> str:
        if detalle is None or detalle.empty:
            return ""
        import json
        cols = ["PORTAFOLIO", "Estrategia", "Plus", "Plus_1", "Huella", "Intensidad"]
        cols = [c for c in cols if c in detalle.columns]
        data = detalle[cols].fillna("").to_dict("records")
        for r in data:
            r["Huella"] = float(r.get("Huella") or 0)
            r["Intensidad"] = float(r.get("Intensidad") or 0)
        payload = json.dumps(data, ensure_ascii=False)
        opts = {c: sorted({str(r[c]) for r in data if r.get(c) not in (None, "")})
                for c in ("PORTAFOLIO", "Plus", "Plus_1") if c in cols}

        def sel(cid, label, values):
            o = "".join(f'<option value="{v}">{v}</option>' for v in values)
            return (f'<div class="fld"><label>{label}</label>'
                    f'<select id="{cid}"><option value="">(Todos)</option>{o}</select></div>')

        selects = "".join(sel(f"f_{c}", c, v) for c, v in opts.items())
        return f"""
