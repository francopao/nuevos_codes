    param = base_param.dropna(axis=0)
    if param.empty:
        fallar("La hoja Parametria del Monitor no tiene filas completas.")
    lista_isins = param.iloc[:, 2].astype(str).tolist()
    lista_nombres = param.iloc[:, 0].tolist()
    dicc_parametria = dict(zip(lista_isins, lista_nombres))

    sect = base_param.iloc[:, 2:4].dropna()
    sect.columns = ["ISIN", "Sector"]
    lista_sectores = sect["Sector"].unique().tolist()
    agrupados_sectores = {s: sect.loc[sect["Sector"] == s, "ISIN"].astype(str).tolist()
                          for s in lista_sectores}

    mon = base_param.iloc[:, [2, 5]].dropna()
    mon.columns = ["ISIN", "Moneda"]
    agrupados_monedas = {m: mon.loc[mon["Moneda"] == m, "ISIN"].astype(str).tolist()
                         for m in mon["Moneda"].unique()}

    lista_in  = ["Fondo", "Dato", "Fecha", "SBS"] + lista_isins
    lista_ex  = ["Fondo", "Fecha", "Fondo_Fecha"] + lista_isins
    lista_bdp = ["Campo", "Fecha"] + lista_isins

    # ------------------------- QEST → DQ_IN / DQ_SIS -------------------------
    DQ_IN_BD  = leer_excel(MONITOR_PATH, "DQ_IN")
    df1       = leer_excel(QEST_PATH, "DQ_IN", header=None)
    DQ_SIS_BD = leer_excel(MONITOR_PATH, "DQ_SIS", header=None)
    df2       = leer_excel(QEST_PATH, "DQ_RV", header=None)

    base_integra = actualizar_DQ_IN(df1, DQ_IN_BD, lista_in)
    base_sistema = actualizar_DQ_SIS(df2, DQ_SIS_BD, lista_ex).reset_index(drop=True)

    fecha_corte = pd.to_datetime(base_integra["Fecha"].iloc[-1])
    print(f"Fecha de corte: {fecha_corte:%d-%m-%Y}")

    # Escribir bases actualizadas al Monitor (xlwings preserva macros/fórmulas)
    try:
        wb1 = xw.Book(str(MONITOR_PATH), update_links=False)
    except Exception as e:
        fallar(f"xlwings no pudo abrir el Monitor (¿Excel instalado?, ¿archivo "
               f"abierto con bloqueo?): {e}")
    wb1.sheets["DQ_IN"]["A2"].options(pd.DataFrame, header=None, index=False).value = base_integra
    wb1.sheets["DQ_SIS"]["A2"].options(pd.DataFrame, header=None, index=False).value = base_sistema

    # ------------------------- AUM y Tipo de Cambio -------------------------
    df_aum_raw = leer_excel(AUM_PATH, "DataHistórica", header=None,
                            usecols="B:V", nrows=22000)
    df_aum_raw.columns = range(df_aum_raw.shape[1])
    df_aum = calculo_aum(df_aum_raw)
    print(f"AUM — última fecha disponible: {df_aum.index[-1]:%d-%m-%Y}")

    df_bdtc = leer_excel(BDPRECIOS_PATH, "BDTC", header=None,
                         usecols="A:DB", nrows=22000)
    df_bdtc.columns = range(df_bdtc.shape[1])
    # [B1] FIX: iloc sobre el propio DataFrame (el original usaba df1.index)
    df_tc = df_bdtc.iloc[5:].transpose().rename(columns={5: "Moneda"})
    filt_tc = (df_tc[df_tc["Moneda"].isin(["Campo", "Fecha", "DOL", "GBP", "CAD"])]
               .transpose().reset_index(drop=True))
    filt_tc.columns = filt_tc.iloc[0]
    filt_tc = filt_tc.drop(0)
    tc = (filt_tc[filt_tc["Campo"].astype(str).str.contains("P")]
          .drop(columns=["Campo"]).reset_index(drop=True))
    tc["Fecha"] = pd.to_datetime(tc["Fecha"].astype(str), format="mixed",
                                 dayfirst=True, errors="raise")
    TC_F = (tc.set_index("Fecha").replace("ND", 0).fillna(0)
              .apply(pd.to_numeric, errors="coerce").fillna(0).astype(np.float64))

    df_aum = df_aum.div(TC_F["DOL"].replace(0, np.nan), axis=0).dropna(how="all").copy()

    # ------------------------- Precios y Retornos (BDat_Act) -------------------------
    df_bdat = leer_excel(BDPRECIOS_PATH, "BDat_Act", header=None)
    df_bdat.columns = range(df_bdat.shape[1])
    # [B1] FIX: iloc propio (antes df1.index[:13])
    df_bdp = df_bdat.iloc[13:].transpose().rename(columns={13: "SBS"})
    filt = (df_bdp[df_bdp["SBS"].isin(lista_bdp)].transpose()
            .reset_index(drop=True))
    filt.columns = filt.iloc[0]
    filt = filt.drop(0)
    filt["Fecha"] = pd.to_datetime(filt["Fecha"].astype(str), format="mixed",
                                   dayfirst=True, errors="raise")

    def _bloque(mascara):
        return (filt[mascara].drop(columns=["Campo"]).reset_index(drop=True)
                .set_index("Fecha").replace("ND", 0).fillna(0)
                .apply(pd.to_numeric, errors="coerce").fillna(0)
                .astype(np.float64))

    campo = filt["Campo"].astype(str)
    precios_vp  = _bloque(campo.str.contains("P"))
    retornos_vp = _bloque(campo.str.contains("Ret", case=False)
                          & ~campo.str.contains("Ret1", case=False))

    faltan = [i for i in lista_isins if i not in precios_vp.columns]
    if faltan:
        warnings.warn(f"{len(faltan)} ISIN(s) de Parametria sin precio en BDat_Act "
                      f"(se tratarán como 0): {faltan[:5]}{'…' if len(faltan) > 5 else ''}")

    # Conversión a PEN según moneda
    for moneda, isins in agrupados_monedas.items():
        if moneda in ("NSOL", "None"):
            continue
        if moneda not in TC_F.columns:
            fallar(f"Moneda '{moneda}' en Parametria sin serie en BDTC.")
        cols = [i for i in isins if i in precios_vp.columns]
        precios_vp[cols] = precios_vp[cols].mul(TC_F[moneda], axis=0)

    # ------------------------- Hoja RVL (Bloomberg) -------------------------
    precios_rvl = pd.read_excel(MONITOR_PATH, sheet_name="RVL", header=None,
                                engine="openpyxl").astype(object)
    fechas_diarias = pd.to_datetime(precios_rvl.iloc[5:, 1], errors="coerce").dropna()

    precios_cdiv = (limpiar_precios_rvl(precios_rvl, "TOT_RETURN_INDEX_GROSS_DVDS",
                                        fechas_diarias)
                    .sort_index().loc[:fecha_corte].copy())
    precios_sdiv = limpiar_precios_rvl(precios_rvl, "Px_last", fechas_diarias)

    for isin in ("5460042E8427", "5076822E0800"):
        if isin not in retornos_vp.columns:
            fallar(f"Benchmark: falta el ISIN {isin} (EPU/ETFPERU) en BDat_Act.")
    epu_acum = (1 + retornos_vp["5460042E8427"].dropna()).cumprod() * 100
    etf_acum = (1 + retornos_vp["5076822E0800"].dropna()).cumprod() * 100

    # ------------------------- Cantidades por AFP -------------------------
    def q_integra(tag):
        df = (base_integra[base_integra["Fondo"].astype(str).str.contains(tag)]
              .drop(columns=["Dato", "SBS"]))
        df = df.reindex(columns=["Fecha"] + lista_isins).fillna(0).copy()
        df["Fecha"] = pd.to_datetime(df["Fecha"])
        return df.set_index("Fecha").astype(np.float64)

    Q = {}
    for f in FONDOS:
        Q[f"IN_F{f}"] = q_integra(f"IN-FONDO{f}")
    Q["IN_M"] = Q["IN_F1"] + Q["IN_F2"] + Q["IN_F3"]

    bs = base_sistema.copy()
    bs[["AFP-Fondo", "Fecha_Dia"]] = bs["Fondo_Fecha"].astype(str).str.split("_", expand=True)
    bs = bs.drop(columns=["Fecha", "Fondo_Fecha"])
    bs["Fecha_Dia"] = pd.to_datetime(bs["Fecha_Dia"], dayfirst=True)
    bs = bs.set_index("Fecha_Dia").iloc[2:].fillna(0)

    def q_sis(tag):
        df = (bs[bs["AFP-Fondo"].astype(str).str.contains(tag)]
              .drop(columns=["AFP-Fondo"]))
        df = df.reindex(columns=lista_isins).fillna(0).copy()
        return convertir_columnas_object_a_float(df).sort_index()

    for afp in ("HA", "PF", "RI"):
        for f in FONDOS:
            Q[f"{afp}_F{f}"] = q_sis(f"{afp}-FONDO{f}")
        Q[f"{afp}_M"] = Q[f"{afp}_F1"] + Q[f"{afp}_F2"] + Q[f"{afp}_F3"]
    for f in FONDOS:
        Q[f"EXSIS_F{f}"] = Q[f"HA_F{f}"] + Q[f"PF_F{f}"] + Q[f"RI_F{f}"]

    IL = [c for c in precios_vp.columns if c not in LIQUIDOS]
    L_pres = [c for c in LIQUIDOS if c in precios_vp.columns]
    if len(L_pres) < len(LIQUIDOS):
        warnings.warn("Algunos ISINs de la cartera líquida no tienen precio; "
                      "se excluyen de '_L'.")

    # ------------------------- PxQ y Weights -------------------------
    PxQ, W, W_L, W_IL = {}, {}, {}, {}
    for clave, q in Q.items():
        dedup = not clave.startswith("IN")
        pxq = _pxq(precios_vp, q, dedup=dedup)
        PxQ[clave] = pxq
        W[clave]   = _rezagar(_weight(pxq))
        W_L[clave] = _rezagar(_weight(pxq[L_pres]))
        W_IL[clave] = _rezagar(_weight(pxq[IL]))

    # ------------------------- Weights sectoriales -------------------------
    sect_w = {}
    for clave, w in W.items():
        afp, ftag = clave.split("_")
        if afp == "EXSIS" and ftag == "M":
            continue
        for nombre_sector, isins in agrupados_sectores.items():
            ws = w.loc[:, w.columns.intersection(isins)]
            sect_w[f"{afp}_{nombre_sector}_{ftag}"] = ws.div(
                ws.sum(axis=1).replace(0, np.nan), axis=0)

    # ------------------------- Benchmarks EPU / ETFPERU -------------------------
    wb_bench = pd.read_excel(MONITOR_PATH, sheet_name="Benchmark", header=None,
                             engine="openpyxl").astype(object)
    epu_w_raw = limpiar_benchmark(wb_bench, "EPU", PxQ["IN_F1"])
    etf_w_raw = limpiar_benchmark(wb_bench, "ETFPERU", PxQ["IN_F1"])

    pxq_epu = precios_sdiv.mul(epu_w_raw, axis=0).dropna(how="all").dropna(axis=1, how="all")
    pxq_etf = precios_sdiv.mul(etf_w_raw, axis=0).dropna(how="all").dropna(axis=1, how="all")
    weight_epu = _rezagar(_weight(pxq_epu))
    weight_etf = _rezagar(_weight(pxq_etf))
    weights_etfs = {"Weight_EPU": weight_epu, "Weight_ETFPERU": weight_etf}

    # ------------------------- Retornos ponderados -------------------------
    precios_cdiv_var = precios_cdiv.pct_change().fillna(0)

    ret_agregados = {}
    for clave in Q:
        ret_agregados[f"Ret_{clave}_O"]    = _ret_ponderado(retornos_vp, W[clave])
        ret_agregados[f"Ret_{clave}_O_L"]  = _ret_ponderado(retornos_vp, W_L[clave])
        ret_agregados[f"Ret_{clave}_O_IL"] = _ret_ponderado(retornos_vp, W_IL[clave])

    ret_epu = (precios_cdiv_var.mul(weight_epu, axis=0)
               .dropna(how="all").dropna(axis=1, how="all").fillna(0))
    ret_etf = (precios_cdiv_var.mul(weight_etf, axis=0)
               .dropna(how="all").dropna(axis=1, how="all").fillna(0))
    ret_etfs = {"Ret_EPU": ret_epu, "Ret_ETFPERU": ret_etf}

    # ------------------------- Acumulados y totales por fondo -------------------------
    ret_acum = {}
    for nombre, df in ret_agregados.items():
        df["Total"] = df.sum(axis=1)
        ret_acum[nombre] = _acumular(df)

    ret_totales = {f: pd.DataFrame() for f in ("F1", "F2", "F3", "M")}
    for nombre, df in ret_acum.items():
        partes = nombre.split("_")          # Ret / AFP / Ftag / O [...]
        afp, ftag = partes[1], partes[2]
        if ftag not in ret_totales:
            continue
        col = f"{afp}{detectar_sufijo_cartera(nombre)}"
        ret_totales[ftag] = ret_totales[ftag].join(
            df[["Total"]].rename(columns={"Total": col}), how="outer")

    for nombre, df in ret_etfs.items():
        df["Total"] = df.sum(axis=1)

    # ------------------------- Retornos sectoriales -------------------------
    ret_sect_acum = {}
    for afp_sector, w in sect_w.items():
        ret = (precios_cdiv_var.mul(w, axis=0)
               .dropna(how="all").dropna(axis=1, how="all"))
        ret["Total"] = ret.sum(axis=1)
        ret_sect_acum[f"Ret_Acum_{afp_sector}"] = _acumular(ret)

    solo_tot_sect = {}
    for sector in lista_sectores:
        for nombre, df in ret_sect_acum.items():
            partes = nombre.split("_")      # Ret Acum AFP Sector Ftag
            if partes[3] != sector:
                continue
            key = f"{sector}_{partes[4]}"
            solo_tot_sect.setdefault(key, pd.DataFrame())
            solo_tot_sect[key] = pd.concat(
                [solo_tot_sect[key], pd.DataFrame({partes[2]: df["Total"]})], axis=1)

    # ------------------------- Exportación a hoja BD -------------------------
    df_exportar = []
    for nom, df in ret_agregados.items():
        r = df.copy(); r.columns = [f"{nom}_{c}" for c in r.columns]
        df_exportar.append(r)

    rp = precios_cdiv_var.copy()
    rp.columns = [f"Retorno_Precios_No_Acum_{c}" for c in rp.columns]
    df_exportar.append(rp)

    df_exportar.append(pd.DataFrame(
        {f"AUM_RVL_{n}": df.sum(axis=1) for n, df in PxQ.items() if n != "EXSIS_M"}))

    # [B2] FIX: cada bloque de weights usa SU DataFrame correcto (el original
    # exportaba weight_EXSIS_F1_L bajo la etiqueta de cartera total).
    for pref, dic in (("weight_{k}_", W), ("weight_{k}_L_", W_L), ("weight_{k}_IL_", W_IL)):
        for clave, df in dic.items():
            if clave == "EXSIS_M":
                continue
            r = df.iloc[:-1].copy()
            r.columns = [f"{pref.format(k=clave)}{c}" for c in r.columns]
            df_exportar.append(r)

    for nom, df in ret_etfs.items():
        r = df.copy(); r.columns = [f"{nom}_{c}" for c in r.columns]
        df_exportar.append(r)
    for nom, df in weights_etfs.items():
        r = df.copy(); r.columns = [f"{nom}_{c}" for c in r.columns]
        df_exportar.append(r)

    rvp = retornos_vp.copy()
    rvp.columns = [f"Retorno_VP_{c}" for c in rvp.columns]
    df_exportar.append(rvp)

    df_final = pd.concat(df_exportar, axis=1)
    print(f"Hoja BD — exportando matriz {df_final.shape[0]} x {df_final.shape[1]}…")

    # [B3] FIX: reutilizar wb1 (no abrir un segundo Book) y guardar al final
    sheet_bd = wb1.sheets["BD"]
    sheet_bd.clear_contents()
    sheet_bd["A1"].options(pd.DataFrame).value = df_final

    if GUARDAR_MONITOR_AL_FINAL:
        wb1.save()
        print("Monitor guardado (DQ_IN, DQ_SIS y BD actualizados).")
    else:
        print("[AVISO] Monitor NO guardado (GUARDAR_MONITOR_AL_FINAL=False). "
              "Guarda manualmente en Excel para conservar la hoja BD.")

    # ------------------------- PDFs -------------------------
    graficar_pdf(PDF_PATH, ret_totales, solo_tot_sect, precios_cdiv,
                 epu_acum, etf_acum, lista_sectores, dicc_parametria)
    if GENERAR_PDF_REDUCIDO:
        graficar_pdf(PDF_RED_PATH, ret_totales, solo_tot_sect, precios_cdiv,
                     epu_acum, etf_acum, lista_sectores, dicc_parametria,
                     solo_integra=True)

    print("\nProceso completado sin errores.")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit("\n[CANCELADO] Ejecución interrumpida por el usuario.")
