def graficar_pdf(ruta_pdf: Path, ret_totales: dict, sectoriales: dict,
                 precios_div: pd.DataFrame, epu_acum, etf_acum,
                 lista_sectores, dicc_parametria, solo_integra=False) -> None:
    colors = ["#3e63ad", "#00B0F0", "#FF0000", "#FFA500"]
    tam = 10
    mapa = {"F1": (0, 0), "F2": (0, 1), "F3": (1, 0), "M": (1, 1)}
    titulos = {"F1": "Fondo 1", "F2": "Fondo 2", "F3": "Fondo 3", "M": "Multifondo"}
    series_afp = [("IN", colors[0], "Integra")] if solo_integra else [
        ("IN", colors[0], "Integra"), ("HA", colors[1], "Habitat"),
        ("PF", colors[2], "Profuturo"), ("RI", colors[3], "Prima")]

    def _pintar(ax, df, titulo):
        ax.plot(epu_acum, color="grey", label="EPU")
        ax.plot(etf_acum, color="green", label="ETF Peru")
        for col, c, lab in series_afp:
            if col in df.columns:
                ax.plot(df[col], color=c, label=lab)
        ax.set_title(titulo, fontsize=12)
        ax.legend()
        ax.tick_params(axis="x", rotation=90, labelsize=tam)
        ax.tick_params(axis="y", labelsize=tam)
        ax.xaxis.set_major_formatter(mdates.DateFormatter("%d-%b-%y"))

    with PdfPages(ruta_pdf) as pdf:
        fig, axis = plt.subplots(2, 2, figsize=(22, 17))
        fig.suptitle("Rendimientos Acumulados - Portafolio RVL",
                     fontsize=20, fontweight="bold")
        plt.tight_layout(pad=5); plt.subplots_adjust(top=0.95)
        for nom, df in ret_totales.items():
            if nom in mapa:
                _pintar(axis[mapa[nom]], df, titulos[nom])
        pdf.savefig(fig); plt.close(fig)

        for sector in lista_sectores:
            fig, axis = plt.subplots(2, 2, figsize=(22, 17))
            fig.suptitle(f"Rendimiento Acumulado: {sector}",
                         fontsize=20, fontweight="bold")
            plt.tight_layout(pad=5); plt.subplots_adjust(top=0.95)
            for nom, df in sectoriales.items():
                partes = nom.split("_")
                if partes[0] == sector and partes[1] in mapa:
                    _pintar(axis[mapa[partes[1]]], df, titulos[partes[1]])
            pdf.savefig(fig); plt.close(fig)

        isins = [c for c in precios_div.columns if c in dicc_parametria]
        contador = 0
        for _ in range(len(isins) // 8 + 1):
            fig, axis = plt.subplots(4, 2, figsize=(22, 17))
            fig.suptitle("Precios", fontsize=20, fontweight="bold")
            plt.tight_layout(pad=5); plt.subplots_adjust(top=0.95)
            for y in range(4):
                for x in (0, 1):
                    if contador == len(isins):
                        break
                    isin = isins[contador]
                    ax = axis[y, x]
                    ax.plot(precios_div[isin], color="#3e63ad")
                    ax.set_title(dicc_parametria[isin], fontsize=12)
                    ax.tick_params(axis="x", rotation=90, labelsize=12)
                    ax.tick_params(axis="y", labelsize=12)
                    ax.xaxis.set_major_formatter(mdates.DateFormatter("%b-%y"))
                    contador += 1
            pdf.savefig(fig); plt.close(fig)
    print(f"PDF generado: {ruta_pdf}")


