def fallar(msg: str) -> None:
    """Aborta con un mensaje claro y accionable."""
    sys.exit(f"\n[ERROR] {msg}\n")


def validar_rutas() -> None:
    faltantes = [p for p in
                 (QEST_PATH, MONITOR_PATH, AUM_PATH, BDPRECIOS_PATH)
                 if not p.exists()]
    if faltantes:
        listado = "\n  - ".join(str(p) for p in faltantes)
        fallar("No se encuentran estos archivos (¿unidad Z: conectada?):\n  - " + listado)
    for pdf in (PDF_PATH, PDF_RED_PATH):
        if not pdf.parent.exists():
            fallar(f"No existe la carpeta de PDFs: {pdf.parent}")


def leer_excel(path: Path, sheet: str, **kw) -> pd.DataFrame:
    """
    Lectura SOLO-LECTURA con calamine (rápido, no bloquea ni altera el archivo).
    Si calamine no está instalado, cae a openpyxl con aviso.
    """
    try:
        return pd.read_excel(path, sheet_name=sheet, engine="calamine", **kw)
    except ImportError:
        warnings.warn("python-calamine no instalado; usando openpyxl (más lento). "
                      "Recomendado:  pip install python-calamine")
        return pd.read_excel(path, sheet_name=sheet, engine="openpyxl", **kw)
    except ValueError as e:
        fallar(f"No se pudo leer la hoja '{sheet}' de {path.name}: {e}")


def buscar_fecha(lista_fechas: list, fecha, contexto: str) -> int:
    """index() blindado: si la última fecha del Monitor no existe en el QEST,
    explica el problema en vez de reventar con ValueError críptico."""
    try:
        return lista_fechas.index(fecha)
    except ValueError:
        fallar(
            f"{contexto}: la última fecha registrada en el Monitor "
            f"({fecha!r}) NO aparece en el QEST. Posibles causas: el QEST fue "
            f"depurado/reiniciado, formatos de fecha distintos, o la hoja del "
            f"Monitor tiene una fecha manual errónea. Revisa ambas hojas antes "
            f"de volver a correr."
        )


def convertir_columnas_object_a_float(df: pd.DataFrame) -> pd.DataFrame:
    """Convierte a float64 toda columna object/str (pandas>=2.1 puede devolver
    dtype 'str' tras leer Excel; pedir ambos es retrocompatible)."""
    df = df.copy()
    for col in df.select_dtypes(include=["object", "string"]).columns:
        df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0).astype("float64")
    return df


def detectar_sufijo_cartera(nombre_clave: str) -> str:
    low = nombre_clave.lower()
    if any(t in low for t in ("_il", "iliq", "ilíquida", "iliquida")):
        return "_IL"
    if any(t in low for t in ("_l", "_liq", "liquida", "líquida")):
        return "_L"
    return ""


