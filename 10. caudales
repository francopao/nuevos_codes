# --- Búsqueda flexible de la fila-ancla (nombre de objeto: río/embalse) ---
# En vez de asumir que el nombre siempre está en la fila 0, se busca en las
# primeras N filas. Esto blinda el script ante filas nuevas insertadas arriba
# (p.ej. numeración de cuadro) en futuras actualizaciones del input.
FILAS_BUSQUEDA = 6

def encontrar_fila_ancla(df, objeto_name, max_filas=FILAS_BUSQUEDA):
    """Busca en qué fila (0..max_filas-1) y columna aparece objeto_name.
    Retorna (fila, columna) o (None, None) si no se encuentra."""
    limite = min(max_filas, df.shape[0])
    for r in range(limite):
        fila_vals = df.iloc[r].astype(str).str.strip()
        matches = df.columns[fila_vals == objeto_name]
        if len(matches) > 0:
            return r, df.columns.get_loc(matches[0])
    return None, None


def process_river_data(df, river_name, anio):
    fila_nombre, filacol = encontrar_fila_ancla(df, river_name)

    if fila_nombre is None:
        print(f"[WARN] Objeto no encontrado en hoja (revisadas primeras {FILAS_BUSQUEDA} filas): {river_name}")
        return None

    # La fila de años se asume inmediatamente debajo de la fila del nombre,
    # y los datos empiezan 2 filas debajo del nombre (ver estructura real del input).
    fila_anios = fila_nombre + 1
    fila_inicio_datos = fila_nombre + 2  # solo referencial / para mensaje de error

    if fila_inicio_datos >= df.shape[0]:
        print(f"[ERROR] Estructura inesperada para '{river_name}': no hay suficientes filas debajo del encabezado.")
        return None

    df_ = df.iloc[:, filacol:filacol+5]

    anios_fila = df_.iloc[fila_anios, :].astype(str).str.strip()
    if anio not in list(anios_fila):
        print(f"[WARN] Año '{anio}' no encontrado en el bloque de '{river_name}'. Años disponibles: {list(anios_fila.dropna())}")
        return None

    df_.columns = df_.iloc[fila_anios, :]
    # Igual que en la lógica original: se arranca desde la fila de años
    # (que queda duplicada tras asignar columnas) y se descarta más abajo,
    # para que "Semana" quede 1-indexado igual que en el histórico ya generado.
    df_ = df_.iloc[fila_anios:, 1:]
    df_ = df_.reset_index(drop=True)

    df_.insert(0, "Semana", df_.index)

    if anio not in df_.columns:
        print(f"[ERROR] No se pudo aislar la columna del año '{anio}' para '{river_name}' tras el recorte.")
        return None

    df_ = df_[['Semana', anio]]
    df_ = df_.iloc[1:, :]
    df_ = df_.set_axis(['Semana', river_name], axis=1)
    return df_


def merge_river_data(df, anio, rivers):
    Total = None

    for idx, river in enumerate(rivers):
        df_river = process_river_data(df, river, anio)

        if df_river is None:
            continue

        if Total is None:
            Total = df_river.copy()
        else:
            Total = pd.merge(Total, df_river, how='left', on='Semana')

    return Total


