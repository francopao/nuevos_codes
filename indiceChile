#%%
def main(mes, anio, mes_, mes_cod):

    ruta_chile = r'Z:\Mesa de Inversiones\Bottom-Up\1 Proceso de Inversión Renta Variable\Proyecto Inputs Macro\Complementos BD\Consumo\BD\IC Chile'
    os.chdir(ruta_chile)

    ## Comercio
    pattern = "CNC-Cuadro-Historico-Indice-de-Ventas-del-Comercio-Minorista*.xlsx"
    lista = glob.glob(pattern)
    if not lista:
        print(f"Error: no se encontró archivo de Comercio Minorista para {mes} {anio}")
        return
    Archivo = lista[0]

    dfc = pd.read_excel(Archivo, sheet_name="LE MINORISTA - BASE 2023")

    dfct = dfc.T
    dfct = dfct.reset_index()
    dfct = dfct.iloc[::, 1:]
    dfcf = dfct.T

    filas_c = dfcf[dfcf[1] == "ENE." + anio].index
    if len(filas_c) == 0:
        print(f"Error: no se encontró 'ENE.{anio}' en Comercio Minorista")
        return
    prifilc = filas_c[0]
    dfcf = dfcf.iloc[prifilc:prifilc + 12, :11].copy()

    dfcf = dfcf.reset_index()
    dfcf = dfcf.iloc[::, 1:]
    dfcf = dfcf.dropna(axis=1, how='all')

    dfcf = dfcf.set_axis(['Fecha','Total Comercio','Vestuario','Calzado','Artefactos electricos','Linea Hogar','Muebles','Abarrotes','Perecibles','Supermercado Tradicional'], axis=1)

    dfcf['Fecha'] = dfcf['Fecha'].astype(str).str.extract(r'(^\w+)')[0]
    dfcf['Fecha'] = dfcf['Fecha'].replace('SEPT', 'SEP')

    headerc = ['Fecha','Total Comercio','Vestuario','Calzado','Artefactos electricos','Linea Hogar','Muebles','Abarrotes','Perecibles','Supermercado Tradicional']

    dfcft = dfcf.T
    dfcft.insert(0, "hola", headerc)
    dfcft = dfcft.reset_index()
    dfcft = dfcft.iloc[::, 1:]

    mes_colc = dfcft.loc[1:, dfcft.iloc[0].isin(['Fecha', mes_cod])]
    mes_colc = mes_colc.set_axis(['TIPO','Fecha'], axis=1)
    mes_colc.insert(0, "DATO", "Variación anual")
    mes_colc.insert(0, "INDICE", "Comercio Minorista")

    ## Supermercado
    pattern1 = "CNC-Cuadro-Historico-Indice-de-Ventas-de-Supermercado-Tradicional*.xlsx"
    lista1 = glob.glob(pattern1)
    if not lista1:
        print(f"Error: no se encontró archivo de Supermercado Tradicional para {mes} {anio}")
        return
    Archivo1 = lista1[0]
    df_s = pd.read_excel(Archivo1, sheet_name="LE SUPERM. CNC - BASE 2023")

    filas_s = df_s[df_s['CÁMARA NACIONAL DE COMERCIO, SERVICIOS Y TURISMO DE CHILE'] == "ENE." + anio].index
    if len(filas_s) == 0:
        print(f"Error: no se encontró 'ENE.{anio}' en Supermercado Tradicional")
        return
    prifil = filas_s[0]
    df_sf = df_s.iloc[prifil:prifil + 12, :8].copy()
    df_sf = df_sf.reset_index()
    df_sf = df_sf.iloc[::, 1:]
    df_sf = df_sf.dropna(axis=1, how='all')

    df_sf = df_sf.set_axis(['Fecha','Supermercados Tradicional','Abarrotes en General (No perecible)','Perecibles Carnes y subproductos','Perecibles Otros','Varios'], axis=1)

    df_sf['Fecha'] = df_sf['Fecha'].astype(str).str.extract(r'(^\w+)')[0]
    df_sf['Fecha'] = df_sf['Fecha'].replace('SEPT', 'SEP')

    header = ['Fecha','Supermercados Tradicional','Abarrotes en General (No perecible)','Perecibles Carnes y subproductos','Perecibles Otros','Varios']

    df_sft = df_sf.T
    df_sft.insert(0, "hola", header)
    df_sft = df_sft.reset_index()
    df_sft = df_sft.iloc[::, 1:]

    mes_cols = df_sft.loc[1:, df_sft.iloc[0].isin(['Fecha', mes_cod])]
    mes_cols = mes_cols.set_axis(['TIPO','Fecha'], axis=1)
    mes_cols.insert(0, "DATO", "Indice Mensual")
    mes_cols.insert(0, "INDICE", "Supermercado Tradicional")

    ######
    Agrupado = pd.concat([mes_colc, mes_cols], ignore_index=True)

    fecha_col = "01" + "/" + meses_n[meses_.index(mes_)] + "/" + anio
    fecha_col = datetime.datetime.strptime(fecha_col, '%d/%m/%Y')

    # FIX: convertir el Index de columnas a dtype object antes de asignar un datetime,
    # ya que con pandas>=2.x + backend pyarrow, columns puede ser de dtype "string"
    # y no acepta valores datetime directamente.
    new_cols = Agrupado.columns.tolist()
    new_cols[3] = fecha_col
    Agrupado.columns = pd.Index(new_cols, dtype=object)

    Agrupado.insert(0, "Key1", Agrupado["INDICE"] + Agrupado["DATO"] + Agrupado["TIPO"])

    # Base total
    Ruta_Base = r"Z:\Mesa de Inversiones\Bottom-Up\1 Proceso de Inversión Renta Variable\Proyecto Inputs Macro\Complementos BD\Consumo\Históricos\IC Chile.xlsx"
    DF_F = Agrupado.copy()

    with pd.ExcelFile(Ruta_Base) as reader:
        BD_Total = reader.parse(sheet_name='Sheet1')

    # FIX: asegurar que las columnas de BD_Total también sean dtype object
    BD_Total.columns = pd.Index(BD_Total.columns.tolist(), dtype=object)

    BD_Total_ = BD_Total.copy()
    BD_Total_['Indicador'] = 'Mapeado'
    BD_Total_ = BD_Total_.set_index("Key1")
    dic_Total_ = BD_Total_.to_dict()

    DF_Total2 = DF_F.copy()
    DF_Total2['Indicador'] = DF_Total2['Key1'].map(dic_Total_['Indicador'])
    DF_Total2 = DF_Total2.loc[DF_Total2['Indicador'].isin([np.nan])].sort_index(ignore_index=True)
    DF_Total2 = DF_Total2.drop(['Indicador'], axis=1)
    BD_Total = pd.concat([BD_Total, DF_Total2])

    DF_Total = DF_F.set_index("Key1")
    dic_cr = DF_Total.to_dict()
    BD_Total[fecha_col] = BD_Total['Key1'].map(dic_cr[fecha_col])

    with pd.ExcelWriter(Ruta_Base, mode="a", engine="openpyxl", if_sheet_exists='replace') as writer:
        BD_Total.to_excel(writer, sheet_name="Sheet1", index=False)

    print(f"OK: {mes} {anio} procesado correctamente.")

